"name":"sec-fetch-site","value":"none"},{"name":"sec-fetch-mode","value":"no-cors"},{"name":"sec-fetch-dest","value":"empty"},{"name":"accept-language","value":"de"}],"queryString":[],"postData":{"mimeType":"application/json","text":"{\"language\":\"de\",\"region\":\"DE\",\"catalogId\":\"tmdb.series\",\"id\":\"series/trending\",\"adult\":false,\"search\":\"\",\"sort\":\"trendingDay\",\"filter\":{},\"cursor\":null,\"clientVersion\":\"3.0.2\"}"},"headersSize":966,"bodySize":177,"_status":"completed","_startTimestamp":1772842820326955,"_endTimestamp":1772842820334995},"response":{"status":200,"statusText":"","httpVersion":"HTTP/2.0","cookies":[],"headers":[{"name":":status","value":"200"},{"name":"date","value":"Sat, 07 Mar 2026 00:20:20 GMT"},{"name":"content-type","value":"application/json; charset=utf-8"},{"name":"server","value":"cloudflare"},{"name":"mediahubmx-endpoint","value":"."},{"name":"etag","value":"W/\"16dc8-p2Lp0wMPjiH9RGKfzZZcUgwE3xA\""},{"name":"strict-transport-security","value":"max-age=31536000; includeSubDomains"},{"name":"content-encoding","value":"gzip"},{"name":"cf-cache-status","value":"DYNAMIC"},{"name":"vary","value":"accept-encoding"},{"name":"nel","value":"{\"report_to\":\"cf-nel\",\"success_fraction\":0.0,\"max_age\":604800}"},{"name":"report-to","value":"{\"group\":\"cf-nel\",\"max_age\":604800,\"endpoints\":[{\"url\":\"https://a.nel.cloudflare.com/report/v4?s=mRb%2BrNmw7sjqJo6nyJuJPJnklvUH916K3zGOHkfU%2BBN8RWnuJdkd9SqzKll4Yvzjt5umeRAPkObUTi%2BcBHEAGonqqDJ%2BS%2BR6hMHWOkoQ0mv%2F0R9Zhw%3D%3D\"}]}"},{"name":"cf-ray","value":"9d856f0b481de51e-TXL"},{"name":"alt-svc","value":"h3=\":443\"; ma=86400"}],"content":{"size":93640,"mimeType":"application/json","text":"{\"options\":{},\"items\":[{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"255661\"},\"name\":\"Young Sherlock\",\"nameTranslations\":{},\"originalName\":\"Young Sherlock\",\"description\":\"Von Guy Ritchie: Erleben Sie die legendäre Entstehungsgeschichte von Sherlock Holmes in diesem respektlosen, actiongeladenen Krimi, der die frühen Abenteuer des ikonischen Detektivs nachzeichnet.\",\"releaseDate\":\"2026-03-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/BMBWTgvL41sOYtfkmXen6nm9mG.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/8mmDLb108DoFZlE8sfc64TRqLvm.jpg\"},\"genres\":[\"Action & Adventure\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"281016\"},\"name\":\"Boyfriend on Demand\",\"nameTranslations\":{},\"originalName\":\"월간남친\",\"description\":\"Seo Mi-rae steckt ihre ganze Energie in ihre Arbeit. An Liebe ist nicht zu denken, doch eine Online-Partnervermittlung bietet vielleicht eine Chance auf eine Romanze.\",\"releaseDate\":\"2026-03-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/kg7Fjhlkp4pRNBWzftLgWJ7uVx8.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/qh3kBok8YkYER2T5zaRSiZssxVn.jpg\"},\"genres\":[\"Sci-Fi & Fantasy\",\"Komödie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"285739\"},\"name\":\"Vladimir\",\"nameTranslations\":{},\"originalName\":\"Vladimir\",\"description\":\"Eine Englischprofessorin ist von ihrem neuen Kollegen besessen, was nicht nur ihre ohnehin schon komplizierte Ehe, sondern auch ihre Karriere ins Chaos stürzt.\",\"releaseDate\":\"2026-03-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/j02VBIGVIk2OTwTUZ1YzyzcONAy.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/fqWXGP79tEMAyLKW0wkJLbKSP61.jpg\"},\"genres\":[\"Drama\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"201834\"},\"name\":\"Ted\",\"nameTranslations\":{},\"originalName\":\"ted\",\"description\":\"Der sprechende Plüschbär Ted ist ein Rüpel, der in der Familie Bennett ständig für Chaos sorgt. Nun muss er auch noch zur Highschool.\",\"releaseDate\":\"2024-01-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/j50t4inyAXNg8gxryxZmC1qbNXk.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/xaiKpxuf9YGuTsqpdK5HSbD8M8f.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"313298\"},\"name\":\"Die Dinosaurier\",\"nameTranslations\":{},\"originalName\":\"The Dinosaurs\",\"description\":\"Von den ersten bis zu den letzten Dinosauriern untersucht diese umfassende Dokuserie ihre 165 Millionen Jahre auf der Erde und die Kräfte, die ihre Evolution beeinflussten.\",\"releaseDate\":\"2026-03-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/x37IK9WWhuzi7tgyMT4ff3kiT5X.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/8X2R9uLys3SmkRuQAmSI96xxJAF.jpg\"},\"genres\":[\"Dokumentarfilm\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"202411\"},\"name\":\"Monarch: Legacy of Monsters\",\"nameTranslations\":{},\"originalName\":\"Monarch: Legacy of Monsters\",\"description\":\"Ein schockierendes Geheimnis erschüttert Cate, die zu den Überlebenden des Angriffs von Godzilla auf San Francisco gehört. Inmitten wahrhaft monströser Bedrohungen begibt sie sich auf eine abenteuerliche, weltumspannende Reise, um die Wahrheit über ihre Familie und eine mysteriöse Organisation zu erfahren, die als Monarch bekannt ist.\",\"releaseDate\":\"2023-11-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7LBbaEaLSbqdviBYaSS1rRPMnrs.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/n5FGEUmId87nZAdFiOFmCKXynmT.jpg\"},\"genres\":[\"Sci-Fi & Fantasy\",\"Drama\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"95479\"},\"name\":\"JUJUTSU KAISEN\",\"nameTranslations\":{},\"originalName\":\"呪術廻戦\",\"description\":\"Mühsal, Reue, Schmach: Die negativen Gefühle, die den Herzen der Menschen entspringen, werden zu Flüchen, die sich in unser aller Leben einnisten. Und das Einzige, was einen Fluch austreiben kann, ist ein anderer Fluch. Yūji verbringt seine Tage wie jeder andere Schüler. Doch eines Tages wird sein Freund von Flüchen angegriffen und um ihn zu retten, isst er den Finger des Zwiegesichts Sukuna. Fortan teilt er sich seinen Körper mit ihm und tritt der Jujutsu-Akademie bei, um gegen Flüche zu kämpfen. So beginnt die Geschichte des Jungen, der zum Fluch wurde, um einen Fluch auszutreiben.\",\"releaseDate\":\"2020-10-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/zKFkzRn1UyE11Jv9CJjVmvmQFvR.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gmECX1DvFgdUPjtio2zaL8BPYPu.jpg\"},\"genres\":[\"Animation\",\"Action & Adventure\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"279388\"},\"name\":\"逐玉\",\"nameTranslations\":{},\"originalName\":\"逐玉\",\"releaseDate\":\"2026-03-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cYV1cn51qeu7aLqMUrSsmPe1QNo.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yiUZ8Ck86FF3obLztVvSQqeBi0Y.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"250307\"},\"name\":\"The Pitt\",\"nameTranslations\":{},\"originalName\":\"The Pitt\",\"description\":\"Das Personal des Trauma Medical Centers Pittsburgh arbeitet rund um die Uhr, um in einer übervollen und unterfinanzierten Notaufnahme Leben zu retten.\",\"releaseDate\":\"2025-01-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/n2RDUgB3qVmqXFLAj0zGzOTPmlI.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/q1z0W19F4T5Xs2qka3xJSmFjv9a.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"273160\"},\"name\":\"The Beauty\",\"nameTranslations\":{},\"originalName\":\"The Beauty\",\"description\":\"In der Welt der High Fashion geht die Angst um: Internationale Supermodels sterben auf grausame und mysteriöse Weise. Die FBI-Agenten Cooper Madsen und Jordan Bennett sollen in Paris die Wahrheit aufdecken und stoßen dabei auf ein sexuell übertragbares Virus. Es verwandelt gewöhnliche Menschen in Abbilder körperlicher Perfektion - jedoch mit schrecklichen Folgen.\",\"releaseDate\":\"2026-01-21\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/tZTG2PPAukzksPkiQV9c4suIQXk.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/cX6dzeKsBTTXHoG3uQUuhQbqyvq.jpg\"},\"genres\":[\"Drama\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"295778\"},\"name\":\"Scrubs\",\"nameTranslations\":{},\"originalName\":\"Scrubs\",\"releaseDate\":\"2026-02-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/nNNM50G7p9C3n4vgidCiybsIdHA.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/em2Jzx5QyBTVI7gKipCoE0kG4ot.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"76479\"},\"name\":\"The Boys\",\"nameTranslations\":{},\"originalName\":\"The Boys\",\"description\":\"Eine ehrfurchtslose Interpretation dessen, was passiert, wenn Superhelden, die berühmt sind wie Stars, einflussreich sind wie Politiker und verehrt werden wie Götter, ihre Superkräfte missbrauchen, anstatt Gutes zu tun. Die Machtlosen stellen sich gegen die Übermächtigen, als The Boys versuchen, die Wahrheit über \\\"The Seven\\\" und Vought dahinter ans Licht zu bringen.\",\"releaseDate\":\"2019-07-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/klwtZ4B8T9Sc3mv6TBMdUY8j3p0.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/czffzEgaBko4mXW84B1J1EnQBzo.jpg\"},\"genres\":[\"Sci-Fi & Fantasy\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"224372\"},\"name\":\"A Knight of the Seven Kingdoms\",\"nameTranslations\":{},\"originalName\":\"A Knight of the Seven Kingdoms\",\"description\":\"Ein Jahrhundert vor den Ereignissen von „Game of Thrones“ durchstreifen zwei unwahrscheinliche Helden durch Westeros, ein junger, naiver, aber mutiger Ritter, Ser Duncan der Große, und sein kleiner Knappe Ei. Die Handlung spielt in einer Zeit, in der die Targaryen immer noch auf dem Eisernen Thron sitzen und die Erinnerung an die letzten lebenden Drachen noch nicht verblasst ist. Ein großes Schicksal, machtvolle Gegner und gefährliche Erlebnisse erwarten diese unwahrscheinlichen und unvergleichlichen Freunde.\",\"releaseDate\":\"2026-01-18\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/w7mQVY9951KdUGWN3rCSOkTR5MK.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/7mkUu1F2hVUNgz24xO8HPx0D6mK.jpg\"},\"genres\":[\"Drama\",\"Sci-Fi & Fantasy\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"198102\"},\"name\":\"Hijack\",\"nameTranslations\":{},\"originalName\":\"Hijack\",\"description\":\"Der erfahrene Krisenvermittler Sam Nelson steht vor der größten Bewährungsprobe seines Lebens. Nachdem eine Gruppe von Entführern die Kontrolle übernommen hat, befinden sich alle Passagiere in höchster Gefahr. Sam muss all seine Erfahrung und Entschlossenheit einsetzen, um die Angreifer zu überwältigen, während das Risiko mit jeder Sekunde steigt.\",\"releaseDate\":\"2023-06-28\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/2C51clnxQdiqPDeqQlXcUx70hse.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/aRZ7k1M3AdjVv8n3Fi6cAkEdpYY.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"209867\"},\"name\":\"Frieren - Nach dem Ende der Reise\",\"nameTranslations\":{},\"originalName\":\"葬送のフリーレン\",\"description\":\"Nach einer zehnjährigen Odyssee gelingt es der Elfenmagierin Frieren zusammen mit Himmels Heldengruppe, den Dämonenkönig zu stürzen und dem Land Frieden zu schenken. Als Elfe mit langer Lebensdauer, streift sie weiter durch die Lande, doch als sie nach 50 Jahren ihren ehemaligen Kameraden einen Besuch abstattet, sind ihre Gesichter von tiefen Furchen gezeichnet. Kurz später wird Frieren Zeugin von Himmels Ableben, was für sie Schmerz und tiefes Bedauern mit sich bringt – Bedauern darüber, nicht genug Zeit mit ihnen verbracht zu haben. Mit dieser Reue im Herzen begibt sie sich auf eine Reise, um verschiedenste Menschen kennenzulernen und mit ihnen neue Abenteuer zu teilen.\",\"releaseDate\":\"2023-09-29\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/k1YVj5fGW1oKjZ19oy0PcphKXlj.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/rBOnrVlck7BIlGeWVlzYiZeg4l2.jpg\"},\"genres\":[\"Animation\",\"Action & Adventure\",\"Drama\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"290856\"},\"name\":\"Marshals - A Yellowstone Story\",\"nameTranslations\":{},\"originalName\":\"Marshals\",\"description\":\"Nach dem Ende der Yellowstone-Ranch schließt sich Kayce den U.S.-Marshals an. Seine Erfahrungen als Cowboy und Navy SEAL helfen dabei. Er und seine Kollegen sind die letzte Bastion gegen das Verbrechen in der Region.\",\"releaseDate\":\"2026-03-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/tUIXVv3kaub7yDxhBcYQUj5BCxZ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yGJGwt7DdIWTUXuahLfhcH1gi7G.jpg\"},\"genres\":[\"Drama\",\"Western\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"223530\"},\"name\":\"Star Trek: Starfleet Academy\",\"nameTranslations\":{},\"originalName\":\"Star Trek: Starfleet Academy\",\"description\":\"Eine Gruppe junger Kadetten findet zusammen, um einen gemeinsamen Traum von Hoffnung und Optimismus zu verfolgen. Unter den wachsamen und anspruchsvollen Augen ihrer Ausbilder entdecken sie, was es braucht, um Sternenflottenoffiziere zu werden, während sie sich durch aufkeimende Freundschaften, explosive Rivalitäten, erste Lieben und einen neuen Feind navigieren, der sowohl die Akademie als auch die Föderation selbst bedroht.\",\"releaseDate\":\"2026-01-15\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/m4JnADIJkF5ck6jq7GUEcPBKxd0.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/rXtSdCGmG07zjAg5h7GR1v52ogX.jpg\"},\"genres\":[\"Sci-Fi & Fantasy\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"91239\"},\"name\":\"Bridgerton\",\"nameTranslations\":{},\"originalName\":\"Bridgerton\",\"description\":\"Diese von den Bestsellern von Julia Quinn inspirierte Serie begleitet die acht Geschwister der Familie Bridgerton in der Londoner High Society auf der Suche nach Liebe.\",\"releaseDate\":\"2020-12-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/pUCGS3E0L5wzOR2nxzjWSumFfax.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/iVadPLeLVb97RznIGDkswxtBzi6.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"245927\"},\"name\":\"Paradise\",\"nameTranslations\":{},\"originalName\":\"Paradise\",\"description\":\"Die Idylle in einer Gemeinde, die von einigen der einflussreichsten Menschen der Welt bewohnt wird, zerbricht, als ein entsetzlicher Mord geschieht und eine hochbrisante Ermittlung beginnt.\",\"releaseDate\":\"2025-01-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/l8RqfhqEk04W5sSOjQ9zeWU1DyM.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5QsLvWh8J1mXl1W05wNJknMmhzR.jpg\"},\"genres\":[\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"276472\"},\"name\":\"샤이닝\",\"nameTranslations\":{},\"originalName\":\"샤이닝\",\"description\":\"Nachdem sich ein junges Paar aus den Augen verliert, treffen sie zehn Jahre später wieder aufeinander. Sie müssen sich Liebeskummer und neuen Herausforderungen stellen.\",\"releaseDate\":\"2026-03-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/pn0c1aRfPHdGdOHA6jQbNqrhI3B.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gtxt1avGOgu3nhYGqWQWFPHSpKc.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"37854\"},\"name\":\"One Piece\",\"nameTranslations\":{},\"originalName\":\"ワンピース\",\"description\":\"Wir schreiben das große Zeitalter der Piraten. Mit dem Tod des einstigen Piratenkönigs Gold Roger begann die Suche nach dem begehrten One Piece, dem größten Schatz der Welt. Diesen hatte Roger noch kurz vor seiner Hinrichtung versteckt. Seitdem ist die Grandline bevölkert von fiesen und miesen Gestalten, die nach Gold, Reichtum und Macht gieren. Nur einer ist irgendwie anders. Einst aß er von der Gum-Gum-Frucht, jetzt lässt er mit gummimäßigen Kräften und mordsmäßigem Appetit jeden Feind erzittern – hier kommt Ruffy, der künftige König der Piraten!\",\"releaseDate\":\"1999-10-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/oag7edI9flSMawmNySEiSEJAbrf.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/2rmK7mnchw9Xr3XdiTFSxTTLXqv.jpg\"},\"genres\":[\"Action & Adventure\",\"Komödie\",\"Animation\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"79744\"},\"name\":\"The Rookie\",\"nameTranslations\":{},\"originalName\":\"The Rookie\",\"description\":\"In einem Alter, in dem sich andere zur Ruhe setzen wollen, tauscht John Nolan das beschauliche Kleinstadtleben gegen einen Neuanfang in Los Angeles ein: Er möchte seinen Lebenstraum verwirklichen und als Polizist arbeiten. Inmitten von Anwärtern in ihren 20ern muss sich Nolan nun als ältester Rookie des LAPD bewähren.\",\"releaseDate\":\"2018-10-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/70kTz0OmjjZe7zHvIDrq2iKW7PJ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/6iNWfGVCEfASDdlNb05TP5nG0ll.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"131142\"},\"name\":\"Love Story\",\"nameTranslations\":{},\"originalName\":\"Love Story\",\"description\":\"John F. Kennedy Jr. galt als Symbol eines modernen amerikanischen Adels und stand seit seiner Kindheit im Fokus der Öffentlichkeit. Sein Weg vom Jungen zum begehrten Junggesellen wurde ebenso intensiv verfolgt wie sein Aufstieg zum Medienliebling. Carolyn Bessette hingegen führte ein eigenständiges Leben abseits politischer Dynastien. Ehrgeizig und stilsicher arbeitete sie sich von einer Verkaufsassistentin zur Führungskraft bei Calvin Klein hoch und entwickelte eine enge Verbindung zu dessen Gründer. Als sich John und Carolyn das erste Mal begegnen, entsteht eine sofortige Anziehung, die schnell zum Gesprächsthema der Nation wird. Doch mit wachsender öffentlicher Aufmerksamkeit geraten ihre Privatsphäre und ihre Beziehung zunehmend unter Druck\",\"releaseDate\":\"2026-02-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7WU3cXD0rip5ONc7owI2dBWAVjW.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/qM0k20AoDXM5YFTJGD1xA0aWiJ.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"249907\"},\"name\":\"Sentenced to Be a Hero\",\"nameTranslations\":{},\"originalName\":\"勇者刑に処す 懲罰勇者9004隊刑務記録\",\"description\":\"Für die Tötung einer Göttin muss Xylo Forbartz sich als sogenannter Strafheld der Einheit 9004 gegen zahllose Monsterhorden beweisen. Selbst wenn er stirbt, gerät er nur in einen Kreislauf aus Reanimationen und gnadenlosen Kämpfen. Doch als Xylo einer geheimnisvollen weiteren Göttin begegnet, führt ihre ungewöhnliche Allianz zu einer Rebellion, die die Ketten seiner ewigen Strafe sprengen könnte.\",\"releaseDate\":\"2026-01-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/juGNOhRx7MXg3i2NuZ9lR6arVQw.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/k8uBEraJWZf9o7oJbaVHrECwvjC.jpg\"},\"genres\":[\"Animation\",\"Action & Adventure\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"315755\"},\"name\":\"En ven, en morder\",\"nameTranslations\":{},\"originalName\":\"En ven, en morder\",\"releaseDate\":\"2026-03-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/t0rkBfR1u1JbdZ687cNjOZAgIAx.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ln16CvrAqvnFJOSDXIxlP3G6TBx.jpg\"},\"genres\":[\"Dokumentarfilm\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"313100\"},\"name\":\"हैलो बच्चों\",\"nameTranslations\":{},\"originalName\":\"हैलो बच्चों\",\"releaseDate\":\"2026-03-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/sBprJ6cIkWWKl4ABWgxNDKxe9kL.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/akwxUU6YDiAixkx7t8AOSzxzkNG.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"313338\"},\"name\":\"Der TikTok-Killer\",\"nameTranslations\":{},\"originalName\":\"El asesino de TikTok\",\"description\":\"In dieser Dokuserie ist eine Familie auf der Suche nach der Wahrheit, nachdem eine 42-jährige Frau in Spanien einen TikToker trifft und kurz darauf verschwindet.\",\"releaseDate\":\"2026-03-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/giINp6zBiLd78VVlSHM1AUaDKf3.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/qTbaaF0zthCuFxFPowr7XdnJl5r.jpg\"},\"genres\":[\"Dokumentarfilm\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"66732\"},\"name\":\"Stranger Things\",\"nameTranslations\":{},\"originalName\":\"Stranger Things\",\"description\":\"Nach dem Verschwinden eines Jungen treten in einer Kleinstadt geheime Regierungsexperimente, übernatürliche Kräfte und ein merkwürdiges kleines Mädchen zutage.\",\"releaseDate\":\"2016-07-15\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/uOOtwVbSr4QDjAGIifLDwpb2Pdl.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/8zbAoryWbtH0DKdev8abFAjdufy.jpg\"},\"genres\":[\"Sci-Fi & Fantasy\",\"Mystery\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"111110\"},\"name\":\"ONE PIECE\",\"nameTranslations\":{},\"originalName\":\"ONE PIECE\",\"description\":\"In dieser Realverfilmung des erfolgreichen Mangas begibt sich der junge Pirat Monkey D. Ruffy mit seinem Strohhut und seiner Crew auf eine abenteuerliche Schatzsuche.\",\"releaseDate\":\"2023-08-31\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/gyyBB4wBYTvS4gtvi4hToq1KOsp.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/qD211Hb5XwFxrszzBBe5EUYJerh.jpg\"},\"genres\":[\"Action & Adventure\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"310800\"},\"name\":\"Siren's Kiss\",\"nameTranslations\":{},\"originalName\":\"세이렌\",\"description\":\"„Wenn du sie liebst, stirbst du.\\\" Versicherungsdetektiv Cha Woo-seok untersucht die Todesfälle, die mit der verführerischen Auktionatorin Han Seol-ah in Verbindung stehen. Nachdem ihre Kollegin stirbt und rauskommt, dass ihre früheren Liebhaber das gleiche Schicksal ereilt hat, vermutet er, dass sie selbst ein Opfer sein könnte. Sie geben sich als Liebespaar aus, um die Wahrheit aufzudecken.\",\"releaseDate\":\"2026-03-02\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4C5iHtnndCvlbMvsKdRFtCDSE5L.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hCEl9Tb27chAWYXYau05pCSKEL.jpg\"},\"genres\":[\"Drama\",\"Krimi\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"257992\"},\"name\":\"Traqués – Gejagt\",\"nameTranslations\":{},\"originalName\":\"Traqués\",\"description\":\"Als Freunde auf einem Jagdausflug in einen tödlichen Konflikt mit anderen Jägern geraten, schwören sie, das Geschehene geheim zu halten. Doch als bei ihnen die Paranoia einsetzt – und sich eine skrupellose Gang an ihnen rächen will – müssen sich die Freunde ihrer Moral, ihren Familien und ihrem Kampfinstinkt stellen.\",\"releaseDate\":\"2026-03-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/xZblVIlX1OulWWiSZfJVXUUKr2X.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nA6AyvaP8syIMRJHAELRZLoFaF4.jpg\"},\"genres\":[\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"106379\"},\"name\":\"Fallout\",\"nameTranslations\":{},\"originalName\":\"Fallout\",\"description\":\"Basierend auf der größten Videospiel-Reihe aller Zeiten, erzählt „Fallout“ die Geschichte von Besitzenden und Besitzlosen in einer Welt, in der es fast nichts mehr zu besitzen gibt. 200 Jahre nach der Apokalypse ist eine friedliche Bewohnerin eines gemütlichen Atombunkers gezwungen, an die Oberfläche zurückzukehren… und ist erschüttert über das Ödland, das sie dort erwartet.\",\"releaseDate\":\"2024-04-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/c15BtJxCXMrISLVmysdsnZUPQft.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/coaPCIqQBPUZsOnJcWZxhaORcDT.jpg\"},\"genres\":[\"Action & Adventure\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"75219\"},\"name\":\"9-1-1 Notruf L.A.\",\"nameTranslations\":{},\"originalName\":\"9-1-1\",\"description\":\"Die Serie folgt den Leben der Ersthelfer von Los Angeles: Polizisten, Sanitäter, Feuerwehrleute und Mitarbeitern der Leitstelle.\",\"releaseDate\":\"2018-01-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/sv17SPivB8UHa1yU4RW9C7rWclh.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/h050XJoiIobaH6bhj3MAhgilkpJ.jpg\"},\"genres\":[\"Drama\",\"Krimi\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"129552\"},\"name\":\"The Night Agent\",\"nameTranslations\":{},\"originalName\":\"The Night Agent\",\"description\":\"Durch einen nächtlichen Telefonanruf zusammengekommen, müssen ein FBI-Agent und eine Cybersecurity-Expertin ein immer komplexeres Netz politischer Intrigen entwirren.\",\"releaseDate\":\"2023-03-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4c5yUNcaff4W4aPrkXE6zr7papX.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gklrevVndG98GHGDwfm8y8kxESo.jpg\"},\"genres\":[\"Action & Adventure\",\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"226637\"},\"name\":\"High Potential\",\"nameTranslations\":{},\"originalName\":\"High Potential\",\"description\":\"Die scharfsinnige und unorthodoxe Art einer alleinerziehenden Mutter mit außergewöhnlichem kriminalistischen Talent, Verbrechen zu lösen, führt zu einer ungewöhnlichen und unschlagbaren Zusammenarbeit mit einem überkorrekten, erfahrenen Detective.\",\"releaseDate\":\"2024-09-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/xCtaUDBUP1iKqtoqpHfeH1T2pWF.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/fGZH7czsIFgf291AI0RLkHnGsRY.jpg\"},\"genres\":[\"Drama\",\"Krimi\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"291339\"},\"name\":\"Memory of a Killer\",\"nameTranslations\":{},\"originalName\":\"Memory of a Killer\",\"releaseDate\":\"2026-01-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3kpXrWW6gmlngwgSa52IhBpjPuz.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/llrSuUkFiR6EjDnh79dq8HEeziF.jpg\"},\"genres\":[\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"213306\"},\"name\":\"Alex Cross\",\"nameTranslations\":{},\"originalName\":\"Cross\",\"description\":\"Washington D.C. ist der Schauplatz dieser Krimiserie um den genialen Mordermittler Alex Cross, dessen Leben und Karriere infolge eines persönlichen Traumas zu entgleisen drohen.\",\"releaseDate\":\"2024-11-14\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/svhI1yJdcbZqx51rE1EWL9E33gX.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/w4HqCpNojW3kbgtj4qHCnf5G7bf.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"287760\"},\"name\":\"纯真年代的爱情\",\"nameTranslations\":{},\"originalName\":\"纯真年代的爱情\",\"releaseDate\":\"2026-02-21\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/oeKrr631Dvn582LoTTnvRWm3AlY.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ufgYAZofbUE7x7MGHaJ5wKj7Or8.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"456\"},\"name\":\"Die Simpsons\",\"nameTranslations\":{},\"originalName\":\"The Simpsons\",\"description\":\"Die Simpsons sind eine amerikanische Durchschnittsfamilie. Immer neue Geschichten gibt es über Homer, Marge, Bart, Lisa und Maggie und über die weiteren Bewohner von Springfield zu erzählen.\",\"releaseDate\":\"1989-12-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/yqYITBxRpsSLjScfFz1o35pelFw.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/jIArNHIekrCSVgdMbKPAXpPY03Y.jpg\"},\"genres\":[\"Familie\",\"Animation\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"312073\"},\"name\":\"Banksters\",\"nameTranslations\":{},\"originalName\":\"Banksters\",\"description\":\"Berlin, 2004, Yusuf wird mitten auf dem Fußballplatz festgenommen. Der Vorwurf: mehrfacher Bankraub. Die Frage: Wer waren seine Komplizen? Schweigen bedeutet Gefängnis, Reden Verrat. Doch wer hat ihn verpfiffen und warum ausgerechnet ihn? Nichts ist wie es zunächst scheint.\",\"releaseDate\":\"2026-02-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/m6wWJFDOHGTDfwucvFGpE1OfcYm.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/3pyADtNpIbhfdAxPXNYtW7pTMuJ.jpg\"},\"genres\":[\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"201289\"},\"name\":\"Beschütze sie\",\"nameTranslations\":{},\"originalName\":\"The Last Thing He Told Me\",\"description\":\"Eine Frau muss eine Beziehung zu ihrer Stieftochter im Teenageralter aufbauen, um ihren Mann zu finden, der auf mysteriöse Weise verschwunden ist.\",\"releaseDate\":\"2023-04-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/AgOfJVwjFFXDoCudFJfcufgCaqL.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hUdsZNxl8zIekBVZOSNFoiVIpiR.jpg\"},\"genres\":[\"Mystery\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"262932\"},\"name\":\"江湖夜雨十年灯\",\"nameTranslations\":{},\"originalName\":\"江湖夜雨十年灯\",\"releaseDate\":\"2026-02-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/fExFPnVTUMmRdSxon9ASsWQGkNr.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1dpNwoB4T3z0RM2Z43iOmix94Ho.jpg\"},\"genres\":[\"Drama\",\"Action & Adventure\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"241372\"},\"name\":\"56 Tage\",\"nameTranslations\":{},\"originalName\":\"56 Days\",\"description\":\"Als in einer Luxuswohnung, die mit Oliver Kennedy und seiner Freundin Ciara Wyse in Verbindung steht, eine nicht identifizierte Leiche gefunden wird, rekonstruieren die Kommissare Lee Reardon und Karl Connolly die tragische Liebesgeschichte des Paares der letzten 56 Tage.\",\"releaseDate\":\"2026-02-18\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/yUsMXPiy4Sagzite1nmaT5W6jzV.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/dnEljhBkw53ra7tEl2JNKGrI0wk.jpg\"},\"genres\":[\"Drama\",\"Krimi\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"300054\"},\"name\":\"BAKI-DOU: The Invincible Samurai\",\"nameTranslations\":{},\"originalName\":\"刃牙道\",\"description\":\"Baki und die stärksten Untergrund-Arena-Kämpfer stellen sich ihrer bisher größten Bedrohung: Japans bestem Samurai Musashi Miyamoto.\",\"releaseDate\":\"2026-02-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qC4JawqYlUS9fwvAzGfY5lSz5uB.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1M8uW8o6fdDaa3zqmBD2UUKu0VZ.jpg\"},\"genres\":[\"Animation\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"203737\"},\"name\":\"[Oshi No Ko] - [Mein*Star]\",\"nameTranslations\":{},\"originalName\":\"【推しの子】\",\"description\":\"Seit eine Patientin ihm die Frage gestellt hat, wie es wohl wäre, als Kind eines Stars wiedergeboren zu werden, ist der Arzt Goro Hardcore-Fan des Idols Ai aus der Gruppe B-Komachi. So kann er es auch kaum glauben, als eben diese eines Tages in seinem Beratungszimmer des ländlich gelegenen Krankenhauses auftaucht! Nicht nur das, sie ist schwanger und möchte die anstehende Geburt ihrer Zwillinge vor der Öffentlichkeit geheim halten, um bald wieder auf die Bühne zurückzukehren. Goro weiß allerdings noch nicht, dass das Schicksal für ihn bald eine weitaus größere Veränderung in seinem Leben bereit hält...\",\"releaseDate\":\"2023-04-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/wXNebTabVlyeRh77uozHWBqbMao.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gArCVC4ML529WMCEqOXbALdQbUq.jpg\"},\"genres\":[\"Animation\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"136311\"},\"name\":\"Shrinking\",\"nameTranslations\":{},\"originalName\":\"Shrinking\",\"description\":\"Jimmy hat damit zu kämpfen, den Verlust seiner Frau zu betrauern und gleichzeitig Vater, Freund und Therapeut zu sein. Er beschließt, mit allen, die ihm über den Weg laufen, einen neuen Ansatz auszuprobieren: ungefilterte, brutale Ehrlichkeit. Wird das die Dinge besser machen - oder ein heilloses Chaos auslösen?\",\"releaseDate\":\"2023-01-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/zEFKMNPBKq6JG7uuDkzTQ9WwErn.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hI9z1UuNhBthvkm3iJ8m3zv43Pf.jpg\"},\"genres\":[\"Drama\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"302074\"},\"name\":\"R.J. Decker\",\"nameTranslations\":{},\"originalName\":\"R.J. Decker\",\"releaseDate\":\"2026-03-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/dRkqrB2pk7qCcfPYNta9ZOnDd1T.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1bGWVysGyy7iTd0cwSZH7OVKaeb.jpg\"},\"genres\":[\"Drama\",\"Komödie\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"297424\"},\"name\":\"우주를 줄게\",\"nameTranslations\":{},\"originalName\":\"우주를 줄게\",\"releaseDate\":\"2026-02-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/2H3LxJjSQNCtMfG1zwToWH5L4RM.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/9SfQBpYsIyPD19sZdZQGZ3HQFrk.jpg\"},\"genres\":[\"Komödie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"314297\"},\"name\":\"Blue Therapy\",\"nameTranslations\":{},\"originalName\":\"Blue Therapy\",\"releaseDate\":\"2026-03-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/H8K1osuUf7OsMbtSVPvXJlcnWS.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/mY1XhTMKEbl8LhZrQpa3zoFiMcw.jpg\"},\"genres\":[\"Reality\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"301507\"},\"name\":\"Heated Rivalry\",\"nameTranslations\":{},\"originalName\":\"Heated Rivalry\",\"description\":\"Heated Rivalry zeigt die geheime, leidenschaftliche Beziehung zweier Eishockey-Rivalen, die zwischen Konkurrenz, Eifersucht und Karriereambitionen hin- und hergerissen sind.\",\"releaseDate\":\"2025-11-28\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3YCKbtAkYWCMDLHvkUjGhG7eWoS.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/QbRbCULZVBcrN2uydpmIOQLV5O.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"206828\"},\"name\":\"DTF St. Louis\",\"nameTranslations\":{},\"originalName\":\"DTF St. Louis\",\"description\":\"Die Miniserie „DTF St. Louis“ dreht sich um ein Liebesdreieck von drei Erwachsenen in St. Louis, die allesamt in einer Art Midlife Crisis stecken – eine der drei Personen wird die Serie nicht überleben.\",\"releaseDate\":\"2026-03-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/xHfafw9UmomDc7jO25s9MpiL4Zs.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/cGxRQdL2zF7UMycN0S5WBaDQ1u8.jpg\"},\"genres\":[\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"235685\"},\"name\":\"The Pendragon Cycle: Rise of the Merlin\",\"nameTranslations\":{},\"originalName\":\"The Pendragon Cycle: Rise of the Merlin\",\"releaseDate\":\"2026-01-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/jJfk8NXauN4UgFQ1qn9lFzEk7ib.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lDmFwAaHL1kXnAfZeUTieAdUTko.jpg\"},\"genres\":[\"Sci-Fi & Fantasy\",\"Action & Adventure\",\"Familie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"95603\"},\"name\":\"Kuruluş Osman\",\"nameTranslations\":{},\"originalName\":\"Kuruluş Osman\",\"releaseDate\":\"2019-11-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/rQUhcrcvWoPHjxRc6hzlD2enmRK.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/puLaqdcTRwFxwv9S3PO6jA3ep7J.jpg\"},\"genres\":[\"War & Politics\",\"Action & Adventure\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1434\"},\"name\":\"Family Guy\",\"nameTranslations\":{},\"originalName\":\"Family Guy\",\"description\":\"Die Griffins sind eine nach außen hin \\\"völlig normale\\\" Mittelklasse-Familie: Peter, seine Frau Lois, die drei Kinder Chris, Meg und Stewie - und Brian, der Hund. Der Vierbeiner ist eindeutig das eloquenteste Mitglied des Griffin-Haushaltes und der einzige, der im täglichen Chaos einen klaren Kopf behält. Seine sarkastischen Bemerkungen sind trocken wie die Martinis, die er so gerne trinkt. Brian ist der erste, an den sich Peter in Krisen wendet und das passiert ziemlich oft...\",\"releaseDate\":\"1999-01-31\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3PFsEuAiyLkWsP4GG6dIV37Q6gu.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/l7wShoIdIUwaDIbsHno9pO5MZXT.jpg\"},\"genres\":[\"Animation\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"247723\"},\"name\":\"The Hunting Party\",\"nameTranslations\":{},\"originalName\":\"The Hunting Party\",\"releaseDate\":\"2025-01-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/mjJMOLr966Q78YUPu0pVA0ydBIP.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/mP3bH1RdN1yCbUxrcQbCzFtIOaR.jpg\"},\"genres\":[\"Drama\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1416\"},\"name\":\"Grey's Anatomy\",\"nameTranslations\":{},\"originalName\":\"Grey's Anatomy\",\"description\":\"Die Serie erzählt die Geschichte von fünf jungen Assistenzärzten des fiktiven Krankenhauses Seattle Grace Hospital in Seattle. Im Mittelpunkt steht die junge Ärztin Meredith Grey, die zusammen mit ihren Kollegen Cristina Yang, Isobel „Izzie“ Stevens, George O’Malley und Alex Karev ihre Ausbildung in der Chirurgie absolviert. Im Kern der Handlung stehen die verschiedenen Beziehungen der Assistenzärzte untereinander und mit ihren Stationsoberärzten.\",\"releaseDate\":\"2005-03-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4Cl0JlrdtFFKwrzKoa9zf13U6zM.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/jP0Rhj9OTPDAwQlHQwOLFDdeE8t.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"42009\"},\"name\":\"Black Mirror\",\"nameTranslations\":{},\"originalName\":\"Black Mirror\",\"description\":\"In dieser dystopischen Anthologieserie treffen die größten Innovationen der Menschheit auf ihre dunkelsten Eigenschaften.\",\"releaseDate\":\"2011-12-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/seN6rRfN0I6n8iDXjlSMk1QjNcq.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/dg3OindVAGZBjlT3xYKqIAdukPL.jpg\"},\"genres\":[\"Sci-Fi & Fantasy\",\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"88046\"},\"name\":\"Fire Force\",\"nameTranslations\":{},\"originalName\":\"炎炎ノ消防隊\",\"description\":\"Terror hat die Metropole Tokio fest im Griff. Von Dämonen besessene Menschen begannen urplötzlich in Flammen aufzugehen. Um dieses Phänomen zu bekämpfen, wurde ein spezielles Feuerbekämpfungsteam gebildet, die Fire Force, bereit jederzeit einzugreifen wenn eine spontane Selbstentzündung stattfinden sollte. Das Team bekommt nun Verstärkung von Shinra, einem Jungen, der in der Lage ist, mithilfe von Flammen an den Füßen mit der Geschwindigkeit einer Rakete zu rennen. Wird die Fire Force es schaffen, die Quelle der Entzündungen zu finden und zu stoppen oder wird die Stadt in einem Flammenmeer untergehen?\",\"releaseDate\":\"2019-07-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qDNgM4STqdzl4IBMyqCVMIr6uUV.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/zDXuwmqkTi2lGM4AyloAAX4v51P.jpg\"},\"genres\":[\"Animation\",\"Action & Adventure\",\"Sci-Fi & Fantasy\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"254953\"},\"name\":\"Rooster\",\"nameTranslations\":{},\"originalName\":\"Rooster\",\"releaseDate\":\"2026-03-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/aikvD4Nu7N6ekbrXNua8vJlO8JU.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/mhZAT8ktiNi7YwuL50kmumsau69.jpg\"},\"genres\":[\"Komödie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"90812\"},\"name\":\"Industry\",\"nameTranslations\":{},\"originalName\":\"Industry\",\"description\":\"Die britische Serie Industry folgt einer Gruppe junger Hochschulabsolventen im Jahre 2008, die um eine begrenzte Anzahl von Festanstellungen bei einer Top-Investmentbank in London konkurrieren. Doch die Grenzen zwischen Kollege, Freund, Liebhaber und Feind verschwimmen bald, als sie in eine Unternehmenskultur eintauchen, die ebenso sehr durch Sex, Drogen und Ego wie durch Geschäfte und Dividenden definiert ist. Während die Mitglieder der Gruppe auf- und absteigen, müssen sie entscheiden, ob es im Leben um mehr geht als um das Endergebnis.\",\"releaseDate\":\"2020-11-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/mZ7YFEOxAKfjXJKWm0sYFXQ8n8A.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/qcV7ebwtZcoRxBufUmXQl0KKdht.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"313289\"},\"name\":\"운명전쟁49\",\"nameTranslations\":{},\"originalName\":\"운명전쟁49\",\"releaseDate\":\"2026-02-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5V2n2JTYCTPD4fpikmPxldpuzos.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hiuzn8JQ4Q0VjA8AaU1qhL5Rjx8.jpg\"},\"genres\":[\"Mystery\",\"Reality\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"126027\"},\"name\":\"Ghosts\",\"nameTranslations\":{},\"originalName\":\"Ghosts\",\"description\":\"Das Ehepaar Samantha (Rose McIver) und Jay Arondeka (Utkarsh Ambudkar) träumt vom Ausbruch aus dem Großstadt-Trott. Die Erbschaft eines Landhauses scheint ihnen den Neuanfang zu ermöglichen – sie wollen das Haus ausbauen, um Touristen zu beherbergen. Schnell finden sich zwei große Hürden: Das Haus ist wirklich in einem sehr schlechten Zustand… und es „leben“ dort die Geister von Menschen, die im Lauf der Jahrhunderte dort verstorben sind. Für die ist der Plan, ein Hotel in dem Haus zu eröffnen, der pure Albtraum. Doch wie wird man die menschlichen Eindringlinge wieder los? Die Geister besinnen sich auf ihre Spuk-Fähigkeiten – leichter gesagt als getan.\",\"releaseDate\":\"2021-10-07\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8yBQYa6AdvMY5H9CiAv0HkvF3UE.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/3MmRal3Uw3O0TVMvhfM63Z3mPz3.jpg\"},\"genres\":[\"Komödie\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"208397\"},\"name\":\"School Spirits\",\"nameTranslations\":{},\"originalName\":\"School Spirits\",\"description\":\"In der Mystery-Jugendserie \\\"School Spirits\\\" wacht Maddie mit einer gewaltigen Kopfwunde in ihrer Schule wacht und muss feststellen, dass sie tot ist - und nun ein Geist. Wie sie gestorben ist, daran kann sich Maddie nicht mehr erinnern. Ihr Geist ist jedoch in der Schule gefangen - und sie ist nicht allein. Eine Handvoll Geister streifen ebenso durch die Gänge der Schule, die sie allesamt aus mystischen Gründen nicht verlassen können und sich in einer Selbsthilfegruppe versammelt. Gemeinsam mit den anderen Geistern beginnt Maddie das Rätsel ihres eigenen Todes zu erforschen. Bei ihrer Suche stolpert sie aber auch über weitere Geheimnisse\",\"releaseDate\":\"2023-03-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/bcIsJ06LptDahicANKK5XTqobd3.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/A6biiToqBbtL2uDxJDYqCjDOSU2.jpg\"},\"genres\":[\"Mystery\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"315213\"},\"name\":\"Friends Like These: The Murder of Skylar Neese\",\"nameTranslations\":{},\"originalName\":\"Friends Like These: The Murder of Skylar Neese\",\"releaseDate\":\"2026-03-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/iBnFAcwkSFF9KmtZSUU4V27k9pG.jpg\"},\"genres\":[\"Krimi\",\"Dokumentarfilm\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"202555\"},\"name\":\"Daredevil: Born Again\",\"nameTranslations\":{},\"originalName\":\"Daredevil: Born Again\",\"description\":\"Matt Murdock, ein blinder Anwalt mit besonderen Fähigkeiten, kämpft in seiner geschäftigen Anwaltskanzlei für Gerechtigkeit, während der ehemalige Mafiaboss Wilson Fisk seine eigenen politischen Ziele in New York verfolgt. Als ihre früheren Identitäten sich ihren Weg an die Oberfläche bahnen, befinden sich beide Männer unausweichlich auf Kollisionskurs.\",\"releaseDate\":\"2025-03-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/9lLuhV703HGCbnz6FxnqCwIwzAZ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/v2cTiLNlviotwugnDKqY21xGmSv.jpg\"},\"genres\":[\"Drama\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"284838\"},\"name\":\"9-1-1: Nashville\",\"nameTranslations\":{},\"originalName\":\"9-1-1: Nashville\",\"description\":\"„9-1-1: Nashville“, der neueste Teil des Franchise, ist eine actiongeladene Serie über heldenhafte Ersthelfer und ihre Familiengeschichten voller Macht und Glamour. Schauplatz ist eine der vielfältigsten und lebendigsten Städte Amerikas.\",\"releaseDate\":\"2025-10-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4Dl0LysUOEWOhitzAfrKFkBeefu.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/eO4cbYrbYIwn6uFZgpvdfD9eY9o.jpg\"},\"genres\":[\"Drama\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"289560\"},\"name\":\"CIA\",\"nameTranslations\":{},\"originalName\":\"CIA\",\"releaseDate\":\"2026-02-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8XbgWv137Umc8resTDeWh9ff7Y0.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5lyGqz3YiqpKNgS78xiZ4ImpB8w.jpg\"},\"genres\":[\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"2190\"},\"name\":\"South Park\",\"nameTranslations\":{},\"originalName\":\"South Park\",\"description\":\"Die Serie konzentriert sich hauptsächlich auf die Abenteuer der vier Kinder Stan Marsh, Kyle Broflovski, Eric Cartman und Kenny McCormick in der fiktionalen Kleinstadt South Park in den Rocky Mountains in den USA der Gegenwart. Neben den vier Hauptcharakteren wird die Stadt von einer Reihe von zusätzlichen Charakteren bevölkert.\",\"releaseDate\":\"1997-08-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1CGwZCFX2qerXaXQJJUB3qUvxq7.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/3UviYOlhn8EgXMBuiT6MnUuo1w9.jpg\"},\"genres\":[\"Animation\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"125935\"},\"name\":\"Abbott Elementary\",\"nameTranslations\":{},\"originalName\":\"Abbott Elementary\",\"description\":\"In einer öffentlichen Schule in Philadelphia arbeitet eine Gruppe engagierter Lehrer allen Widerständen – inklusive eines immer wieder ins Fettnäpfchen tretenden Rektors – zum Trotz zusammen, um ihren Schülern zu vermitteln, was sie für einen erfolgreichen Start ins Leben brauchen. Sie gehen mit voller Liebe zur Berufung zu Werke, auch, wenn sie unterfinanziert sind, es einfach zu viele Schüler gibt und die örtliche Schulbehörde geradezu gegen sie zu arbeiten scheint.\",\"releaseDate\":\"2021-12-07\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/nBe1e3JJEZ6veGrVXNF0fRoLu56.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/asDINJT3b7tEa76uWI1rZ5TWdJF.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"280632\"},\"name\":\"成何体统\",\"nameTranslations\":{},\"originalName\":\"成何体统\",\"releaseDate\":\"2026-02-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/sgVBl9UD2s8GZDBia65WFkIViso.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nz6Pg1RKfTrcw6ddPXCvqZM2M5p.jpg\"},\"genres\":[\"Drama\",\"Mystery\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"243875\"},\"name\":\"Georgie & Mandy\",\"nameTranslations\":{},\"originalName\":\"Georgie & Mandy's First Marriage\",\"description\":\"Georgie und Mandy sind nach ihrer Hochzeit mit ihrer Tochter CeeCee zu Mandys Eltern, Audrey und Jim, gezogen. Dort steht das junge Paar vor den Herausforderungen des Erwachsenseins, der Elternschaft und ihrer Ehe ...\",\"releaseDate\":\"2024-10-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/6Yr6uh6MVNWQAMDEaKjj3nAyjhP.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/pCr3YYJkkLt9fdGVD7I2Z1l6lzK.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"235635\"},\"name\":\"Bittersüße Schokolade\",\"nameTranslations\":{},\"originalName\":\"Como agua para chocolate\",\"description\":\"Tita de la Garza und Pedro Muzquiz sind zwei Seelen, die sich lieben, aber aufgrund tief verwurzelter Familientraditionen nicht zusammen sein können. Dies zwingt Tita, sich mit magischen Farben und Aromen zwischen dem von ihrer Familie diktierten Schicksal und dem Kampf um ihre Liebe zurechtzufinden, während wir sie in ihrem größten Zufluchtsort begleiten: der Küche.\",\"releaseDate\":\"2024-11-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ayRzAZ68ovnEHXUGYxmVpCAOOlt.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yykLaIafqnJ4wTiSaIUwMtSEQov.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"139060\"},\"name\":\"Demon Slave - The Chained Soldier\",\"nameTranslations\":{},\"originalName\":\"魔都精兵のスレイブ\",\"description\":\"Die Dämonenwelt öffnet ihre Pforten und stürzt alles ins Chaos: Frauen sind nun die Stärkeren, während Männer nur noch als Helfer dienen. Der Grund für diesen Wandel sind besondere Pfirsiche aus der Dämonenwelt, die Frauen mit außergewöhnlichen Fähigkeiten ausstatten. In dieser neuen Realität bekämpfen sie die Dämonen erfolgreich.\\n\\nAls der Oberschüler Yuki in diese Welt gerät, verändert sich sein Leben rasant. Von Kyoka, einer Kämpferin der Anti-Dämoneneinheit, gerettet, wird er zum Sklaven gemacht und sogar in einen Dämon verwandelt, um den Feind zu besiegen. Im Gegenzug erfüllt sie ihm seine intimsten Wünsche, während er als Hausmann in ihrer Einheit arbeitet – ein Arrangement, das rasch die Aufmerksamkeit anderer Mädchen auf sich zieht …\",\"releaseDate\":\"2024-01-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ieI3bn3oBKkqbJtYEPiaCV22Gps.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/t02dITrzFNNFEaogaxSOgibpZfp.jpg\"},\"genres\":[\"Animation\",\"Action & Adventure\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"95350\"},\"name\":\"Lanterns\",\"nameTranslations\":{},\"originalName\":\"Lanterns\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/nQX30kvXprW58w3jnkV8KSZZITB.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/moA5NNpOsSeQ2gNkOBgbMeNOl3d.jpg\"},\"genres\":[\"Sci-Fi & Fantasy\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"87083\"},\"name\":\"Formula 1: Drive to Survive\",\"nameTranslations\":{},\"originalName\":\"Formula 1: Drive to Survive\",\"description\":\"Wem die Formel-1-Testfahrten vor dem Saisonstart 2019 nicht ausreichen, der kann sich auf eine neue Dokumentation freuen. Dabei soll den Fans ein exklusiver Einblick hinter die Kulissen ihrer Lieblings-Fahrer und -Teams geboten werden. In 'Formula 1: Drive to Survive' soll es demnach nicht nur um den Kampf um den Titel auf der Strecke gehen, sondern auch um das Privatleben der Fahrer und Teamverantwortlichen abseits der Rennstrecke.\",\"releaseDate\":\"2019-03-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/xGOGjJFYYeRSoOpnhN9IHZTXIxj.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/xefmNmSGCApfRPaqhIRTaAjFlpo.jpg\"},\"genres\":[\"Dokumentarfilm\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"278127\"},\"name\":\"唐宫奇案之青雾风鸣\",\"nameTranslations\":{},\"originalName\":\"唐宫奇案之青雾风鸣\",\"releaseDate\":\"2026-02-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/t9uq0A7luhtnbzLcp0jCQu8f6Ii.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1mLSH6ssXakJXj9bIQh4GAg5eO.jpg\"},\"genres\":[\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"281495\"},\"name\":\"除恶\",\"nameTranslations\":{},\"originalName\":\"除恶\",\"releaseDate\":\"2026-02-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ky9Eit4aA3BFLQdrulRuDNdvWLS.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gc9ySDlKwKnwlEw6km6KUXM44Yq.jpg\"},\"genres\":[\"Krimi\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"30983\"},\"name\":\"Detektiv Conan\",\"nameTranslations\":{},\"originalName\":\"名探偵コナン\",\"description\":\"Conan Edogawa sieht aus wie ein Grundschüler. Tatsächlich ist er Shinichi Kudo, der 17-jährige Meisterdetektiv Japans, der von zwei Verbrechern vergiftet wurde. Er starb zwar nicht, entwickelte sich aber körperlich zum Kind zurück. Im Kopf ist er aber weiter der brillante Ermittler von einst und so stürzt er sich weiterhin auf geheimnisvolle Mordfälle.\",\"releaseDate\":\"1996-01-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1IfcpJRkSUnXbzy2ZVjHtxtqtdL.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5546GF3zT3yA25ydCz0KlujjRA3.jpg\"},\"genres\":[\"Animation\",\"Krimi\",\"Mystery\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"285357\"},\"name\":\"ROLL OVER AND DIE: I Will Fight for an Ordinary Life with My Love and Cursed Sword!\",\"nameTranslations\":{},\"originalName\":\"「お前ごときが魔王に勝てると思うな」と勇者パーティを追放されたので、王都で気ままに暮らしたい\",\"description\":\"Durch ihre Fähigkeit „Umkehren“ ist das junge Mädchen Flum schwächer als der Durchschnittsmensch. Aufgrund einer göttlichen Fügung wurde sie jedoch dazu auserwählt, ein Mitglied der Heldengruppe zu werden. Im Kampf ist sie zwar recht nutzlos, aber sie gibt ihr Bestes, um die Gruppe zu unterstützen, indem sie sich um die Bedürfnisse jedes Einzelnen kümmert. Für Jean, den Priester, ist das jedoch nicht genug. Er möchte sie loswerden, schikaniert sie und verkauft sie kurzerhand an einen Sklavenhändler. In dieser für Flum aussichtslosen Welt gelangt sie in den Besitz eines verfluchten Schwertes. Dieses Schwert wird das Schicksal von Flum und Milkit, einer anderen Sklavin die sie kennengelernt hat, „umkehren“.\",\"releaseDate\":\"2026-01-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/nH6Ch1q5rwdRs56bYTA9wuOhfbL.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/uLC9tdRSPcKsgvRLth38WEbm8pa.jpg\"},\"genres\":[\"Animation\",\"Drama\",\"Action & Adventure\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"198178\"},\"name\":\"Wonder Man\",\"nameTranslations\":{},\"originalName\":\"Wonder Man\",\"description\":\"Der aufstrebende Hollywood-Schauspieler Simon Williams kämpft darum, seine Karriere in Gang zu bringen. Bei einer zufälligen Begegnung mit Trevor Slattery, einem Schauspieler, dessen größte Rollen wohl schon hinter ihm liegen, erfährt Simon, dass der legendäre Regisseur Von Kovak eine Neuverfilmung des Superheldenfilms „Wonder Man“ plant. Die beiden Schauspieler, die sich an entgegengesetzten Enden ihrer Karriere befinden, streben verbissen nach Rollen in diesem Film, die ihr Leben verändern könnten, während das Publikum einen Blick hinter die Kulissen der Unterhaltungsindustrie werfen kann.\",\"releaseDate\":\"2026-01-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/6yy9nQlFt2l6UVWzrfhszFCaZ5C.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ldz9THIHaV4orMsUrPT1nlQF51T.jpg\"},\"genres\":[\"Komödie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"240459\"},\"name\":\"Spartacus: Das Haus Ashur\",\"nameTranslations\":{},\"originalName\":\"Spartacus: House of Ashur\",\"description\":\"Was, wenn Ashur überlebt hätte und mit dem Ludus belohnt worden wäre, in dem er einst blutete? Mit der Gladiatorin Achillia entfacht er Spektakel, das Rome trotzt und die Elite schockiert.\",\"releaseDate\":\"2025-12-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/xvMpLyFCBRnNJJ34kS3IUU2tzQ2.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/c78kbj781ddvmSn5mgLWFQbC7di.jpg\"},\"genres\":[\"Drama\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"279446\"},\"name\":\"Swords Into Plowshares\",\"nameTranslations\":{},\"originalName\":\"太平年\",\"description\":\"In der turbulenten Zeit der Fünf Dynastien und Zehn Reiche wollen der jüngere Bruder eines verstorbenen Königs und seine Verbündeten China einen.\",\"releaseDate\":\"2026-01-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/76gwCVQG1MoItK25o48opYP7TmG.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/c5mwcq4lvp96cHPgAWE1uxdwxkR.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1877\"},\"name\":\"Phineas und Ferb\",\"nameTranslations\":{},\"originalName\":\"Phineas and Ferb\",\"description\":\"Die Stiefbrüder Phineas und Ferb sind fest entschlossen, an jedem Tag ihrer Sommerferien ein anderes aufregendes Abenteuer zu erleben. Deshalb denken sich die beiden jede Menge \\\"phinomenal-ferbastische\\\" Dinge aus. Dummerweise erweist sich ihre große Schwester Candace als reinste Spaßbremse, die nur darauf wartet, die Jungs bei der Mutter verpetzen zu können. Ganz nebenbei ist das Familien-Schnabeltier Perry in Wirklichkeit ein Geheimagent namens \\\"Agent P.\\\", der die Welt vor dem skrupellosen Dr. Doofenschmirtz retten muss.\",\"releaseDate\":\"2007-08-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/tYbupI7MhsGc2HZS62m7uJh9BPw.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5MWFjQ3NuNtNeOE9FdrVLeNMNPs.jpg\"},\"genres\":[\"Animation\",\"Komödie\",\"Familie\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"251983\"},\"name\":\"Erica\",\"nameTranslations\":{},\"originalName\":\"Erica\",\"releaseDate\":\"2025-01-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/hHDXhcayTqlT0qBUlREBtxMXcK0.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1Qp2avVoG8nlFamnsgNqHqJySDB.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"226285\"},\"name\":\"Elsbeth\",\"nameTranslations\":{},\"originalName\":\"Elsbeth\",\"description\":\"Im Mittelpunkt der US-Anwaltsserie „Elsbeth“ steht die Juristin Elsbeth Tascioni, eine recht eigenwillige, etwas schrille, aber herzliche Strafverteidigerin. Sie zieht es nach New York, wo sie nach einer erfolgreichen Karriere in Chicago neue Wege beschreiten möchte. Elsbeth Tascioni sorgt hier mit ihrer Fähigkeit, genauestens und messerscharf zu beobachten, für Aufsehen, so auch bei den Beamten des NYPD, die sie bei ihren Ermittlungen unterstützt\",\"releaseDate\":\"2024-02-29\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7lnNSbT90qwtrn1h9TvEkVFMz2P.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ezQSOeu9uj4bWulxHR7D5CSNv3r.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Komödie\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"255055\"},\"name\":\"Doc\",\"nameTranslations\":{},\"originalName\":\"Doc\",\"description\":\"Amy Larsen, Leiterin der Inneren Medizin, muss nach einer Gehirnverletzung, die ihr Gedächtnis der letzten acht Jahre gelöscht hat, in einer ihr unbekannten Welt zurechtkommen.\",\"releaseDate\":\"2025-01-07\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/hYHrPWM6qGq2XSbaWUONckBgUir.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/iTt37Rl8AidvU5aQf5M4odroCuF.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"280049\"},\"name\":\"HELL MODE: The Hardcore Gamer Dominates in Another World with Garbage Balancing\",\"nameTranslations\":{},\"originalName\":\"ヘルモード ～やり込み好きのゲーマーは廃設定の異世界で無双する～ はじまりの召喚士\",\"description\":\"Yamada Kenichis Herz wird schwer: Die Server für sein geliebtes Multiplayer-Game werden abgeschaltet. Auf der Suche nach einem Ersatz stößt er auf ein Spiel, das eine unvergleichliche Herausforderung verspricht. Ohne zu zögern wählt er den Schwierigkeitsgrad „Höllenmodus“. Und siehe da, er findet sich widergeboren als Leibeigener in einer anderen Welt wieder! Ohne die Hilfe von Walkthroughs, Spielanleitungen oder Online-Foren muss er nun die Geheimnisse seiner mysteriösen Beschwörerklasse lüften und sich einen Weg an die Spitze des Games bahnen!\",\"releaseDate\":\"2026-01-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8ORt29GnG4gFNrQDUUSE1ZQP9Vm.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gf62V8UBVBMFPpD9yI0UFvkFvq2.jpg\"},\"genres\":[\"Animation\",\"Action & Adventure\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"44006\"},\"name\":\"Chicago Fire\",\"nameTranslations\":{},\"originalName\":\"Chicago Fire\",\"description\":\"Für die Feuerwehrmänner und Rettungssanitäter der Feuerwache 51 in Chicago sind Stress und Gefahren an der Tagesordnung. Die enorme Verantwortung, der sich die Alltagshelden aussetzen, macht auch vor dem Privatleben nicht halt. Matthew Casey, der Chef von Truck 81, steckt gerade mitten in einer Scheidung und sucht in seinem Job Ablenkung. Nach dem Tod eines Feuerwehrmanns gerät er mit Kelly Severide, dem Anführer von Rescue Squad 3, aneinander. Trotz gelegentlicher Scharmützel ist das Department für die meisten Teammitglieder wie eine Ersatzfamilie, zumal die bisweilen traumatischen Erlebnisse während der Einsätze für eine emotionale Bindung sorgen.\",\"releaseDate\":\"2012-10-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/c1gvOG6a4UWkP4d6IUomYdwGs4G.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/14LzHqJrFcHk7ruMNCXpEkB0Thg.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"233833\"},\"name\":\"찬란한 너의 계절에\",\"nameTranslations\":{},\"originalName\":\"찬란한 너의 계절에\",\"releaseDate\":\"2026-02-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/eUkIxWK9KhLQLPQct9G8HeY61Rj.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/pHhGVPOi9qI6CVYIrgZ2VWflg0u.jpg\"},\"genres\":[\"Mystery\",\"Drama\",\"Familie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"95557\"},\"name\":\"Invincible\",\"nameTranslations\":{},\"originalName\":\"Invincible\",\"description\":\"Als Mark Grayson mit siebzehn endlich Superkräfte bekommt, wird er wie sein Vater einer der größten Superhelden der Erde. All seine Träume werden wahr – bis ein schreckliches Ereignis alles verändert.\",\"releaseDate\":\"2021-03-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/jBn4LWlgdsf6xIUYhYBwpctBVsj.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/dfmPbyeZZSz3bekeESvMJaH91gS.jpg\"},\"genres\":[\"Animation\",\"Sci-Fi & Fantasy\",\"Action & Adventure\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"154385\"},\"name\":\"BEEF\",\"nameTranslations\":{},\"originalName\":\"BEEF\",\"description\":\"Ein Verkehrsstreit zwischen zwei Fremden – einem gescheiterten Bauunternehmer und einer unzufriedenen Entrepreneurin – führt zu einem Kleinkrieg, der völlig aus dem Ruder läuft.\",\"releaseDate\":\"2023-04-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4b4v7RnPhNyPEaVGFarEuo74r8W.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/f2sLP1SKXdfy9tICjCpm6bVMDX2.jpg\"},\"genres\":[\"Komödie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"67063\"},\"name\":\"The Outcast\",\"nameTranslations\":{},\"originalName\":\"一人之下\",\"description\":\"Zhang Chulan führt eigentlich ein normales Studentenleben, bis er auf einem Friedhof eines kleinen Dorfes Grausiges erlebt. Als er das Grab seines Großvaters besuchen möchte, wird er von Zombies und einer geheimnisvollen Frau attackiert. Eine Begegnung, die sein Leben drastisch verändert\",\"releaseDate\":\"2016-07-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/kUTsnVSo9JWcFK3Y2XILQfH0imK.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/tRQMZPYWQTOygIeGZ7rmmQaeq1z.jpg\"},\"genres\":[\"Animation\",\"Sci-Fi & Fantasy\",\"Action & Adventure\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"225171\"},\"name\":\"Pluribus\",\"nameTranslations\":{},\"originalName\":\"Pluribus\",\"description\":\"Ausgerechnet der unglücklichste Mensch auf Erden soll die Welt vor dem Glück retten.\",\"releaseDate\":\"2025-11-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/9jZcSqGD7ZzmsexpE1rPJh5JVYd.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ulm1ex4JFYJByyaPyqTr47MFyEQ.jpg\"},\"genres\":[\"Drama\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"313138\"},\"name\":\"언제나 다시 만나\",\"nameTranslations\":{},\"originalName\":\"언제나 다시 만나\",\"releaseDate\":\"2026-03-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3UfAqEdXdiuV6qAVgzuihBVbsXz.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/meJhZt0zDjC4IjGO12ThnTxxJZL.jpg\"},\"genres\":[\"Drama\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"270572\"},\"name\":\"Lord of the Flies\",\"nameTranslations\":{},\"originalName\":\"Lord of the Flies\",\"description\":\"Nach einem Flugzeugabsturz stranden mehrere junge Schulkinder ohne Erwachsene auf einer tropischen Insel. Ralph wird zum Anführer gewählt und versucht gemeinsam mit dem klugen Piggy, Ordnung und Zivilisation aufrechtzuerhalten. Jack, der für das Signalfeuer verantwortlich ist, wendet sich zunehmend der Jagd und Machtkämpfen zu. Dies führt zu Konflikten innerhalb der Gruppe und lässt die Kinder langsam von Hoffnung und Struktur in Chaos und Tragödie abrutschen.\",\"releaseDate\":\"2026-02-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/zD50ejpus5rNidj6CBr4Ml59KOL.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/liGU5vmxT1FisyfAh1v6octAFDz.jpg\"},\"genres\":[\"Drama\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"276083\"},\"name\":\"Kacken an der Havel\",\"nameTranslations\":{},\"originalName\":\"Kacken an der Havel\",\"description\":\"Als Rapper Toni zur Beerdigung seiner Mutter in die Heimat zurückkehrt, steht plötzlich nicht nur die große Karrierechance vor ihm, sondern auch ein Sohn, von dem er nichts wusste.\",\"releaseDate\":\"2026-02-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/9XXKr1vEgodDhfEW5slzcwwUIuS.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/rTTEaQ54i6zUSDGnVyuNbvu86wf.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"273977\"},\"name\":\"The Art of Sarah\",\"nameTranslations\":{},\"originalName\":\"레이디 두아\",\"description\":\"Eine Leiche mitten in der Stadt, ein Luxuslabel im Aufwind. Ein Kommissar hinterfragt die Geschichte einer Frau, die sich ständig ändert. Was ist hier wirklich passiert?\",\"releaseDate\":\"2026-02-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/fjy2cv3Edy39bWHdc8yjQF66pqk.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/uLYp6qxGNzDlDtBOAlDbfcf4QgO.jpg\"},\"genres\":[\"Krimi\",\"Mystery\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"86031\"},\"name\":\"Dr. STONE\",\"nameTranslations\":{},\"originalName\":\"Dr.STONE\",\"description\":\"Mehrere tausend Jahre, nachdem die Menschheit durch ein mysteriöses Phänomen versteinert wurde, erwacht der außergewöhnlich intelligente und von der Wissenschaft begeisterte Senku Ishigami aus seinem Schlaf. Mit nichts außer Steinen und einer zusammengebrochenen Zivilisation um ihn herum fasst Senku den Entschluss, die Welt mithilfe von Wissenschaft wieder aufzubauen. Zusammen mit seinem muskelbepacktem Kindheitsfreund Taiju Oki, der kurz nach ihm erwacht, wollen sie die Gesellschaft aus dem Nichts neu errichten ...\",\"releaseDate\":\"2019-07-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/dLlnzbDCblBXcJqFLXyvN43NIwp.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lN13BPAEnc5iXmoxxBQHOZ1ScfZ.jpg\"},\"genres\":[\"Animation\",\"Action & Adventure\",\"Komödie\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"116799\"},\"name\":\"The Lincoln Lawyer\",\"nameTranslations\":{},\"originalName\":\"The Lincoln Lawyer\",\"description\":\"Der coole Strafverteidiger Mickey Haller tut bei seinen Fällen in L.A. alles, um zu gewinnen – von seinem kultigen Lincoln aus, als Kanzlei auf vier Rädern.\",\"releaseDate\":\"2022-05-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4jSaIqEU8CPBBNn4iVCK6wzPjSx.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/jBFOVEE5sMIyT141YIqIwyU8Y1D.jpg\"},\"genres\":[\"Drama\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"272681\"},\"name\":\"岁月有情时\",\"nameTranslations\":{},\"originalName\":\"岁月有情时\",\"releaseDate\":\"2026-02-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ly8KtCEkT57YmMO7ztGkawzVXBy.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/y0R84gqHuRuGJ0rpf7dRf3QjZJW.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"218557\"},\"name\":\"Portobello\",\"nameTranslations\":{},\"originalName\":\"Portobello\",\"releaseDate\":\"2026-02-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/mS6rJQXFDHk5ZHz6oisEuudpmAo.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ebaW4MeaKlWYSABcPlA5zFHGtKb.jpg\"},\"genres\":[\"Drama\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"200875\"},\"name\":\"Es - Welcome to Derry\",\"nameTranslations\":{},\"originalName\":\"IT: Welcome to Derry\",\"description\":\"Derry, im Jahr 1962: Die Familie Hanlon zieht in die scheinbar idyllische Kleinstadt im US-Bundesstaat Maine, um ein neues Leben zu beginnen. Während die Eltern versuchen, sich mitsamt ihrem kleinen Sohn einzuleben, häufen sich bald beunruhigende Vorfälle: Immer wieder verschwinden kleine Kinder spurlos, und seltsame Erscheinungen versetzen die Bewohner in Angst. Unterdessen schließen ein paar Jugendliche eine schicksalhafte Freundschaft und entdecken gemeinsam ein uraltes Grauen, das tief unter der Stadt lauert. Sie geraten in einen Strudel aus dunklen Geheimnissen – bis sich die unfassbare Bedrohung allmählich in einer unheimlichen Clownsgestalt verdichtet.\",\"releaseDate\":\"2025-10-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ahIrhPWCDJZKJnzfaFsTo789RwP.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/2746UvsbkZINd873Yd3o3TxOwCP.jpg\"},\"genres\":[\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"45790\"},\"name\":\"JoJo's Bizarre Adventure\",\"nameTranslations\":{},\"originalName\":\"ジョジョの奇妙な冒険\",\"description\":\"Im England des Jahres 1880 nimmt der Adlige George Joestar seinen neuen Adoptivsohn bei sich auf: den jungen Dio Brando, dessen Vater Georges Leben vor 12 Jahren gerettet hat. Doch statt friedlich in seinem neuen Heim einzuziehen, möchte der in Armut großgewordene Dio die Joestar-Familie zerstören und ihren Status für sich gewinnen. Was als simple Fehde mit Georges Sohn Jonathan beginnt, entwickelt sich bald zu einem Konflikt, welcher weit über 100 Jahre andauert und sämtliche Generationen der Joestars in den Kampf gegen Vampire, aztekische Gottheiten, Nazis und gewitzte Serienmörder schickt.\",\"releaseDate\":\"2012-10-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ieP7Q9z24sNUfVNFC38rYBw6yxq.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/mLKN1dsimKPiXCZ48KED0X8a02t.jpg\"},\"genres\":[\"Animation\",\"Action & Adventure\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"287527\"},\"name\":\"The Testaments\",\"nameTranslations\":{},\"originalName\":\"The Testaments\",\"releaseDate\":\"2026-04-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/6KbDKKjCntM6ytJnTcbPYIuJAkQ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/dPMDCieFOlk1E8cklhXD6cSxq1v.jpg\"},\"genres\":[\"Drama\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"211288\"},\"name\":\"Tracker\",\"nameTranslations\":{},\"originalName\":\"Tracker\",\"description\":\"Colter Shaw reist in seinem Old-School-Wohnmobil durch das Land, um der Polizei und Privatleuten bei der Aufklärung von Verbrechen und der Suche nach vermissten Personen zu helfen, bis sein neuester Fall alles verändert.\",\"releaseDate\":\"2024-02-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/otula4h1ITZ0eV84eg7Lb8u614C.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5C5cMYUlmX6BU5YxBqhp7ZpSd3Q.jpg\"},\"genres\":[\"Drama\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"241609\"},\"name\":\"Your Friends & Neighbors\",\"nameTranslations\":{},\"originalName\":\"Your Friends & Neighbors\",\"description\":\"Als sich ein Finanzmogul plötzlich ohne Frau und Job im Leben wiederfindet, beginnt er damit seine wohlhabenden Nachbarn zu bestehlen, um sich über Wasser zu halten. Erst gibt ihm das Ganze einen seltsamen Kick - doch er verstrickt sich allmählich in einem tödlichen Netz.\",\"releaseDate\":\"2025-04-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8ZZkBJEdHl5WdWuv9fqQzjBAVea.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/8NX2kBLHS6vSrl8Lg3Y2JAqzmy9.jpg\"},\"genres\":[\"Drama\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"4614\"},\"name\":\"Navy CIS\",\"nameTranslations\":{},\"originalName\":\"NCIS\",\"description\":\"Der Naval Crime Investigative Service wird dann gerufen, wenn Verbrechen begangen werden, die gegen den Uniform Code of Military Justice verstoßen und innerhalb der Navy stattfinden. Das Hauptquartier befindet sich in Washington D.C. und steht unter der Leitung von Special Agent Leroy Jethro Gibbs. Er selbst ist ein Veteran aus dem Irak-Krieg und hat mit moderner Technik wenig zu tun. Aus diesem Grund ermittelt er gemeinsam mit einem Elite-Team, bestehend aus dem Ballistik-Experten Tony DiNozzo, dem Technikspezialisten Tim McGee, der Forensikspezialistin Abby Sciuto sowie dem Gerichtsmediziner Ducky Mallard.\",\"releaseDate\":\"2003-09-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/mBcu8d6x6zB1el3MPNl7cZQEQ31.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nn3SuLTO4hum8yAxaY4ql8h6kRk.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"63926\"},\"name\":\"One Punch Man\",\"nameTranslations\":{},\"originalName\":\"ワンパンマン\",\"description\":\"Was tun, wenn’s mit der Arbeit nicht klappt? Genau, man wird ein Held! Saitama ist ein stinknormaler Typ ohne Job - bis er einen kleinen Jungen vor einem Krabben-Monster retten muss. Er kann die Krabbe besiegen und beschließt daraufhin, die Jobsuche hinzuschmeißen und Hobby-Held zu werden. Nach drei Jahren hartem Training ist auf seinem Kopf zwar kein Haar mehr übrig, aber dafür erledigt er jeden Gegner mit nur einem Schlag! Von seiner eigenen Kraft gelangweilt, sehnt sich Saitama aka One Punch Man nach härteren Gegnern. Zwar zollen ihm die Leute dafür keinen Respekt, doch das geht ihm an seinem Hobby-Helden-Hintern vorbei. Ihm reicht schon der demütige Cyborg Genos, der im gleichgültigen Saitama seinen Meister sieht und ihm nun ständig an den Hacken hängt ...\",\"releaseDate\":\"2015-10-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/a8BknzvFVK5EZ83rKg1a83iwaj0.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/s0w8JbuNNxL1YgaHeDWih12C3jG.jpg\"},\"genres\":[\"Animation\",\"Komödie\",\"Action & Adventure\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"262793\"},\"name\":\"PONIES\",\"nameTranslations\":{},\"originalName\":\"PONIES\",\"description\":\"Moskau, 1977: Bea und Twila arbeiten in der amerikanischen Botschaft als einfache Sekretärinnen. Für die Geheimdienste des Kalten Krieges sind sie schlicht „Ponies“ – Personen, für die sie keinerlei Interesse haben. Das ändert sich schlagartig, als die Ehemänner der beiden unter mysteriösen Umständen ums Leben kommen. Kurzerhand rekrutiert sie die CIA als Agentinnen. Bea, die als hochgebildetes Kind sowjetischer Emigranten fließend Russisch spricht, und Twila, ihre Kollegin mit dem schroffen Charme einer furchtlosen Provinzlerin, sollen gemeinsam herausfinden, warum ihre Gatten sterben mussten. Bald kommen die beiden unterschiedlichen Frauen dabei einer weitreichenden Verschwörung auf die Spur.\",\"releaseDate\":\"2026-01-15\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/rwKS6rSAqMGnXwBVteYkHxeDLWX.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/Ak7AdQpvmZpSe9WYBd5KrgjSsSX.jpg\"},\"genres\":[\"Drama\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"286702\"},\"name\":\"Piekło kobiet\",\"nameTranslations\":{},\"originalName\":\"Piekło kobiet\",\"releaseDate\":\"2026-03-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/or3qGeZF4FgZ7Dax9HNJ5JdOIuq.jpg\"},\"genres\":[\"Drama\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"123249\"},\"name\":\"My Dress-Up Darling\",\"nameTranslations\":{},\"originalName\":\"その着せ替え人形は恋をする\",\"description\":\"Wakanas Wunsch ist es, zu einem Kishirashi wie sein Opa heranzuwachsen – ein Meister, der traditionelle japanische Hina-Puppen herstellt. Obwohl er von diesem Handwerk begeistert ist, hat er nicht den blassesten Schimmer von den neusten Modetrends und kann sich nur schwer in seiner Klasse einbringen. Seine beliebten Klassenkameraden, allen voran das Mädchen Marin, scheinen in einer völlig anderen Welt zu leben. Das ändert sich eines Tages, als sie ihm von ihrem geheimen Hobby des Cosplay erzählt und ihre völlig unterschiedliche Welten aufeinanderprallen.\",\"releaseDate\":\"2022-01-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/yDry50KhVrNJyS0Cjzv6auNJ0cx.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gWPK2RIVJ6i3myf7Xdw8DqlznT8.jpg\"},\"genres\":[\"Animation\",\"Komödie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"293608\"},\"name\":\"언더커버 미쓰홍\",\"nameTranslations\":{},\"originalName\":\"언더커버 미쓰홍\",\"releaseDate\":\"2026-01-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/nJ0gSaXfoiPFngy1ulCCuxsKt0q.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/awldlWlTkCeuohxZMGKhQwyydGA.jpg\"},\"genres\":[\"Krimi\",\"Komödie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"287231\"},\"name\":\"Vanished\",\"nameTranslations\":{},\"originalName\":\"Vanished\",\"releaseDate\":\"2026-02-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/6Htrg4SobTHu9aYaYLGZaNLJvLX.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/qI2pX6IWQojvh2kaLv6M233Iwqb.jpg\"},\"genres\":[\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"289690\"},\"name\":\"러브 포비아\",\"nameTranslations\":{},\"originalName\":\"러브 포비아\",\"releaseDate\":\"2026-02-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/9DwR70nqCwRv7BE8Otkmr2dfmkV.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/zs4kMFDdMDH0Bv0ERGLLUxR0g03.jpg\"},\"genres\":[\"Komödie\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"65334\"},\"name\":\"Miraculous - Geschichten von Ladybug und Cat Noir\",\"nameTranslations\":{},\"originalName\":\"Miraculous, les aventures de Ladybug et Chat Noir\",\"description\":\"Marinette und Adrien sind zwei Schüler – fast – wie andere auch. Bei der kleinsten Bedrohung von Paris werden sie zu Ladybug und Cat Noir. Ihre Mission: Die Akumas des mysteriösen Hawk Moth fangen, der die Pariser in Super-Bösewichte verwandelt. Obwohl die beiden Helden ein Team bilden, wissen sie wenig voneinander: Marinette weiß nicht, dass sich hinter Cat Noir Adrien verbirgt, der Junge, in den sie heimlich verliebt ist; und Adrien, dessen Herzen für Ladybug schlägt, ignoriert, dass sich hinter dem Kostüm der Superheldin das nette und zerstreute Mädchen aus seiner Klasse verbirgt\",\"releaseDate\":\"2015-10-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/2gIfJXgcz6N2wgOZ4qXoNKh0qFZ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lH22EnM0ofC7GsVGU8dAA2RXV1c.jpg\"},\"genres\":[\"Action & Adventure\",\"Animation\",\"Kids\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"117465\"},\"name\":\"Hell's Paradise\",\"nameTranslations\":{},\"originalName\":\"地獄楽\",\"description\":\"Gabimaru war einst der stärkste Shinobi – nun erwartet ihn in der Todeszelle sein ultimatives Ende. Durch eine glückliche Fügung wird ihm von der Scharfrichterin Sagiri eine zweite Chance gewährt: Zusammen mit anderen Todeskandidaten soll er im Wettlauf das sogenannte Lebenselixier auf einer paradiesischen Insel ausfindig machen, um einen Freispruch von seinen erbarmungslosen Gräueltaten zu erwirken. Das idyllische Eiland offenbart sich jedoch schon bald als Hölle auf Erden, denn Leichen dienen als Dünger für den fruchtbaren Boden und nähren allerlei andersartige Kreaturen. Kann es Gabimaru gelingen, das Elixier in seinen Besitz zu bringen und dieser unerbittlichen Todesfalle, die bisher niemanden freigab, zu entfliehen?\",\"releaseDate\":\"2023-04-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/jfPqPQy2EiS8TwDlbvU9hgyxCdF.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/vjiIuR3XGpoGSumQ7DziPAmxIYR.jpg\"},\"genres\":[\"Animation\",\"Action & Adventure\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1433\"},\"name\":\"American Dad\",\"nameTranslations\":{},\"originalName\":\"American Dad!\",\"description\":\"Stan Smith ist ein echter Vorzeigeamerikaner. Als Waffenexperte bei der CIA immer auf den Fall eines terroristischen Anschlags vorbereitet, würde er alles dafür tun, sein geliebtes Vaterland zu beschützen. Neben seiner Tätigkeit bei der CIA ist er vor allem eins: Familienmensch. Dem Anschein nach sind die Smiths also eine ganz normale Familie, wären da neben dem pubertierenden Sohn Steve und der ultra-liberalen Tochter Hayley nicht noch die Familienmitglieder Roger und Klaus. Roger, ein Alien, wurde von Stan einst aus der Area 51 vor dem sicheren Tod gerettet, und Klaus ist ein deutsch-sprechender Goldfisch – ein missglücktes Experiment aus den CIA-Labors.\",\"releaseDate\":\"2005-02-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/eb9sH2am9IUSQ8GhXTNAVoujk8W.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/iixxhk3ycXmFqBn616pAsC3lu53.jpg\"},\"genres\":[\"Animation\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"263330\"},\"name\":\"SHIBOYUGI: Das Phantom-Mädchen im Spiel des Todes\",\"nameTranslations\":{},\"originalName\":\"死亡遊戯で飯を食う。\",\"description\":\"Yūki ist siebzehn und Teilnehmerin an Todesspielen. Sie hat bei den Spieln einiges gelernt: Fürs Überleben muss man berechnend sein. Es geht nicht um Glück. Fehlschläge bedeuten das Ende. Für die meisten sind die Games ein auswegloser Albtraum. Für Yūki sind sie jedoch ein Geschäft. Doch in einer Welt, in der jeder Raum zum Grab werden kann, bietet nicht einmal Erfahrung wirklichen Schutz.\",\"releaseDate\":\"2026-01-07\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4EswDHj9GVcSNmKwWcxvQDynTVJ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/rcwfBh8gPBL4sKUEPqu0lEKreha.jpg\"},\"genres\":[\"Animation\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"56570\"},\"name\":\"Outlander\",\"nameTranslations\":{},\"originalName\":\"Outlander\",\"description\":\"US-amerikanische Fantasy-Abenteuerserie nach der „Highland-Saga“ von Diana Gabaldons um die Krankenschwester Claire, die sich im Zweiten Weltkrieg um die verletzten Soldaten kümmert. Durch einen merkwürdigen Zufall wird sie in die Zeit vor 200 Jahren zurückversetzt, wo sie verfolgt und schließlich zwangsverheiratet wird …\",\"releaseDate\":\"2014-08-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/bxBmfyzK0ARF9hqf2pbFWsddH14.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nf3Vlxm3C9U1aKUUQHmKFZmxPSc.jpg\"},\"genres\":[\"Drama\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"65930\"},\"name\":\"My Hero Academia\",\"nameTranslations\":{},\"originalName\":\"僕のヒーローアカデミア\",\"description\":\"Der junge Izuku Midoriya hat nur einen Traum: Er möchte eines Tages ein Superheld werden - genau wie sein großes Idol All Might! Diese Seifenblase zerplatzt, als er feststellt, dass er einer der wenigen Menschen ist, die keine angeborene Spezialität - also eine besondere Fähigkeit – besitzen. Aber auch als Normalo will Izuku nicht aufgeben und bewirbt sich trotz der Lästereien seiner Mitschüler für die Aufnahmeprüfung an der Yuei-Akademie für Superhelden. Eigentlich ist sein Vorhaben zum Scheitern verurteilt, doch dann läuft er eines Tages zufällig All Might über den Weg. Gerührt von Izukus unbändigem Willen, lässt sich der größte Held aller Zeiten schließlich darauf ein, den naiven Wuschelkopf unter seine Fittiche zu nehmen. Wird das allein aber ausreichen, um gegen die starke Konkurrenz an Heldenanwärtern zu bestehen?\",\"releaseDate\":\"2016-04-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/dmUuNVWAJumRkDNuauFaLSvga00.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/6wSSyRNeF9vBJ1h29nuw3vG9hZI.jpg\"},\"genres\":[\"Action & Adventure\",\"Animation\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"282810\"},\"name\":\"The Judge Returns\",\"nameTranslations\":{},\"originalName\":\"The Judge Returns\",\"releaseDate\":\"2026-01-02\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/AnfCTqCrcrKqRO1HNJEFpt6oiIx.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/l3qDk8o59jgLfO5HBAJKpCwMAld.jpg\"},\"genres\":[\"Krimi\",\"Sci-Fi & Fantasy\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"71912\"},\"name\":\"The Witcher\",\"nameTranslations\":{},\"originalName\":\"The Witcher\",\"description\":\"Geralt von Riva, ein mutierter Monsterjäger, folgt seiner Bestimmung in eine turbulente Welt, in der Menschen oft boshafter sind als Biester.\",\"releaseDate\":\"2019-12-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/FdsAB1Z1IbECvvPu4JMkS0eQTY.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/foGkPxpw9h8zln81j63mix5B7m8.jpg\"},\"genres\":[\"Drama\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"124364\"},\"name\":\"FROM\",\"nameTranslations\":{},\"originalName\":\"FROM\",\"description\":\"Enträtseln Sie das Geheimnis einer alptraumhaften Stadt in Mittelamerika, die alle, die sie betreten, gefangen hält. Während die unfreiwilligen Bewohner darum kämpfen, ein Gefühl der Normalität zu bewahren und nach einem Ausweg zu suchen, müssen sie auch die Bedrohungen des umliegenden Waldes überleben – einschließlich der schrecklichen Kreaturen, die von dort kommen, wenn die Sonne untergeht.\",\"releaseDate\":\"2022-02-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cjXLrg4R7FRPFafvuQ3SSznQOd9.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/6gN8DYnIEln8v7OhRy61c57w0Xy.jpg\"},\"genres\":[\"Mystery\",\"Drama\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"314006\"},\"name\":\"DOC\",\"nameTranslations\":{},\"originalName\":\"DOC\",\"releaseDate\":\"2026-03-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/pG7oNCHSjuajUFXpqjJ76fac5J7.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/iY96OP57eKDmsIRkUWwQnPZxLUu.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"32608\"},\"name\":\"Ancient Aliens - Unerklärliche Phänomene\",\"nameTranslations\":{},\"originalName\":\"Ancient Aliens\",\"description\":\"Haben intelligente Wesen aus dem Weltraum die Erde vor Tausenden von Jahren besucht? Vom Zeitalter der Dinosaurier bis zum alten Ägypten, von frühen Höhlenzeichnungen bis zu fortgesetzten Massensichten in den USA, jede Episode gibt den Fragen, Spekulationen, provokativen Kontroversen, Berichten aus erster Hand und fundierten Theorien rund um diese uralte Debatte historische Tiefe.\",\"releaseDate\":\"2010-04-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/bGU7sAjlmx3MLinmqUxKi93jApK.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/6dHdAzaxpB9VrkVLXb5NHFlhGlg.jpg\"},\"genres\":[\"Dokumentarfilm\",\"Mystery\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"89456\"},\"name\":\"Primal\",\"nameTranslations\":{},\"originalName\":\"Primal\",\"description\":\"In einer Vorzeit, in der Spezies zusammenleben, die in der Realität nie zusammen existiert haben, trifft der Höhlenmensch Speer auf den Tyrannosaurus Reißzahn und die beiden bilden nach Anfangsschwierigkeiten eine ungewöhnliche Allianz, um in einer gewalttätigen und feindlichen Welt bestehen zu können.\",\"releaseDate\":\"2019-10-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/mf12pRakr3eYdJtv6klQtoznnbU.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/tbHQDtoDZGJsfe7Kx6BEShcrZAa.jpg\"},\"genres\":[\"Action & Adventure\",\"Animation\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"163813\"},\"name\":\"亲爱的·客栈\",\"nameTranslations\":{},\"originalName\":\"亲爱的·客栈\",\"releaseDate\":\"2017-10-07\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/b43cWIC1ABkOgl4MjsqAxLaHnBL.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hJGyjTYFPN9HKHkHcXTd5iriL0k.jpg\"},\"genres\":[\"Reality\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"205715\"},\"name\":\"Gen V\",\"nameTranslations\":{},\"originalName\":\"Gen V\",\"description\":\"„Gen V“ spielt an Amerikas einzigem Superhelden-College. Die Studenten stellen ihre Moral auf die Probe und wetteifern um den ersten Platz im Uni-Ranking und eine Chance, Teil der Seven zu werden, dem elitären Superheldenteam von Vought. Als die düsteren Geheimnisse der Uni zutage treten, müssen sie sich entscheiden, was für Helden sie werden wollen.\",\"releaseDate\":\"2023-09-28\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/uA713S9jqMmK1QjmbGXddkOGkni.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/tldMHeR7UnihV5ffrxxM8cDhbtT.jpg\"},\"genres\":[\"Action & Adventure\",\"Drama\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"103913\"},\"name\":\"Teheran\",\"nameTranslations\":{},\"originalName\":\"טהרן\",\"description\":\"Tamar ist eine Hackerin und Agentin des Mossad, die unter falscher Identität in Teheran eingeschleust wurde, um bei der Zerstörung des iranischen Atomreaktors zu helfen. Doch als ihre Mission scheitert, muss Tamar einen Einsatz planen, der alle in Gefahr bringt, die ihr wichtig sind.\",\"releaseDate\":\"2020-06-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/oUCjGc5U8ubrLh3RK3bFBqAhZNl.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/bgt0Qd2AfEq6tdwOHXKWiQb8Z0N.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"119051\"},\"name\":\"Wednesday\",\"nameTranslations\":{},\"originalName\":\"Wednesday\",\"description\":\"Clever, sarkastisch und fast eiskalt will Wednesday Addams eine Mordserie aufklären. Dabei findet sie an der Nevermore Academy jedoch nicht nur Freunde.\",\"releaseDate\":\"2022-11-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/36xXlhEpQqVVPuiZhfoQuaY4OlA.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/iHSwvRVsRyxpX7FE7GbviaDvgGZ.jpg\"},\"genres\":[\"Sci-Fi & Fantasy\",\"Mystery\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"54493\"},\"name\":\"Top Chef\",\"nameTranslations\":{},\"originalName\":\"Top Chef\",\"releaseDate\":\"2010-02-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1RYpOk7GWbFbUbPasw85YC7iPgo.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5PvRfVsansmSnJbhgmRqZzGvaCn.jpg\"},\"genres\":[\"Reality\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"57532\"},\"name\":\"Paw Patrol: Helfer auf vier Pfoten\",\"nameTranslations\":{},\"originalName\":\"PAW Patrol\",\"description\":\"Die sechs heldenhaften Hunde Chase, Marshall, Rocky, Zuma, Rubble und Skye werden von dem 10-jährigen Technikliebhaber Ryder angeführt. Die Paw Patrol vereint Heldenmut und coole Fahrzeuge mit ganz viel niedlichem Humor. Alle haben einen kleinen Rucksack auf dem Rücken für ihre Missionen, damit sie für alles gewappnet sind – egal, ob sie nun eine Katze vom Baum retten oder einen Zug vor herabfallenden Steinen bewahren. Kein Job ist zu groß, kein Hund zu klein!\",\"releaseDate\":\"2013-08-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8HXkgUBO5OF8ZK9XbY69RM4S5rv.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/7OrV2aAH5Yp7hA9zCCvUloLvZtl.jpg\"},\"genres\":[\"Animation\",\"Kids\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"154526\"},\"name\":\"MF GHOST\",\"nameTranslations\":{},\"originalName\":\"MFゴースト\",\"description\":\"202X: eine Zukunft jenseits von Initial D.\\n\\nSelbstfahrende Autos sind in Japan weitverbreitet, und öffentliche Straßen werden für Autorennen genutzt. In dieser Zeit hat ein Rennen namens MFG weltweit an Popularität gewonnen. Porsche, Ferrari, Lamborghini – die Teilnehmer werden eingeladen, mit ihren schnellsten Sportwagen anzutreten. Einer dieser Teilnehmer ist Kanata Livington, der unter der Anleitung von Takumi Fujiwara eine britische Rennsportschule absolvierte. Er kehrt nach Japan zurück, um am MFG teilzunehmen und ein weiteres Ziel zu erfüllen.\",\"releaseDate\":\"2023-10-02\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/vMnd8iqPwOOoIZ9a2RcqAHppDoq.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/qEqLerjgjX9BL1fsqRc4MoWzqIU.jpg\"},\"genres\":[\"Animation\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"218961\"},\"name\":\"Drops of God\",\"nameTranslations\":{},\"originalName\":\"Les Gouttes de Dieu\",\"description\":\"Während die Weinwelt den Tod von Alexandre Léger betrauert, erfährt seine entfremdete Tochter Camille, dass seine außergewöhnliche Sammlung nun ihr gehört. Doch bevor sie ihr Erbe antreten kann, muss Camille Alexandres Schützling Issei in einem Test der Sinne besiegen.\",\"releaseDate\":\"2023-04-21\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/wSJCFusGuZjBNbZXMIwWM6tPwUP.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/n1S7wjXldg351ajDMWSgMpfmfyW.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"74561\"},\"name\":\"明星大侦探\",\"nameTranslations\":{},\"originalName\":\"明星大侦探\",\"releaseDate\":\"2016-03-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/dmWr4vJgvGMH8m60fuTh0wzYGde.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/fLSxAR9UqEFus4CjJb1Er1qumyV.jpg\"},\"genres\":[\"Krimi\",\"Mystery\",\"Reality\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"58841\"},\"name\":\"Chicago P.D.\",\"nameTranslations\":{},\"originalName\":\"Chicago P.D.\",\"description\":\"Der District 21 des Chicago Police Departments besteht aus zwei unterschiedlichen Abteilungen: Einmal gibt es die Uniformed Cops, die ihren Einsatz auf den Straßen der Stadt haben und sich um Kleinkriminelle kümmern. Die Intelligence Unit hingegen bekämpft Straftaten im großen Stil, sei es Drogenschmuggel oder Morde aller Art.\",\"releaseDate\":\"2014-01-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/xjaAEVaZEI8qmchnJmfhNdXDuuv.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/rhp8vYG1sIFtqH3ETmHJuI5Z3Cb.jpg\"},\"genres\":[\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"615\"},\"name\":\"Futurama\",\"nameTranslations\":{},\"originalName\":\"Futurama\",\"description\":\"Silvester 1999, Mitternacht: Der New Yorker Pizzabote Philip J. Fry wird - scheinbar versehentlich - in einen kryostatischen Tiefschlaf versetzt, aus dem er eintausend Jahre später an Silvester 2999 wieder erwacht. Bei Planet Express, einem interplanetaren Lieferdienst, der von seinem entfernten Nachfahren Professor Farnsworth geleitet wird, nimmt er eine Anstellung an. In seinen Mitarbeitern findet er Freunde. Zusammen erleben sie skurrile Abenteuer, die etwa durch Lieferaufträge zu entfernten Planeten oder Erfindungen des Professors ausgelöst werden.\",\"releaseDate\":\"1999-03-28\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/6ZS8SOno6kTmWz4eQ8lX8EBXOMv.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/4xKG4S1IyLIglHbCYGJDsptgQNh.jpg\"},\"genres\":[\"Animation\",\"Komödie\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"79481\"},\"name\":\"Battle Through the Heavens\",\"nameTranslations\":{},\"originalName\":\"斗破苍穹\",\"description\":\"Xiao Yan ist der Sohn von Xiao Zhan und Gu Wenxin und von klein auf ein Wunderkind, sehr begabt und intelligent. Seit dem Tod seiner Mutter hat er all seine Fähigkeiten im Kämpfen verloren. Im Alter von 15 Jahren entdeckt Xiao Yan, dass er mit dem Ring, den er von seiner Mutter geerbt hat, den Kämpfer Yao Chen herbeirufen kann, der ihm dabei hilft, seine Fähigkeiten wieder zurückzugewinnen. Die beiden verbünden sich, um sich zu rächen. Können Xiao Yan und Yao Chen zusammen mit Xiao Yans Kindheitsfreundin Xiao Xun'er und einer Gruppe treuer Waffengefährten einer teuflischen Sekte Einhalt gebieten und den Frieden wieder herstellen?\",\"releaseDate\":\"2017-01-07\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/lT9pZfrFk8PgdzsQ7QzpCdiCfFF.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/3Wi5mEdCsvApYQZh34gMOHiOjvH.jpg\"},\"genres\":[\"Animation\",\"Action & Adventure\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"240740\"},\"name\":\"Scarpetta\",\"nameTranslations\":{},\"originalName\":\"Scarpetta\",\"releaseDate\":\"2026-03-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/zvkcHCJUPqv7R9ukaiDNkm75jy.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/bopD6OeHkV3AoIj36XaFHM5M2t1.jpg\"},\"genres\":[\"Krimi\",\"Mystery\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"262262\"},\"name\":\"Under Salt Marsh\",\"nameTranslations\":{},\"originalName\":\"Under Salt Marsh\",\"releaseDate\":\"2026-01-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/dZQUJiG2scf8APdnMnMilB8A9GS.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/eV31zFSUF534xmpBEkHINkmsSnG.jpg\"},\"genres\":[\"Krimi\",\"Mystery\"],\"similarItems\":[]}],\"nextCursor\":8}"},"redirectURL":"","headersSize":699,"bodySize":35645,"_status":"completed","_startTimestamp":1772842820753502,"_endTimestamp":1772842820787377},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"2606:4700:3032::ac43:cdc0","connection":"12","comment":"","_id":36,"_uid":"c302dfaa-08a9-4de8-9e56-e46962acd0d5","_cid":12,"_ctime":1772842816360,"_sid":43,"_stime":1772842820326,"_serverAddress":"2606:4700:3032::ac43:cdc0","_serverAddressFamily":1,"_serverPort":443,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":57859,"_app":{"name":"VAVOO","id":"VAVOO.exe","path":"C:\\Users\\isada\\AppData\\Local\\Programs\\vavoo\\VAVOO.exe","pid":139300}},{"startedDateTime":"2026-03-07T00:20:20.345Z","time":468,"request":{"method":"POST","url":"https://www.kool.to/mediahubmx-catalog.json","httpVersion":"HTTP/2.0","cookies":[],"headers":[{"name":":method","value":"POST"},{"name":":authority","value":"www.kool.to"},{"name":":path","value":"/mediahubmx-catalog.json"},{"name":":scheme","value":"https"},{"name":"content-length","value":"175"},{"name":"content-type","value":"application/json; charset=utf-8"},{"name":"mediahubmx-signature","value":""},{"name":"user-agent","value":"MediaHubMX/2"},{"name":"accept","value":"*/*"},{"name":"accept-encoding","value":"gzip,deflate"},{"name":"sec-fetch-site","value":"none"},{"name":"sec-fetch-mode","value":"no-cors"},{"name":"sec-fetch-dest","value":"empty"},{"name":"accept-language","value":"de"}],"queryString":[],"postData":{"mimeType":"application/json","text":"{\"language\":\"de\",\"region\":\"DE\",\"catalogId\":\"tmdb.series\",\"id\":\"series/popular\",\"adult\":false,\"search\":\"\",\"sort\":\"popularity\",\"filter\":{},\"cursor\":null,\"clientVersion\":\"3.0.2\"}"},"headersSize":966,"bodySize":175,"_status":"completed","_startTimestamp":1772842820345420,"_endTimestamp":1772842820357361},"response":{"status":200,"statusText":"","httpVersion":"HTTP/2.0","cookies":[],"headers":[{"name":":status","value":"200"},{"name":"date","value":"Sat, 07 Mar 2026 00:20:20 GMT"},{"name":"content-type","value":"application/json; charset=utf-8"},{"name":"server","value":"cloudflare"},{"name":"mediahubmx-endpoint","value":"."},{"name":"etag","value":"W/\"16966-ALGzn35vJ7K0oBgoaQPqyS1l3hY\""},{"name":"strict-transport-security","value":"max-age=31536000; includeSubDomains"},{"name":"content-encoding","value":"gzip"},{"name":"cf-cache-status","value":"DYNAMIC"},{"name":"vary","value":"accept-encoding"},{"name":"nel","value":"{\"report_to\":\"cf-nel\",\"success_fraction\":0.0,\"max_age\":604800}"},{"name":"report-to","value":"{\"group\":\"cf-nel\",\"max_age\":604800,\"endpoints\":[{\"url\":\"https://a.nel.cloudflare.com/report/v4?s=0a7UA3sksk%2Fvng5%2BnjFFhLgEE5H5zdv3yKDpf7akJY0CYQmIuGEezvnv0js7IZz0QajbqNJNVrtXgVmNIdB2eT7qyKFrvRNDSd7AxZxF8%2Frmo8278Q%3D%3D\"}]}"},{"name":"cf-ray","value":"9d856f0b785fe51e-TXL"},{"name":"alt-svc","value":"h3=\":443\"; ma=86400"}],"content":{"size":92518,"mimeType":"application/json","text":"{\"options\":{},\"items\":[{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"94722\"},\"name\":\"Tagesschau\",\"nameTranslations\":{},\"originalName\":\"Tagesschau\",\"description\":\"Die Tagesschau ist die älteste und populärste Nachrichtensendung Deutschlands.\",\"releaseDate\":\"1952-12-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7dFZJ2ZJJdcmkp05B9NWlqTJ5tq.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/jWXrQstj7p3Wl5MfYWY6IHqRpDb.jpg\"},\"genres\":[\"News\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"79744\"},\"name\":\"The Rookie\",\"nameTranslations\":{},\"originalName\":\"The Rookie\",\"description\":\"In einem Alter, in dem sich andere zur Ruhe setzen wollen, tauscht John Nolan das beschauliche Kleinstadtleben gegen einen Neuanfang in Los Angeles ein: Er möchte seinen Lebenstraum verwirklichen und als Polizist arbeiten. Inmitten von Anwärtern in ihren 20ern muss sich Nolan nun als ältester Rookie des LAPD bewähren.\",\"releaseDate\":\"2018-10-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/70kTz0OmjjZe7zHvIDrq2iKW7PJ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/6iNWfGVCEfASDdlNb05TP5nG0ll.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"91239\"},\"name\":\"Bridgerton\",\"nameTranslations\":{},\"originalName\":\"Bridgerton\",\"description\":\"Diese von den Bestsellern von Julia Quinn inspirierte Serie begleitet die acht Geschwister der Familie Bridgerton in der Londoner High Society auf der Suche nach Liebe.\",\"releaseDate\":\"2020-12-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/pUCGS3E0L5wzOR2nxzjWSumFfax.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/iVadPLeLVb97RznIGDkswxtBzi6.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1416\"},\"name\":\"Grey's Anatomy\",\"nameTranslations\":{},\"originalName\":\"Grey's Anatomy\",\"description\":\"Die Serie erzählt die Geschichte von fünf jungen Assistenzärzten des fiktiven Krankenhauses Seattle Grace Hospital in Seattle. Im Mittelpunkt steht die junge Ärztin Meredith Grey, die zusammen mit ihren Kollegen Cristina Yang, Isobel „Izzie“ Stevens, George O’Malley und Alex Karev ihre Ausbildung in der Chirurgie absolviert. Im Kern der Handlung stehen die verschiedenen Beziehungen der Assistenzärzte untereinander und mit ihren Stationsoberärzten.\",\"releaseDate\":\"2005-03-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4Cl0JlrdtFFKwrzKoa9zf13U6zM.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/jP0Rhj9OTPDAwQlHQwOLFDdeE8t.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"255661\"},\"name\":\"Young Sherlock\",\"nameTranslations\":{},\"originalName\":\"Young Sherlock\",\"description\":\"Von Guy Ritchie: Erleben Sie die legendäre Entstehungsgeschichte von Sherlock Holmes in diesem respektlosen, actiongeladenen Krimi, der die frühen Abenteuer des ikonischen Detektivs nachzeichnet.\",\"releaseDate\":\"2026-03-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/BMBWTgvL41sOYtfkmXen6nm9mG.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/8mmDLb108DoFZlE8sfc64TRqLvm.jpg\"},\"genres\":[\"Action & Adventure\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"14424\"},\"name\":\"Malhação\",\"nameTranslations\":{},\"originalName\":\"Malhação\",\"releaseDate\":\"1995-04-24\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/bF24r2FxsjzgkJcrbBU8RC9JVoU.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/arzEXF03COX1Yj39riYGSEfgNtY.jpg\"},\"genres\":[\"Soap\",\"Komödie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"2734\"},\"name\":\"Law & Order: Special Victims Unit\",\"nameTranslations\":{},\"originalName\":\"Law & Order: Special Victims Unit\",\"description\":\"Bei Polizei und Staatsanwaltschaft gelten Sexualverbrechen als besonders abscheulich. In New York City gehören die engagierten Detectives, die in diesen brutalen Fällen ermitteln, zur Sondereinheit für Sexualdelikte. Dies sind ihre Geschichten. Innerhalb der New Yorker Polizei gibt es eine Sondereinheit, die Special Victims Unit. Die Fälle, die das SVU untersucht, beschränken sich ausschließlich auf Sexualdelikte und Verbrechen an Kindern\",\"releaseDate\":\"1999-09-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/iofokHZoUB4Qhik4PflvJl8TT6a.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/obtdxPgmfykYwVnvuYXC5f2xKlQ.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1622\"},\"name\":\"Supernatural\",\"nameTranslations\":{},\"originalName\":\"Supernatural\",\"description\":\"Als Jungen verloren Sam und Dean Winchester ihre Mutter an eine mysteriöse und dämonische übernatürliche Kraft. Anschließend erklärte ihr Vater ihnen das paranormale Böse bei, das in den dunklen Ecken und auf den Nebenstraßen Amerikas lebt und wie man es tötet. Jetzt durchqueren die Winchester-Brüder das Land und bekämpfen jede Art von übernatürlicher Bedrohung, die ihnen auf dem Weg begegnet.\",\"releaseDate\":\"2005-09-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/fOVIpyRhNCUbKTn9ZDxYduyLwB.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ro0tlgnsco4SwbdAgmscLkSlMSL.jpg\"},\"genres\":[\"Drama\",\"Mystery\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"4614\"},\"name\":\"Navy CIS\",\"nameTranslations\":{},\"originalName\":\"NCIS\",\"description\":\"Der Naval Crime Investigative Service wird dann gerufen, wenn Verbrechen begangen werden, die gegen den Uniform Code of Military Justice verstoßen und innerhalb der Navy stattfinden. Das Hauptquartier befindet sich in Washington D.C. und steht unter der Leitung von Special Agent Leroy Jethro Gibbs. Er selbst ist ein Veteran aus dem Irak-Krieg und hat mit moderner Technik wenig zu tun. Aus diesem Grund ermittelt er gemeinsam mit einem Elite-Team, bestehend aus dem Ballistik-Experten Tony DiNozzo, dem Technikspezialisten Tim McGee, der Forensikspezialistin Abby Sciuto sowie dem Gerichtsmediziner Ducky Mallard.\",\"releaseDate\":\"2003-09-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/mBcu8d6x6zB1el3MPNl7cZQEQ31.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nn3SuLTO4hum8yAxaY4ql8h6kRk.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"22980\"},\"name\":\"Watch What Happens Live with Andy Cohen\",\"nameTranslations\":{},\"originalName\":\"Watch What Happens Live with Andy Cohen\",\"releaseDate\":\"2009-07-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/onSD9UXfJwrMXWhq7UY7hGF2S1h.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/butPVWgcbtAjL9Z7jU7Xj1KA8KD.jpg\"},\"genres\":[\"Talk\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"456\"},\"name\":\"Die Simpsons\",\"nameTranslations\":{},\"originalName\":\"The Simpsons\",\"description\":\"Die Simpsons sind eine amerikanische Durchschnittsfamilie. Immer neue Geschichten gibt es über Homer, Marge, Bart, Lisa und Maggie und über die weiteren Bewohner von Springfield zu erzählen.\",\"releaseDate\":\"1989-12-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/yqYITBxRpsSLjScfFz1o35pelFw.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ukzJIPKTTSUzdr7jQoGKdrvZGk7.jpg\"},\"genres\":[\"Familie\",\"Animation\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"290856\"},\"name\":\"Marshals - A Yellowstone Story\",\"nameTranslations\":{},\"originalName\":\"Marshals\",\"description\":\"Nach dem Ende der Yellowstone-Ranch schließt sich Kayce den U.S.-Marshals an. Seine Erfahrungen als Cowboy und Navy SEAL helfen dabei. Er und seine Kollegen sind die letzte Bastion gegen das Verbrechen in der Region.\",\"releaseDate\":\"2026-03-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/nInfaveN1iFpRIcMGNKENoVVUT2.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yGJGwt7DdIWTUXuahLfhcH1gi7G.jpg\"},\"genres\":[\"Drama\",\"Western\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1399\"},\"name\":\"Game of Thrones\",\"nameTranslations\":{},\"originalName\":\"Game of Thrones\",\"description\":\"Die Handlung ist in einer fiktiven Welt angesiedelt und spielt auf den Kontinenten Westeros, den Sieben Königreichen sowie im Gebiet der \\\"Mauer\\\" und jenseits davon im Norden und Essos. In dieser Welt ist die Länge der Sommer und Winter unvorhersehbar und variabel; eine Jahreszeit kann Jahre oder sogar Jahrzehnte dauern. Der Handlungsort auf dem Kontinent Westeros in den Sieben Königreichen ähnelt dabei stark dem mittelalterlichen Europa. Die Geschichte spielt am Ende eines langen Sommers und wird in drei Handlungssträngen weitgehend parallel erzählt. In den Sieben Königreichen bauen sich zwischen den mächtigsten Adelshäusern des Reiches Spannungen auf, die schließlich zum offenen Thronkampf führen. Gleichzeitig droht der Wintereinbruch und es zeichnet sich eine Gefahr durch eine fremde Rasse im hohen Norden von Westeros ab.\",\"releaseDate\":\"2011-04-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1XS1oqL89opfnbLl8WnZY1O1uJx.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/zZqpAXxVSBtxV9qPBcscfXBcL2w.jpg\"},\"genres\":[\"Sci-Fi & Fantasy\",\"Drama\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"2261\"},\"name\":\"The Tonight Show Starring Johnny Carson\",\"nameTranslations\":{},\"originalName\":\"The Tonight Show Starring Johnny Carson\",\"releaseDate\":\"1962-10-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/uSvET5YUvHNDIeoCpErrbSmasFb.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/okdGCM8cJB1TKIFhTEoEUEo9Wf7.jpg\"},\"genres\":[\"Talk\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1434\"},\"name\":\"Family Guy\",\"nameTranslations\":{},\"originalName\":\"Family Guy\",\"description\":\"Die Griffins sind eine nach außen hin \\\"völlig normale\\\" Mittelklasse-Familie: Peter, seine Frau Lois, die drei Kinder Chris, Meg und Stewie - und Brian, der Hund. Der Vierbeiner ist eindeutig das eloquenteste Mitglied des Griffin-Haushaltes und der einzige, der im täglichen Chaos einen klaren Kopf behält. Seine sarkastischen Bemerkungen sind trocken wie die Martinis, die er so gerne trinkt. Brian ist der erste, an den sich Peter in Krisen wendet und das passiert ziemlich oft...\",\"releaseDate\":\"1999-01-31\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3PFsEuAiyLkWsP4GG6dIV37Q6gu.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/l7wShoIdIUwaDIbsHno9pO5MZXT.jpg\"},\"genres\":[\"Animation\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"549\"},\"name\":\"Law & Order\",\"nameTranslations\":{},\"originalName\":\"Law & Order\",\"description\":\"Vertreter der Polizei und der Staatsanwaltschaft klären Kriminalverbrechen in und um New York auf. Mit allen zur Verfügung stehenden Mitteln versuchen die Ermittler dabei, den oder die Straftäter zur Verantwortung zu ziehen.\",\"releaseDate\":\"1990-09-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/haJ9eHytVO3H3JooMJG1DiWwDNm.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/tc7canPSAn2X14hYi6Rl3gZm1o4.jpg\"},\"genres\":[\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"2661\"},\"name\":\"仮面ライダー\",\"nameTranslations\":{},\"originalName\":\"仮面ライダー\",\"releaseDate\":\"1971-04-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/fIJNVBa6MJStPiOvhLV69nAdu0e.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/usLRh1bcbL0Q9X8zf6rL4OV1qrA.jpg\"},\"genres\":[\"Action & Adventure\",\"Sci-Fi & Fantasy\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"95479\"},\"name\":\"JUJUTSU KAISEN\",\"nameTranslations\":{},\"originalName\":\"呪術廻戦\",\"description\":\"Mühsal, Reue, Schmach: Die negativen Gefühle, die den Herzen der Menschen entspringen, werden zu Flüchen, die sich in unser aller Leben einnisten. Und das Einzige, was einen Fluch austreiben kann, ist ein anderer Fluch. Yūji verbringt seine Tage wie jeder andere Schüler. Doch eines Tages wird sein Freund von Flüchen angegriffen und um ihn zu retten, isst er den Finger des Zwiegesichts Sukuna. Fortan teilt er sich seinen Körper mit ihm und tritt der Jujutsu-Akademie bei, um gegen Flüche zu kämpfen. So beginnt die Geschichte des Jungen, der zum Fluch wurde, um einen Fluch auszutreiben.\",\"releaseDate\":\"2020-10-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/zKFkzRn1UyE11Jv9CJjVmvmQFvR.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gmECX1DvFgdUPjtio2zaL8BPYPu.jpg\"},\"genres\":[\"Animation\",\"Action & Adventure\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"224372\"},\"name\":\"A Knight of the Seven Kingdoms\",\"nameTranslations\":{},\"originalName\":\"A Knight of the Seven Kingdoms\",\"description\":\"Ein Jahrhundert vor den Ereignissen von „Game of Thrones“ durchstreifen zwei unwahrscheinliche Helden durch Westeros, ein junger, naiver, aber mutiger Ritter, Ser Duncan der Große, und sein kleiner Knappe Ei. Die Handlung spielt in einer Zeit, in der die Targaryen immer noch auf dem Eisernen Thron sitzen und die Erinnerung an die letzten lebenden Drachen noch nicht verblasst ist. Ein großes Schicksal, machtvolle Gegner und gefährliche Erlebnisse erwarten diese unwahrscheinlichen und unvergleichlichen Freunde.\",\"releaseDate\":\"2026-01-18\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/w7mQVY9951KdUGWN3rCSOkTR5MK.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/7mkUu1F2hVUNgz24xO8HPx0D6mK.jpg\"},\"genres\":[\"Drama\",\"Sci-Fi & Fantasy\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"66732\"},\"name\":\"Stranger Things\",\"nameTranslations\":{},\"originalName\":\"Stranger Things\",\"description\":\"Nach dem Verschwinden eines Jungen treten in einer Kleinstadt geheime Regierungsexperimente, übernatürliche Kräfte und ein merkwürdiges kleines Mädchen zutage.\",\"releaseDate\":\"2016-07-15\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/uOOtwVbSr4QDjAGIifLDwpb2Pdl.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/8zbAoryWbtH0DKdev8abFAjdufy.jpg\"},\"genres\":[\"Sci-Fi & Fantasy\",\"Mystery\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"5920\"},\"name\":\"The Mentalist\",\"nameTranslations\":{},\"originalName\":\"The Mentalist\",\"description\":\"Der Job des charismatischen Ex-TV-Show-Stars Patrick Jane innerhalb des California Bureau of Investigation ist es, die Ermittlungen einer Spezialeinheit zu unterstützen. Jane, der seine Karriere als \\\"Mentalist\\\" mit vermeintlich übersinnlichen Fähigkeiten nach einer familiären Tragödie beendete, besitzt eine unvergleichliche Beobachtungsgabe und verblüffende Kombinationsfähigkeiten.\",\"releaseDate\":\"2008-09-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4GrRdnfrxNZw5hr2OA4NGZfxX3U.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/q3pCsNvJ7CmdJUz2sJEEUY3pOPC.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1911\"},\"name\":\"Bones - Die Knochenjägerin\",\"nameTranslations\":{},\"originalName\":\"Bones\",\"description\":\"Dr. Temperance Brennan ist eine forensische Anthropologin und arbeitet am Jeffersonian Institut. Wegen ihrer unglaublichen Fähigkeit, Hinweise auf Opfer und Täter in den Überresten und Knochen der Leichen zu finden, wird sie von der Strafverfolgung engagiert. Zusammen mit dem ehemaligen Scharfschützen, Special Agent Seeley Booth, macht sie sich an die Arbeit um Verbrechen aufzuklären.\",\"releaseDate\":\"2005-09-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/eyTu5c8LniVciRZIOSHTvvkkgJa.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/4AXxajuAz9tHAOe6h5zDg8z1X2s.jpg\"},\"genres\":[\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"2224\"},\"name\":\"The Daily Show\",\"nameTranslations\":{},\"originalName\":\"The Daily Show\",\"description\":\"Satirische Nachrichtensendung, in der Moderator Trevor Noah und Team das aktuelle Zeitgeschehen kommentieren und ihren ganz eigenen Blick auf die Nachrichten des Tages werfen.\\n\\nDie „Fake-Newsshow“ ist mit zahlreichen Emmys ausgezeichnet und erzielt beim jungen US-Publikum oft höhere Einschaltquoten als die echten Nachrichten. Die Show wurde ursprünglich von Craig Kilborn, dann lange Jahre von Jon Stewart moderiert.\",\"releaseDate\":\"1996-07-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ixcfyK7it6FjRM36Te4OdblAq4X.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/qLMfcvdCcCGD2BNLH8b6ZCBuO7D.jpg\"},\"genres\":[\"News\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1408\"},\"name\":\"Dr. House\",\"nameTranslations\":{},\"originalName\":\"House\",\"description\":\"Dr. Gregory House, Arzt am fiktiven Princeton-Plainsboro Teaching Hospital, ist nicht gerade einfühlsam im Umgang mit Patienten und würde am liebsten gar nicht mit ihnen sprechen, wenn er damit ungeschoren davon kommen könnte. Nach erfolgreicher Entfernung großer Teile nekrotisierten Gewebes aus seinem rechten Oberschenkel, leidet er selbst unter ständigen Schmerzen und ist auf seinen Gehstock angewiesen, der seine bittere, schonungslose Haltung zusätzlich unterstreicht. Ruppig im Umgang mit seinen Patienten und Kollegen, gelingt es ihm jedoch immer wieder, schnelle und akurate Diagnosen zu stellen, nachdem er seinen Patienten scheinbar keine Aufmerksamkeit gezollt hat. Obwohl sein Verhalten oft ans Unsoziale grenzt, ist House ein herausragender, wenn auch eigenbrödlerischer Mediziner, dessen unkonventionelle Denkweise und tadellosen Instinkte ihm großen Respekt eingebracht haben.\",\"releaseDate\":\"2004-11-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/tS3c86kDSlaSUDbjpGpxrQdXsx2.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/r0Q6eeN9L1ORL9QsV0Sg8ZV3vnv.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"4057\"},\"name\":\"Criminal Minds\",\"nameTranslations\":{},\"originalName\":\"Criminal Minds\",\"description\":\"Criminal Minds ist eine US-amerikanische Fernsehserie, die erstmals am 22. September 2005 vom Sender CBS ausgestrahlt wurde. In der Serie wird die Arbeit des FBI im Bereich der operativen Fallanalyse („Profiling“) durch die Behavioral Analysis Unit (BAU) (engl. für „Verhaltensanalyseeinheit“) aus Quantico (Virginia) dargestellt. Criminal Minds unterscheidet sich von anderen Serien durch die Fokussierung auf den jeweiligen Kriminellen und weniger auf das Verbrechen im Allgemeinen.\",\"releaseDate\":\"2005-09-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5AhkTNfZDEEqldnKqqN5qCTFmn.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/w88B4ooZ2LSYPw5107JOkjvI8PI.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"19530\"},\"name\":\"霹靂布袋戲\",\"nameTranslations\":{},\"originalName\":\"霹靂布袋戲\",\"releaseDate\":\"1988-06-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/sBVfyRYPmKSARRTodsTbwHqgcRA.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/luUTaPpTBM8BjP4wgCLxNIPkx6k.jpg\"},\"genres\":[\"Action & Adventure\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"14610\"},\"name\":\"Salatut elämät\",\"nameTranslations\":{},\"originalName\":\"Salatut elämät\",\"description\":\"Salatut elämät (Versteckte Leben) ist eine finnische Fernseh-Seifenoper, die am 25. Januar 1999 auf MTV3 Premiere hatte. Die Handlungsstränge der Serie folgen dem Alltag mehrerer Familien, die im selben Wohnblock in Helsinki leben.\",\"releaseDate\":\"1999-01-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ugYAGyxwajuplDUUYT8Bzbj8eNR.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nG2im8JKKNB6dXg9ZmVTuiYqFJI.jpg\"},\"genres\":[\"Soap\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1871\"},\"name\":\"EastEnders\",\"nameTranslations\":{},\"originalName\":\"EastEnders\",\"description\":\"Im fiktiven Stadviertel Walford in Londons East End treffen um den Albert Square die Bewohner aufeinander. Fußläufig entfernt finden sich die Geschäftsstraße Bridge Street in der sich auch das ‚Bridge Street Cafe‘ von Alan Beale findet, die hochpreisige George Street und die Turpin Road mit dem Postamt, dem Wettbüro und der Frittenbude ‚Beale‘s Place’ – und natürlich der Nachtclub ‚Scarlett‘ von Johnny Allen. Rund um den Albert Suare und seine ‚Bank der Tränen‘ treffen sie alle aufeinander, die Butchers, Watts, Mitchells, Di Marcos, Beales und die Fowlers. Es kommt zu Krach und Streitereien, Insolvenz, Hochzeiten und Todesfällen. Thematisiert werden HIV, Vergewaltigung, Sterbehilfe und Kindesmissbrauch. Und immer diskutieren die Zuschauer am nächsten Tag im Büro und in der Kantine die neueste Folge.\",\"releaseDate\":\"1985-02-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/z4jgyI5TpoRZiJTNchkVkMrGQyz.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/4og4Eme2gHcTRaHVpZTSCDd7ZNY.jpg\"},\"genres\":[\"Soap\",\"Drama\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"59941\"},\"name\":\"The Tonight Show Starring Jimmy Fallon\",\"nameTranslations\":{},\"originalName\":\"The Tonight Show Starring Jimmy Fallon\",\"description\":\"Die Tonight Show ist die erste und erfolgreichste Late-Night-Show der Welt und zugleich die am längsten existierende Unterhaltungssendung des US-Fernsehens.\\n\\nSie hatte am 27. September 1954 unter dem Namen Tonight Premiere. Vorläufer war eine regionale Show aus New York. Erster Moderator war der Komiker und Musiker Steve Allen. Die Sendung wechselte bis 1962 mehrfach den Gastgeber und ihren Namen. Dann übernahm Johnny Carson und moderierte 30 Jahre lang die Show. Erst seitdem trägt sie den Namen „The Tonight Show“. Trotzdem zählt man auch die Zeit davor zur Tonight Show.\\n\\nJ\",\"releaseDate\":\"2014-02-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1N4o5PmmqhlVDrcdJ2RlCFWbLGX.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/7VO04TtL1jIT6XOPs9u4jdB8KaB.jpg\"},\"genres\":[\"Komödie\",\"Talk\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"4604\"},\"name\":\"Smallville\",\"nameTranslations\":{},\"originalName\":\"Smallville\",\"description\":\"„Smallville“ erzählt die Geschichte der Jugendjahre Clark Kents, der später dann als „Superman“ bekannt werden soll. Clark ist ein ganz normaler Jugendlicher, der, wie seine Altersgenossen, mit Alltagsproblemen zu kämpfen hat. Er hat zwar schon Superkräfte, diese helfen ihm allerdings nicht viel, im Gegenteil: Eigentlich wünscht er sich, ein ganz normaler Junge zu sein. Erst nach und nach entdeckt er, was er mit diesen Kräften erreichen kann, und lernt, mit ihnen umzugehen.\",\"releaseDate\":\"2001-10-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/mHZSq8LA5Dt48JjaOZ5tcPXQRVN.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hBSSm06lrxjhbCKhCUiRN8AGBQG.jpg\"},\"genres\":[\"Sci-Fi & Fantasy\",\"Action & Adventure\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"34307\"},\"name\":\"Shameless - Nicht ganz nüchtern\",\"nameTranslations\":{},\"originalName\":\"Shameless\",\"description\":\"Was für eine Familie! Frank Gallagher hat keine Frau mehr, dafür aber sechs Kinder – und jede Menge Probleme. Seine knapp bemessene Invalidenrente trägt er in die Kneipe seines besten Freundes Kevin, wenn er nicht gerade einer neuen Flamme nachstellt. Seinen bezaubernden Nachwuchs überlässt er derweil weitgehend sich selbst. Die Kleinen kommen erstaunlich gut zurecht, vor allem seine älteste Tochter Fiona kümmert sich nicht nur rührend um ihre Geschwister, sondern hält die Familie auch mit allerlei Nebenjobs über Wasser. Wenn ein Tag bei den Gallaghers mal ohne kleine oder größere Katastrophen vergeht, grenzt das trotzdem manchmal an ein Wunder.\",\"releaseDate\":\"2011-01-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ifo31fMWLmyOVpdak9K0kY4jldQ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5s9XHTB9SLPdg3mNU6BlSLnZ9Qq.jpg\"},\"genres\":[\"Drama\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"13945\"},\"name\":\"Gute Zeiten, schlechte Zeiten\",\"nameTranslations\":{},\"originalName\":\"Gute Zeiten, schlechte Zeiten\",\"description\":\"Gute Zeiten, schlechte Zeiten ist eine Seifenoper. Sie wird seit 1992 beim deutschen Privatsender RTL montags bis freitags im Vorabendprogramm ausgestrahlt. Sie gilt als erfolgreichste deutsche Fernsehserie ihres Genres, mit über 8300 ausgestrahlten Episoden (Stand: Juni 2025).\",\"releaseDate\":\"1992-05-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qujVFLAlBnPU9mZElV4NZgL8iXT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ottT2Yt0OfHiHp3PHJTLNVV8JPE.jpg\"},\"genres\":[\"Drama\",\"Soap\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"202411\"},\"name\":\"Monarch: Legacy of Monsters\",\"nameTranslations\":{},\"originalName\":\"Monarch: Legacy of Monsters\",\"description\":\"Ein schockierendes Geheimnis erschüttert Cate, die zu den Überlebenden des Angriffs von Godzilla auf San Francisco gehört. Inmitten wahrhaft monströser Bedrohungen begibt sie sich auf eine abenteuerliche, weltumspannende Reise, um die Wahrheit über ihre Familie und eine mysteriöse Organisation zu erfahren, die als Monarch bekannt ist.\",\"releaseDate\":\"2023-11-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7LBbaEaLSbqdviBYaSS1rRPMnrs.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/n5FGEUmId87nZAdFiOFmCKXynmT.jpg\"},\"genres\":[\"Sci-Fi & Fantasy\",\"Drama\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"16656\"},\"name\":\"Фитиль\",\"nameTranslations\":{},\"originalName\":\"Фитиль\",\"releaseDate\":\"1962-06-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/9hdEulzIzfj0M2JBKRRIxWOBXUY.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hdlpSh7NstYZSVmuoeVENJdNaLR.jpg\"},\"genres\":[\"Komödie\",\"Dokumentarfilm\",\"Animation\",\"Familie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"15226\"},\"name\":\"सीआईडी\",\"nameTranslations\":{},\"originalName\":\"सीआईडी\",\"releaseDate\":\"1998-01-21\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/zNCpkoHN3LSK9yi1C2M0Z1rOv6J.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1gZrOa2E9DOohEvSLLBJqus2zGu.jpg\"},\"genres\":[\"Action & Adventure\",\"Krimi\",\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"46952\"},\"name\":\"The Blacklist\",\"nameTranslations\":{},\"originalName\":\"The Blacklist\",\"description\":\"Raymond „Red“ Reddington ist ein ehemaliger Offizier des amerikanischen Marinegeheimdienstes und einer der meistgesuchten Verbrecher der USA. Eines Tages stellt er sich in der FBI-Hauptzentrale in Washington, D.C. und bietet dem FBI an, bei der Suche nach Verbrechern und Terroristen zu helfen. Allerdings verlangt er, einzig mit der FBI-Agentin Elizabeth Keen zu verhandeln, die vor Kurzem erst aus Quantico zugezogen ist. Die Informationen, die er weitergibt, stammen von einer von ihm über Jahre angelegten Liste, der sogenannten Blacklist.\",\"releaseDate\":\"2013-09-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/zwXY8e26RahW6mEcvGSshP0ef43.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/2eIlCirgcvEwmCSYh2wDfz5Sxvz.jpg\"},\"genres\":[\"Drama\",\"Krimi\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"764\"},\"name\":\"Inspector Barnaby\",\"nameTranslations\":{},\"originalName\":\"Midsomer Murders\",\"description\":\"Die auf den Romanen der britischen Autorin Caroline Graham basierende Krimiserie spielt in der idyllischen Grafschaft Midsomer. Bis zum Ende der 13. Staffel werden die Ermittlungen von Inspector Tom Barnaby und seiner Assistenten in den Mittelpunkt gestellt. Dabei steht Barnaby bis zur sechsten Staffel Seargant Gavin Troy zur Seite, später ermittelt zunächst Dan Scott und dann Ben Jones gemeinsam mit dem Inspector. Barnabys Frau Joyce hat es auch nicht leicht, bekommt sie ihren immer mit ruhiger Hand arbeitenden Mann doch viel zu selten zu Gesicht.\",\"releaseDate\":\"1997-03-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/52NaZyhRDqYTEJJ09wg6nPxAJGa.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/qVmgq1KXBp6BF2EqYPPaUG9iUGy.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"300054\"},\"name\":\"BAKI-DOU: The Invincible Samurai\",\"nameTranslations\":{},\"originalName\":\"刃牙道\",\"description\":\"Baki und die stärksten Untergrund-Arena-Kämpfer stellen sich ihrer bisher größten Bedrohung: Japans bestem Samurai Musashi Miyamoto.\",\"releaseDate\":\"2026-02-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qC4JawqYlUS9fwvAzGfY5lSz5uB.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1M8uW8o6fdDaa3zqmBD2UUKu0VZ.jpg\"},\"genres\":[\"Animation\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"498\"},\"name\":\"Late Show with David Letterman\",\"nameTranslations\":{},\"originalName\":\"Late Show with David Letterman\",\"releaseDate\":\"1993-08-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3wzEg2MknkM5AGytRrb1DRife6F.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/7jEnft2CLNbILWAiBRIBrXNN7Qh.jpg\"},\"genres\":[\"Talk\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1431\"},\"name\":\"CSI - Den Tätern auf der Spur\",\"nameTranslations\":{},\"originalName\":\"CSI: Crime Scene Investigation\",\"description\":\"Gil Grissom und sein Team arbeiten für die Polizei von Las Vegas in der forensischen Abteilung. Sie finden und analysieren Spuren, die von den Tätern an ihren Tatorten zurückgelassen werden. Aus diesen Spuren können sie schließlich den Täter ermitteln, auch auf den ungeahntesten Wegen. Bis zum Schluss bleibt unklar, wer der Täter ist. Ist es der eifersüchtige Ehemann, der Sohn in Geldnöten oder doch der Gärtner?\\n\\nZum Team gehören neben Grissom vier weitere Forensiker Chaterine Willows, Warrick Brown, Nick Stokes und Sarah Siddle, der Laborant Greg Sanders, Polizist Capt. Jim Brass und der Pathologe Dr. Al Robbins.\",\"releaseDate\":\"2000-10-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/dKWe2dD64oOqjJ0QSOW6Mcl5R9F.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/cvlLBcQWpO9X21jDHhgPJnE2aVq.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"206559\"},\"name\":\"Binnelanders\",\"nameTranslations\":{},\"originalName\":\"Binnelanders\",\"releaseDate\":\"2005-10-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3bzECfllho8PphdYujLUIuhncJD.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/s1dTt4M31q2HwD5Fkl1tf5tQzJg.jpg\"},\"genres\":[\"Soap\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"4656\"},\"name\":\"Raw\",\"nameTranslations\":{},\"originalName\":\"Raw\",\"releaseDate\":\"1993-01-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7wq6uV8YRdWNEyI9TY5k80yWENg.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/eGPH1IwktalozwCmeLTp3aPbHGC.jpg\"},\"genres\":[\"Reality\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"11890\"},\"name\":\"Goede Tijden, Slechte Tijden\",\"nameTranslations\":{},\"originalName\":\"Goede Tijden, Slechte Tijden\",\"releaseDate\":\"1990-10-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/p1oXgtJ0q0wAcEp3tHA5DpiynxL.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hlVfglhjnlCP5tp8hFvTQKQVaMp.jpg\"},\"genres\":[\"Soap\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1396\"},\"name\":\"Breaking Bad\",\"nameTranslations\":{},\"originalName\":\"Breaking Bad\",\"description\":\"Ein krebskranker Chemielehrer tut sich mit einem ehemaligen Schüler zusammen, um die Zukunft seiner Familie durch die Herstellung und den Verkauf von Meth zu sichern.\",\"releaseDate\":\"2008-01-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/u1N5AQ0T6Xr28bZGP84AcSJ5M6b.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/tsRy63Mu5cu8etL1X7ZLyf7UP1M.jpg\"},\"genres\":[\"Drama\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"63770\"},\"name\":\"The Late Show with Stephen Colbert\",\"nameTranslations\":{},\"originalName\":\"The Late Show with Stephen Colbert\",\"releaseDate\":\"2015-09-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/9jkThAGYj2yp8jsS6Nriy5mzKFT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gMMnf8VRg3Z98WaFmOLr9Jk8pIs.jpg\"},\"genres\":[\"Komödie\",\"Talk\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"60574\"},\"name\":\"Peaky Blinders - Gangs of Birmingham\",\"nameTranslations\":{},\"originalName\":\"Peaky Blinders\",\"description\":\"Eine berüchtigte Gang im Birmingham des Jahres 1919 wird von Tommy Shelby, einem toughen Bandenboss angeführt. Dieser will um jeden Preis in der Welt aufsteigen.\",\"releaseDate\":\"2013-09-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/vUUqzWa2LnHIVqkaKVlVGkVcZIW.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/dzq83RHwQcnP6WGJ6YkenIqeaa5.jpg\"},\"genres\":[\"Drama\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"71712\"},\"name\":\"The Good Doctor\",\"nameTranslations\":{},\"originalName\":\"The Good Doctor\",\"description\":\"Shaun Murphy ist anders als seine Kollegen: Der autistische Chirurg ist inselbegabt und sowohl durch sein tiefgehendes medizinisches Verständnis als auch durch seine scharfsinnigen medizinischen Diagnosen ein echtes Genie. Sein Mentor und Jugendbekannter Dr. Aaron Glassman hält daher große Stücke auf Shauns Fähigkeiten und verschafft ihm als Klinikchef des St. Bonaventure Hospitals in San José einen Job als Assistenzarzt in der dortigen Chirurgie.\",\"releaseDate\":\"2017-09-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/luhKkdD80qe62fwop6sdrXK9jUT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/f3cin9kOz4nOrlYEMxGFQhv4bdN.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"61818\"},\"name\":\"Late Night with Seth Meyers\",\"nameTranslations\":{},\"originalName\":\"Late Night with Seth Meyers\",\"description\":\"Seth Meyers, der dienstälteste Moderator des äußerst beliebten \\\"Weekend Update\\\" bei \\\"Saturday Night Live\\\", übernimmt die Moderation von NBCs \\\"Late Night\\\" – der Heimat von prominenten Gästen, unvergesslicher Comedy und herausragenden musikalischen Talenten. Als mit dem Emmy ausgezeichneter Chefautor von \\\"SNL\\\" hat Meyers sich einen Ruf für scharfen Witz und perfektes Timing in der Comedy erworben und wurde durch seine treffsicheren Witze und Satire bekannt. Meyers verlässt \\\"SNL\\\", um seine neue Position bei \\\"Late Night\\\" anzutreten, während Jimmy Fallon zur \\\"Tonight Show\\\" wechselt.\",\"releaseDate\":\"2014-02-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/jm95V8XjfvqmEhw0MN09wbg9Mi3.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/dfX2UaHVE5c7kLBFbgmEZJuy4Ev.jpg\"},\"genres\":[\"Talk\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1668\"},\"name\":\"Friends\",\"nameTranslations\":{},\"originalName\":\"Friends\",\"description\":\"Ross, Rachel,  Monica,  Chandler und Joey sind beste Freunde. Ob bei regelmäßigen Treffen im Café Central Perk oder in der WG mit den lilafarbenen Wänden, gemeinsam wird getratscht, gestritten und gelacht. Dabei ergeben sich im Laufe der Zeit immer wieder auch amouröse Verbindungen in und außerhalb der Gruppe, die zu Konflikten, aber auch zu herrlich romantischen Momenten führen. \",\"releaseDate\":\"1994-09-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/2koX1xLkpTQM4IZebYvKysFW1Nh.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ykDYy50mHU52PqYEu4xiFFOw5mw.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1405\"},\"name\":\"Dexter\",\"nameTranslations\":{},\"originalName\":\"Dexter\",\"description\":\"Dexter Morgan, Blutanalyst bei der Polizei von Miami, geht nachts einer etwas anderen Tätigkeit nach. Er streift als Serienkiller durch die Nacht und tötet Menschen, die ihrerseits bereits gemordet haben. Gleichzeitig versucht er, sein Berufs- und Privatleben mit seiner ungewöhnlichen nächtlichen Aktivität in Einklang zu bringen.\",\"releaseDate\":\"2006-10-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/q8dWfc4JwQuv3HayIZeO84jAXED.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/aSGSxGMTP893DPMCvMl9AdnEICE.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"50821\"},\"name\":\"Barátok közt\",\"nameTranslations\":{},\"originalName\":\"Barátok közt\",\"releaseDate\":\"1998-10-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/kBBbSgNchtMvsgD6z1oI1RRluHP.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hHMWfDlqKisD5zVcZfz3KEw5U3v.jpg\"},\"genres\":[\"Drama\",\"Familie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"4629\"},\"name\":\"Stargate\",\"nameTranslations\":{},\"originalName\":\"Stargate SG-1\",\"description\":\"Die Fortsetzung des Films \\\"Stargate\\\" von 1994, beschreibt die weiteren Abenteuer des SGC (Stargate Command). Es stellt sich heraus, dass der Goa'uld Ra nur einer von vielen außerirdischen Herrschern war, der das Stargate zur Eroberung des Universum benutzte. Nach der vollständigen Entschlüsslung des Stargates, können nun Reisen ins ganze Universum unternommen werden. Das Militär sendet SG-Teams um diese neuen Welten zu erforschen, um neue Technologien zu entdecken und sich den Goa'uld zu stellen. Die Charakter Jack O'Neill and Daniel Jackson aus dem Film sind teil von SG-1. Begleitet werden sie von Sam Carter, einer Wissenschaftlerin, und Teal'c, einem Jaffa, der davon überzeugt ist, dass die Goa'uld keine Götter sind.\",\"releaseDate\":\"1997-07-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/dQjmI7XxI47v8IM2MUysHG0LuU2.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yOyzlRw54oYaGvhUBdPr7TFwtrX.jpg\"},\"genres\":[\"Sci-Fi & Fantasy\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"2316\"},\"name\":\"The Office\",\"nameTranslations\":{},\"originalName\":\"The Office\",\"description\":\"In der Papiergroßhandelsfirma Dunder Mifflin herrscht der alltägliche Bürowahnsinn. Verkaufsleiter Michael Scott hält sich für einen lustigen Entertainer und den besten Chef der Welt. Für weitere Egokrämpfe sorgt der pedantische Nerd Dwight Schrute, der um Michaels Posten buhlt. Zum bunten Büro-Team gehören u. a. der talentierte wie unterforderte Jim Halpert, die scheue Sekretärin Pam Beesly, der übermotivierte Ryan Howard sowie der spätere Regionalmanager Andy Bernard und die ehrgeizige Karrierefrau Karen Filippelli. Zusammen sabotieren sie die Langeweile und Arbeitspflicht des lästigen Alltags, der im fröhlichen Chaos versinkt.\",\"releaseDate\":\"2005-03-24\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7DJKHzAi83BmQrWLrYYOqcoKfhR.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/mLyW3UTgi2lsMdtueYODcfAB9Ku.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"45789\"},\"name\":\"Sturm der Liebe\",\"nameTranslations\":{},\"originalName\":\"Sturm der Liebe\",\"description\":\"Die Telenovela erzählt in mehreren, miteinander verwobenen Handlungsfäden Beziehungsgeschichten rund um das Fünf-Sterne-Hotel Fürstenhof und um die Liebe. Die Handlung ist in der fiktiven Gemeinde Bichlheim im oberbayerischen Landkreis Bad Tölz-Wolfratshausen angesiedelt.\",\"releaseDate\":\"2005-09-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/jfFNydakwvbeACEwSd2Gh8UWtba.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/kGxPVyra9Lvf5tPmTXnMEBpwOip.jpg\"},\"genres\":[\"Drama\",\"Soap\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"265167\"},\"name\":\"ZIBB\",\"nameTranslations\":{},\"originalName\":\"ZIBB\",\"description\":\"deutsche Nachrichtensendung\",\"releaseDate\":\"2003-11-10\",\"images\":{},\"genres\":[\"News\",\"Talk\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"60735\"},\"name\":\"The Flash\",\"nameTranslations\":{},\"originalName\":\"The Flash\",\"description\":\"Barry Allen ist ein junger kriminaltechnischer Ermittler, der nach Starling kommt, um eine Reihe von Überfällen zu untersuchen, die mit einer Tragödie in seiner Vergangenheit zusammenhängen könnten. Dabei triftt er auf den maskierten Helden Arrow und wird selbst zum kostümierten Kämpfer für das Gute\",\"releaseDate\":\"2014-10-07\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/yZevl2vHQgmosfwUdVNzviIfaWS.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gFkHcIh7iE5G0oVOgpmY8ONQjhl.jpg\"},\"genres\":[\"Drama\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"14750\"},\"name\":\"Na Wspólnej\",\"nameTranslations\":{},\"originalName\":\"Na Wspólnej\",\"releaseDate\":\"2003-01-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/uksRhdaOn64bO5d33d7rcTbrhJI.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/pmB8uYJF1WKQCZnJjhnAx2IJjhk.jpg\"},\"genres\":[\"Soap\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1421\"},\"name\":\"Modern Family\",\"nameTranslations\":{},\"originalName\":\"Modern Family\",\"description\":\"Die Mockumentary begleitet die Familien von Jay Pritchett, seiner Tochter Claire Dunphy und seines Sohns Mitchell Pritchett . Während Claire die Rolle der Hausfrau in einer klassischen Familie innehat, ist Jay mit einer viel jüngeren Frau verheiratet, mit der er seinen Stiefsohn erzieht. Mitchell und sein Lebensgefährte haben ein asiatisches Baby adoptiert.\",\"releaseDate\":\"2009-09-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/k5Qg5rgPoKdh3yTJJrLtyoyYGwC.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nO7EzksrBzlNpAg5rgv8HzaBIkx.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"18165\"},\"name\":\"Vampire Diaries\",\"nameTranslations\":{},\"originalName\":\"The Vampire Diaries\",\"description\":\"Die Highschool-Schülerin Elena Gilbert hat ihre Eltern bei einem Autounfall verloren. Ihre Tante Jenna Sommers, die jüngere Schwester der Mutter, ist nach Mystic Falls gekommen, um sich um sie und ihren jüngeren Bruder Jeremy zu kümmern. Als der neue Mitschüler Stefan Salvatore auf der Bildfläche erscheint, weckt er sofort Elenas Interesse. Sie ahnt nicht, dass es sich bei Stefan um einen bereits jahrhundertealten Vampir handelt. Als dann noch Stefans älterer Bruder Damon auftaucht, der von Elena ebenfalls angezogen ist, überschlagen sich die Ereignisse. Stefan wird misstrauisch, denn er weiß, dass Damon nichts Gutes im Sinn hat. Elena wird in eine Welt hineingeworfen, von deren Existenz sie bislang nichts geahnt hat.\",\"releaseDate\":\"2009-09-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/b3vl6wV1W8PBezFfntKTrhrehCY.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/cJYLon9ejKJV7ua03ab8Tj9u067.jpg\"},\"genres\":[\"Drama\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"65701\"},\"name\":\"Good Mythical Morning\",\"nameTranslations\":{},\"originalName\":\"Good Mythical Morning\",\"releaseDate\":\"2012-01-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/jMpBQr2aNOFAI6wsC47zsOG6qOh.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hvFCS0dMeC3ffiF4uYTKzUAkvYL.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"65733\"},\"name\":\"ドラえもん\",\"nameTranslations\":{},\"originalName\":\"ドラえもん\",\"releaseDate\":\"2005-04-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/9YqdMXlPTQGLIG67vqZdsPdPC4T.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/c2oiRa7V3bQzof4wVGzLXtWJ5QU.jpg\"},\"genres\":[\"Action & Adventure\",\"Animation\",\"Komödie\",\"Sci-Fi & Fantasy\",\"Kids\",\"Familie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1433\"},\"name\":\"American Dad\",\"nameTranslations\":{},\"originalName\":\"American Dad!\",\"description\":\"Stan Smith ist ein echter Vorzeigeamerikaner. Als Waffenexperte bei der CIA immer auf den Fall eines terroristischen Anschlags vorbereitet, würde er alles dafür tun, sein geliebtes Vaterland zu beschützen. Neben seiner Tätigkeit bei der CIA ist er vor allem eins: Familienmensch. Dem Anschein nach sind die Smiths also eine ganz normale Familie, wären da neben dem pubertierenden Sohn Steve und der ultra-liberalen Tochter Hayley nicht noch die Familienmitglieder Roger und Klaus. Roger, ein Alien, wurde von Stan einst aus der Area 51 vor dem sicheren Tod gerettet, und Klaus ist ein deutsch-sprechender Goldfisch – ein missglücktes Experiment aus den CIA-Labors.\",\"releaseDate\":\"2005-02-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/eb9sH2am9IUSQ8GhXTNAVoujk8W.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/mc3rG5M9dFVjMfaCFNfbD5gu2pK.jpg\"},\"genres\":[\"Animation\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1402\"},\"name\":\"The Walking Dead\",\"nameTranslations\":{},\"originalName\":\"The Walking Dead\",\"description\":\"Nach einer weltweiten Zombie-Apokalypse sucht eine Gruppe Überlebender, unter Führung des Sheriffs Rick Grimes, nach einer dauerhaften und vor allem sicheren Bleibe. Dabei stellen die fast überall präsenten Untoten eine permanent vorhandene Bedrohung dar, die jederzeit ohne Vorwarnung zuschlagen kann.\",\"releaseDate\":\"2010-10-31\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7J5sJONPZuyNH9SuLYi4XvVUujk.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/rAOjnEFTuNysY7bot8zonhImGMh.jpg\"},\"genres\":[\"Action & Adventure\",\"Drama\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"46831\"},\"name\":\"Државни посао\",\"nameTranslations\":{},\"originalName\":\"Државни посао\",\"releaseDate\":\"2012-09-24\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/sceVlRK5RvnU1qjNipyWDHQXB7x.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ucsg6ywfOf0u21sM54orBcXGjGs.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"291\"},\"name\":\"Coronation Street\",\"nameTranslations\":{},\"originalName\":\"Coronation Street\",\"releaseDate\":\"1960-12-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5x1HXqYqPyYw7oc7Isu1lvVmwRP.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5APjn4LnV5wWk5DXq7ZewT6zzP1.jpg\"},\"genres\":[\"Soap\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"57243\"},\"name\":\"Doctor Who\",\"nameTranslations\":{},\"originalName\":\"Doctor Who\",\"description\":\"Die Serie handelt von einem mysteriösen Außerirdischen namens \\\"Der Doktor\\\", der mit seinem Raumschiff, der TARDIS (Time and Relative Dimension in Space), welches von außen aussieht wie eine englische Notruf-Telefonzelle der 60er Jahre, durch Raum und Zeit fliegt. Der Doktor ist ein Time Lord vom Planeten Gallifrey - und bereits über 900 Jahre alt. Dass man ihm das nicht ansieht, liegt vor allem daran, dass ein Time Lord, wenn er stirbt, in der Lage ist, sich zu regenerieren, wobei er auch eine andere Gestalt annimmt.\",\"releaseDate\":\"2005-03-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/w8enSKCf6Zm0topeQ2XPccDqsqp.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/vcFW09U4834DyFOeRZpsx9x1D3S.jpg\"},\"genres\":[\"Action & Adventure\",\"Drama\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"306215\"},\"name\":\"Sevdiğim Sensin\",\"nameTranslations\":{},\"originalName\":\"Sevdiğim Sensin\",\"releaseDate\":\"2026-02-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/eVMb930nCNRYGhPlAVRI5hsMdAz.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/jlIKAoJNn5lLF2vXMcWSEMkOAnN.jpg\"},\"genres\":[\"Drama\",\"Soap\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"300015\"},\"name\":\"イチゴ哀歌～雑で生イキな妹と割り切れない兄～\",\"nameTranslations\":{},\"originalName\":\"イチゴ哀歌～雑で生イキな妹と割り切れない兄～\",\"releaseDate\":\"2026-01-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/fjKOO6PBLwLG3ViyvrIL9oZUmbU.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/bFdIuq0tWRSeYENCf1i3ZQWY8iF.jpg\"},\"genres\":[\"Animation\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"34860\"},\"name\":\"忍たま乱太郎\",\"nameTranslations\":{},\"originalName\":\"忍たま乱太郎\",\"releaseDate\":\"1993-04-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/fzNiSp0HhCthOTYu9IYWlPPa7fU.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/4fVwc77cov2q9i0szzYhlkAaqza.jpg\"},\"genres\":[\"Komödie\",\"Action & Adventure\",\"Kids\",\"Animation\",\"Familie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"17887\"},\"name\":\"7de Laan\",\"nameTranslations\":{},\"originalName\":\"7de Laan\",\"releaseDate\":\"2000-04-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/vQcC4Kcx0ZEXxmj0gUrfkFR14LU.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ovnj5NSQRAn54e81ecIyAIfKRZK.jpg\"},\"genres\":[\"Soap\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"6836\"},\"name\":\"康熙來了\",\"nameTranslations\":{},\"originalName\":\"康熙來了\",\"releaseDate\":\"2004-01-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/bVWEPDZHRSdd7voVled6CLLq1zB.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/390GKeZ6GLJNEbazLq7SFIYLvxW.jpg\"},\"genres\":[\"Talk\",\"Reality\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"57911\"},\"name\":\"ドラえもん\",\"nameTranslations\":{},\"originalName\":\"ドラえもん\",\"releaseDate\":\"1979-04-02\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/a8LwHrfrBRn2nEN9THo1tlpKiDN.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/6oVBODwFvbDJczBFlf4J930jKZg.jpg\"},\"genres\":[\"Action & Adventure\",\"Animation\",\"Komödie\",\"Sci-Fi & Fantasy\",\"Kids\",\"Familie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"44217\"},\"name\":\"Vikings\",\"nameTranslations\":{},\"originalName\":\"Vikings\",\"description\":\"Inspiriert von den überlieferten Sagen des legendären Wikingerkönigs Ragnar Lothbrok entführt die gefeierte Hitserie in den eisigen Norden des europäischen Kontinents im 8. Jahrhundert: Krieger Ragnar glaubt, dass jenseits des wilden Ozeans im unerforschten Westen ein neues Land mit reichen Schätzen auf die Wikingerhorden wartet. Für seine Überzeugungen setzt er alles auf eine Karte, lässt ein neues Schiff bauen und macht sich in den packenden neun Episoden der ersten Staffel auf, um Geschichte zu schreiben.\",\"releaseDate\":\"2013-03-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/bQLrHIRNEkE3PdIWQrZHynQZazu.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/13kblIK8DnxMurcRDkeyy2sGR7v.jpg\"},\"genres\":[\"Action & Adventure\",\"Drama\",\"War & Politics\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"228091\"},\"name\":\"香港八十系列\",\"nameTranslations\":{},\"originalName\":\"香港八十系列\",\"releaseDate\":\"1981-06-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/6IpuLrhh7XZfIvz0OmFOSJdSORe.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/kmwOP8ep8QZBKxC6gZ6igkR9pLq.jpg\"},\"genres\":[\"Komödie\",\"Drama\",\"Familie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"37680\"},\"name\":\"Suits\",\"nameTranslations\":{},\"originalName\":\"Suits\",\"description\":\"Harvey Specter, einer der Top-Anwälte Manhattans, engagiert für seine renommierte Kanzlei den brillanten, aber etwas unmotivierten College-Abgänger Mike Ross. Dabei müssen beide verheimlichen, dass Mike eigentlich gar nicht als Anwalt arbeiten darf …\",\"releaseDate\":\"2011-06-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/vQiryp6LioFxQThywxbC6TuoDjy.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/or0E36KfzJYZwqXeiCfm1JgepKF.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"4607\"},\"name\":\"Lost\",\"nameTranslations\":{},\"originalName\":\"Lost\",\"description\":\"Im Bruchteil einer Sekunde gerät das Leben einer Gruppe Reisender aus den Fugen: Ein Flugzeug stürzt auf einer scheinbar einsamen Insel im Pazifik ab - weitab vom Kurs. Nur 48 der Insassen überleben das Inferno. Ihre Hoffnung auf Rettung erweist sich schnell als Illusion und die Überlebenden lernen, sich in der Wildnis zurechtzufinden. Jeder von ihnen hat etwas zu verbergen, jeder eine dunkle Vergangenheit, die langsam ans Tageslicht gelangt. Doch jeder entwickelt auch ungeahnte Stärken, mit denen er den Herausforderungen, die überall lauern, begegnen kann. Denn die gefährlichsten Geheimnisse birgt die Insel selbst.\",\"releaseDate\":\"2004-09-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/og6S0aTZU6YUJAbqxeKjCa3kY1E.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yUOFocKDW7MCC5isx4FK8A68QFp.jpg\"},\"genres\":[\"Mystery\",\"Action & Adventure\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"5092\"},\"name\":\"무한도전\",\"nameTranslations\":{},\"originalName\":\"무한도전\",\"releaseDate\":\"2005-04-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/fpXfEfcZu5uDTOKqjwXSGgrL4iY.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/s2qJb1FLwp1Mse9lY08JqgMp0kw.jpg\"},\"genres\":[\"Reality\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"73586\"},\"name\":\"Yellowstone\",\"nameTranslations\":{},\"originalName\":\"Yellowstone\",\"description\":\"„Yellowstone“ folgt der einflussreichen Familie Dutton, die eine der größten Ranches in den USA besitzt und ständig um deren Erhalt kämpfen muss. Die Serie zeigt, wie sie sich gegen politische Interessen, Landentwickler und rivalisierende Gruppen behaupten. Gleichzeitig beleuchtet sie die komplexen Beziehungen innerhalb der Familie und die moralischen Grenzen, die sie zu überschreiten bereit sind. Insgesamt verbindet die Serie moderne Western‑Atmosphäre mit Machtkämpfen, Loyalität und Konflikten um Land und Identität.\",\"releaseDate\":\"2018-06-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/n3LvkTNTULObSGmDOixRtahBLjR.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ynSOcgDLZfdLCZfRSYZGiTgYJVo.jpg\"},\"genres\":[\"Western\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"80748\"},\"name\":\"FBI\",\"nameTranslations\":{},\"originalName\":\"FBI\",\"description\":\"Die Agenten des New Yorker Büro des FBI arbeiten rund um die Uhr daran, die Stadt und ihr Land vor Terror, organisiertem Verbrechen und fremden Spionen zu beschützen. Unter der Leitung von Special Agent in Charge Dana Mosier setzt sich ihr Team aus verschiedenen Spezialisten mit einzigartigen Fähigkeiten zusammen.\",\"releaseDate\":\"2018-09-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/zfKS4WL0OZ9udpNoSYZw91VB3aH.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5DFvscYGpcFaQMJljCic5gbzVe6.jpg\"},\"genres\":[\"Krimi\",\"Action & Adventure\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"63174\"},\"name\":\"Lucifer\",\"nameTranslations\":{},\"originalName\":\"Lucifer\",\"description\":\"Lucifer, der charmante, charismatische und höllisch gut aussehende allererste gefallene Engel, der, nach einer zunehmend langweiligen und trostlosen Zeit in der Hölle in Los Angeles Unterschlupf sucht. Dort setzt er fortan seine Gabe zur Beeinflussung Anderer ein, um Bösewichte zu bestrafen. Doch je länger er der Unterwelt fern bleibt desto stärker wächst die Gefahr, dass das größte Übel der Menschheit entkommen könnte.\",\"releaseDate\":\"2016-01-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ekZobS8isE6mA53RAiGDG93hBxL.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ncftkNAjIz2PBbUMY7T0CHVJP8d.jpg\"},\"genres\":[\"Krimi\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"502\"},\"name\":\"Sesame Street\",\"nameTranslations\":{},\"originalName\":\"Sesame Street\",\"description\":\"Die amerikanische Vorlage für die deutsche Adaption \\\"Sesamstrasse\\\".\",\"releaseDate\":\"1969-11-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/14k9BfZ2p4rQBMeJ5crKTfUZVwD.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/tNi2aJPdCKfielGYzIi3IKxStz9.jpg\"},\"genres\":[\"Kids\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"60572\"},\"name\":\"Pokémon\",\"nameTranslations\":{},\"originalName\":\"ポケットモンスター\",\"description\":\"Ash Ketchum hat nur eines im Sinn: Er möchte der weltbeste Pokemontrainer werden! Pokemon, das sind kleine tierähnliche Wesen, die von Menschen eingefangen werden können. Leute, die die Kräfte ihrer Pokemon trainieren und in einem Kampf messen, werden Pokemontrainer genannt. Schnell merkt Ash jedoch, dass das Pokemontraining nicht nur aus Spaß besteht und er auch einige Pflichten seinen kleinen Monstern gegenüber hat. Ein praktisch unendliches Abenteuer beginnt für Ash.\",\"releaseDate\":\"1997-04-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/uoBwsiZNyOFDBh9WdDhpxc2JERM.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yYpQV25I7XB6S0POJOScPjxYWV5.jpg\"},\"genres\":[\"Animation\",\"Action & Adventure\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"44006\"},\"name\":\"Chicago Fire\",\"nameTranslations\":{},\"originalName\":\"Chicago Fire\",\"description\":\"Für die Feuerwehrmänner und Rettungssanitäter der Feuerwache 51 in Chicago sind Stress und Gefahren an der Tagesordnung. Die enorme Verantwortung, der sich die Alltagshelden aussetzen, macht auch vor dem Privatleben nicht halt. Matthew Casey, der Chef von Truck 81, steckt gerade mitten in einer Scheidung und sucht in seinem Job Ablenkung. Nach dem Tod eines Feuerwehrmanns gerät er mit Kelly Severide, dem Anführer von Rescue Squad 3, aneinander. Trotz gelegentlicher Scharmützel ist das Department für die meisten Teammitglieder wie eine Ersatzfamilie, zumal die bisweilen traumatischen Erlebnisse während der Einsätze für eine emotionale Bindung sorgen.\",\"releaseDate\":\"2012-10-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/c1gvOG6a4UWkP4d6IUomYdwGs4G.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/14LzHqJrFcHk7ruMNCXpEkB0Thg.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"57775\"},\"name\":\"ちびまる子ちゃん\",\"nameTranslations\":{},\"originalName\":\"ちびまる子ちゃん\",\"releaseDate\":\"1990-01-07\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5Ta4wnZPzOf4oCEgpBfmvXWhYwJ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/cqeeBvjpXu28JerXBItA73z5tqU.jpg\"},\"genres\":[\"Animation\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"32415\"},\"name\":\"Conan\",\"nameTranslations\":{},\"originalName\":\"Conan\",\"releaseDate\":\"2010-11-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/oQxrvUhP3ycwnlxIrIMQ9Z3kleq.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hFX1He833KhSyyu3g0wzYFwkKUk.jpg\"},\"genres\":[\"Talk\",\"Komödie\",\"News\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1407\"},\"name\":\"Homeland\",\"nameTranslations\":{},\"originalName\":\"Homeland\",\"description\":\"Top CIA Officer Carrie Mathison leistet großartige Arbeit im vielfältigen Kampf gegen den Terrorismus. Mit Hilfe ihres langjährigen Mentors Saul Berenson gibt die furchtlose Carrie alles und riskiert hierfür persönliches Wohl und Geisteszustand. Ihre bipolare Störung macht sie dabei verletzlich und unberechenbar.\",\"releaseDate\":\"2011-10-02\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/6GAvS2e6VIRsms9FpVt33PsCoEW.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/391ixi0wVbFtFLQnOy8ZncWv2io.jpg\"},\"genres\":[\"Drama\",\"War & Politics\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"33238\"},\"name\":\"Running Man\",\"nameTranslations\":{},\"originalName\":\"런닝맨\",\"releaseDate\":\"2010-07-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/15SMnscZqd7HZ0bzruatOcKUlOV.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/wsHj4oHQJoe7DMYaqNFwVoyLiAh.jpg\"},\"genres\":[\"Komödie\",\"Reality\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1973\"},\"name\":\"24\",\"nameTranslations\":{},\"originalName\":\"24\",\"description\":\"Die Handlung des Thrillers spielt sich in 24 Stunden ab. Jack Bauer, Chef einer Anti-Terror-Einheit, erfährt, dass seine Tochter entführt wurde und muss gleichzeitig einen Anschlag auf den Präsidentschaftskandidaten vereiteln. Dazu bleiben ihm nur 24 Stunden. Diese 24 Stunden sind exakt auf 24 Episoden verteilt, teilweise mit Split-Screen, um die sich überstürzenden Ereignisse zeitgenau zu dokumentieren.\",\"releaseDate\":\"2001-11-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/iq6yrZ5LEDXf1ArCOYLq8PIUBpV.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/be6mDIMv7cg8duWkcYVnTB8rphO.jpg\"},\"genres\":[\"Action & Adventure\",\"Drama\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"4087\"},\"name\":\"Akte X - Die unheimlichen Fälle des FBI\",\"nameTranslations\":{},\"originalName\":\"The X-Files\",\"description\":\"Im Zentrum stehen die FBI-Agenten Dana Katherine Scully und Fox William Mulder die unter ihrem Vorgesetzten FBI Assistant Director Walter Skinner mysteriöse Fälle aufklären sollen. Obwohl die Ansichten der wissenschaftlich arbeitenden Scully und des intuitiv ermittelnden Mulder oft weit auseinander gehen, bilden sie ein hervorragendes Team. Gemeinsam ergründen sie paranormale wie auch außerirdische Aktivitäten. Dabei geraten sie immer tiefer in einen Strudel aus Verschwörungen, in dem das FBI und die amerikanische Regierung eine entscheidende Rolle zu spielen scheinen …\",\"releaseDate\":\"1993-09-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qouWZKZ1ygWkvqSgMQOMDei1kFX.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/w00lfexrsOeR25dO4hsWhbcUnmD.jpg\"},\"genres\":[\"Mystery\",\"Sci-Fi & Fantasy\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"2691\"},\"name\":\"Two and a Half Men\",\"nameTranslations\":{},\"originalName\":\"Two and a Half Men\",\"description\":\" Charlie ist ein recht wohlhabender Junggeselle mit einem Haus am Strand und einem Jaguar in der Garage. Nachdem sich sein Bruder Alan hat scheiden lassen zieht er mit seinem Sohn bei Onkel Charlie ein. Ganz klar, dass dessen \\\"Malibu Lifestyle\\\" nun völlig durcheinander kommt. Nach einigen Anfangsschwierigkeiten läuft der Alltag in der Männer-WG eigentlich ganz gut, wären da nicht die ständigen Kontrollbesuche ihrer Mutter Evelyn. Außerdem versucht Nachbarin Rose alles, um nur in der Nähe von Charlie sein zu können.\",\"releaseDate\":\"2003-09-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/xgfjxyV3g1S68opzuvG6G87muDp.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/2pOmuq4nkWZzwZbOfZq7CyyQAsM.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"58841\"},\"name\":\"Chicago P.D.\",\"nameTranslations\":{},\"originalName\":\"Chicago P.D.\",\"description\":\"Der District 21 des Chicago Police Departments besteht aus zwei unterschiedlichen Abteilungen: Einmal gibt es die Uniformed Cops, die ihren Einsatz auf den Straßen der Stadt haben und sich um Kleinkriminelle kümmern. Die Intelligence Unit hingegen bekämpft Straftaten im großen Stil, sei es Drogenschmuggel oder Morde aller Art.\",\"releaseDate\":\"2014-01-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/xjaAEVaZEI8qmchnJmfhNdXDuuv.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/rhp8vYG1sIFtqH3ETmHJuI5Z3Cb.jpg\"},\"genres\":[\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"124364\"},\"name\":\"FROM\",\"nameTranslations\":{},\"originalName\":\"FROM\",\"description\":\"Enträtseln Sie das Geheimnis einer alptraumhaften Stadt in Mittelamerika, die alle, die sie betreten, gefangen hält. Während die unfreiwilligen Bewohner darum kämpfen, ein Gefühl der Normalität zu bewahren und nach einem Ausweg zu suchen, müssen sie auch die Bedrohungen des umliegenden Waldes überleben – einschließlich der schrecklichen Kreaturen, die von dort kommen, wenn die Sonne untergeht.\",\"releaseDate\":\"2022-02-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cjXLrg4R7FRPFafvuQ3SSznQOd9.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/6gN8DYnIEln8v7OhRy61c57w0Xy.jpg\"},\"genres\":[\"Mystery\",\"Drama\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"224\"},\"name\":\"Match of the Day\",\"nameTranslations\":{},\"originalName\":\"Match of the Day\",\"releaseDate\":\"1964-08-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/paRFRd11WlFOxVbGnzjjCBym7FW.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/3EGjqKhVHGsvNHvBIbxmqS17Aal.jpg\"},\"genres\":[\"Talk\",\"News\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"308\"},\"name\":\"Morangos com Açúcar\",\"nameTranslations\":{},\"originalName\":\"Morangos com Açúcar\",\"releaseDate\":\"2003-08-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/uyzx0JkWOOF3Mfcq4uiuIr2Ykju.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/7P7zskNRdowZslBv5yJbnMeBuKR.jpg\"},\"genres\":[\"Drama\",\"Komödie\",\"Soap\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"693\"},\"name\":\"Desperate Housewives\",\"nameTranslations\":{},\"originalName\":\"Desperate Housewives\",\"description\":\"Die vier Freundinnen Bree, Susan, Lynette und Gabrielle leben in der beschaulichen Wysteria Lane in einer typischen Vorstadtsiedlung. Neben den alltäglichen Freuden und Nöten in der Familie werden die Frauen auch immer wieder in spannende Geschichten hineingezogen, denn hinter den Fassaden der zahlreichen Wohnzimmerfenster der Gegend verbergen sich verborgene Skandale, versteckte Geheimnisse und große Dramen.\",\"releaseDate\":\"2004-10-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4qeI51jDzH81PpUUNaJCBrfm7f6.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/kub3bZS2sOGviEjo4p1ohREboVb.jpg\"},\"genres\":[\"Mystery\",\"Drama\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"32798\"},\"name\":\"Hawaii Five-0\",\"nameTranslations\":{},\"originalName\":\"Hawaii Five-0\",\"description\":\"Im Mittelpunkt der Serie steht der hochdekorierte ehemalige Marineoffizier Steve McGarrett, der von der Gouverneurin von Hawaii mit der Bildung einer Sondereinheit zur Bekämpfung des organisierten Verbrechens beauftragt wird. Er rekrutiert den ehemaligen Polizisten Chin Ho Kelly, der nach ungerechtfertigten Bestechungsvorwürfen die Polizei verlassen musste, den Polizisten Danny \\\"Danno\\\" Williams, der seiner geschiedenen Frau und deren Tochter von New Jersey nach Hawaii gefolgt ist, und die junge Polizistin Kona \\\"Kono\\\" Kalakaua, die gerade ihre Ausbildung beendet hat und die Cousine von Chin ist. Sie nennen sich Five-0 und arbeiten gemeinsam an einer Vielzahl unterschiedlicher Kriminalfälle.\",\"releaseDate\":\"2010-09-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/sIdCKlmM2nU4akIvFQaAIiU8YES.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/tLccUh3uazZ9TkLhe53UwprJhI4.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"76479\"},\"name\":\"The Boys\",\"nameTranslations\":{},\"originalName\":\"The Boys\",\"description\":\"Eine ehrfurchtslose Interpretation dessen, was passiert, wenn Superhelden, die berühmt sind wie Stars, einflussreich sind wie Politiker und verehrt werden wie Götter, ihre Superkräfte missbrauchen, anstatt Gutes zu tun. Die Machtlosen stellen sich gegen die Übermächtigen, als The Boys versuchen, die Wahrheit über \\\"The Seven\\\" und Vought dahinter ans Licht zu bringen.\",\"releaseDate\":\"2019-07-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/klwtZ4B8T9Sc3mv6TBMdUY8j3p0.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/czffzEgaBko4mXW84B1J1EnQBzo.jpg\"},\"genres\":[\"Sci-Fi & Fantasy\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1398\"},\"name\":\"Die Sopranos\",\"nameTranslations\":{},\"originalName\":\"The Sopranos\",\"description\":\"Der Mafiaboss Tony Soprano aus New Jersey hat mit persönlichen und beruflichen Problemen zu kämpfen, die sich auf seine psychische Verfassung auswirken und ihn dazu bringen, sich in psychotherapeutische Behandlung zu begeben.\",\"releaseDate\":\"1999-01-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/6oF0gzry5SMCdfScginUObtcDZN.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lNpkvX2s8LGB0mjGODMT4o6Up7j.jpg\"},\"genres\":[\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1419\"},\"name\":\"Castle\",\"nameTranslations\":{},\"originalName\":\"Castle\",\"description\":\"Rick Castle ist einer der erfolgreichsten Krimiautoren weltweit. Doch sein Rockstarleben reicht ihm nicht - dieser Haudegen sucht nach neuen Herausforderungen. Und die findet er in der Arbeit mit der schlauen und attraktiven Detective Kate Beckett. Woche um Woche lösen sie gemeinsam Verbrechensfälle, wobei ihre Partnerschaft stärker wird. Sie könnten gemeinsam ein neues Kapitel der Verbrechensbekämpfung schreiben.\",\"releaseDate\":\"2009-03-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cNWrNpd8TawT5GVbtBs65ljJ1pN.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/zOnLMRD3PIhwO5KZmWMVEnLokMo.jpg\"},\"genres\":[\"Drama\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"64190\"},\"name\":\"Volle Kanne\",\"nameTranslations\":{},\"originalName\":\"Volle Kanne\",\"description\":\"Die Sendung berichtet über verschiedene Servicethemen. Zusätzlich gibt es Tipps für die großen und kleinen Herausforderungen des Alltags und es wird ein prominenter Studiogast eingeladen, mit dem ein unterhaltsames Gespräch geführt wird.\",\"releaseDate\":\"1999-08-30\",\"images\":{\"backdrop\":\"https://image.tmdb.org/t/p/original/rWZXt8MOLNF4zSj68rptePNzksX.jpg\"},\"genres\":[\"News\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1620\"},\"name\":\"CSI: Miami\",\"nameTranslations\":{},\"originalName\":\"CSI: Miami\",\"description\":\"Bombenexperte Horatio Caine ist der Leiter des CSI-Teams in Miami: Zu seinen besonderen Merkmalen gehören sein fotografisches Gedächtnis und sein trockener Charme.\",\"releaseDate\":\"2002-09-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/oWSpWkL57u9PuDkJwV5uyoWMyEb.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/bhG1XJ1fubbZkLnoBAxNrzzGXOg.jpg\"},\"genres\":[\"Drama\",\"Mystery\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"250307\"},\"name\":\"The Pitt\",\"nameTranslations\":{},\"originalName\":\"The Pitt\",\"description\":\"Das Personal des Trauma Medical Centers Pittsburgh arbeitet rund um die Uhr, um in einer übervollen und unterfinanzierten Notaufnahme Leben zu retten.\",\"releaseDate\":\"2025-01-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/n2RDUgB3qVmqXFLAj0zGzOTPmlI.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/q1z0W19F4T5Xs2qka3xJSmFjv9a.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"2190\"},\"name\":\"South Park\",\"nameTranslations\":{},\"originalName\":\"South Park\",\"description\":\"Die Serie konzentriert sich hauptsächlich auf die Abenteuer der vier Kinder Stan Marsh, Kyle Broflovski, Eric Cartman und Kenny McCormick in der fiktionalen Kleinstadt South Park in den Rocky Mountains in den USA der Gegenwart. Neben den vier Hauptcharakteren wird die Stadt von einer Reihe von zusätzlichen Charakteren bevölkert.\",\"releaseDate\":\"1997-08-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1CGwZCFX2qerXaXQJJUB3qUvxq7.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/3UviYOlhn8EgXMBuiT6MnUuo1w9.jpg\"},\"genres\":[\"Animation\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"57532\"},\"name\":\"Paw Patrol: Helfer auf vier Pfoten\",\"nameTranslations\":{},\"originalName\":\"PAW Patrol\",\"description\":\"Die sechs heldenhaften Hunde Chase, Marshall, Rocky, Zuma, Rubble und Skye werden von dem 10-jährigen Technikliebhaber Ryder angeführt. Die Paw Patrol vereint Heldenmut und coole Fahrzeuge mit ganz viel niedlichem Humor. Alle haben einen kleinen Rucksack auf dem Rücken für ihre Missionen, damit sie für alles gewappnet sind – egal, ob sie nun eine Katze vom Baum retten oder einen Zug vor herabfallenden Steinen bewahren. Kein Job ist zu groß, kein Hund zu klein!\",\"releaseDate\":\"2013-08-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8HXkgUBO5OF8ZK9XbY69RM4S5rv.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/7OrV2aAH5Yp7hA9zCCvUloLvZtl.jpg\"},\"genres\":[\"Animation\",\"Kids\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"14981\"},\"name\":\"The Late Late Show with Craig Ferguson\",\"nameTranslations\":{},\"originalName\":\"The Late Late Show with Craig Ferguson\",\"releaseDate\":\"2005-01-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/gGC7zSDgG0FY0MbM1pjfhTCWQBI.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/m0bV3qBiJBBlpFaaKjwHo13MVjm.jpg\"},\"genres\":[\"Komödie\",\"Talk\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"15844\"},\"name\":\"真情\",\"nameTranslations\":{},\"originalName\":\"真情\",\"releaseDate\":\"1995-05-15\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/fpOAhBePSowxPsRUUT0ov9tMXwc.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/w6SFPNZJScvO47QjGyFlaUvriKX.jpg\"},\"genres\":[\"Drama\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"209867\"},\"name\":\"Frieren - Nach dem Ende der Reise\",\"nameTranslations\":{},\"originalName\":\"葬送のフリーレン\",\"description\":\"Nach einer zehnjährigen Odyssee gelingt es der Elfenmagierin Frieren zusammen mit Himmels Heldengruppe, den Dämonenkönig zu stürzen und dem Land Frieden zu schenken. Als Elfe mit langer Lebensdauer, streift sie weiter durch die Lande, doch als sie nach 50 Jahren ihren ehemaligen Kameraden einen Besuch abstattet, sind ihre Gesichter von tiefen Furchen gezeichnet. Kurz später wird Frieren Zeugin von Himmels Ableben, was für sie Schmerz und tiefes Bedauern mit sich bringt – Bedauern darüber, nicht genug Zeit mit ihnen verbracht zu haben. Mit dieser Reue im Herzen begibt sie sich auf eine Reise, um verschiedenste Menschen kennenzulernen und mit ihnen neue Abenteuer zu teilen.\",\"releaseDate\":\"2023-09-29\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/k1YVj5fGW1oKjZ19oy0PcphKXlj.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/rBOnrVlck7BIlGeWVlzYiZeg4l2.jpg\"},\"genres\":[\"Animation\",\"Action & Adventure\",\"Drama\",\"Sci-Fi & Fantasy\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"70672\"},\"name\":\"아는 형님\",\"nameTranslations\":{},\"originalName\":\"아는 형님\",\"releaseDate\":\"2015-12-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/zak7mqMxJGnnWplSdbjDtV7bg2Y.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/a8a8z4aJr40zYgRMfmSESppX2eO.jpg\"},\"genres\":[\"Reality\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1400\"},\"name\":\"Seinfeld\",\"nameTranslations\":{},\"originalName\":\"Seinfeld\",\"description\":\"Oft löst ein kleines Ereignis das größte Chaos aus. Jerry Seinfeld und seine drei Freunde Elaine, Kramer und George sind eine Chaotenclique: Ein Kampf um einen Sitzplatz im Restaurant, ein illegaler Kabelanschluss, die Frage nach der richtigen Höhe des Trinkgeldes oder auch nur eine falsche Bemerkung auf dem Anrufbeantworter der neuen Flamme...\",\"releaseDate\":\"1989-07-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/aCw8ONfyz3AhngVQa1E2Ss4KSUQ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/tMRdEsMg9MyXAkcufK9YJEeIaNW.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"4556\"},\"name\":\"Scrubs – Die Anfänger\",\"nameTranslations\":{},\"originalName\":\"Scrubs\",\"description\":\"Der junge Mediziner John “J.D.” Dorian schlägt sich mit seinen Kollegen durch den chaotisch-skurrilen Krankenhausalltag. Dabei werden die jungen Ärzte von ihrem bösartigen Chef Dr. Kelso und dem hinterhältigen Hausmeister geplagt. Doch nicht nur der Job hält die Mediziner auf Trab – auch ihr Privatleben gerät immer wieder in Turbulenzen.\",\"releaseDate\":\"2001-10-02\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/z5Gd7XrweDeuxZohZWMHPMEM4h9.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/vIqDfrp6ApLxM9yRg3xDnQqXy0T.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"235685\"},\"name\":\"The Pendragon Cycle: Rise of the Merlin\",\"nameTranslations\":{},\"originalName\":\"The Pendragon Cycle: Rise of the Merlin\",\"releaseDate\":\"2026-01-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/jJfk8NXauN4UgFQ1qn9lFzEk7ib.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lDmFwAaHL1kXnAfZeUTieAdUTko.jpg\"},\"genres\":[\"Sci-Fi & Fantasy\",\"Action & Adventure\",\"Familie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"245927\"},\"name\":\"Paradise\",\"nameTranslations\":{},\"originalName\":\"Paradise\",\"description\":\"Die Idylle in einer Gemeinde, die von einigen der einflussreichsten Menschen der Welt bewohnt wird, zerbricht, als ein entsetzlicher Mord geschieht und eine hochbrisante Ermittlung beginnt.\",\"releaseDate\":\"2025-01-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/l8RqfhqEk04W5sSOjQ9zeWU1DyM.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5QsLvWh8J1mXl1W05wNJknMmhzR.jpg\"},\"genres\":[\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1636\"},\"name\":\"Top of the Pops\",\"nameTranslations\":{},\"originalName\":\"Top of the Pops\",\"description\":\"Top of the Pops war eine internationale Musiksendung der BBC aus Großbritannien. Es wurde überwiegend aktuelle Musik mit Auftritten von Künstlern aus dem Bereich Pop und Rock vorgestellt.\",\"releaseDate\":\"1964-01-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/jjfTTjVYWyD6rGHVbnC44IrsJ7P.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/q8fmM50In8xGVW0iYoENPa71kAA.jpg\"},\"genres\":[\"Reality\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"11366\"},\"name\":\"Big Brother\",\"nameTranslations\":{},\"originalName\":\"Big Brother\",\"releaseDate\":\"2000-07-18\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cx0YldpEMh1EBpwwdgY1Awcg6ty.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/3SWOj8ydFrxiuZdLg63fDAt4jYR.jpg\"},\"genres\":[\"Reality\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"32692\"},\"name\":\"Blue Bloods\",\"nameTranslations\":{},\"originalName\":\"Blue Bloods\",\"description\":\"Familie Reagan teilt eine berufliche Leidenschaft: Großvater Henry ist der ehemalige Polizeichef New Yorks, Frank ist in die Fußstapfen seines Vaters getreten, und auch die dritte Generation der Reagans hat sich der Bekämpfung der Kriminalität in New York verschrieben. Während Danny für seine unkonventionellen Ermittlungsmethoden bekannt ist, versucht Polizeineuling Jamie, den Mord an seinem Bruder Joe aufzuklären.\",\"releaseDate\":\"2010-09-24\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/q1WlrxnCvNhBjJ4N7V0JQXjnIBN.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/goDtZCB5pFIuuSfYDvApe6iXTID.jpg\"},\"genres\":[\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"60622\"},\"name\":\"Fargo\",\"nameTranslations\":{},\"originalName\":\"Fargo\",\"description\":\"In Anlehnung an den gleichnamigen Hit der Coen-Brüder werden in dieser Serie mehrere skurrile Bewohner des US-Bundesstaates Minnesota in „reale“ Verbrechen verwickelt.\",\"releaseDate\":\"2014-04-15\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/6U9CPeD8obHzweikFhiLhpc7YBT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/4jrSbRpLqpvYJtLKncaxZVC47EW.jpg\"},\"genres\":[\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"310800\"},\"name\":\"Siren's Kiss\",\"nameTranslations\":{},\"originalName\":\"세이렌\",\"description\":\"„Wenn du sie liebst, stirbst du.\\\" Versicherungsdetektiv Cha Woo-seok untersucht die Todesfälle, die mit der verführerischen Auktionatorin Han Seol-ah in Verbindung stehen. Nachdem ihre Kollegin stirbt und rauskommt, dass ihre früheren Liebhaber das gleiche Schicksal ereilt hat, vermutet er, dass sie selbst ein Opfer sein könnte. Sie geben sich als Liebespaar aus, um die Wahrheit aufzudecken.\",\"releaseDate\":\"2026-03-02\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4C5iHtnndCvlbMvsKdRFtCDSE5L.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hCEl9Tb27chAWYXYau05pCSKEL.jpg\"},\"genres\":[\"Drama\",\"Krimi\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"82873\"},\"name\":\"The Kelly Clarkson Show\",\"nameTranslations\":{},\"originalName\":\"The Kelly Clarkson Show\",\"description\":\"Kelly Clarkson präsentiert die größten Nachrichtenmacher und Namen aus Film, Fernsehen und Musik sowie aufstrebende neue Talente und alltägliche Menschen, die in ihren Gemeinden Leuchttürme der Hoffnung sind.\",\"releaseDate\":\"2019-09-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/sBix25bie9UQFzbarN51DpFO5ky.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/bk7QdAIUqkGpZO5GUX4AMB2AZIB.jpg\"},\"genres\":[\"Talk\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"203505\"},\"name\":\"Escándalo, relato de una obsesión\",\"nameTranslations\":{},\"originalName\":\"Escándalo, relato de una obsesión\",\"releaseDate\":\"2023-01-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/mra3tUkixvDE0lxQw1ZjuSkCa1U.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/cfoFgrPULUMFAP0XCo6hfjzKZGN.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"62650\"},\"name\":\"Chicago Med\",\"nameTranslations\":{},\"originalName\":\"Chicago Med\",\"description\":\"Im täglichen Kampf gegen Krankheit und Tod müssen alle Mitarbeiter des modernsten Krankenhauses der Stadt an einem Strang ziehen. Zusammen stehen sie den medizinisch kompliziertesten Fällen Chicagos gegenüber und meistern moralische Dilemma mit Mut, Entschlossenheit und hochmodernen Behandlungsmethoden.\",\"releaseDate\":\"2015-11-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/nw8jlrALg0m1PQbxNNLrDNAdxZj.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/x2jNLrYw1s9i6kihEJqsBQgs9nR.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"2288\"},\"name\":\"Prison Break\",\"nameTranslations\":{},\"originalName\":\"Prison Break\",\"description\":\"Michael Scofield ist ein erfolgreicher Ingenieur, doch er ist verzweifelt. Sein Bruder Lincoln Burrows wurde eines schrecklichen Mordes schuldig gesprochen und sitzt nun in der Todeszelle des Fox River Staatsgefängnisses. Trotz der erdrückenden Beweislage gegen Lincoln ist Michael von der Unschuld seines Bruders fest überzeugt. Michael sieht keinen anderen Ausweg mehr und entschließt sich zu einem waghalsigen Ausbruchsversuch. Notgedrungen überfällt Michael also eine Bank und wird kurzerhand in dasselbe Gefängnis gesteckt, in dem sein Bruder sitzt. Zusammen wollen die beiden nun Ausbrechen und die Unschuld von Lincoln beweisen. Pikanterweise verdient sich Michael mit dem Bau von Gefängnissen seinen Lebensunterhalt, was dazu führt, dass er die gesamten Pläne des Fox River besitzt..\",\"releaseDate\":\"2005-08-29\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/wnmNPaLvhnMeOqnWlhNkYCZxtda.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/n3Brk7roueE9HOwVmYlJx5j462g.jpg\"},\"genres\":[\"Action & Adventure\",\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1412\"},\"name\":\"Arrow\",\"nameTranslations\":{},\"originalName\":\"Arrow\",\"description\":\"Als einziger Überlebender eines Schiffbruchs führt der Playboy und Milliardärssohn Oliver Queen fünf Jahre lang ein Robinson-Crusoe-Leben auf einer einsamen Insel. Er wird zum meisterhaften Bogenschützen. Nach seiner Rettung kehrt Queen charakterlich geläutert in seine Heimatstadt Starling City zurück. Er beschließt, der steigenden Kriminalitätsrate ein Ende zu setzen. Während er tagsüber in der Öffentlichkeit seine frühere Rolle als verwöhnter Snob spielt, bekämpft er nachts mit Pfeil und Bogen in geheimer Identität Verbrechen und Korruption. Zugleich versucht er, wieder bei Ex-Freundin Laurel zu landen. Deren Vater, ein Detective, betrachtet die Ankunft eines neuen Superhelden in Starling City aber mit Skepsis...\",\"releaseDate\":\"2012-10-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/u8ZHFj1jC384JEkTt3vNg1DfWEb.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/wAFuDJfZJrnh6a1wf1Vt7PqYBvR.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Action & Adventure\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"283123\"},\"name\":\"Eşref Rüya\",\"nameTranslations\":{},\"originalName\":\"Eşref Rüya\",\"releaseDate\":\"2025-03-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/eeFYLgiRFaG3bKx1qLyC7YOdHJz.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/opxjwbFSadDgVmZtrLTlWJsUxrB.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"241372\"},\"name\":\"56 Tage\",\"nameTranslations\":{},\"originalName\":\"56 Days\",\"description\":\"Als in einer Luxuswohnung, die mit Oliver Kennedy und seiner Freundin Ciara Wyse in Verbindung steht, eine nicht identifizierte Leiche gefunden wird, rekonstruieren die Kommissare Lee Reardon und Karl Connolly die tragische Liebesgeschichte des Paares der letzten 56 Tage.\",\"releaseDate\":\"2026-02-18\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/yUsMXPiy4Sagzite1nmaT5W6jzV.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/dnEljhBkw53ra7tEl2JNKGrI0wk.jpg\"},\"genres\":[\"Drama\",\"Krimi\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"65334\"},\"name\":\"Miraculous - Geschichten von Ladybug und Cat Noir\",\"nameTranslations\":{},\"originalName\":\"Miraculous, les aventures de Ladybug et Chat Noir\",\"description\":\"Marinette und Adrien sind zwei Schüler – fast – wie andere auch. Bei der kleinsten Bedrohung von Paris werden sie zu Ladybug und Cat Noir. Ihre Mission: Die Akumas des mysteriösen Hawk Moth fangen, der die Pariser in Super-Bösewichte verwandelt. Obwohl die beiden Helden ein Team bilden, wissen sie wenig voneinander: Marinette weiß nicht, dass sich hinter Cat Noir Adrien verbirgt, der Junge, in den sie heimlich verliebt ist; und Adrien, dessen Herzen für Ladybug schlägt, ignoriert, dass sich hinter dem Kostüm der Superheldin das nette und zerstreute Mädchen aus seiner Klasse verbirgt\",\"releaseDate\":\"2015-10-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/2gIfJXgcz6N2wgOZ4qXoNKh0qFZ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lH22EnM0ofC7GsVGU8dAA2RXV1c.jpg\"},\"genres\":[\"Action & Adventure\",\"Animation\",\"Kids\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"62992\"},\"name\":\"DAS!\",\"nameTranslations\":{},\"originalName\":\"DAS!\",\"description\":\"Jeden Abend pünktlich 18:45 Uhr nimmt ein prominenter Gast auf dem Roten Sofa Platz - dazu informiert DAS! täglich, was im Norden Gesprächsthema ist.\",\"releaseDate\":\"1991-01-02\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/yMg0l6hxCnR94Fcl1F1IEkmG26V.jpg\"},\"genres\":[\"Talk\",\"News\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"71790\"},\"name\":\"S.W.A.T.\",\"nameTranslations\":{},\"originalName\":\"S.W.A.T.\",\"description\":\"Die Serie dreht sich um einen lokal verwurzelten S.W.A.T. Seargent, der im Spannungsfeld zwischen der Loyalität zur Straße und seinen polizeilichen Pflichten mit seinem trainierten Team die letzte Bastion der Verbrechensbekämpfung in Los Angeles darstellt.\",\"releaseDate\":\"2017-11-02\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5XRG2Mw87Jl0Sx9oomZH2BgI4Qu.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/7j4ug9B6JXVeh5HhQjjPScrdj4Z.jpg\"},\"genres\":[\"Krimi\",\"Action & Adventure\",\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"153485\"},\"name\":\"サザエさん\",\"nameTranslations\":{},\"originalName\":\"サザエさん\",\"releaseDate\":\"1969-10-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ovOdOiGr0xHxB8rCwLSXAchCrta.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/tsCAhbrs3RIsHz5sdURsWxqTNAK.jpg\"},\"genres\":[\"Animation\",\"Komödie\",\"Familie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1307\"},\"name\":\"कसौटी ज़िंदगी के\",\"nameTranslations\":{},\"originalName\":\"कसौटी ज़िंदगी के\",\"releaseDate\":\"2001-10-29\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/v8Hdqnx4uvtZVnSHIQYiiTYnd16.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/xVCmBf9kNKBNWEgxsoaI1g326EQ.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"2912\"},\"name\":\"Jeopardy!\",\"nameTranslations\":{},\"originalName\":\"Jeopardy!\",\"releaseDate\":\"1984-09-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/hfz0IgebqGENG6ZnuqKQKMFk2vy.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/55tcKzl0gZ0lR1q7TrVJm0h9lkT.jpg\"},\"genres\":[\"Reality\",\"Familie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"1220\"},\"name\":\"The Graham Norton Show\",\"nameTranslations\":{},\"originalName\":\"The Graham Norton Show\",\"description\":\"Jede Woche diskutieren prominente Gäste mit dem irischen Komiker Graham Norton über die aktuellen Ereignisse der Woche weltweit. Die Gäste machen sich lustig und tauschen ihre Meinungen zu den wichtigsten Nachrichten aus. Graham wird oft von einer Band oder einem Künstler begleitet, die die Show musikalisch untermalen.\",\"releaseDate\":\"2007-02-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/vrbqaBXB8AALynQzpWz6JdCPEJS.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5UNcEz7Lc3OGilpPn1Tb9cd1xsc.jpg\"},\"genres\":[\"Komödie\",\"Talk\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"221468\"},\"name\":\"Hollywood Squares\",\"nameTranslations\":{},\"originalName\":\"Hollywood Squares\",\"releaseDate\":\"1998-09-14\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/vHwgcxGQH8KpgTL4KEV4eG2IAn8.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"10536\"},\"name\":\"The Mike Douglas Show\",\"nameTranslations\":{},\"originalName\":\"The Mike Douglas Show\",\"releaseDate\":\"1961-12-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qNk97cbF3dZyhkfIcJhjFDD64sM.jpg\"},\"genres\":[\"Komödie\",\"Talk\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"72879\"},\"name\":\"Demain nous appartient\",\"nameTranslations\":{},\"originalName\":\"Demain nous appartient\",\"releaseDate\":\"2017-07-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/24rWFf7CeBVwEEmqLYuQexID8I7.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/kkfqNkGQR5og5sDjJTxTVmI9PW.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Soap\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"8590\"},\"name\":\"Plus belle la vie\",\"nameTranslations\":{},\"originalName\":\"Plus belle la vie\",\"releaseDate\":\"2004-08-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/jmU8HlTDn87xmRqXagcL2swDr8I.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lqDlYLNA0RdMXDiz70lU8Ib1nwW.jpg\"},\"genres\":[\"Drama\",\"Komödie\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"12415\"},\"name\":\"Egoli: Place of Gold\",\"nameTranslations\":{},\"originalName\":\"Egoli: Place of Gold\",\"releaseDate\":\"1992-04-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/l8ivo9sEkKrLYRsNeyaVmAbH0eg.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/9daf0KXr3xUkMt2NCI0ZhDIZJEa.jpg\"},\"genres\":[\"Soap\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"95897\"},\"name\":\"Overflow\",\"nameTranslations\":{},\"originalName\":\"おーばーふろぉ\",\"description\":\"Die beiden Schwestern Ayane und Kotone beschließen bei ihrem »Bruder« und einstigen Kindheitsfreund Kazushi einzuziehen, ohne diesen nach seiner Meinung zu fragen. Kazushi ist nicht wirklich mit den beiden verwandt, sieht sie aber als Teil der Familie. Nachdem der in Teilzeit arbeitende Student ein Badesalz von Ayane und Kotone benutzt, werden sie wütend und steigen kurzerhand mit ihm zusammen in das Wasser, um auch etwas von dem Erlebnis zu haben. Dabei kommen die drei sich trotz der knapp bemessenen Badeanzüge ungewollt näher als gedacht …\",\"releaseDate\":\"2020-01-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8RtwL5gxUvh9YViqjhNlVRvJpum.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/4NRBKA8qVzCvuD3WeLieiLGmIjm.jpg\"},\"genres\":[\"Animation\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"4385\"},\"name\":\"The Colbert Report\",\"nameTranslations\":{},\"originalName\":\"The Colbert Report\",\"description\":\"Rechtskonservativ, engstirnig, egozentrisch, größenwahnsinnig – alles Attribute, in denen Stephen Colbert seinem großen Vorbild Bill O’Reilly von Fox News in nichts nachsteht. Als Parodie des rechten Newsshow-Frontmanns moderiert Colbert viermal pro Woche seine eigene Nachrichtensendung und ist mit dem halbstündigen Satireformat mittlerweile sogar erfolgreicher als die „Daily Show with Jon Stewart“, von der sie als Spin-Off entstanden ist. \",\"releaseDate\":\"2005-10-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/pn2CVXjOlR8kY5MgOTJjZ71IM0Q.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/Ajku4m7jbMpCTEPr794Imv19mCA.jpg\"},\"genres\":[\"News\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"30983\"},\"name\":\"Detektiv Conan\",\"nameTranslations\":{},\"originalName\":\"名探偵コナン\",\"description\":\"Conan Edogawa sieht aus wie ein Grundschüler. Tatsächlich ist er Shinichi Kudo, der 17-jährige Meisterdetektiv Japans, der von zwei Verbrechern vergiftet wurde. Er starb zwar nicht, entwickelte sich aber körperlich zum Kind zurück. Im Kopf ist er aber weiter der brillante Ermittler von einst und so stürzt er sich weiterhin auf geheimnisvolle Mordfälle.\",\"releaseDate\":\"1996-01-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1IfcpJRkSUnXbzy2ZVjHtxtqtdL.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5546GF3zT3yA25ydCz0KlujjRA3.jpg\"},\"genres\":[\"Animation\",\"Krimi\",\"Mystery\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"series\",\"ids\":{\"tmdb_id\":\"36361\"},\"name\":\"Die Gasse\",\"nameTranslations\":{},\"originalName\":\"Ulice\",\"description\":\"Die Gasse (Ulice) ist eine lang laufende, tschechische Fernsehserie. Die Handlung dreht sich um eine fiktionale Straße in den Prager Randbezirken und die Familien, die dort leben.\",\"releaseDate\":\"2005-09-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/gFEHva8Csx18hMGJJZ6gi4sFSKR.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/cchlQWYrnMPyl1EbjZWCzeAz8l5.jpg\"},\"genres\":[\"Drama\",\"Komödie\"],\"similarItems\":[]}],\"nextCursor\":8}"},"redirectURL":"","headersSize":693,"bodySize":35005,"_status":"completed","_startTimestamp":1772842820787807,"_endTimestamp":1772842820813920},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"2606:4700:3032::ac43:cdc0","connection":"12","comment":"","_id":37,"_uid":"0e1e5ed3-7519-4900-ba3a-c2d0b89fba88","_cid":12,"_ctime":1772842816360,"_sid":45,"_stime":1772842820345,"_serverAddress":"2606:4700:3032::ac43:cdc0","_serverAddressFamily":1,"_serverPort":443,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":57859,"_app":{"name":"VAVOO","id":"VAVOO.exe","path":"C:\\Users\\isada\\AppData\\Local\\Programs\\vavoo\\VAVOO.exe","pid":139300}},{"startedDateTime":"2026-03-07T00:20:20.358Z","time":681,"request":{"method":"POST","url":"https://www.kool.to/mediahubmx-catalog.json","httpVersion":"HTTP/2.0","cookies":[],"headers":[{"name":":method","value":"POST"},{"name":":authority","value":"www.kool.to"},{"name":":path","value":"/mediahubmx-catalog.json"},{"name":":scheme","value":"https"},{"name":"content-length","value":"175"},{"name":"content-type","value":"application/json; charset=utf-8"},{"name":"mediahubmx-signature","value":""},{"name":"user-agent","value":"MediaHubMX/2"},{"name":"accept","value":"*/*"},{"name":"accept-encoding","value":"gzip,deflate"},{"name":"sec-fetch-site","value":"none"},{"name":"sec-fetch-mode","value":"no-cors"},{"name":"sec-fetch-dest","value":"empty"},{"name":"accept-language","value":"de"}],"queryString":[],"postData":{"mimeType":"application/json","text":"{\"language\":\"de\",\"region\":\"DE\",\"catalogId\":\"tmdb.movie\",\"id\":\"movie/trending\",\"adult\":false,\"search\":\"\",\"sort\":\"trendingDay\",\"filter\":{},\"cursor\":null,\"clientVersion\":\"3.0.2\"}"},"headersSize":966,"bodySize":175,"_status":"completed","_startTimestamp":1772842820358816,"_endTimestamp":1772842820371284},"response":{"status":200,"statusText":"","httpVersion":"HTTP/2.0","cookies":[],"headers":[{"name":":status","value":"200"},{"name":"date","value":"Sat, 07 Mar 2026 00:20:20 GMT"},{"name":"content-type","value":"application/json; charset=utf-8"},{"name":"server","value":"cloudflare"},{"name":"mediahubmx-endpoint","value":"."},{"name":"etag","value":"W/\"19a1a-kuZBf0GJ1FKZ/9B6+967O6Zawc4\""},{"name":"strict-transport-security","value":"max-age=31536000; includeSubDomains"},{"name":"content-encoding","value":"gzip"},{"name":"cf-cache-status","value":"DYNAMIC"},{"name":"vary","value":"accept-encoding"},{"name":"nel","value":"{\"report_to\":\"cf-nel\",\"success_fraction\":0.0,\"max_age\":604800}"},{"name":"report-to","value":"{\"group\":\"cf-nel\",\"max_age\":604800,\"endpoints\":[{\"url\":\"https://a.nel.cloudflare.com/report/v4?s=bZRq9fRgT4oFDsqLe30fIU36ihgtx%2FZenjEVwlA%2FgGKdVMDF3XrqpRAYHMrRqt7VSkolLMtiq1ZoW%2FY7nhD%2F5lEqf5Muvz3q6%2FTn1ZyLR7J46RINEw%3D%3D\"}]}"},{"name":"cf-ray","value":"9d856f0bf914e51e-TXL"},{"name":"alt-svc","value":"h3=\":443\"; ma=86400"}],"content":{"size":104986,"mimeType":"application/json","text":"{\"options\":{},\"items\":[{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1265609\"},\"name\":\"War Machine\",\"nameTranslations\":{},\"originalName\":\"War Machine\",\"description\":\"Auf einer letzten mörderischen Mission während der Army-Ranger-Ausbildung muss ein Kampfingenieur seine Einheit im Kampf gegen eine außerirdische Killermaschine anführen.\",\"releaseDate\":\"2026-02-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/6GDx3WnG7jukJLd8y0f7TLk3ghP.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/6yeVcxFR0j08vlv2OlL6zbewm4D.jpg\"},\"genres\":[\"Action\",\"Science Fiction\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"696393\"},\"name\":\"Cold Storage\",\"nameTranslations\":{},\"originalName\":\"Cold Storage\",\"description\":\"Teacake und Naomi sind zwei junge Angestellte eines Selfstorage-Unternehmens auf dem Gelände eines ehemaligen US-Militärstützpunkts und erleben ihre turbulenteste Nachtschicht, als ein parasitärer Pilz aus der versiegelten untersten Ebene ausbricht, wo er vor Jahrzehnten von der Regierung eingeschlossen wurde. Mit steigender Temperatur im Untergrund vermehrt sich der hoch ansteckende, schnell mutierende Mikroorganismus und entfesselt seinen gehirnkontrollierenden, körperzerstörenden Schrecken auf Menschen und andere Lebewesen. Gemeinsam mit einem ergrauten, pensionierten Bioterror-Agenten versuchen Teacake und Naomi, die Bedrohung einzudämmen und das drohende Aussterben der Menschheit zu verhindern.\",\"releaseDate\":\"2026-01-29\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/naOt7nBjOkRLlsn7TerzXbQnjSe.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nbzTcx2gdAY4ujUNwU2opc8ampg.jpg\"},\"genres\":[\"Komödie\",\"Horror\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1159831\"},\"name\":\"The Bride! - Es lebe die Braut\",\"nameTranslations\":{},\"originalName\":\"The Bride!\",\"description\":\"In den 1930er Jahren reist ein einsamer Frankenstein nach Chicago, um mit Hilfe eines Dr. Euphronius eine Gefährtin für sich zu erschaffen. Die beiden beleben eine ermordete junge Frau wieder und die Braut ist geboren. Sie übertrifft die Erwartungen der beiden und entfacht eine brennende Romanze, die Aufmerksamkeit der Polizei und eine wilde und radikale soziale Bewegung.\",\"releaseDate\":\"2026-03-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/p9Tm37C1C0yexPFx7bgTLQeDlKJ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/8XeUEIXiZiRNqz0EcKC65vje8Th.jpg\"},\"genres\":[\"Science Fiction\",\"Horror\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1327819\"},\"name\":\"Hoppers\",\"nameTranslations\":{},\"originalName\":\"Hoppers\",\"description\":\"Das findet man am besten heraus, wenn man selbst zum Tier wird. In Disney Pixars HOPPERS gewinnt Tierfreundin Mabel als Biber äußerst überraschende Erkenntnisse. Aber anstatt sich an die Regeln zu halten, stellt sie die natürliche Ordnung völlig auf den Kopf und zettelt einen tierischen Aufstand an. Und das nur, weil sie unbedingt den Teich retten will.\",\"releaseDate\":\"2026-02-28\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/nP3oMYwggLjnv5v1oQSmUso6yTd.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/2RrLuIfIzGWWIH8IAEo6o0IYHmx.jpg\"},\"genres\":[\"Animation\",\"Familie\",\"Komödie\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1159559\"},\"name\":\"Scream 7\",\"nameTranslations\":{},\"originalName\":\"Scream 7\",\"description\":\"Als in der beschaulichen Stadt, in der sich Sidney Prescott ein neues Leben aufgebaut hat, ein neuer Ghostface-Killer auftaucht, werden ihre schlimmsten Befürchtungen wahr: Ihre Tochter gerät ins Visier der Ermordung. Entschlossen, ihre Familie zu schützen, muss Sidney sich den Schrecken ihrer Vergangenheit stellen, um dem Blutvergießen ein für alle Mal ein Ende zu setzen.\",\"releaseDate\":\"2026-02-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5VhF4IxrieKUVBYZ5As4AVphsUH.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hz7TdCrpLLt2Dz7S3PS2HG9rpAO.jpg\"},\"genres\":[\"Horror\",\"Mystery\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1010755\"},\"name\":\"The Strangers: Chapter 3\",\"nameTranslations\":{},\"originalName\":\"The Strangers: Chapter 3\",\"releaseDate\":\"2026-02-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/yPHwX78mcwJw3I6YOJ9qh2wQBFr.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/fPfDB0IHOqvmKIzFP9CA51OOS1N.jpg\"},\"genres\":[\"Horror\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1317288\"},\"name\":\"Marty Supreme\",\"nameTranslations\":{},\"originalName\":\"Marty Supreme\",\"description\":\"In den Hinterhöfen Manhattans träumt der junge Schuhverkäufer Marty von einer Zukunft, die ein paar Nummern größer ist als der kleine Schuhladen seines Onkels. Angetrieben von der Idee, Weltmeister im Tischtennis werden zu können, taucht er jede Nacht ab in die verrauchten Wettkampfhallen der Stadt, wo er sich mit viel Talent, der nötigen Chuzpe und dank der Hilfe seines besten Freundes ein paar Dollar dazu verdient. Zu wenig, um eine Profikarriere zu finanzieren und an den Turnieren in London, Paris oder Tokio teilnehmen zu können. Also ‚leiht‘ sich Marty kurzerhand Geld aus dem Safe seines Onkels, belügt seine Mutter ebenso wie seine Freundin (Odessa A’zion) und schmeißt sich schamlos an eine Hollywood-Diva (Gwyneth Paltrow) ran, deren Ehemann er gleichzeitig als Sponsor gewinnen will. Doch das ist erst der Anfang der Odyssey eines Mannes, der bereit ist, für Ruhm und Erfolg alles zu riskieren.\",\"releaseDate\":\"2025-12-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8LGm5kOZnWpUI4uiomBYit4GWdF.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/qKWDHofjMHPSEOTLaixkC9ZmjTT.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1193501\"},\"name\":\"Whistle\",\"nameTranslations\":{},\"originalName\":\"Whistle\",\"description\":\"Eine Gruppe unangepasster Highschool-Schüler stößt auf eine alte aztekische Todespfeife. Sie entdecken, dass der furchterregende Klang, den sie ausstößt, sie in Zukunft zum Tode zwingt und sie aufspürt. Während die Zahl der Toten steigt, untersuchen die Freunde die Herkunft des tödlichen Artefakts in einem verzweifelten Versuch, die schreckliche Kette der Ereignisse zu stoppen, die sie selbst in Gang gesetzt haben.\",\"releaseDate\":\"2026-01-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4PvnAwa0JUo6ATPy15tiBxRwfP6.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yJi6g0CnsqANLNuVaRX28tZxeHX.jpg\"},\"genres\":[\"Horror\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"799882\"},\"name\":\"The Bluff\",\"nameTranslations\":{},\"originalName\":\"The Bluff\",\"description\":\"Als ihr ruhiges Leben auf einer abgelegenen Insel durch die Rückkehr ihres rachsüchtigen Ex-Kapitäns zerstört wird, muss eine erfahrene ehemalige Piratin sich ihrer blutigen Vergangenheit stellen und ihre tödlichen Talente einsetzen, um ihre Familie vor einer gnadenlosen Belagerung zu retten.\",\"releaseDate\":\"2026-02-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4zC5m3JdO76guCDd5YMh7wj7JnQ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hYgUkH7TusddHRtelj53I6gFOWR.jpg\"},\"genres\":[\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1629382\"},\"name\":\"Banlieusards 3\",\"nameTranslations\":{},\"originalName\":\"Banlieusards 3\",\"description\":\"Noch immer trauernd, stellen sich die Traoré-Brüder den Konsequenzen ihrer Verbrechen und erhalten eine letzte Chance, einen neuen Weg einzuschlagen.\",\"releaseDate\":\"2026-03-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/rCkg72HTCyhvqez8ez9pJpaAmVs.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/jhfJZ82qzcMV4Kr7G0uczdU4n2v.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1084242\"},\"name\":\"Zoomania 2\",\"nameTranslations\":{},\"originalName\":\"Zootopia 2\",\"description\":\"Judy Hopps und Nick Wilde stoßen auf die rätselhafte Spur eines geheimnisvollen Reptils, das in Zootopia auftaucht und die Metropole völlig auf den Kopf stellt: Gary De'Snake! Um den Fall zu lösen, müssen die beiden Undercover in völlig unbekannte Stadtteile vordringen – und dabei wird ihre wachsende Partnerschaft auf eine harte Probe stellt.\",\"releaseDate\":\"2025-11-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/q4RqhHz21kwRyemR9gePrTstSSe.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5BeOSbwt6BR7q2Fax70lF4AIshD.jpg\"},\"genres\":[\"Animation\",\"Komödie\",\"Abenteuer\",\"Familie\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1290821\"},\"name\":\"Shelter\",\"nameTranslations\":{},\"originalName\":\"Shelter\",\"description\":\"Ein Mann, der sich auf einer abgelegenen Insel in selbstgewählter Abgeschiedenheit befindet, rettet ein junges Mädchen vor einem heftigen Sturm und löst damit eine Kette von Ereignissen aus, die ihn zwingen, seine Abgeschiedenheit zu verlassen, um sie vor Feinden aus seiner Vergangenheit zu schützen.\",\"releaseDate\":\"2026-01-28\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/buPFnHZ3xQy6vZEHxbHgL1Pc6CR.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nHxWyy18SvAZ8jJeemtS8k1UNjM.jpg\"},\"genres\":[\"Action\",\"Krimi\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1226863\"},\"name\":\"Der Super Mario Galaxy Film\",\"nameTranslations\":{},\"originalName\":\"The Super Mario Galaxy Movie\",\"description\":\"Ein neuer Film, der auf der Welt von Super Mario Bros. basiert und Marios Welt mit einer heiteren und unterhaltsamen Geschichte erweitert. Handlung wird noch bekannt gegeben.\",\"releaseDate\":\"2026-04-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/stLhfpLgLjnOGzTuWJt1AQDhw9Z.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5U0tqruExz7ssDyr5pwiAGFzI8S.jpg\"},\"genres\":[\"Familie\",\"Fantasy\",\"Komödie\",\"Abenteuer\",\"Animation\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"858024\"},\"name\":\"Hamnet\",\"nameTranslations\":{},\"originalName\":\"Hamnet\",\"description\":\"Wir schreiben das Jahr 1580 und der im kleinen englischen Dorf Stratford-upon-Avon als Lateinlehrer arbeitende William Shakespeare verliebt sich in Agnes. Im Dorf wird hinter immer weniger vorgehaltener Hand vermutet, sie sei eigentlich gar keine Heilerin, sondern eine richtige Hexe. Aber das ist William egal. Die beiden stürzen sich Hals über Kopf in das gemeinsame Leben und bekommen auch schnell drei Kinder. Erst wird Susanna geboren, kurz darauf die Zwillinge Judith und Hamnet. Doch mit der Familie endet das Träumen zumindest für William noch nicht. Er will das Lehren endlich hinter sich lassen können und als Dramatiker arbeiten. Auf dem Land geht das jedoch eher schlecht als recht. Also geht er, ermutigt von Agnes, nach London. Erst ist die Familie als nur räumlich voneinander getrennt, dann pflügt die Pest durch das Land und tötet auch Hamnet mit gerade einmal elf Jahren. Das treibt William an, seinem Sohn zu Ehren ein Stück zu schreiben...\",\"releaseDate\":\"2025-11-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/Ua43qwtLJNtFcTeAtO3q1SG5NV.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/73BClq9FOcrWrutnpiqhCNEWEwJ.jpg\"},\"genres\":[\"Drama\",\"Liebesfilm\",\"Historie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1368166\"},\"name\":\"The Housemaid - Wenn sie wüsste\",\"nameTranslations\":{},\"originalName\":\"The Housemaid\",\"description\":\"Nicht jeder Neuanfang bietet eine zweite Chance. Die 27-jährige Millie hofft nach der Entlassung aus dem Gefängnis als Hausmädchen bei einem wohlhabenden Ehepaar neu anzufangen. Doch schon bald merkt sie, dass sich hinter der Fassade aus Luxus und Eleganz eine dunkle Wahrheit verbirgt, die weitaus gefährlicher ist als ihre eigene. Ein verführerisches Spiel um Geheimnisse, Skandale und Macht beginnt…\",\"releaseDate\":\"2025-12-18\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/uXZ7i3BgcFkLdG5nD16zCDXPgjz.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5Q71GYwh2mOz5rr8tPTcvbeBWtN.jpg\"},\"genres\":[\"Drama\",\"Mystery\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1032892\"},\"name\":\"In the Blink of an Eye\",\"nameTranslations\":{},\"originalName\":\"In the Blink of an Eye\",\"description\":\"Drei über Jahrtausende hinweg verwobene Geschichten erzählen von Hoffnung, Gemeinschaft und dem Kreislauf des Lebens.\",\"releaseDate\":\"2026-01-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/odlnSrjODWOyZ2mZv5ZD1E2j1YH.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/uM5i623wwNfoGD97iwwQWQ7GlZL.jpg\"},\"genres\":[\"Drama\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"687163\"},\"name\":\"Der Astronaut - Project Hail Mary\",\"nameTranslations\":{},\"originalName\":\"Project Hail Mary\",\"description\":\"Als Ryland Grace erwacht, muss er feststellen, dass er ganz allein ist. Er ist anscheinend der einzige Überlebende einer Raumfahrtmission, Millionen Kilometer von zu Hause entfernt, auf einem Flug ins Tau-Ceti-Sternsystem. Aber was erwartet ihn dort? Und warum sind alle anderen Besatzungsmitglieder tot? Nach und nach dämmert es Grace, dass von seinem Überleben nicht nur die Mission, sondern die Zukunft der gesamten Erdbevölkerung abhängt.\",\"releaseDate\":\"2026-03-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/uKoPaIv5E4uVWouaySOQchKxTML.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/o2xLxY1LdwBMsrGD9hjIaOrIQm6.jpg\"},\"genres\":[\"Science Fiction\",\"Abenteuer\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1631485\"},\"name\":\"Parque Lezama\",\"nameTranslations\":{},\"originalName\":\"Parque Lezama\",\"releaseDate\":\"2026-02-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ckBRproYQsXAJGtyejKjDr5ZcBU.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/zFIdOkN4ULw6K6HBpMUMn6njMnK.jpg\"},\"genres\":[\"Komödie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1272837\"},\"name\":\"28 Years Later: The Bone Temple\",\"nameTranslations\":{},\"originalName\":\"28 Years Later: The Bone Temple\",\"description\":\"Nia DaCosta knüpft an die Welt an, die Danny Boyle und Alex Garland in „28 Years Later“ geschaffen haben – und stellt sie auf den Kopf. In der Fortsetzung dieser epischen Geschichte findet sich Dr. Kelson in einer schockierenden neuen Beziehung wieder – mit Konsequenzen, die die Welt, wie sie sie kennen, verändern könnten –, und Spikes (Alfie Williams) Begegnung mit Jimmy Crystal wird zu einem Albtraum, dem er nicht entkommen kann. In der Welt von The Bone Temple sind die Infizierten nicht mehr die größte Bedrohung für das Überleben – die Unmenschlichkeit der Überlebenden kann seltsamer und erschreckender sein.\",\"releaseDate\":\"2026-01-14\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qCyxbvtCm3V4KPEEFzTFK5HIFRT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hHDNOlATHhre4eZ7aYz5cdyJLik.jpg\"},\"genres\":[\"Horror\",\"Thriller\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1419406\"},\"name\":\"Shadow Chase - Im Netz der Diebe\",\"nameTranslations\":{},\"originalName\":\"捕风追影\",\"description\":\"Wong Tak-chung ist ein pensionierter Überwachungsexperte der Polizei von Macau. Als eine Gangsterbande die Hafenstadt terrorisiert, sind seine ehemaligen Chefs allerdings am verzweifeln, weil seine Nachfolger den Verbrechern einfach nichts nachweisen können. Deshalb wird Wong aus dem Ruhestand zurück in den Dienst beordert. Gemeinsam mit einem Team junger Ermittler*innen, die mit modernster Technologie arbeiten, nimmt der Veteran sich des Falles an, verlässt sich dabei aber lieber weiterhin auf traditionelle Methoden und seine Old-School-Ausrüstung. Dass die Kollaboration zwischen Alt und Jung, abgebrüht und nassforsch nicht gerade reibungslos abläuft, ist glücklicherweise nur ein kleines Hindernis. Denn schnell stellen sich erste Ergebnisse ein. Als Fu Long-sheng, der Boss der Verbrecher, und sein psychopathischer Sohn Hu Feng bemerken, dass Wong und sein Team ihnen auf der Spur sind, gehen sie zum Frontalangriff auf die Cops über, die nun kompromisslos zusammenhalten müssen.\",\"releaseDate\":\"2025-08-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5u0SE4xPEfJdmgIpzQBzEIL2lsA.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/tn95fumbkVAgXjOuw9CQOg0aYQz.jpg\"},\"genres\":[\"Action\",\"Krimi\",\"Drama\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1236153\"},\"name\":\"Mercy\",\"nameTranslations\":{},\"originalName\":\"Mercy\",\"description\":\"LAPD-Detective Raymond steht, wie immer mehr in dieser dystopischen Zukunft, wegen des Mordes an seiner Frau vor Gericht. Die hochmoderne KI-Richterin Maddox, deren Einführung er einst selbst unterstützte, leitet schließlich das Verfahren gegen ihn. Binnen lediglich 90 Minuten muss der Gesetzeshüter nun seine eigene Unschuld hieb- und stichfest beweisen, bevor die künstliche Rechtsprechung über sein weiteres Leben – oder dessen Ende – entscheidet.\",\"releaseDate\":\"2026-01-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/lLyipreraQYBCpzABtqBXEeYlqJ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/7HKpc11uQfxnw0Y8tRUYn1fsKqE.jpg\"},\"genres\":[\"Science Fiction\",\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1262547\"},\"name\":\"सूबेदार\",\"nameTranslations\":{},\"originalName\":\"सूबेदार\",\"releaseDate\":\"2026-03-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/gKn63ZWEVK66OaC1svlI7g6r9ah.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/eZJ3z1aAcHzoYmPSxuJjaYRMgi3.jpg\"},\"genres\":[\"Action\",\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1434973\"},\"name\":\"Die Waffenruhe\",\"nameTranslations\":{},\"originalName\":\"La tregua\",\"description\":\"In einem sowjetischen Gulag während des Zweiten Weltkriegs müssen zwei Gruppen spanischer Soldaten (Frankisten auf der einen, Republikaner auf der anderen Seite) lernen, miteinander auszukommen, wenn sie die harten Bedingungen ihrer Gefangenschaft überleben wollen.\",\"releaseDate\":\"2025-10-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ifjcuqmDCCe1ISeXjQ5WGvr2bqh.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/mHT50O1oAGwKR4hQ3jPLWaqYYJM.jpg\"},\"genres\":[\"Drama\",\"Historie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1381027\"},\"name\":\"Good Boy - Wir wollen nur dein Bestes\",\"nameTranslations\":{},\"originalName\":\"The Good Boy\",\"description\":\"Der 19-jährige Tommy (Anson Boon) genießt sein Leben als Krimineller, treibt seine Freunde immer wieder zu grausamen Gewalttaten an und prahlt damit auf Social Media – bis er eines Nachts von einem Fremden entführt wird. Als Tommy erwacht, findet er sich angekettet im Keller eines abgelegenen Vorstadthauses wieder, in dem sein Entführer Chris (Stephen Graham) mit seiner Frau Kathryn (Andrea Riseborough) und ihrem jungen Sohn Jonathan lebt. Die Familie setzt alles daran, Tommys unkontrolliertes Verhalten zu „reformieren“, und unterzieht ihn zahlreichen psychologischen Spielchen, um aus ihm einen „braven Jungen“ zu machen. Während Tommy sich mit allen Mitteln dagegen wehrt, wird er immer tiefer in die dysfunktionale Familiendynamik von Chris, Kathryn und Jonathan hineingezogen, aber auch mit seinen eigenen Sehnsüchten konfrontiert. Und schleichend merkt Tommy, dass seine Gefühle zwischen Hass und Sympathie, zwischen Fluchtreflex und dem Bedürfnis nach Nähe verschwimmen.\",\"releaseDate\":\"2026-03-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ziliP7npRNuRnBfnqnzapUexULY.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ksqaGSybKVyzkRmLFBgefMSa45a.jpg\"},\"genres\":[\"Thriller\",\"Drama\",\"Mystery\",\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1316092\"},\"name\":\"“Wuthering Heights” – Sturmhöhe\",\"nameTranslations\":{},\"originalName\":\"\\\"Wuthering Heights\\\"\",\"description\":\"Der Film, basierend auf dem gleichnamigen Roman von Emily Brontë aus dem Jahr 1847, erzählt die tragische Liebesgeschichte zwischen Cathy, einer wohlhabenden jungen Frau des 19. Jahrhunderts, und Heathcliff, einem gesellschaftlichen Außenseiter. Nachdem Cathy sich aus gesellschaftlichen Gründen für einen anderen Mann entscheidet, kehrt Heathcliff nach Jahren nach Wuthering Heights zurück, um sich seiner Vergangenheit zu stellen und um ihre Liebe zu kämpfen.\",\"releaseDate\":\"2026-02-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/zuXjNG3o6as2au643nyXcdiKrfB.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/vSQSYd2zZTqc0zmHImwWEGGluMI.jpg\"},\"genres\":[\"Liebesfilm\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1242898\"},\"name\":\"Predator: Badlands\",\"nameTranslations\":{},\"originalName\":\"Predator: Badlands\",\"description\":\"Ein noch junger Predator namens Dek wird von seinem eigenen Clan verstoßen. Die anderen sehen in ihm keinen starken, furchtlosen Krieger heranwachsen. Damit ist er für die Gemeinschaft wertlos, da niemand glaubt, dass Dek eine glorreiche Zukunft bei der Jagd bevorsteht. Fortan muss er also alleine auf einem abgelegenen Planeten klarkommen. Doch dort bleibt er nicht lange alleine. Dek stößt auf Thia mit der er eine unverhoffte Verbündete findet. Von nun an gehen die beiden also gemeinsam auf die Jagd und treffen einen weiteren Weggefährten. Zu dritt müssen sie sich schließlich auch einer scheinbar übermächtigen Bedrohung stellen. Im Laufe ihres gemeinsamen Abenteuers werden sie beste Freunde und lernen, einander auch in ausweglosen Situationen zu vertrauen. Dek wächst dabei als Jäger über sich hinaus und lernt, richtig gut zu jagen.\",\"releaseDate\":\"2025-11-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/lxw9cD6g5Ccfml1PthmO6YT2aMp.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gaKFXcB5J1gz0QqYj8bWIfrPc04.jpg\"},\"genres\":[\"Action\",\"Science Fiction\",\"Abenteuer\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1297842\"},\"name\":\"G.O.A.T. - Bock auf große Sprünge\",\"nameTranslations\":{},\"originalName\":\"GOAT\",\"description\":\"Im Mittelpunkt der Geschichte steht Will, ein kleiner Ziegenbock mit großen Träumen. Er bekommt die einmalige Chance, einem Profiteam beizutreten und Roarball zu spielen – ein kontaktintensiver Hochleistungssport, bei dem die schnellsten und furchterregendsten Tiere der Welt dominieren. Wills neue Teammitglieder sind daher nicht gerade begeistert, nun eine schmächtige Ziege in ihrer Mannschaft zu haben, doch Will ist wild entschlossen, den Sport zu revolutionieren und ein für alle Mal zu beweisen, dass auch Kleine ganz groß rauskommen können.\",\"releaseDate\":\"2026-02-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/RV3EmWdwIoFz6knlYzpVk9WeYE.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1qwhYqg7YEZajh3Q4biqbuQoDq8.jpg\"},\"genres\":[\"Animation\",\"Komödie\",\"Familie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1290432\"},\"name\":\"Paris Murder Mystery\",\"nameTranslations\":{},\"originalName\":\"Vie privée\",\"description\":\"Die Amerikanerin Lilian Steiner (Jodie Foster) lebt seit Jahren in Paris und hat sich dort einen Namen als brillante Therapeutin gemacht. Als ihre Patientin Paula (Virginie Efira) unter mysteriösen Umständen ums Leben kommt, ist sie fassungslos. War es wirklich Selbstmord, wie die Polizei rasch annimmt? Oder hat jemand sehr geschickt nachgeholfen? Zusammen mit ihrem Ex-Mann Gabriel (Daniel Auteuil), der noch immer nicht von ihr lassen kann, begibt sich Lilian auf eine turbulente Spurensuche, um dem Geheimnis von Paula auf die Spur zu kommen.  Regisseurin Rebecca Zlotowski gelingt ein temporeicher Cocktail voller überraschender Wendungen und pointierter Dialoge, der mit viel Fantasie und Leichtigkeit zwischen Humor, Spannung und Romantik navigiert.\",\"releaseDate\":\"2025-09-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/wgPWUA14aQruRL8eWjV9WgL7bha.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/3fZ5HvkrjaS34sZERshWm9koXdF.jpg\"},\"genres\":[\"Krimi\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1422562\"},\"name\":\"The Moment\",\"nameTranslations\":{},\"originalName\":\"The Moment\",\"description\":\"THE MOMENT ist eine Mockumentary über die Höhen und Tiefen des Erfolgs. Nach dem von ihr lancierten Phänomen BRAT SUMMER kämpft Charli xcx gegen die immensen Erwartungen – diejenigen von außen, aber auch ihre eigenen … Regisseur Aidan Zamiri hat bereits mit Künstlern wie FKA Twigs und Billie Eilish gearbeitet und präsentiert nun die Musikerin Charli xcx in ihrer bisher persönlichsten Rolle.\",\"releaseDate\":\"2026-01-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/2p8VNm35LAlB50wpHjONY5xFRBD.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lQUsfSUcai6ZOHQHgobSlF0IDUV.jpg\"},\"genres\":[\"Musik\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"425274\"},\"name\":\"Die Unfassbaren 3 - Now you see me\",\"nameTranslations\":{},\"originalName\":\"Now You See Me: Now You Don't\",\"description\":\"Die ursprünglichen Vier Reiter verbünden sich mit einer neuen Generation von Illusionisten, um es mit der mächtigen Diamantenerbin Veronika Vanderberg aufzunehmen, die ein kriminelles Imperium leitet, das auf Geldwäsche und Menschenhandel basiert. Die alten und neuen Magier müssen ihre Differenzen überwinden, um gemeinsam ihren bisher ambitioniertesten Coup zu landen.\",\"releaseDate\":\"2025-11-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/9Udi4U0u5No1OQJ0DYubsSzFipb.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/dHSz0tSFuO2CsXJ1CApSauP9Ncl.jpg\"},\"genres\":[\"Thriller\",\"Krimi\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"83533\"},\"name\":\"Avatar: Fire and Ash\",\"nameTranslations\":{},\"originalName\":\"Avatar: Fire and Ash\",\"description\":\"Nach dem verheerenden Krieg gegen die RDA und dem Verlust ihres ältesten Sohnes sehen sich Jake Sully und Neytiri mit einer neuen Bedrohung auf Pandora konfrontiert: dem Aschvolk, einem gewalttätigen und machthungrigen Na'vi-Stamm unter der Führung des skrupellosen Varang. Jakes Familie muss in einem Konflikt, der sie an ihre emotionalen und physischen Grenzen bringt, um ihr Überleben und die Zukunft von Pandora kämpfen. *Der Film enthält Sequenzen, die sich auf photosensitive Menschen oder Menschen mit photosensitiver Epilepsie auswirken könnten.\",\"releaseDate\":\"2025-12-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/lE9KpVwgeWHMwgwkNaeH5nEFh20.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/sdZSjtGUTSN8B3al5o0f2WoQfQQ.jpg\"},\"genres\":[\"Science Fiction\",\"Abenteuer\",\"Fantasy\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1340110\"},\"name\":\"Redux Redux\",\"nameTranslations\":{},\"originalName\":\"Redux Redux\",\"description\":\"Rache kennt keine Grenzen. Das weiß auch Irene Kelly (Michaela McManus), deren Wut für ihre eigene Welt zu groß geworden ist: Mithilfe einer Zeitmaschine durchquert sie ein Paralleluniversum nach dem anderen, um immer wieder und auf jede erdenkliche Art und Weise den Mörder ihrer Tochter zu töten. Getrieben von einem unstillbaren Durst, findet Irene keinen Ausweg aus dem Teufelskreis ihrer Vergeltung – bis eines Tages wegen einer Abweichung plötzlich alles aus den Fugen gerät …\",\"releaseDate\":\"2026-02-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/6WzyyjHXGFmBuRuVVWkQDn6xqju.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nBTUocp7lHmyrTmD8mTBOYem4ok.jpg\"},\"genres\":[\"Science Fiction\",\"Mystery\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"680493\"},\"name\":\"Return to Silent Hill\",\"nameTranslations\":{},\"originalName\":\"Return to Silent Hill\",\"description\":\"Als ein geheimnisvoller Brief James auf der Suche nach seiner großen Liebe zurück nach Silent Hill ruft, findet er eine einst bekannte Stadt vor, die von einem unbekannten Übel verwandelt wurde. Während James tiefer in die Dunkelheit abtaucht, begegnet er furchterregenden Gestalten, sowohl bekannten als auch neuen, und beginnt, an seinem eigenen Verstand zu zweifeln, während er versucht, die Realität zu verstehen und lange genug durchzuhalten, um seine verlorene Liebe zu retten.\",\"releaseDate\":\"2026-01-21\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cytGWiEiqGD8vxaSD7noaLrZwIR.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nTbO6UF944b0VZrgypMK5rFYRSW.jpg\"},\"genres\":[\"Mystery\",\"Drama\",\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1234731\"},\"name\":\"Anaconda\",\"nameTranslations\":{},\"originalName\":\"Anaconda\",\"description\":\"DIES IST KEIN REBOOT, sondern ist eine völlig neue Komödie, inspiriert vom „Klassiker“ Anaconda, in der Doug und Griff die Hauptrollen spielen. Die beiden sind seit ihrer Kindheit beste Freunde und träumen schon immer davon, ihren absoluten Lieblingsfilm neu zu verfilmen. Ihre Midlife-Crisis treibt sie dazu, ihren Traum endlich in die Tat umzusetzen. Sie reisen tief in den Amazonas, um mit den Dreharbeiten zu beginnen. Doch aus Spaß wird schnell Ernst, als plötzlich eine echte Riesenanaconda auftaucht – und das chaotisch-komische Filmset in eine tödliche Falle verwandelt.\",\"releaseDate\":\"2025-12-24\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/gEd2zQkOuPTMWmyJ3374cZ5iPLn.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/swxhEJsAWms6X1fDZ4HdbvYBSf9.jpg\"},\"genres\":[\"Abenteuer\",\"Komödie\",\"Horror\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1233413\"},\"name\":\"Blood & Sinners\",\"nameTranslations\":{},\"originalName\":\"Sinners\",\"description\":\"Beim Versuch, ihr von Problemen geplagtes Leben hinter sich zu lassen, kehren Zwillingsbrüder in ihre Heimatstadt zurück, um dort einen Neuanfang zu wagen. Doch schon bald müssen sie feststellen, dass bei ihrer Rückkehr ein noch größeres Übel auf sie wartet.\",\"releaseDate\":\"2025-04-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/445HsfnktkmM5y4cr62vYGzfo6h.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nAxGnGHOsfzufThz20zgmRwKur3.jpg\"},\"genres\":[\"Horror\",\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1610418\"},\"name\":\"The House on Haunted Grounds\",\"nameTranslations\":{},\"originalName\":\"The House on Haunted Grounds\",\"releaseDate\":\"2026-01-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/750RNSHr25GQcCr2Ws8iSGrHJA9.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/r9aYDDP7tHpwCvQbOxcfhZFBT63.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1451398\"},\"name\":\"カラダ探し THE LAST NIGHT\",\"nameTranslations\":{},\"originalName\":\"カラダ探し THE LAST NIGHT\",\"releaseDate\":\"2025-09-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/lCDy4STGnqVS8QE6cAxD5phdxfI.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gmu4liRCTk5nKSiGL6XHFbsJvD8.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1325866\"},\"name\":\"用武之地\",\"nameTranslations\":{},\"originalName\":\"用武之地\",\"releaseDate\":\"2025-12-24\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/v8JNXoPcQRoEvUNYZYSOcYZvKEf.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/9HZ216SwRwYq8sndNxAp9Wuc4Ic.jpg\"},\"genres\":[\"Drama\",\"Kriegsfilm\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1273221\"},\"name\":\"Scary Movie 6\",\"nameTranslations\":{},\"originalName\":\"Scary Movie\",\"releaseDate\":\"2026-06-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/opJeybZ5EL4zObkgFPFkke0KnIq.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lj6AaDqDUbzm2XJltFNHeAm2uXN.jpg\"},\"genres\":[\"Komödie\",\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"798645\"},\"name\":\"The Running Man\",\"nameTranslations\":{},\"originalName\":\"The Running Man\",\"description\":\"In einer nahen Zukunft, ist The Running Man die meistgesehene Show im Fernsehen. Ein tödlicher Wettbewerb, in dem die Mitspieler, die man Runner nennt, 30 Tage lang überleben müssen, während sie von Profikillern gejagt werden. Dabei wird jede ihrer Bewegungen einem blutrünstigen Publikum live übertragen. Jeder Tag, den sie durchhalten, wird mit mehr Geld belohnt. Ben Richards stammt aus der Arbeiterklasse und versucht verzweifelt, seine kranke Tochter zu retten. Daher lässt er sich von Dan Killian, dem charmanten, aber rücksichtslosen Produzenten der Show, als letzte Hoffnung überreden, bei dem Spiel mitzumachen. Bens Trotz, Instinkte und Mut machen ihn bald unerwartet zum Fan-Favoriten – und zu einer Bedrohung für das gesamte System. Während die Einschaltquoten durch die Decke gehen, steigt auch die Gefahr und Ben muss nicht nur die Jäger überlisten, sondern auch eine ganze Nation, die süchtig danach ist, ihn scheitern zu sehen.\",\"releaseDate\":\"2025-11-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/s9vQpHl2ZHOHbsgoznaNr2eaIjZ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/aHj7d7wSLqrg5cjAcgHhiGr97Ih.jpg\"},\"genres\":[\"Action\",\"Thriller\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1220564\"},\"name\":\"The Secret Agent\",\"nameTranslations\":{},\"originalName\":\"O Agente Secreto\",\"description\":\"Brasilien, 1977. Marcelo, ein Technikexperte in seinen frühen 40ern, ist auf der Flucht. Er kommt in der Karnevalswoche in Recife an, in der Hoffnung, seinen Sohn wiederzusehen, muss aber bald feststellen, dass die Stadt bei weitem nicht die gewaltfreie Zuflucht ist, die er sucht.\",\"releaseDate\":\"2025-07-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/j7GRvRvK9ZM2pnFa1kAK2t3WxuQ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/eeGRpU64sIrRApjWXvTpK5Lep2K.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"701387\"},\"name\":\"Bugonia\",\"nameTranslations\":{},\"originalName\":\"Bugonia\",\"description\":\"Michelle Fuller, Chefin des großen Pharmaunternehmens Auxolith, wird von Teddy Gatz und dessen Cousin Don entführt. Teddy ist überzeugt, dass Michelle zu einer gefährlichen außerirdischen Gruppe gehört – den sogenannten „Andromedanern“. Diese Wesen, so glaubt er, wollen die Bienen auf der Erde vernichten, Gemeinschaften zerstören und die Menschen dazu bringen, sich ihnen willenlos zu unterwerfen.\",\"releaseDate\":\"2025-10-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/mMmj8FFMJmGanUvvxVohTNXVXaY.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/tN3pTxkQoP96wtaEahYuRVdUWb2.jpg\"},\"genres\":[\"Science Fiction\",\"Thriller\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1418302\"},\"name\":\"อนงค์ 2..สามสี่ชาติ\",\"nameTranslations\":{},\"originalName\":\"อนงค์ 2..สามสี่ชาติ\",\"releaseDate\":\"2025-10-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/jCXbS2yCqHKPpaSAdTClGIW8FtO.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/bK7hnpxPmdLA4dvTESjPLhDCNqP.jpg\"},\"genres\":[\"Liebesfilm\",\"Komödie\",\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"967941\"},\"name\":\"Wicked: Teil 2\",\"nameTranslations\":{},\"originalName\":\"Wicked: For Good\",\"description\":\"Da der Zauberer und ganz Oz sie für böse halten, gerät Elphabas rechtschaffener Kreuzzug in Konflikt mit Glindas Kampf um die Macht. Als ein mysteriöser Wirbelsturm einen unwissenden jungen Außenseiter herbeiruft, werden die ehemaligen Freundinnen bald entdecken, wie sehr ihre Handlungen einander - und ganz Oz - für immer verändert haben. Der zweite Teil einer zweiteiligen Spielfilmadaption des Broadway-Musical-Phänomens.\",\"releaseDate\":\"2025-11-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/yJ5rNq70Xe0GpagfS5ng5lU1LHT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/cGbPBHKSFO7hSIjxkb3KOaGdOep.jpg\"},\"genres\":[\"Fantasy\",\"Abenteuer\",\"Liebesfilm\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"911430\"},\"name\":\"F1 - Der Film\",\"nameTranslations\":{},\"originalName\":\"F1\",\"description\":\"In den 1990er Jahren galt Sonny Hayes noch als die nächste große Nummer im Rennsport und der höchsten Klasse, der Formel 1. Doch auch als Rennfahrer legt man seinen Körper in die Waagschale und muss letztlich mit dem Schlimmsten rechnen. Für Sonny Hayes bedeutet das das Ende seiner Karriere als Formel-1-Profi nach einem folgenschweren Unfall auf der Rennstrecke. Fortan dümpelt er in niedrigeren Rennklassen herum und hält sich drei Jahrzehnte nach seinem schicksalsträchtigen Unfall noch als Gelegenheitsrennfahrer über Wasser und versucht dabei, von seinem alten Formel-1-Ruf zu zehren. Sein damaliger Teamkollege Ruben Cervantes weiß das. Der ist mittlerweile Chef des Teams APXGP, das scheinbar hoffnungs- und punktlos am untersten Ende der Formel-1-Tabelle verweilt. Weil Cervantes damit also fast nichts mehr zu verlieren hat, will er Hayes zurück in die Königsklasse holen und ihn zusammen mit dem Rookie Noah genannten Joshua Pearce einen Rettungsanker für den Rennstall formen lassen.\",\"releaseDate\":\"2025-06-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8IUkPSxOh0KRbbVNYHSyBKQI5J0.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1KFv63mmcBGVbFl3jxxozoSFlhA.jpg\"},\"genres\":[\"Action\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1302848\"},\"name\":\"T’as pas changé\",\"nameTranslations\":{},\"originalName\":\"T’as pas changé\",\"releaseDate\":\"2025-11-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1FFRm0hJzB7bOyGVkBH1DGXhw1Q.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5Bv769BOiMIpLiMwGfX9VD8qqmT.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1124566\"},\"name\":\"Sentimental Value\",\"nameTranslations\":{},\"originalName\":\"Affeksjonsverdi\",\"description\":\"Nora und Agnes verbindet eine komplexe Beziehung zu ihrem Vater, der seine Arbeit stets über die Familie stellte. Nun steht Gustav nach Jahren der Funkstille plötzlich wieder vor der Tür – mit einem charmanten Grinsen und dem emotionalen Gepäck eines halben Lebens. Augenblicklich geraten alte Familiendynamiken ins Rollen. Und nach und nach wird deutlich, dass sich Vater und Töchter ähnlicher sind, als sie glaubten. Vielleicht ist es doch nicht zu spät für einen Neuanfang?\",\"releaseDate\":\"2025-08-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/zOeMU4kot9ek7N23SL5v885vVCN.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/mXlDBIHh9hBkDCMNazGV2fEPr5J.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1214931\"},\"name\":\"Nürnberg\",\"nameTranslations\":{},\"originalName\":\"Nuremberg\",\"description\":\"Hermann Göring wird von den Alliierten verhaftet und soll als ranghöchster noch verbliebener Nazi für die unfassbaren Taten des NS-Regimes zur Rechenschaft gezogen werden. Der Psychiater Dr. Kelley wird beauftragt, alle Angeklagten auf ihre Prozessfähigkeit hin zu untersuchen. Schnell ist er von Görings Scharfsinn und Charisma eingenommen und obwohl er dessen Machtspiele durchschaut, kann sich Dr. Kelley der manipulativen Stärke und Faszination des Bösen nur schwer entziehen. Um Görings Vertrauen zu gewinnen, überschreitet Dr. Kelley moralische Grenzen und gefährdet sogar den Nürnberger Prozess.  Das bis in die Nebenrollen hochkarätig besetzte Justizdrama erzählt vom folgenreichsten Prozess des 20. Jahrhunderts, der zudem die Geburtsstunde des Völkerrechts markiert.\",\"releaseDate\":\"2025-11-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/iwOMJasPIhumNRNLglDnuHmax2J.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/bf5TG9RODkPXmtJSgf8Iymof1wl.jpg\"},\"genres\":[\"Historie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1128377\"},\"name\":\"In Cold Light\",\"nameTranslations\":{},\"originalName\":\"In Cold Light\",\"description\":\"Kurz nach ihrer Entlassung aus dem Gefängnis versucht Ava, die Kontrolle über ihr früheres Drogenimperium zurückzugewinnen. Ihr Vorhaben scheitert jedoch abrupt, als sie eines Mordes bezichtigt wird und sowohl die Polizei als auch eine skrupellose Unterweltgröße hinter ihr her sind.\",\"releaseDate\":\"2026-01-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ap7IiuBFxnvMZS1BZsPCsNEsAkA.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/AmTImtiEa13vujOEgTbqgzGcfyK.jpg\"},\"genres\":[\"Thriller\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1084244\"},\"name\":\"Toy Story 5\",\"nameTranslations\":{},\"originalName\":\"Toy Story 5\",\"description\":\"Die Aufgaben von Buzz, Woody, Jessie und Co. werden immer schwieriger, wenn sie es mit einer ganz neuen Bedrohung der Spielzeit zu tun bekommen: der Technik.\",\"releaseDate\":\"2026-06-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/gaiMtK2ll6BLdK1qKFuZGDwwEuD.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/coyHrYHD2xHhDoYD6o4uwoJ2o7b.jpg\"},\"genres\":[\"Animation\",\"Familie\",\"Komödie\",\"Abenteuer\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1328803\"},\"name\":\"Prisoner of War\",\"nameTranslations\":{},\"originalName\":\"Prisoner of War\",\"description\":\"Der britische RAF-Geschwaderkommandeur James Wright wird im Zweiten Weltkrieg von den Japanern gefangen genommen und zum brutalen Nahkampf gezwungen. Die japanischen Soldaten bekommen mehr, als sie erwartet hatten, denn Wrights jahrelanges Kampfkunsttraining in Hongkong erweist ihn als furchterregenden Gegner.\",\"releaseDate\":\"2025-09-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/94RmnViWjlmFhsZOPHPZgUqsqNg.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/bYsx7EUapg2uRE8W9rWOiDTGJum.jpg\"},\"genres\":[\"Action\",\"Kriegsfilm\",\"Thriller\",\"Historie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1054867\"},\"name\":\"One Battle After Another\",\"nameTranslations\":{},\"originalName\":\"One Battle After Another\",\"description\":\"Vor 16 Jahren hat die Widerstandsgruppe namens „French 75“ auf einen Schlag 200 Häftlinge aus den Fängen des skrupellosen United States Immigration and Customs Enforcement – kurz: ICE – befreit. Danach verschwanden die Widerständler, darunter auch der von allen nur Ghetto Pat genannte Bob Ferguson, von der Bildfläche. Heute ist Bob getrieben von Paranoia, denn er fürchtet, dass es der damalige ICE-Colonel Steven J. Lockjaw immer noch auf ihn abgesehen hat.\",\"releaseDate\":\"2025-09-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5k2WV1i6jcnbPmRhoXSEQWQGT9u.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gre7gyocZSuwd7M51CGlqsJqBmB.jpg\"},\"genres\":[\"Thriller\",\"Krimi\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1330421\"},\"name\":\"Bone Lake\",\"nameTranslations\":{},\"originalName\":\"Bone Lake\",\"description\":\"Ebenso böser wie verführerischer Horrorthriller für Fans von Barbarian.Diego und seine Freundin Sage haben sich das romantische Wochenende am Bone Lake anders vorgestellt, denn ihr Ferientraumhaus wurde doppelt gebucht: Will und Cin sind ein (s)extrovertiertes Paar, das für eine Menge erotischer Spannung sorgt. Doch das Spiel aus Sex, Lügen und Manipulation eskaliert bald auf blutigste Weise…\",\"releaseDate\":\"2025-10-02\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/nVsZOjSRaeamW4rnwFtkpXz5UOT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/168dp7vy3kwOehcMpFaLOfB52NV.jpg\"},\"genres\":[\"Horror\",\"Thriller\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1367642\"},\"name\":\"Für immer ein Teil von dir - Reminders Of Him\",\"nameTranslations\":{},\"originalName\":\"Reminders of Him\",\"description\":\"Kenna Rowan kehrt in ihre Heimatstadt zurück, nachdem sie fünf Jahre wegen eines tragischen Fehlers im Gefängnis gesessen hat. Sie hofft, wieder mit ihrer kleinen Tochter zusammenzukommen, obwohl alle darauf bedacht sind, sie voneinander fernzuhalten. Nur eine Person in der Gegend hat sie nicht gemieden, und das ist der örtliche Barbesitzer Ledger Ward, der ein wichtiger Teil von Kennas Leben wird.\",\"releaseDate\":\"2026-03-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/aNQOmANRMkMwRWbA3lcKIxqJ0WI.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/dJpG9ydoYUHvgCuzTIj6ARkD4w2.jpg\"},\"genres\":[\"Drama\",\"Liebesfilm\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1062722\"},\"name\":\"Frankenstein\",\"nameTranslations\":{},\"originalName\":\"Frankenstein\",\"description\":\"Dr. Victor Frankenstein, ein brillanter, aber egoistischer Wissenschaftler, erweckt in einem monströsen Experiment eine Kreatur zum Leben, die letztendlich zum Untergang sowohl des Schöpfers als auch seiner tragischen Schöpfung führt.\",\"releaseDate\":\"2025-10-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8p3WYNFIP6v4WfIL1JM3cwQzeV2.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hpXBJxLD2SEf8l2CspmSeiHrBKX.jpg\"},\"genres\":[\"Drama\",\"Fantasy\",\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1196067\"},\"name\":\"Worldbreaker\",\"nameTranslations\":{},\"originalName\":\"Worldbreaker\",\"description\":\"Nachdem die Breakers aufgetaucht sind – Wesen, die ihre Opfer infizieren und verwandeln – bricht die bestehende Ordnung zusammen. Zunächst fallen die Männer, wodurch Frauen gezwungen sind, den bewaffneten Widerstand zu übernehmen. Willas Mutter gehört zu den gefürchtetsten Kämpferinnen dieses Krieges, während ihr vom Erlebten gezeichneter Vater sich mit der Tochter auf eine abgelegene Insel zurückgezogen hat, um sie dort auf das Überleben vorzubereiten. Abgeschieden von der Außenwelt scheint ihr Alltag zunächst sicher, bis ein fremdes Mädchen an der Küste angespült wird. Aus dem Wunsch nach Nähe nimmt Willa sie heimlich bei sich auf. Als verborgene Wahrheiten ans Licht kommen, gerät der fragile Schutzraum in Gefahr.\",\"releaseDate\":\"2025-10-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7K8w6mdrJp0oaSoKWGyjSZ4Zv2z.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gMItMzDOyrfQGZsMWRM9tdxq5cV.jpg\"},\"genres\":[\"Science Fiction\",\"Action\",\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1140498\"},\"name\":\"Is This Thing On?\",\"nameTranslations\":{},\"originalName\":\"Is This Thing On?\",\"description\":\"Während ihre Ehe still und leise in die Brüche geht, sucht Alex in der New Yorker Comedy-Szene nach einem neuen Lebensinhalt, während Tess sich mit den Opfern auseinandersetzt, die sie für ihre Familie gebracht hat. Das zwingt sie dazu, sich mit der gemeinsamen Erziehung, ihrer Identität und der Frage auseinanderzusetzen, ob die Liebe eine neue Form annehmen kann.\",\"releaseDate\":\"2025-12-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/9jf0S7oUPyaKcKRgq3hRJ1jTNd0.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/bcw0QrKe9cM7MbjypxMPFdT6hrM.jpg\"},\"genres\":[\"Komödie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1314481\"},\"name\":\"Der Teufel trägt Prada 2\",\"nameTranslations\":{},\"originalName\":\"The Devil Wears Prada 2\",\"description\":\"Miranda Priestly navigiert ihre Karriere inmitten des Niedergangs des traditionellen Zeitschriftenwesens. Sie tritt gegen Emily Charlton an, ihre ehemalige Assistentin, jetzt eine einflussreiche Führungskraft für eine Luxusgruppe, mit Werbegeldern, die Priestly dringend benötigt.\",\"releaseDate\":\"2026-04-29\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/xTI42pmsP5EDnvsNJPEDubwWBQO.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/2cr7imTLVSSrzgL3bFKAMCMdgKw.jpg\"},\"genres\":[\"Drama\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1331358\"},\"name\":\"Les Braises\",\"nameTranslations\":{},\"originalName\":\"Les Braises\",\"releaseDate\":\"2025-11-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/dioOL6pQ0xsOAga13uEuQm1Fl1u.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/rjeUwEE8sCX2xycgM3Z4PLwsMHf.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1315303\"},\"name\":\"Primate\",\"nameTranslations\":{},\"originalName\":\"Primate\",\"description\":\"Das erste Jahr am College ist geschafft! Lucy fährt deshalb zurück in die Heimat, um dort ihre Familie zu besuchen. Doch Entspannung und Harmonie sind Worte, die schnell kürzer treten müssen. Denn zu Lucys Familie gehört auch der Schimpanse Ben. Und Ben hat sich dummerweise mit Tollwut infiziert. Aus dem eigentlich harmlosen Menschenaffen wird so schnell ein blutrünstiges Biest, das es auf Lucy, ihre Familie und ihre beste Freundin Hannah abgesehen hat. Alle springen in den Pool, weil sie glauben, dass Ben nicht schwimmen kann und sie dort sicher sind. Aber weit gefehlt...\",\"releaseDate\":\"2026-01-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/UwNEEuTe6WAtBuyi4u6qPBDZqB.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/9uakM2woks0JV8HKIc4oatIVS88.jpg\"},\"genres\":[\"Horror\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"804370\"},\"name\":\"Arco\",\"nameTranslations\":{},\"originalName\":\"Arco\",\"description\":\"Als der Junge Arco aus einer fernen Zukunft zufällig in die Welt der zehnjährigen Iris ins Jahr 2075 stürzt, müssen die beiden – unterstützt von ihrem Haushaltsroboter – über Zeit und Welten hinweg zusammenarbeiten, um Arco wieder nach Hause zu bringen.\",\"releaseDate\":\"2025-10-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/rWvbMnqLTpyTHmNii4TrnmgzpcS.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/reQELo8rDiLIOoYIA7M6q7KGRW0.jpg\"},\"genres\":[\"Animation\",\"Abenteuer\",\"Fantasy\",\"Familie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1242419\"},\"name\":\"Der Hochstapler - Roofman\",\"nameTranslations\":{},\"originalName\":\"Roofman\",\"description\":\"Jeffrey Manchester, ein Häftling auf der Flucht, versteckt sich an einem Ort, an dem niemand nach ihm suchen würde - einem Spielzeugladen. Als dieses Paradies des Spaßes zu einem Gefängnis der Einsamkeit wird, verfällt er der einzigen Sache, die ihn daran hindern kann, zu entkommen ... der Liebe.\",\"releaseDate\":\"2025-10-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/dEluo7G2r1uqb0leREnzhfycqdQ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/2YOnE2qmoyyOUqQsFit12gDSauk.jpg\"},\"genres\":[\"Krimi\",\"Komödie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1266127\"},\"name\":\"Ready or Not 2: Here I Come\",\"nameTranslations\":{},\"originalName\":\"Ready or Not 2: Here I Come\",\"description\":\"Nur wenige Augenblicke nachdem sie einen Großangriff der Familie Le Domas überlebt hat, erkennt Grace, dass sie die nächste Stufe des alptraumhaften Spiels erreicht hat – und diesmal ist ihre entfremdete Schwester Faith an ihrer Seite. Grace hat nur eine Chance zu überleben, ihre Schwester am Leben zu erhalten und den Hohen Sitz des Rates zu erobern, der die Welt beherrscht. Vier rivalisierende Familien jagen sie, um den Thron zu erobern, und wer gewinnt, herrscht über alles.\",\"releaseDate\":\"2026-03-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/13ZcJzSGEqVgDSqsS9U5EkQwPkV.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/sJAzq4IvgohP9nVzijCH6lovX3e.jpg\"},\"genres\":[\"Horror\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"840464\"},\"name\":\"Greenland 2\",\"nameTranslations\":{},\"originalName\":\"Greenland 2: Migration\",\"description\":\"Fünf Jahre nach dem verheerenden Einschlag des Kometen Clarke leben John (Gerard Butler), Allison (Morena Baccarin) und ihr Sohn Nathan (Roman Griffin Davis) noch immer in dem Bunker in Grönland, der ihr Überleben sicherte. Doch Frieden finden sie hier nicht: Luft und Wasser sind verseucht, Strahlungsstürme wüten über die Oberfläche und Fragmente des Kometen schweben noch immer in der Umlaufbahn und drohen auf die Erde zu stürzen. Als ein verheerendes Beben den Bunker zerstört, muss die Familie erneut aufbrechen und sich durch ein verwüstetes Europa bis zum einzig sicher scheinenden Ort auf dem Planeten durchschlagen – dem gigantischen Krater des Clarke-Kometen in Südfrankreich.  Ein absolutes Highlight für alle Action-Fans: Mit atemberaubenden Bildern, packender Spannung und einer emotionalen Familiengeschichte bietet GREENLAND 2 alles, was einen großen Endzeit-Blockbuster ausmacht.\",\"releaseDate\":\"2026-01-07\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4EfFRgXde2iFFDfdFDMAOB9RuYJ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/u9jE0R1nvkmdWu3bt7Op8joPywa.jpg\"},\"genres\":[\"Abenteuer\",\"Thriller\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1171145\"},\"name\":\"Crime 101\",\"nameTranslations\":{},\"originalName\":\"Crime 101\",\"description\":\"Davis ist ein schwer fassbarer Juwelendieb, dessen Überfallserie die Polizei vor ein Rätsel stellt. Als er gerade den Coup seines Lebens ins Visier nimmt, trifft er auf die desillusionierte Versicherungsmanagerin Sharon, die selbst an einem Scheideweg steht. Überzeugt davon, ein Muster entdeckt zu haben, kommt währenddessen der unerbittliche Detective Lt. Lubesnik der ganzen Operation immer näher und erhöht damit das Risiko noch weiter.\",\"releaseDate\":\"2026-02-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/6T7ra8tsoYCQJMTZpkAqbKS17lE.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yWZc7ZglTAecVLKHS0oROuetKce.jpg\"},\"genres\":[\"Krimi\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1198984\"},\"name\":\"We Bury the Dead\",\"nameTranslations\":{},\"originalName\":\"We Bury the Dead\",\"description\":\"Nachdem der verheerende Test einer neuen Massenvernichtungswaffe des US-Militärs vor der Küste Tasmaniens eine halbe Million Menschen das Leben gekostet hat, erwachen einige der Todesopfer wieder zum Leben. Den Behörden zufolge geht von ihnen keine Gefahr aus. Zu den Freiwilligen, die das betroffene Gebiet auf der Suche nach Leichen durchkämmen, gehört auch Ava (Daisy Ridley), deren Ehemann seit dem Vorfall vermisst wird. In der Sperrzone wird das Bergungsteam allerdings schon bald mit der grausamen Realität konfrontiert: Die angeblich harmlosen Untoten werden nicht nur immer mehr, sondern mit jeder Stunde gewalttätiger, unerbittlicher und aggressiver ...\",\"releaseDate\":\"2026-01-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/xZqo0yPARmyF8TACVNyaOACkYWG.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/vbkW4KerpshPZnP84w9qwSfYrhu.jpg\"},\"genres\":[\"Horror\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"467905\"},\"name\":\"How to Make a Killing: Tödliches Erbe\",\"nameTranslations\":{},\"originalName\":\"How to Make a Killing\",\"description\":\"Becket Redfellow hat Witz, Stil, Bildung und Charme. Doch eines besitzt er nach wie vor nicht – das milliardenschwere Vermögen, das ihm laut seiner Mutter von Geburt an zusteht. Seine Mutter Mary, einst Erbin des gewaltigen Redfellow-Imperiums, wurde von ihrer einflussreichen Familie bei Beckets Geburt verstoßen und starb völlig verarmt. Jetzt ist ihr charismatischer, vom Drang nach Höherem getriebener Sohn fest entschlossen, all das zurückzuholen, was er für gestohlen hält.\",\"releaseDate\":\"2026-02-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/kw7x5mSmHhoeeqwXLwXTBsofD1N.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/aRR90kdGuJiEOqzhBZ5UML463CF.jpg\"},\"genres\":[\"Komödie\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1371185\"},\"name\":\"Song Sung Blue\",\"nameTranslations\":{},\"originalName\":\"Song Sung Blue\",\"description\":\"Inspiriert von wahren Begebenheiten: In SONG SUNG BLUE wagen zwei Musiker (Hugh Jackman und Kate Hudson), die noch immer vom grossen Durchbruch träumen, in ihrer Lebensmitte einen mutigen Neuanfang. Sie gründen eine Neil-Diamond-Tribute-Band – und beweisen, dass es nie zu spät ist, die grosse Liebe zu finden und den eigenen Träumen zu folgen.\",\"releaseDate\":\"2025-12-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5sYaY77K1zvWhgK2AuVQkhwdPRo.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/wLauNnJYmvVLN0MiOv0tjdiPs0J.jpg\"},\"genres\":[\"Musik\",\"Liebesfilm\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"991494\"},\"name\":\"SpongeBob Schwammkopf: Piraten Ahoi!\",\"nameTranslations\":{},\"originalName\":\"The SpongeBob Movie: Search for SquarePants\",\"description\":\"In ihrem brandneuen und bisher größten Kinoabenteuer, SPONGEBOB SCHWAMMKOPF: PIRATEN AHOI!, stechen SpongeBob und seine Freunde aus Bikini Bottom in See! SpongeBob, der endlich auch zu den Großen gehören möchte und Mr. Krabs seinen Mut beweisen will, folgt dem Fliegenden Holländer - einem mysteriösen, verwegenen Geisterpiraten. Und so beginnt ein rasantes und witziges Seefahrts-Abenteuer, das ihn in die tiefsten Tiefen der Tiefsee führt, wo noch kein Schwamm zuvor gewesen ist.\",\"releaseDate\":\"2025-12-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/M7KKeJfhV5AVJO8JCd5Hix0vyH.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/kVSUUWiXoNwq2wVCZ4Mcqkniqvr.jpg\"},\"genres\":[\"Animation\",\"Familie\",\"Komödie\",\"Abenteuer\",\"Fantasy\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1100988\"},\"name\":\"28 Years Later\",\"nameTranslations\":{},\"originalName\":\"28 Years Later\",\"description\":\"Es ist fast drei Jahrzehnte her, dass das Rage-Virus aus einem biologischen Waffenlabor entkommen ist, und noch immer gilt eine strikt verordnete Quarantäne. Einige Menschen haben Wege gefunden, inmitten der Infizierten zu existieren. Eine solche Gruppe von Überlebenden lebt auf einer kleinen Insel, die durch einen einzigen, stark verteidigten Damm mit dem Festland verbunden ist. Als einer der Bewohner die Insel verlässt, um in das dunkle Innere des Festlandes vorzudringen, entdeckt er Geheimnisse, Wunder und Schrecken und dass nicht nur die Infizierten, sondern auch die Überlebenden mutiert sind.\",\"releaseDate\":\"2025-06-18\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ygCqIBzLOgm1QmBDhDwKs9XE5PY.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/6WqqEjiycNvDLjbEClM1zCwIbDD.jpg\"},\"genres\":[\"Horror\",\"Thriller\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1292695\"},\"name\":\"They Will Kill You\",\"nameTranslations\":{},\"originalName\":\"They Will Kill You\",\"releaseDate\":\"2026-03-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/j1yZpgJzjDCbXyA7voSC7SEhcZY.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/qnTdOizsXBzYu3uIbfhHSfE29TE.jpg\"},\"genres\":[\"Action\",\"Komödie\",\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1309587\"},\"name\":\"Hell in Paradise\",\"nameTranslations\":{},\"originalName\":\"Hell in Paradise\",\"releaseDate\":\"2025-11-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/nCL9LCKau7c0PBbkRMh7fKHjRRI.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/rwp9tjccz9OG0b48ux6Y9DdsQ14.jpg\"},\"genres\":[\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1116201\"},\"name\":\"Iron Lung\",\"nameTranslations\":{},\"originalName\":\"Iron Lung\",\"description\":\"In einer postapokalyptischen Zukunft, in der ein Ereignis namens „The Quiet Rapture” alle bekannten Sterne und bewohnbaren Planeten im Universum verschwinden ließ, wird ein Sträfling ausgesandt, um einen Ozean aus Blut zu erforschen, der auf einem öden Mond entdeckt wurde. Dazu benutzt er ein kleines U-Boot mit dem Spitznamen „Iron Lung”.\",\"releaseDate\":\"2026-01-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/sIwakdbMGS1krtgendTWpxTY9Hw.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gqGQ0zADV5FIcgMWtWX8FcGQjFp.jpg\"},\"genres\":[\"Horror\",\"Science Fiction\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1327690\"},\"name\":\"One Mile: Chapter Two\",\"nameTranslations\":{},\"originalName\":\"One Mile: Chapter Two\",\"releaseDate\":\"2026-02-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3sjc9qXXmQoUWKQ3qIjS1nZaUJy.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/jxQIjkJBTyZSxN3yyilpR0ns6HA.jpg\"},\"genres\":[\"Action\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1428862\"},\"name\":\"Cortafuego – Umgeben von Feuer\",\"nameTranslations\":{},\"originalName\":\"Cortafuego\",\"description\":\"Die kleine Lide verschwindet im Wald, während ihre Familie alles zusammenpackt. Als ein Feuer im Wald ausbricht, macht sich ihre Mutter auf die Suche.\",\"releaseDate\":\"2026-02-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cO7NbeNm1QA9H0JETj7OAFxMgXa.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/thgemkoLauZxcqe6KX8wxqEc70z.jpg\"},\"genres\":[\"Thriller\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1223601\"},\"name\":\"Sisu: Road to Revenge\",\"nameTranslations\":{},\"originalName\":\"Sisu 2\",\"description\":\"„Der Mann, der nicht sterben will“ kehrt in das Haus zurück, in dem seine Familie während des Krieges brutal ermordet wurde. Er zerlegt es in seine Einzelteile, verlädt es auf einen Lastwagen und ist fest entschlossen, es an einem sicheren Ort zu Ehren seiner Familie wieder aufzubauen. Doch als der Kommandant der Roten Armee zurückkehrt, der seine Familie getötet hat – fest entschlossen, die Arbeit zu Ende zu bringen – beginnt eine unerbittliche, atemberaubende Verfolgungsjagd quer durch das Land.\",\"releaseDate\":\"2025-10-21\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/hYbeWYK21FCc58mFWuKCHXTrQCB.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yCatt8lmp3oRFEcOZF8KHhsiASQ.jpg\"},\"genres\":[\"Action\",\"Kriegsfilm\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1546319\"},\"name\":\"Kill Will\",\"nameTranslations\":{},\"originalName\":\"Kill Will\",\"releaseDate\":\"2026-02-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5F8khQq9jP3MaeMr7VvDDoPwFnL.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/47UeCr9OAPCme2mC9EZMUKMNf6u.jpg\"},\"genres\":[\"Action\",\"Komödie\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1208348\"},\"name\":\"Rental Family\",\"nameTranslations\":{},\"originalName\":\"Rental Family\",\"description\":\"Der Film erzählt die Geschichte eines in Tokio lebenden US-Schauspielers, der auf der Suche nach einem Sinn in seinem Leben ist, bis es ihm gelingt, einen ungewöhnlichen Job an Land zu ziehen. Für eine japanische „Rental Family“-Agentur schlüpft er in unterschiedliche Rollen und spielt als Familienmitglied den Sohn, Ehemann oder Vater. Während er mehr und mehr in die Lebenswelten seiner Kunden eintaucht und ihnen hilft ihre familiären Lücken zu füllen, beginnt er echte Bindungen aufzubauen, die die Grenzen zwischen Schauspiel und Realität verschwimmen lassen. In der Auseinandersetzung mit den moralischen Aspekten seines neuen Jobs, entdeckt er den Sinn im Leben, das Gefühl von Zusammengehörigkeit und die Schönheit zwischenmenschlicher Beziehungen neu.\",\"releaseDate\":\"2025-11-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/vTeJgz2mtk4VHp1pMW9hfwbnXiv.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/euoXeFAOt9o7yAWA9zGZk7DdZWZ.jpg\"},\"genres\":[\"Drama\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1264805\"},\"name\":\"만약에 우리\",\"nameTranslations\":{},\"originalName\":\"만약에 우리\",\"releaseDate\":\"2025-12-31\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qUY4Q99ZO5MtsMdLiwjIExMO5uT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5ziZTaQ7zb3IUMkw6IEimFktNMS.jpg\"},\"genres\":[\"Liebesfilm\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1241983\"},\"name\":\"Train Dreams\",\"nameTranslations\":{},\"originalName\":\"Train Dreams\",\"description\":\"Ein einfacher Holzfäller erfährt im Lauf seines Lebens im sich im Umbruch befindenden Amerika des 20. Jahrhunderts Liebe und Verlust.\",\"releaseDate\":\"2025-11-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/2UKhvcdV2bBQtYgfD476K0YU6gy.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/u5NWHVhZ6HWc1fXnqn82cMar5St.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"936075\"},\"name\":\"Michael\",\"nameTranslations\":{},\"originalName\":\"Michael\",\"description\":\"Er ist einer der einflussreichsten Künstler aller Zeiten – der King of Pop. MICHAEL ist das Portrait eines Ausnahmekünstlers, dessen Musik die Welt bewegt und jede Generation bis heute inspiriert hat.\",\"releaseDate\":\"2026-04-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3Qud19bBUrrJAzy0Ilm8gRJlJXP.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/xh3v9v8RRbJgjcubewQ0wBjp8Qv.jpg\"},\"genres\":[\"Musik\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1311031\"},\"name\":\"Demon Slayer: Kimetsu no Yaiba Infinity Castle\",\"nameTranslations\":{},\"originalName\":\"劇場版「鬼滅の刃」無限城編 第一章 猗窩座再来\",\"description\":\"Während die Mitglieder des Dämonentöter-Korps und die Hashira in Vorbereitung auf den bevorstehenden Kampf gegen die Dämonen ein gemeinsames Krafttrainingsprogramm, das Hashira-Training, absolvieren, taucht Muzan Kibutsuji in der Ubuyashiki-Villa auf. Da der Leiter des Dämonenkorps in Gefahr ist, eilen Tanjiro und die Hashira zum Hauptquartier, werden aber von Muzan Kibutsuji in einen tiefen Abstieg in einen mysteriösen Raum gestürzt. Das Ziel, in das Tanjiro und das Dämonentöter-Korps gestürzt sind, ist die Festung der Dämonen - die Unendlichkeitsburg. Und so ist das Schlachtfeld für die finale Schlacht zwischen dem Dämonentöterkorps und den Dämonen bereitet.\",\"releaseDate\":\"2025-07-18\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cqlahADJmDdqQvLAPuEYD6EKPAN.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lNYympQM5O6QSInusbyG9eJDIe4.jpg\"},\"genres\":[\"Animation\",\"Action\",\"Fantasy\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1168190\"},\"name\":\"The Wrecking Crew\",\"nameTranslations\":{},\"originalName\":\"The Wrecking Crew\",\"description\":\"Die entfremdeten Halbbrüder Jonny und James kommen sich nach dem mysteriösen Tod ihres Vaters auf Hawaii wieder näher. Bei der Suche nach der Wahrheit decken sie eine Verschwörung auf, die ihre Familie zu zerreißen droht.\",\"releaseDate\":\"2026-01-28\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/jodAPxXMZppnmmJ9tccrmmq6YJ3.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/cz4vLJrmaV1zJlRYbxqtvLzeLWB.jpg\"},\"genres\":[\"Action\",\"Komödie\",\"Krimi\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1408208\"},\"name\":\"Exit 8\",\"nameTranslations\":{},\"originalName\":\"８番出口\",\"description\":\"Ein Mann verirrt sich in einem unterirdischen Gang. Er folgt dem „Führer“ durch den Gang, doch nacheinander passieren ihm seltsame Dinge. Ist dieser Raum real? Oder eine Illusion? Wird es dem Mann gelingen, aus dem Gang zu entkommen?\",\"releaseDate\":\"2025-08-28\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/b2lOJsOPwLNjdewjcXIVXqqx25b.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/3cVrg7tzSf5AgEecYWDOSAzXAeX.jpg\"},\"genres\":[\"Horror\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1022453\"},\"name\":\"The Raja Saab\",\"nameTranslations\":{},\"originalName\":\"ది రాజాసాబ్\",\"description\":\"Als ein junger Erbe den Thron besteigt, verbindet er seine königliche Herkunft mit einem ausgeprägten Hang zur Rebellion. Unter dem Namen Raja Saab übernimmt er die Führung und beginnt, bestehende Strukturen aufzubrechen, indem er eigene Regeln etabliert und neue Wege einschlägt.\",\"releaseDate\":\"2026-01-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/nvK6gYa4diCnQkDVN42uoYXPrdT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/kCwmLYy9ZMto1eMH8BI9KcVVIH2.jpg\"},\"genres\":[\"Komödie\",\"Horror\",\"Fantasy\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1306368\"},\"name\":\"The Rip\",\"nameTranslations\":{},\"originalName\":\"The Rip\",\"description\":\"Das Vertrauen bröckelt, als ein Polizeiteam in Miami in einem verwahrlosten Haus Bargeld in Millionenhöhe entdeckt. Plötzlich stellen sie einander – und einfach alles – infrage.\",\"releaseDate\":\"2026-01-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/t8DBuGkmnEEZi0UqhbUtiZZDWkG.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/3F2EXWF1thX0BdrVaKvnm6mAhqh.jpg\"},\"genres\":[\"Action\",\"Thriller\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1646787\"},\"name\":\"Sundutan\",\"nameTranslations\":{},\"originalName\":\"Sundutan\",\"releaseDate\":\"2026-03-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/2neZgVuY7prWIak5hhNKT53Hk0N.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/zYm62AouAahA71AoOWHE5Qb0FYH.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"639988\"},\"name\":\"No Other Choice\",\"nameTranslations\":{},\"originalName\":\"어쩔수가없다\",\"description\":\"Man-su hat sich mit viel Fleiß und harter Arbeit ein perfektes Leben geschaffen: Haus mit Garten, harmonische Ehe, talentierte Kinder und genug Zeit für sein geliebtes Bonsai-Hobby. Doch als KI plötzlich seinen Job ersetzt, müssen er und seine Familie auf allerlei Annehmlichkeiten verzichten: die Tennisstunden der Gattin, das Netflix-Abo der Kinder und selbst die zwei treuen Golden Retriever können sie sich nicht mehr leisten. Und je länger Man-su vergeblich Bewerbungen schreibt, desto näher rückt auch der Verlust des geliebten Hauses. Schließlich begreift er: Nicht der Mangel an Jobs ist das Problem, sondern die Menge an Mitbewerbern. Man-su bleibt keine andere Wahl als sich – auf sehr kreative Art und Weise – seiner Konkurrenten zu entledigen.\",\"releaseDate\":\"2025-09-24\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/tImzXp37Q2RBcIdYS1HRdtffEaD.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/vuUDwAi9UgLyNN9xZLtKTaLQWnl.jpg\"},\"genres\":[\"Komödie\",\"Krimi\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1246049\"},\"name\":\"Dracula - Die Auferstehung\",\"nameTranslations\":{},\"originalName\":\"Dracula\",\"description\":\"Die Geschichte von Prinz Vladimir aus dem 15. Jahrhundert, der nach dem Tod seiner geliebten Frau Gott verflucht und in einen Vampir verwandelt wird. Später, im London des 19. Jahrhunderts, entdeckt er die Doppelgängerin seiner Frau und verdammt sich selbst, indem er ihr nachstellt.\",\"releaseDate\":\"2025-07-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/pcNwDuieKeSxz6CyOqASdp9oqzt.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/be5SIsRGMckO8tU9lrLcIik70Dy.jpg\"},\"genres\":[\"Horror\",\"Fantasy\",\"Liebesfilm\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1325734\"},\"name\":\"Das Drama - Noch mal auf Anfang\",\"nameTranslations\":{},\"originalName\":\"The Drama\",\"description\":\"Ein glücklich verlobtes Paar steht kurz vor der Traumhochzeit - doch in den Tagen vor dem Ja-Wort bröckelt die Fassade. Eine unerwartete Enthüllung wirft nicht nur die Hochzeitsplanung aus der Bahn, sondern alles, was sie über einander zu wissen glauben.\",\"releaseDate\":\"2026-04-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/iv1nYOctoocIYqCNhemXcA8EngQ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ghY17WXsnD36m8Xo98O0ZL52FsT.jpg\"},\"genres\":[\"Drama\",\"Liebesfilm\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1213243\"},\"name\":\"Toxic\",\"nameTranslations\":{},\"originalName\":\"Toxic\",\"description\":\"Diese fesselnde Geschichte spielt in einer längst vergangenen Zeit und entfaltet sich im Küstenparadies Goa, wo ein mächtiges Drogenkartell hinter der Fassade sonnenverwöhnter Strände und lebendiger Kultur die Fäden zieht.\",\"releaseDate\":\"2026-06-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/tZ8eSBXbza96vzCYeVTG9RBJ78E.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/tBRSSfgqOAq7YlG8udcoJIBm2FG.jpg\"},\"genres\":[\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1299655\"},\"name\":\"Blue Moon\",\"nameTranslations\":{},\"originalName\":\"Blue Moon\",\"releaseDate\":\"2025-10-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ijn4lOOP84YksaBQUpmAYmtkTW2.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/fsuqi2SIjoPHmuVhJlrk1McomEo.jpg\"},\"genres\":[\"Historie\",\"Drama\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"533533\"},\"name\":\"Tron: Ares\",\"nameTranslations\":{},\"originalName\":\"TRON: Ares\",\"description\":\"Vor Jahrzehnten hatte der Videospielentwickler Kevin Flynn eine Technologie entwickelt, die es ihm ermöglichte, in digitale Welten abzutauchen, in denen Daten mit Raumschiffen und anderen Gefährten transportiert werden sowie Programme in menschlicher Gestalt agieren. Nun verspricht sich der junge Konzernchef Julian Dillinger, Enkel von Flynns einstigem Rivalen Ed Dillinger, vom umgekehrten Weg aber noch viel mehr: Er möchte intelligente Computerprogramme in die echte Welt holen, um sie dort als entbehrliche Soldaten lukrativ in Umlauf zu bringen. Sein Vorzeigemodell ist der digitale Elitesoldat Ares, der zur Zeit aber nur 29 Minuten lang in der echten Welt existieren kann, bevor er zerfällt. Die notwendige Technologie für einen permanenten Transfer wurde einst von Flynn entwickelt und befindet sich nun in den Händen seiner Nachfolgerin Eve Kim, weshalb Dillinger Ares auf sie ansetzt.\",\"releaseDate\":\"2025-10-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/pbl8YCYi2mrvq3GxqzUacyEWvsU.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/pUNfHmVqfwRdILhCkU8TdysVOXo.jpg\"},\"genres\":[\"Science Fiction\",\"Abenteuer\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"650524\"},\"name\":\"尋秦記\",\"nameTranslations\":{},\"originalName\":\"尋秦記\",\"releaseDate\":\"2025-12-31\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/h3OUaPfCaFmzwB2eMHik50RsXlP.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gpJr8wRED8BpBVaxM0eODQEBNwC.jpg\"},\"genres\":[\"Science Fiction\",\"Action\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1061474\"},\"name\":\"Superman\",\"nameTranslations\":{},\"originalName\":\"Superman\",\"description\":\"Superman ist bereits seit einiger Zeit als Superheld in Metropolis aktiv und arbeitet unter dem Deckmantel seines menschlichen Alter Egos, dem Reporter Clark Kent, bei der Zeitung „Daily Planet\\\". Dort hat er auch die Reporterin Lois Lane kennengelernt, die tatsächlich als einzige von seiner geheimen Identität als Superman weiß. Gemeinsam mit zahlreichen anderen Helden und Heldinnen, darunter Guy Gardner alias Green Lantern, Mister Terrific, Hawkgirl und Metamorpho, beschützt Superman die Menschheit vor Bedrohungen, von denen es wirklich zahlreiche gibt. Doch eine Bedrohung, die sticht hervor: Supermans Erzfeind Lex Luthor versucht mit allen Mitteln, ihn endgültig aus dem Weg zu räumen und in Ungnade fallen zu lassen. Dafür stellt sich ihm auch Angela Spica, bekannt als „The Engineer\\\", in den Weg …\",\"releaseDate\":\"2025-07-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/fJKSDmkXDLZ0qDmAZ5lXEaToN3L.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yRBc6WY3r1Fz5Cjd6DhSvzqunED.jpg\"},\"genres\":[\"Science Fiction\",\"Abenteuer\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1569555\"},\"name\":\"Fish, Fists and Ambergris\",\"nameTranslations\":{},\"originalName\":\"Fish, Fists and Ambergris\",\"releaseDate\":\"2025-11-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/aW5YR7paFxiIeUVG7EIuKh4H8ao.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/39Orrr4PJuD9EMI5P43OliHr7O7.jpg\"},\"genres\":[\"Action\",\"Abenteuer\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1151272\"},\"name\":\"Sirāt\",\"nameTranslations\":{},\"originalName\":\"Sirāt\",\"description\":\"Ein Vater und sein Sohn kommen zu einem Rave tief in den Bergen Südmarokkos. Sie sind auf der Suche nach Mar - Tochter und Schwester - die vor Monaten auf einer dieser endlosen, schlaflosen Partys verschwunden ist.\",\"releaseDate\":\"2025-06-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/jWhr3veBAaHplq0uVL8Fl2azxaK.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/kOUV5WbisWMg56d8eB45ZHEVxYq.jpg\"},\"genres\":[\"Drama\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1198994\"},\"name\":\"Send Help\",\"nameTranslations\":{},\"originalName\":\"Send Help\",\"description\":\"Nach einem Flugzeugabsturz stranden eine fähige Mitarbeiterin und ihr nerviger Chef auf einer abgelegenen Insel. Sie muss ihre Überlebenskünste einsetzen, um beide am Leben zu erhalten, trotz ihrer schwierigen Beziehung.\",\"releaseDate\":\"2026-01-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/nKbcjoO2BDkA3r5oR3Z8LnHHNXw.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hO2jx1H3XafR7Y8QbFgVH1sHTY9.jpg\"},\"genres\":[\"Horror\",\"Thriller\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1078605\"},\"name\":\"Weapons - Die Stunde des Verschwindens\",\"nameTranslations\":{},\"originalName\":\"Weapons\",\"description\":\"Mit einer einzigen Ausnahme verschwinden eines Nachts alle Kinder einer Schulklasse zur exakt gleichen Zeit auf mysteriöse Weise. Die Bewohner der betroffenen Gemeinde stehen vor der Frage, wer oder was hinter dem rätselhaften Verschwinden steckt.\",\"releaseDate\":\"2025-08-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/aOTZOU3aI5SDELJz5YpAkB0wFDH.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yKWZIDo4ixcDUeelk2QGVA1EVmC.jpg\"},\"genres\":[\"Horror\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1321179\"},\"name\":\"왕과 사는 남자\",\"nameTranslations\":{},\"originalName\":\"왕과 사는 남자\",\"releaseDate\":\"2026-02-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/zEH1FQTEnRY05i8gQIYdR10Vp92.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1s1r4OOdnU8VX2inALVTA2q94uY.jpg\"},\"genres\":[\"Historie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1642494\"},\"name\":\"Murder in the Highland Manor\",\"nameTranslations\":{},\"originalName\":\"Murder in the Highland Manor\",\"releaseDate\":\"2026-03-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/xFvEbjlE9rRgZ5ezSex1fQZX2FK.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/zzRcgny4YTEbyPsk6rDJIvocMsp.jpg\"},\"genres\":[\"Thriller\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1389149\"},\"name\":\"अक्यूज़्ड\",\"nameTranslations\":{},\"originalName\":\"अक्यूज़्ड\",\"description\":\"Das Leben einer angesehenen Gynäkologin gerät aus den Fugen, als schwere Anschuldigungen gegen sie erhoben werden. Ihre Frau will der Wahrheit auf die Spur kommen.\",\"releaseDate\":\"2026-02-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/eeP55mdqj4KpWtEPBvZJoxmnkXI.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/8QRMlkCMFNKZM2ApnIaut5t4snf.jpg\"},\"genres\":[\"Thriller\",\"Mystery\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1646488\"},\"name\":\"2026年中央广播电视总台元宵晚会\",\"nameTranslations\":{},\"originalName\":\"2026年中央广播电视总台元宵晚会\",\"releaseDate\":\"2026-03-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ozHjR4Azg9jDA4RProAEuLfOyVs.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hgq0F88N6oPxylwbQbJII7eeHHQ.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"812583\"},\"name\":\"Wake Up Dead Man: A Knives Out Mystery\",\"nameTranslations\":{},\"originalName\":\"Wake Up Dead Man: A Knives Out Mystery\",\"description\":\"Der Detektiv Benoit Blanc arbeitet mit einem jungen Priester zusammen, um ein absolut unmögliches Verbrechen in einer Kirche mit dunkler Vergangenheit zu lösen.\",\"releaseDate\":\"2025-11-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/bIeHhOqCQysfed98TKjZhRWRc7x.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/fiRDzpcJe7qz3yIR43hdXIE3NHv.jpg\"},\"genres\":[\"Thriller\",\"Mystery\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1160360\"},\"name\":\"If I Had Legs I'd Kick You\",\"nameTranslations\":{},\"originalName\":\"If I Had Legs I'd Kick You\",\"releaseDate\":\"2025-10-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/va0TQ9WprMXRqQAzY56vyqY0Yd5.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/Gq68CyfTlj4QiDsX8eZqFi8ce6.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1456349\"},\"name\":\"Ein einfacher Unfall\",\"nameTranslations\":{},\"originalName\":\"Un simple accident\",\"description\":\"Als der Automechaniker Vahid zufällig auf den Mann trifft, der ihn mutmaßlich im Gefängnis gefoltert hat, entführt er ihn, um Vergeltung zu üben. Doch der einzige Hinweis auf Eghbals Identität ist das unverkennbare Quietschen seiner Beinprothese. Auf der Suche nach Gewissheit wendet sich Vahid an einen zerstreuten Kreis anderer, inzwischen freigelassener Opfer. Doch je tiefer sie in ihre Vergangenheit eintauchen und je mehr ihre unterschiedlichen Weltanschauungen aufeinanderprallen, desto größer werden die Zweifel: Ist er es wirklich? Und was hieße Vergeltung überhaupt?\",\"releaseDate\":\"2025-09-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/giBFj9Et00E8cymsBqVfrqMWUnk.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/zhoMwQofjgVec5Sin05hWECJtVQ.jpg\"},\"genres\":[\"Drama\",\"Thriller\",\"Krimi\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"875828\"},\"name\":\"Peaky Blinders: The Immortal Man\",\"nameTranslations\":{},\"originalName\":\"Peaky Blinders: The Immortal Man\",\"releaseDate\":\"2026-03-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/gRMalasZEzsZi4w2VFuYusfSfqf.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/filZFYKr17wIJ4j1Cz115DOdegh.jpg\"},\"genres\":[\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"402431\"},\"name\":\"Wicked\",\"nameTranslations\":{},\"originalName\":\"Wicked\",\"description\":\"Die zwei Hexen Elphaba und Glinda könnten unterschiedlich nicht sein. Während Glinda privilegiert, hübsch und attraktiv ist, muss sich Elphaba aufgrund ihrer grünen Hautfarbe immer wieder beweisen und vor allem ihre wahren Fähigkeiten erst noch entdecken. So unterschiedlich die beiden Hexen auch sind, umso enger befreunden sie sich während ihrer Zeit auf der Universität Glizz im fantastischen Land Oz. Eine Reihe unerwarteter Ereignisse stellt die beiden Freundinnen jedoch auf eine harte Probe, die sogar zum mächtigen Zauberer von Oz führt. Welche Rolle spielt der mächtigste Mann des Landes im Leben der beiden Hexen und ist er wirklich der gutmütige Herrscher, der er vorgibt zu sein? Elphaba und Glinda sehen sich einer folgenschweren Entscheidung gegenüber, die ihre besondere Freundschaft für immer und ewig verändern wird.\",\"releaseDate\":\"2024-10-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/r48wrB5wT9Q9x7KBbBqw9m7KkZP.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/uVlUu174iiKhsUGqnOSy46eIIMU.jpg\"},\"genres\":[\"Drama\",\"Liebesfilm\",\"Fantasy\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1427832\"},\"name\":\"No Hit Wonder\",\"nameTranslations\":{},\"originalName\":\"No Hit Wonder\",\"description\":\"Daniel ist Sänger und wurde dank eines Songs über Nacht berühmt. Doch für den aufstrebenden Künstler war der Traum des Ruhms ein kurzer: Sein Song entwickelt sich zu einem echten One-Hit-Wonder und Daniel verfällt in eine tiefe depressive Phase, als seine nachfolgenden Songs nicht beim Publikum landen. Für Daniel gibt es bald kaum mehr Optionen auf einen Ausweg – er möchte aus dem Leben treten. Bei seinem Suizidversuch schießt er jedoch daneben und sitzt fortan auf der geschlossenen Anstalt. Nur unter einer Bedingung darf er gehen: Er muss eine Gruppe depressiver Menschen mit seiner Musik glücklich machen. Die Ironie des Schicksals spielt ein übles Spiel mit ihm.\",\"releaseDate\":\"2025-10-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/rs3TQEXnKpMK9LkvkPb3anbxdfP.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/4z2k4ut1uemDkuvYoOeH8R5lDqy.jpg\"},\"genres\":[\"Komödie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"786567\"},\"name\":\"Gandhi Talks\",\"nameTranslations\":{},\"originalName\":\"Gandhi Talks\",\"releaseDate\":\"2026-01-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/p4iQT3s97T3gQOLhTj0UplzYMOj.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/4Cqad6ZpWJRhBumGE1QwHs9pVuB.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1327688\"},\"name\":\"One Mile: Chapter One\",\"nameTranslations\":{},\"originalName\":\"One Mile: Chapter One\",\"releaseDate\":\"2026-02-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1GZaoYe0mQy211DgDSAxAXr30ul.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/xBORKTaQJTq3l7EdnTTnrZnYzYa.jpg\"},\"genres\":[\"Action\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1038392\"},\"name\":\"Conjuring 4: Das letzte Kapitel\",\"nameTranslations\":{},\"originalName\":\"The Conjuring: Last Rites\",\"description\":\"Ed und Lorraine Warren nehmen einen besonders verstörenden Fall an: Jack (Elliot Cowan) und Janet Smurl ziehen 1976 mit ihren Kindern in ein neues Haus in Pennsylvania. Sie erfüllen sich damit ihren schon lange gehegten Traum vom Eigenheim. Doch schon bald häufen sich unerklärliche Vorkommnisse. Bis zum Jahr 1985 werden die Phänomene immer bedrohlicher, die Familie gerät immer näher an ihre Belastungsgrenze. In ihrer Not wenden sich die Smurls schließlich an die erfahrenen Ermittler für paranormale Erscheinungen, als die Ed und Lorraine Warren bekannt sind. Aus dem Ruhestand zurückgekehrt, stoßen die Warrens vor Ort auf ein Artefakt, das mit der Geburt ihrer Tochter Judy  in Verbindung steht und Erinnerungen an ihren allerersten Fall weckt. Die Ereignisse spitzen sich zu – es kommt zu einer letzten Konfrontation mit einem Dämon, der sie seit Jahrzehnten verfolgt.\",\"releaseDate\":\"2025-09-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1znowvqAYATIKezg7A7l1sPNj9M.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/tcBX2dtkNozZ0uDLVaxXrE6rqyN.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1422096\"},\"name\":\"Good Boy - Trust His Instincts\",\"nameTranslations\":{},\"originalName\":\"Good Boy\",\"description\":\"Ein treuer Hund zieht mit seinem Besitzer Todd in ein ländliches Familienhaus, entdeckt dort aber übernatürliche Kräfte, die im Schatten lauern. Als dunkle Wesen seinen menschlichen Begleiter bedrohen, muss der tapfere Welpe kämpfen, um seinen Liebsten zu beschützen.\",\"releaseDate\":\"2025-10-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/fLCA0C6GxQGEM7OFvEC1hmigYDJ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/mPtPJzBkwksUoMEKpkZqxBrlKpZ.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1379266\"},\"name\":\"Kokuho - The Master of Kabuk\",\"nameTranslations\":{},\"originalName\":\"国宝\",\"description\":\"Nach dem Tod seines Vaters wird der 14-jährige Kikuo unter die Fittiche des berühmten Kabuki-Schauspielers Hanjiro genommen. Zusammen mit Shunsuke, Hanjiros einzigem Sohn, beschliesst er, sich dieser traditionellen Form des Theaters zu widmen. Über Jahrzehnte hinweg entwickeln sich die beiden jungen Männer gemeinsam weiter – von der Schauspielschule bis zu den grossen Bühnen – zwischen Skandalen und Ruhm, Bruderschaft und Verrat. Regisseur Lee Sang-il hat mit seinem Spielfilm ein beeindruckendes, immersives Werk geschaffen, das uns in die Welt des Kabuki-Theaters entführt. Ein episches Kino- und Theaterspektakel!\",\"releaseDate\":\"2025-06-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/30BPyvFH9nvQF6ds7Q5erjJQzf1.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/3C8yAIuXlH4BGCpTwEetIv0VBt8.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1106382\"},\"name\":\"Bau, Artist at War\",\"nameTranslations\":{},\"originalName\":\"Bau, Artist at War\",\"releaseDate\":\"2025-09-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/pMLKb0U2XctHx7xAeMxdko4kpCD.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ioMUeaiNwPrTRnKRqjkzzcRlAEy.jpg\"},\"genres\":[\"Drama\",\"Historie\",\"Liebesfilm\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1317149\"},\"name\":\"I Swear\",\"nameTranslations\":{},\"originalName\":\"I Swear\",\"releaseDate\":\"2025-09-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/vUwyhNWBKkSwK8ELvEeBRwV724h.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/fe6kkxaxn0mCU2gl1vfU44IYWsy.jpg\"},\"genres\":[\"Drama\",\"Historie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1228246\"},\"name\":\"Five Nights at Freddy's 2\",\"nameTranslations\":{},\"originalName\":\"Five Nights at Freddy's 2\",\"description\":\"Sie sind nicht mehr nur bei Freddy’s … Seit den albtraumhaften Geschehnissen in Freddy’s Pizzeria ist ein Jahr vergangen. Die Geschichten darüber, was sich dort genau abgespielt hat, haben sich längst zu einem lokalen Mythos verklärt – ein Mythos, der so populär ist, dass die Stadt nun sogar das erste „Fazfest“ abhalten will. Der ehemalige Wachmann Mike und die Polizistin Vanessa haben Mikes elfjähriger Schwester Abby die Wahrheit über das Schicksal ihrer animatronischen Freunde bislang verschwiegen. Eines Tages schleicht sich Abby heimlich davon, um sich mit Freddy, Bonnie, Chica und Foxy zu treffen. Sie ahnt nicht, dass sie damit eine Reihe von schrecklichen Ereignissen in Gang setzt, die dunkle Geheimnisse über den Ursprung von Freddy’s Pizzeria enthüllen – und einen Schrecken entfesseln, der seit Jahrzehnten verborgen lag.\",\"releaseDate\":\"2025-12-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/byFxrm3IS9wErulqpqDIsaLaTeG.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/54BOXpX2ieTXMDzHymdDMnUIzYG.jpg\"},\"genres\":[\"Horror\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1154538\"},\"name\":\"Nirvanna the Band the Show the Movie\",\"nameTranslations\":{},\"originalName\":\"Nirvanna the Band the Show the Movie\",\"releaseDate\":\"2026-02-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/sm5TGX8WbnCd9Uo26cLyTxVwA1n.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gYxOlYtLvGNrzYm6kQBcY5mqKja.jpg\"},\"genres\":[\"Science Fiction\",\"Abenteuer\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"604079\"},\"name\":\"The Long Walk - Todesmarsch\",\"nameTranslations\":{},\"originalName\":\"The Long Walk\",\"description\":\"In einer nicht allzu fernen Zukunft herrscht ein repressives Regime über die Vereinigten Staaten von Amerika. Angeführt von dem namenlosen autoritären Major sichert ein gnadenloser Polizeistaat seine Macht mit strengen Regeln – und einem brutalen Wettkampf. Jedes Jahr treten insgesamt hundert Jugendliche gegeneinander an, doch nur eine Person kann gewinnen: wer den Marsch überlebt. Ray Garraty meldet sich freiwillig für das blutige Spektakel an, angelockt vom Versprechen von einem sorgenfreien Leben, in dem man alles bekommt, was man sich wünscht. Doch der Weg dorthin ist tödlich. Die Teilnehmer müssen dauerhaft ein Tempo von mindestens vier Meilen pro Stunde halten. Jede Unterschreitung führt zu einer Verwarnung. Wer sich drei davon einhandelt, wird hingerichtet – ohne Ausnahme. Ray macht sich als Nummer 47 auf den Weg und setzt alles daran, am Ende als Nummer 1 zu überleben.\",\"releaseDate\":\"2025-09-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/mk1slDTg4HbGA65GGijLMdkDEt7.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/o0Id62Wx3gjYMHunJV96WAOspN.jpg\"},\"genres\":[\"Science Fiction\",\"Thriller\",\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1159206\"},\"name\":\"Father Mother Sister Brother\",\"nameTranslations\":{},\"originalName\":\"Father Mother Sister Brother\",\"description\":\"Drei Geschichten kreisen um die Beziehungen erwachsener Kinder zu ihren teils distanzierten Eltern und untereinander. Jedes der drei Kapitel spielt in der Gegenwart, jedes in einem anderen Land: FATHER ist im Nordosten der USA angesiedelt, MOTHER in Dublin und SISTER BROTHER in Paris.\",\"releaseDate\":\"2025-12-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/jlHQJYg1pFJtjEMiRqOrFDewbju.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/n36zycrAqHn2uzx65IeAdnsZcMj.jpg\"},\"genres\":[\"Komödie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"803796\"},\"name\":\"KPop Demon Hunters\",\"nameTranslations\":{},\"originalName\":\"KPop Demon Hunters\",\"description\":\"Wenn die K-Pop-Superstars Rumi, Mira und Zoey nicht gerade vor ausverkauften Stadien auftreten, setzen sie ihre geheimen Kräfte gegen übernatürliche Bedrohungen ein.\",\"releaseDate\":\"2025-06-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3Ps8dRYdD4kcJQACirB2Vfqs01c.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/w3Bi0wygeFQctn6AqFTwhGNXRwL.jpg\"},\"genres\":[\"Fantasy\",\"Musik\",\"Komödie\",\"Animation\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"951305\"},\"name\":\"Enterre Seus Mortos\",\"nameTranslations\":{},\"originalName\":\"Enterre Seus Mortos\",\"releaseDate\":\"2025-10-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/41Nwv99NYnrkOZRyoLI8zacZkM3.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/mstNi3X5e6WbQ9zdBG8QcY8Fvrt.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1499984\"},\"name\":\"Gladiator Underground\",\"nameTranslations\":{},\"originalName\":\"Gladiator Underground\",\"releaseDate\":\"2025-08-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qLN16AeIjS5P5Kk5B6pBi1Mh1mi.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/O50sdY6JEwpU7cQRaFtTO9eSAk.jpg\"},\"genres\":[\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1261188\"},\"name\":\"Die schwedische Verbindung\",\"nameTranslations\":{},\"originalName\":\"Den svenska länken\",\"description\":\"In dieser wenig bekannten wahren Geschichte wird ein schwedischer Bürokrat zum Helden, als er versucht, im 2. Weltkrieg jüdische Leben zu retten.\",\"releaseDate\":\"2026-02-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/wUfdjrCGdXDUWnAzvruLj7BlUUB.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/56VfTGANetZ5IIYQsXuciNePM28.jpg\"},\"genres\":[\"Drama\",\"Historie\",\"Kriegsfilm\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1200320\"},\"name\":\"Killing Faith\",\"nameTranslations\":{},\"originalName\":\"Killing Faith\",\"releaseDate\":\"2025-10-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/bNHlTTdpdDv8xxrXF3krVghyCcj.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/dC15RaDX4mmPB0omILrjTKMGy6W.jpg\"},\"genres\":[\"Thriller\",\"Western\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1199193\"},\"name\":\"Pose\",\"nameTranslations\":{},\"originalName\":\"Pose\",\"releaseDate\":\"2026-02-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qhyyyWrHUbl6QG4udAJj17CBa5.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/bAFnjhweXxHUWjmFzMTuX12Ud3b.jpg\"},\"genres\":[\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1049942\"},\"name\":\"Bambi - Die Abrechnung\",\"nameTranslations\":{},\"originalName\":\"Bambi: The Reckoning\",\"description\":\"Nachdem eine Mutter und ihr Sohn einen Autounfall haben, werden sie bald von Bambi gejagt, einem mutierten, von Trauer geplagten Hirsch, der auf tödlichem Amoklauf ist und Rache für den Tod seiner Mutter und seiner Frau nehmen will.\",\"releaseDate\":\"2025-07-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/nr9AQimZS98NaEPEKqj3gxgLHm7.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/tG5ZSx57zkijfK975aENinlOdIy.jpg\"},\"genres\":[\"Horror\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1383731\"},\"name\":\"Protector\",\"nameTranslations\":{},\"originalName\":\"Protector\",\"releaseDate\":\"2026-03-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/hUv1DarjEMmQM38i9DvW9pHYPZ4.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/pYcO7MQgrygQERoWub0R35Nh5ec.jpg\"},\"genres\":[\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1259102\"},\"name\":\"Eternity\",\"nameTranslations\":{},\"originalName\":\"Eternity\",\"description\":\"Als Larry Cutler unerwartet stirbt – noch vor seiner Frau Joan –, ist er schockiert, in einer chaotischen Zwischenwelt zu erwachen, wo Verkäufer eine endlose Auswahl möglicher Jenseitswelten anpreisen. Dort erfährt er von seiner zuständigen Jenseits-Koordinatorin, dass ihm nur eine Woche bleibt, sich der ultimativen Frage zu stellen: Wo und mit wem will er die Ewigkeit verbringen? Doch als Joan kurz nach ihm eintrifft, stellt sie fest, dass ihre erste Liebe Luke seit 67 Jahren darauf wartet, wieder mit ihr zusammen zu sein. Sie steht vor einer unmöglichen Wahl zwischen dem Mann, mit dem sie ihr Leben verbracht hat, und dem Mann, der ihr das Leben verspricht, das sie hätte führen können.\",\"releaseDate\":\"2025-11-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/rqBymLKQLi7G8IkfGrXfZpOSbLE.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/fuacZLpnohQtLD0AhtCErcPVL98.jpg\"},\"genres\":[\"Liebesfilm\",\"Komödie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1480387\"},\"name\":\"undertone\",\"nameTranslations\":{},\"originalName\":\"undertone\",\"releaseDate\":\"2026-03-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1wREWUEHzjDWSreNFbFLDO7YEaM.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/711jYfJrsY5x2R0Yh0pFeJTPWA7.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1287141\"},\"name\":\"Pillion\",\"nameTranslations\":{},\"originalName\":\"Pillion\",\"description\":\"Als der schüchterne Colin in einer Bar auf den charismatischen Ray trifft, ist es sofort um ihn geschehen. Dass der attraktive Biker ausgerechnet ihn zu seinem neuen Gefährten erwählt, kann er kaum fassen. Ray fordert absolute Unterwerfung, zu der Colin nur allzu gern bereit ist. Er putzt, kocht, kauft ein und schläft anstandslos auf dem Bettvorleger. Im Gegenzug öffnet ihm Ray die Tür zu einer aufregenden Welt wilder Abenteuer und sexueller Ekstase. Während sich seine Eltern zunehmend Sorgen machen, genießt Colin sein neues Leben in vollen Zügen. Doch langsam erwacht in ihm eine leise Sehnsucht nach etwas, das Ray ihm vielleicht niemals geben kann.  Alexander Skarsgård und Harry-Potter-Star Harry Melling brillieren in Harry Lightons überraschend sensibler DomCom mit einer herausragenden Performance voller Humor, Zärtlichkeit und emotionaler Tiefe.\",\"releaseDate\":\"2025-11-28\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7bAlkQC0X5App52NrVVpvZSPiOA.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/rBYrtkAy9YtRuFpX1g6JbcjRT8h.jpg\"},\"genres\":[\"Liebesfilm\",\"Drama\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1290937\"},\"name\":\"Pumuckl und das große Missverständnis\",\"nameTranslations\":{},\"originalName\":\"Pumuckl und das große Missverständnis\",\"description\":\"Für Meister Eder ist jeden Tag was los, denn bei ihm in der Werkstatt lebt der kleine rothaarige Pumuckl, ein vorlauter und abenteuerlustiger Kobold mit großer Lust am Schabernack. Mit einer Schildkröte, einem Ausflug aufs Land und dann auch noch dem Geburtstag von Nachbar Burke geht es diesen Sommer bei Eder und Pumuckl drunter und drüber. In dem ganzen Trubel schaffen die beiden es kaum noch, ihre Freundschaft zu pflegen. Ein großes Missverständnis hat da gerade noch gefehlt und stellt plötzlich alle Beteiligten gewaltig auf die Probe..\",\"releaseDate\":\"2025-10-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/uXxiLRvOGlqpMCn1Y6HctRoqZ1k.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/bvHe9JE9IjXp9R1OxhckhQVQE14.jpg\"},\"genres\":[\"Familie\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1119449\"},\"name\":\"Good Luck, Have Fun, Don't Die\",\"nameTranslations\":{},\"originalName\":\"Good Luck, Have Fun, Don't Die\",\"description\":\"Ein mysteriöser \\\"Mann aus der Zukunft\\\" betritt ein unscheinbares Diner in Los Angeles. Dort trifft er auf eine bunte Mischung von Gästen. Doch diese scheinbar gewöhnliche Begegnung entpuppt sich schnell als alles andere als zufällig. Der Mann aus der Zukunft enthüllt, dass er dringend eine Gruppe von Menschen braucht, um an einer nächtlichen Mission teilzunehmen, die das Schicksal der Welt entscheiden könnte.\",\"releaseDate\":\"2026-02-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/af7yguGbWQyvYtk6QCD5l4yBbKN.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yjOSpDQe8tzr8easpjTFVoQXsOX.jpg\"},\"genres\":[\"Science Fiction\",\"Action\",\"Abenteuer\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1263012\"},\"name\":\"Dead Man's Wire\",\"nameTranslations\":{},\"originalName\":\"Dead Man's Wire\",\"releaseDate\":\"2026-01-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/hjre9SuECdBsuZ6KtKdFsnK2iRm.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ulw8SrKbDeDrsSVNKPb5211AseI.jpg\"},\"genres\":[\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1153111\"},\"name\":\"Oxana - Mein Leben für Freiheit\",\"nameTranslations\":{},\"originalName\":\"Oxana\",\"description\":\"Am 23. Juli 2018 steht für die ehemalige FEMEN-Anführerin Oxana Chatchko ein bedeutendes Ereignis an: die Eröffnung ihrer Ausstellung blasphemischer Ikonen. Während sie durch Paris streift, trifft sie Liebhaber, diskutiert mit einem Kunstkritiker und stellt sich einem entscheidenden Termin zur Bestätigung ihres politischen Flüchtlingsstatus. Doch die Begegnungen rufen schmerzhafte Erinnerungen wach – an ihre Jahre als feministische Aktivistin, an Verrat und die Narben ihres Kampfes. Zwischen Kunst, Politik und persönlichen Dämonen stellt sich die Frage: Kann sie ihre Lebenslust wiederfinden?\",\"releaseDate\":\"2025-04-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/w8NadzyoeelGQ37FHINROqzCvGT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/o8FCHWNsvPA6UjxHi8TgoeLDXJP.jpg\"},\"genres\":[\"Historie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"7451\"},\"name\":\"xXx - Triple X\",\"nameTranslations\":{},\"originalName\":\"xXx\",\"description\":\"Vin Diesel ist Xander “xXx” Cage, Extremsportler und Adrenalinjunkie. Der tätowierte Draufgänger führt seine berüchtigten, lebensgefährlichen Stunts am liebsten in gestohlenen Luxusschlitten durch und besitzt nicht den geringsten Respekt vor jeglicher Autorität, ganz besonders nicht vor staatlicher – was xXx zum idealen Kandidaten für die Geheimmission des NSA-Agenten Gibbons macht. Dieser droht xXx mit einer Gefängnisstrafe, sollte er sich nicht bereit erklären, die äußerst gefährliche Untergrund-Organisation “Anarchie 99” zu infiltrieren. Unter der Führung des ehemaligen Soldaten Yorgi plant diese die Weltmächte USA und Russland mithilfe einer biologischen Waffe gegeneinander auszuspielen. Ein Himmelfahrtskommando wie es im Buche steht – genau das Richtige für xXx.\",\"releaseDate\":\"2002-08-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/o6QwWAedNuMoQ5yEqLaR1c81NoA.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/2OHa6ukEq3Hce7Pc2kvu8wkmMFY.jpg\"},\"genres\":[\"Action\",\"Abenteuer\",\"Thriller\",\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1266798\"},\"name\":\"Zone 3\",\"nameTranslations\":{},\"originalName\":\"Chien 51\",\"description\":\"Paris, 2045. Die Bevölkerung der Hauptstadt wird von einer künstlichen Intelligenz namens Alma überwacht und in drei Zonen unterteilt. In jeder Zone ist die gleiche soziale Schicht vertreten. Eines Tages wird der Schöpfer der KI ermordet. Die Ermittlungen werden Salia, einer Polizistin aus Zone 2, und Zem, einem Polizisten aus Zone 3, anvertraut.\",\"releaseDate\":\"2025-10-15\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5b2Ub037f5Z4eVLhpLlWrcGkdYD.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/OO75q1cTWWXDmy52bB79yzpxBt.jpg\"},\"genres\":[\"Thriller\",\"Science Fiction\",\"Krimi\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1234821\"},\"name\":\"Jurassic World: Die Wiedergeburt\",\"nameTranslations\":{},\"originalName\":\"Jurassic World Rebirth\",\"description\":\"Fünf Jahre nach den Ereignissen von 'Jurassic World: Ein neue Zeitalter' wird die Spezialistin für verdeckte Operationen, Zora Bennett, auf eine streng geheime Mission geschickt: Sie soll genetisches Material von den drei größten Dinosauriern der Welt sichern. Doch als ihr Team auf eine Familie trifft, deren Boot bei einem Ausflug gekentert ist, stranden sie gemeinsam auf einer abgelegenen Insel. Dort stoßen sie auf eine finstere und schockierende Entdeckung, die jahrzehntelang vor der Menschheit verborgen blieb – und deren Geheimnis alles verändern könnte.\",\"releaseDate\":\"2025-07-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/uUGZdps8TesT34lPMfvTWuyZmZe.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/zNriRTr0kWwyaXPzdg1EIxf0BWk.jpg\"},\"genres\":[\"Science Fiction\",\"Abenteuer\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1322692\"},\"name\":\"Saipan\",\"nameTranslations\":{},\"originalName\":\"Saipan\",\"releaseDate\":\"2025-11-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/s7IbZFANLHKNglQ9IfjDdrHCVNZ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/66goUG18qJdtbnJ7R4HIsibUMKI.jpg\"},\"genres\":[\"Drama\",\"Historie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1230368\"},\"name\":\"Springsteen: Deliver Me from Nowhere\",\"nameTranslations\":{},\"originalName\":\"Springsteen: Deliver Me from Nowhere\",\"description\":\"Im Jahr 1982 arbeitet Bruce Springsteen – im Film verkörpert von Jeremy Allen White – an seinem wohl radikalsten Album: „Nebraska“. In einer Phase innerer Zerrissenheit, in der ihn der eigene Ruhm zunehmend zu erdrücken droht, entscheidet er sich bewusst gegen das Tonstudio. Stattdessen zieht er sich in die Abgeschiedenheit seines Schlafzimmers zurück. Dort entstehen keine mitreißenden Rockhymnen, sondern düstere, zerbrechliche Songs – Geschichten von Schuld, Verlorenheit und Gewalt, aufgenommen auf einem einfachen Vierspurgerät. SPRINGSTEEN: DELIVER ME FROM NOWHERE zeichnet ein intimes Porträt eines zerrissenen Künstlers, der mit inneren Dämonen ringt – und dabei unbeabsichtigt ein Meisterwerk der Musikgeschichte schafft.\",\"releaseDate\":\"2025-10-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/l31ROftCkHvaFJmZCdPveYzs6FP.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/oOczvrnhpXUmqCbyKYFj4FQExAo.jpg\"},\"genres\":[\"Drama\",\"Musik\"],\"similarItems\":[]}],\"nextCursor\":8}"},"redirectURL":"","headersSize":697,"bodySize":40883,"_status":"completed","_startTimestamp":1772842821027222,"_endTimestamp":1772842821039636},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"2606:4700:3032::ac43:cdc0","connection":"12","comment":"","_id":38,"_uid":"322af294-c77d-4b62-b660-8f1963907d8f","_cid":12,"_ctime":1772842816360,"_sid":47,"_stime":1772842820358,"_serverAddress":"2606:4700:3032::ac43:cdc0","_serverAddressFamily":1,"_serverPort":443,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":57859,"_app":{"name":"VAVOO","id":"VAVOO.exe","path":"C:\\Users\\isada\\AppData\\Local\\Programs\\vavoo\\VAVOO.exe","pid":139300}},{"startedDateTime":"2026-03-07T00:20:20.373Z","time":653,"request":{"method":"POST","url":"https://www.kool.to/mediahubmx-catalog.json","httpVersion":"HTTP/2.0","cookies":[],"headers":[{"name":":method","value":"POST"},{"name":":authority","value":"www.kool.to"},{"name":":path","value":"/mediahubmx-catalog.json"},{"name":":scheme","value":"https"},{"name":"content-length","value":"173"},{"name":"content-type","value":"application/json; charset=utf-8"},{"name":"mediahubmx-signature","value":""},{"name":"user-agent","value":"MediaHubMX/2"},{"name":"accept","value":"*/*"},{"name":"accept-encoding","value":"gzip,deflate"},{"name":"sec-fetch-site","value":"none"},{"name":"sec-fetch-mode","value":"no-cors"},{"name":"sec-fetch-dest","value":"empty"},{"name":"accept-language","value":"de"}],"queryString":[],"postData":{"mimeType":"application/json","text":"{\"language\":\"de\",\"region\":\"DE\",\"catalogId\":\"tmdb.movie\",\"id\":\"movie/popular\",\"adult\":false,\"search\":\"\",\"sort\":\"popularity\",\"filter\":{},\"cursor\":null,\"clientVersion\":\"3.0.2\"}"},"headersSize":966,"bodySize":173,"_status":"completed","_startTimestamp":1772842820373413,"_endTimestamp":1772842820448950},"response":{"status":200,"statusText":"","httpVersion":"HTTP/2.0","cookies":[],"headers":[{"name":":status","value":"200"},{"name":"date","value":"Sat, 07 Mar 2026 00:20:20 GMT"},{"name":"content-type","value":"application/json; charset=utf-8"},{"name":"server","value":"cloudflare"},{"name":"mediahubmx-endpoint","value":"."},{"name":"etag","value":"W/\"14cf2-b8m/XrBaEYpOKO0P43lAQFNOass\""},{"name":"strict-transport-security","value":"max-age=31536000; includeSubDomains"},{"name":"content-encoding","value":"gzip"},{"name":"cf-cache-status","value":"DYNAMIC"},{"name":"vary","value":"accept-encoding"},{"name":"nel","value":"{\"report_to\":\"cf-nel\",\"success_fraction\":0.0,\"max_age\":604800}"},{"name":"report-to","value":"{\"group\":\"cf-nel\",\"max_age\":604800,\"endpoints\":[{\"url\":\"https://a.nel.cloudflare.com/report/v4?s=dRhfOGKXNyXxwIRjpWPBTnJ6IbuU%2F1mnIGVjFqFTHrgYLqxzphoQMobT7DylPwSff%2FK0u333sYlpdu5qtw75RTeX8Cxc6jTBzQuVd9r6fAyNDvsdKg%3D%3D\"}]}"},{"name":"cf-ray","value":"9d856f0bf916e51e-TXL"},{"name":"alt-svc","value":"h3=\":443\"; ma=86400"}],"content":{"size":85234,"mimeType":"application/json","text":"{\"options\":{},\"items\":[{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1290821\"},\"name\":\"Shelter\",\"nameTranslations\":{},\"originalName\":\"Shelter\",\"description\":\"Ein Mann, der sich auf einer abgelegenen Insel in selbstgewählter Abgeschiedenheit befindet, rettet ein junges Mädchen vor einem heftigen Sturm und löst damit eine Kette von Ereignissen aus, die ihn zwingen, seine Abgeschiedenheit zu verlassen, um sie vor Feinden aus seiner Vergangenheit zu schützen.\",\"releaseDate\":\"2026-01-28\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/buPFnHZ3xQy6vZEHxbHgL1Pc6CR.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nHxWyy18SvAZ8jJeemtS8k1UNjM.jpg\"},\"genres\":[\"Action\",\"Krimi\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"10156\"},\"name\":\"Mel Brooks - Die verrückte Geschichte der Welt\",\"nameTranslations\":{},\"originalName\":\"History of the World: Part I\",\"description\":\"Die Weltgeschichte als bunter Reigen von ihren Anfängen bis zur Zukunft, wobei konsequent mit bislang herrschenden falschen Vorstellungen aufgeräumt wird: zeitgenössische Kritik an Höhlenmalerei in der Steinzeit, Moses ungeschickter Umgang mit den Gebotstafeln, der erste Auftritt des Stand-up-Philosophen Comicus in Caesars Palast, die Wahrheit über das letzte Abendmahl, die spanische Inquisition als Musical-Nummer und obszöne Spielchen zur Zeit der Französischen Revolution.\",\"releaseDate\":\"1981-06-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ywmaTE1MV0xMroXvAvZ8FavESFQ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/huW5dZywslw6muqmpDtMl6Ywl3m.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"799882\"},\"name\":\"The Bluff\",\"nameTranslations\":{},\"originalName\":\"The Bluff\",\"description\":\"Als ihr ruhiges Leben auf einer abgelegenen Insel durch die Rückkehr ihres rachsüchtigen Ex-Kapitäns zerstört wird, muss eine erfahrene ehemalige Piratin sich ihrer blutigen Vergangenheit stellen und ihre tödlichen Talente einsetzen, um ihre Familie vor einer gnadenlosen Belagerung zu retten.\",\"releaseDate\":\"2026-02-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4zC5m3JdO76guCDd5YMh7wj7JnQ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hYgUkH7TusddHRtelj53I6gFOWR.jpg\"},\"genres\":[\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1199193\"},\"name\":\"Pose\",\"nameTranslations\":{},\"originalName\":\"Pose\",\"releaseDate\":\"2026-02-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qhyyyWrHUbl6QG4udAJj17CBa5.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/bAFnjhweXxHUWjmFzMTuX12Ud3b.jpg\"},\"genres\":[\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1159559\"},\"name\":\"Scream 7\",\"nameTranslations\":{},\"originalName\":\"Scream 7\",\"description\":\"Als in der beschaulichen Stadt, in der sich Sidney Prescott ein neues Leben aufgebaut hat, ein neuer Ghostface-Killer auftaucht, werden ihre schlimmsten Befürchtungen wahr: Ihre Tochter gerät ins Visier der Ermordung. Entschlossen, ihre Familie zu schützen, muss Sidney sich den Schrecken ihrer Vergangenheit stellen, um dem Blutvergießen ein für alle Mal ein Ende zu setzen.\",\"releaseDate\":\"2026-02-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5VhF4IxrieKUVBYZ5As4AVphsUH.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hz7TdCrpLLt2Dz7S3PS2HG9rpAO.jpg\"},\"genres\":[\"Horror\",\"Mystery\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"680493\"},\"name\":\"Return to Silent Hill\",\"nameTranslations\":{},\"originalName\":\"Return to Silent Hill\",\"description\":\"Als ein geheimnisvoller Brief James auf der Suche nach seiner großen Liebe zurück nach Silent Hill ruft, findet er eine einst bekannte Stadt vor, die von einem unbekannten Übel verwandelt wurde. Während James tiefer in die Dunkelheit abtaucht, begegnet er furchterregenden Gestalten, sowohl bekannten als auch neuen, und beginnt, an seinem eigenen Verstand zu zweifeln, während er versucht, die Realität zu verstehen und lange genug durchzuhalten, um seine verlorene Liebe zu retten.\",\"releaseDate\":\"2026-01-21\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cytGWiEiqGD8vxaSD7noaLrZwIR.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nTbO6UF944b0VZrgypMK5rFYRSW.jpg\"},\"genres\":[\"Mystery\",\"Drama\",\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1499984\"},\"name\":\"Gladiator Underground\",\"nameTranslations\":{},\"originalName\":\"Gladiator Underground\",\"releaseDate\":\"2025-08-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qLN16AeIjS5P5Kk5B6pBi1Mh1mi.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/O50sdY6JEwpU7cQRaFtTO9eSAk.jpg\"},\"genres\":[\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1401778\"},\"name\":\"Turbulence\",\"nameTranslations\":{},\"originalName\":\"Turbulence\",\"releaseDate\":\"2025-11-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/jRuiKL4S9UpLma2ZlM47xIu2gbe.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/vOV4Qy3g791OTzEndiSGoJwuI2M.jpg\"},\"genres\":[\"Thriller\",\"Action\",\"Abenteuer\",\"Drama\",\"Fantasy\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1634301\"},\"name\":\"Vanaveera\",\"nameTranslations\":{},\"originalName\":\"Vanaveera\",\"releaseDate\":\"2026-02-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/oBYExKI8E3bTzQjPkofhpV2EJon.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lmns2jlRmATs8OGWKcCkgrbHLM4.jpg\"},\"genres\":[\"Action\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1461181\"},\"name\":\"Hierarchy\",\"nameTranslations\":{},\"originalName\":\"Hierarchy\",\"releaseDate\":\"2025-08-15\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3KVq24NkOn98nrSEAFphnRWVWNd.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ImIRPOvlxKC1jsKld5ZEpxmvmV.jpg\"},\"genres\":[\"Action\",\"Krimi\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1236153\"},\"name\":\"Mercy\",\"nameTranslations\":{},\"originalName\":\"Mercy\",\"description\":\"LAPD-Detective Raymond steht, wie immer mehr in dieser dystopischen Zukunft, wegen des Mordes an seiner Frau vor Gericht. Die hochmoderne KI-Richterin Maddox, deren Einführung er einst selbst unterstützte, leitet schließlich das Verfahren gegen ihn. Binnen lediglich 90 Minuten muss der Gesetzeshüter nun seine eigene Unschuld hieb- und stichfest beweisen, bevor die künstliche Rechtsprechung über sein weiteres Leben – oder dessen Ende – entscheidet.\",\"releaseDate\":\"2026-01-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/lLyipreraQYBCpzABtqBXEeYlqJ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/7HKpc11uQfxnw0Y8tRUYn1fsKqE.jpg\"},\"genres\":[\"Science Fiction\",\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1088434\"},\"name\":\"Hellfire - Verbrannte Erde\",\"nameTranslations\":{},\"originalName\":\"Hellfire\",\"description\":\"Von seiner bewegten Vergangenheit verfolgt, hofft ein namenloser Mann in dem mitten im Nirgendwo des US-amerikanischen Südens gelegenen Städtchen Rondo, etwas Ruhe und Frieden zu finden. Schnell muss er jedoch feststellen, dass das Kaff und seine völlig verängstigten Einwohner von dem skrupellosen Verbrecherboss Jeremiah und dem auf seiner Gehaltsliste stehenden Sheriff Wiley terrorisiert werden. Als er Zeuge von brutalen Gewaltakten gegen harmlose Bürger wird, beschließt er, die Bösewichte nicht damit durchkommen zu lassen. Mit Hilfe seiner militärischen Ausbildung und des stattlichen Waffenarsenals, das er immer mit sich herumträgt, versucht er, Rondo als Ein-Mann-Armee von den Bösewichten zu befreien. Die setzen ihrerseits natürlich alles daran, sich seiner zu entledigen.\",\"releaseDate\":\"2026-02-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/korG41pRFj6npbX50dIszqFjx4j.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1gLFGrxHqQebqLWpISmoFR6XWtJ.jpg\"},\"genres\":[\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1084242\"},\"name\":\"Zoomania 2\",\"nameTranslations\":{},\"originalName\":\"Zootopia 2\",\"description\":\"Judy Hopps und Nick Wilde stoßen auf die rätselhafte Spur eines geheimnisvollen Reptils, das in Zootopia auftaucht und die Metropole völlig auf den Kopf stellt: Gary De'Snake! Um den Fall zu lösen, müssen die beiden Undercover in völlig unbekannte Stadtteile vordringen – und dabei wird ihre wachsende Partnerschaft auf eine harte Probe stellt.\",\"releaseDate\":\"2025-11-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/q4RqhHz21kwRyemR9gePrTstSSe.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5BeOSbwt6BR7q2Fax70lF4AIshD.jpg\"},\"genres\":[\"Animation\",\"Komödie\",\"Abenteuer\",\"Familie\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1419406\"},\"name\":\"Shadow Chase - Im Netz der Diebe\",\"nameTranslations\":{},\"originalName\":\"捕风追影\",\"description\":\"Wong Tak-chung ist ein pensionierter Überwachungsexperte der Polizei von Macau. Als eine Gangsterbande die Hafenstadt terrorisiert, sind seine ehemaligen Chefs allerdings am verzweifeln, weil seine Nachfolger den Verbrechern einfach nichts nachweisen können. Deshalb wird Wong aus dem Ruhestand zurück in den Dienst beordert. Gemeinsam mit einem Team junger Ermittler*innen, die mit modernster Technologie arbeiten, nimmt der Veteran sich des Falles an, verlässt sich dabei aber lieber weiterhin auf traditionelle Methoden und seine Old-School-Ausrüstung. Dass die Kollaboration zwischen Alt und Jung, abgebrüht und nassforsch nicht gerade reibungslos abläuft, ist glücklicherweise nur ein kleines Hindernis. Denn schnell stellen sich erste Ergebnisse ein. Als Fu Long-sheng, der Boss der Verbrecher, und sein psychopathischer Sohn Hu Feng bemerken, dass Wong und sein Team ihnen auf der Spur sind, gehen sie zum Frontalangriff auf die Cops über, die nun kompromisslos zusammenhalten müssen.\",\"releaseDate\":\"2025-08-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5u0SE4xPEfJdmgIpzQBzEIL2lsA.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/tn95fumbkVAgXjOuw9CQOg0aYQz.jpg\"},\"genres\":[\"Action\",\"Krimi\",\"Drama\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1523145\"},\"name\":\"Твое сердце будет разбито\",\"nameTranslations\":{},\"originalName\":\"Твое сердце будет разбито\",\"releaseDate\":\"2026-03-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/iGpMm603GUKH2SiXB2S5m4sZ17t.jpg\"},\"genres\":[\"Liebesfilm\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1266798\"},\"name\":\"Zone 3\",\"nameTranslations\":{},\"originalName\":\"Chien 51\",\"description\":\"Paris, 2045. Die Bevölkerung der Hauptstadt wird von einer künstlichen Intelligenz namens Alma überwacht und in drei Zonen unterteilt. In jeder Zone ist die gleiche soziale Schicht vertreten. Eines Tages wird der Schöpfer der KI ermordet. Die Ermittlungen werden Salia, einer Polizistin aus Zone 2, und Zem, einem Polizisten aus Zone 3, anvertraut.\",\"releaseDate\":\"2025-10-15\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5b2Ub037f5Z4eVLhpLlWrcGkdYD.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/OO75q1cTWWXDmy52bB79yzpxBt.jpg\"},\"genres\":[\"Thriller\",\"Science Fiction\",\"Krimi\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1497970\"},\"name\":\"Tom und Jerry: Der Verlorene Kompass\",\"nameTranslations\":{},\"originalName\":\"猫和老鼠：星盘奇缘\",\"releaseDate\":\"2025-08-02\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/fb91YKKxeG7kzB1oEicmvQICwC5.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/wmTBmCLPZSX5eAVAiBf8td8Hb9g.jpg\"},\"genres\":[\"Animation\",\"Komödie\",\"Familie\",\"Fantasy\",\"Abenteuer\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"840464\"},\"name\":\"Greenland 2\",\"nameTranslations\":{},\"originalName\":\"Greenland 2: Migration\",\"description\":\"Fünf Jahre nach dem verheerenden Einschlag des Kometen Clarke leben John (Gerard Butler), Allison (Morena Baccarin) und ihr Sohn Nathan (Roman Griffin Davis) noch immer in dem Bunker in Grönland, der ihr Überleben sicherte. Doch Frieden finden sie hier nicht: Luft und Wasser sind verseucht, Strahlungsstürme wüten über die Oberfläche und Fragmente des Kometen schweben noch immer in der Umlaufbahn und drohen auf die Erde zu stürzen. Als ein verheerendes Beben den Bunker zerstört, muss die Familie erneut aufbrechen und sich durch ein verwüstetes Europa bis zum einzig sicher scheinenden Ort auf dem Planeten durchschlagen – dem gigantischen Krater des Clarke-Kometen in Südfrankreich.  Ein absolutes Highlight für alle Action-Fans: Mit atemberaubenden Bildern, packender Spannung und einer emotionalen Familiengeschichte bietet GREENLAND 2 alles, was einen großen Endzeit-Blockbuster ausmacht.\",\"releaseDate\":\"2026-01-07\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4EfFRgXde2iFFDfdFDMAOB9RuYJ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/u9jE0R1nvkmdWu3bt7Op8joPywa.jpg\"},\"genres\":[\"Abenteuer\",\"Thriller\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"891644\"},\"name\":\"Zero - Wettlauf gegen die Zeit\",\"nameTranslations\":{},\"originalName\":\"Zero\",\"description\":\"Zwei Amerikaner erwachen in Dakar mit an ihren Körpern befestigten Bomben, deren Timer in zehn Stunden abläuft. Von einer bedrohlichen Stimme am Telefon gesteuert, führen die Männer eine Reihe gewalttätiger Aktionen aus, die in der Stadt zu starken Protesten gegen westlichen Einfluss führen.\",\"releaseDate\":\"2025-04-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/yuNU4a1s9UGPyKcnxDqicjihUVR.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/8h3Ev1xf3WBrzHD4fNOGs790GWZ.jpg\"},\"genres\":[\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1319280\"},\"name\":\"Run Baby Run\",\"nameTranslations\":{},\"originalName\":\"Run Baby Run\",\"releaseDate\":\"2024-08-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/p9e7gGdYfdRauIbh9dBu6PgzVGP.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/efcAOJ9Thm0NHzMk16Bpo4m550G.jpg\"},\"genres\":[\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"83533\"},\"name\":\"Avatar: Fire and Ash\",\"nameTranslations\":{},\"originalName\":\"Avatar: Fire and Ash\",\"description\":\"Nach dem verheerenden Krieg gegen die RDA und dem Verlust ihres ältesten Sohnes sehen sich Jake Sully und Neytiri mit einer neuen Bedrohung auf Pandora konfrontiert: dem Aschvolk, einem gewalttätigen und machthungrigen Na'vi-Stamm unter der Führung des skrupellosen Varang. Jakes Familie muss in einem Konflikt, der sie an ihre emotionalen und physischen Grenzen bringt, um ihr Überleben und die Zukunft von Pandora kämpfen. *Der Film enthält Sequenzen, die sich auf photosensitive Menschen oder Menschen mit photosensitiver Epilepsie auswirken könnten.\",\"releaseDate\":\"2025-12-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/lE9KpVwgeWHMwgwkNaeH5nEFh20.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/sdZSjtGUTSN8B3al5o0f2WoQfQQ.jpg\"},\"genres\":[\"Science Fiction\",\"Abenteuer\",\"Fantasy\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1368166\"},\"name\":\"The Housemaid - Wenn sie wüsste\",\"nameTranslations\":{},\"originalName\":\"The Housemaid\",\"description\":\"Nicht jeder Neuanfang bietet eine zweite Chance. Die 27-jährige Millie hofft nach der Entlassung aus dem Gefängnis als Hausmädchen bei einem wohlhabenden Ehepaar neu anzufangen. Doch schon bald merkt sie, dass sich hinter der Fassade aus Luxus und Eleganz eine dunkle Wahrheit verbirgt, die weitaus gefährlicher ist als ihre eigene. Ein verführerisches Spiel um Geheimnisse, Skandale und Macht beginnt…\",\"releaseDate\":\"2025-12-18\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/uXZ7i3BgcFkLdG5nD16zCDXPgjz.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5Q71GYwh2mOz5rr8tPTcvbeBWtN.jpg\"},\"genres\":[\"Drama\",\"Mystery\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1032892\"},\"name\":\"In the Blink of an Eye\",\"nameTranslations\":{},\"originalName\":\"In the Blink of an Eye\",\"description\":\"Drei über Jahrtausende hinweg verwobene Geschichten erzählen von Hoffnung, Gemeinschaft und dem Kreislauf des Lebens.\",\"releaseDate\":\"2026-01-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/odlnSrjODWOyZ2mZv5ZD1E2j1YH.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/uM5i623wwNfoGD97iwwQWQ7GlZL.jpg\"},\"genres\":[\"Drama\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1327819\"},\"name\":\"Hoppers\",\"nameTranslations\":{},\"originalName\":\"Hoppers\",\"description\":\"Das findet man am besten heraus, wenn man selbst zum Tier wird. In Disney Pixars HOPPERS gewinnt Tierfreundin Mabel als Biber äußerst überraschende Erkenntnisse. Aber anstatt sich an die Regeln zu halten, stellt sie die natürliche Ordnung völlig auf den Kopf und zettelt einen tierischen Aufstand an. Und das nur, weil sie unbedingt den Teich retten will.\",\"releaseDate\":\"2026-02-28\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/nP3oMYwggLjnv5v1oQSmUso6yTd.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/2RrLuIfIzGWWIH8IAEo6o0IYHmx.jpg\"},\"genres\":[\"Animation\",\"Familie\",\"Komödie\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1159831\"},\"name\":\"The Bride! - Es lebe die Braut\",\"nameTranslations\":{},\"originalName\":\"The Bride!\",\"description\":\"In den 1930er Jahren reist ein einsamer Frankenstein nach Chicago, um mit Hilfe eines Dr. Euphronius eine Gefährtin für sich zu erschaffen. Die beiden beleben eine ermordete junge Frau wieder und die Braut ist geboren. Sie übertrifft die Erwartungen der beiden und entfacht eine brennende Romanze, die Aufmerksamkeit der Polizei und eine wilde und radikale soziale Bewegung.\",\"releaseDate\":\"2026-03-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/p9Tm37C1C0yexPFx7bgTLQeDlKJ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/8XeUEIXiZiRNqz0EcKC65vje8Th.jpg\"},\"genres\":[\"Science Fiction\",\"Horror\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"755898\"},\"name\":\"Krieg der Welten\",\"nameTranslations\":{},\"originalName\":\"War of the Worlds\",\"description\":\"Will Radford ist ein Top-Cybersicherheitsanalytiker des Heimatschutzes, der potenzielle Bedrohungen für die nationale Sicherheit durch ein Massenüberwachungsprogramm aufspürt, bis ihn eines Tages ein Angriff eines unbekannten Wesens dazu bringt, sich zu fragen, ob die Regierung etwas vor ihm verbirgt … und vor dem Rest der Welt.\",\"releaseDate\":\"2025-07-29\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3dQfE0RRDgPEtTDY5iTM92DaqGA.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/iZLqwEwUViJdSkGVjePGhxYzbDb.jpg\"},\"genres\":[\"Science Fiction\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1311031\"},\"name\":\"Demon Slayer: Kimetsu no Yaiba Infinity Castle\",\"nameTranslations\":{},\"originalName\":\"劇場版「鬼滅の刃」無限城編 第一章 猗窩座再来\",\"description\":\"Während die Mitglieder des Dämonentöter-Korps und die Hashira in Vorbereitung auf den bevorstehenden Kampf gegen die Dämonen ein gemeinsames Krafttrainingsprogramm, das Hashira-Training, absolvieren, taucht Muzan Kibutsuji in der Ubuyashiki-Villa auf. Da der Leiter des Dämonenkorps in Gefahr ist, eilen Tanjiro und die Hashira zum Hauptquartier, werden aber von Muzan Kibutsuji in einen tiefen Abstieg in einen mysteriösen Raum gestürzt. Das Ziel, in das Tanjiro und das Dämonentöter-Korps gestürzt sind, ist die Festung der Dämonen - die Unendlichkeitsburg. Und so ist das Schlachtfeld für die finale Schlacht zwischen dem Dämonentöterkorps und den Dämonen bereitet.\",\"releaseDate\":\"2025-07-18\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cqlahADJmDdqQvLAPuEYD6EKPAN.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lNYympQM5O6QSInusbyG9eJDIe4.jpg\"},\"genres\":[\"Animation\",\"Action\",\"Fantasy\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1168190\"},\"name\":\"The Wrecking Crew\",\"nameTranslations\":{},\"originalName\":\"The Wrecking Crew\",\"description\":\"Die entfremdeten Halbbrüder Jonny und James kommen sich nach dem mysteriösen Tod ihres Vaters auf Hawaii wieder näher. Bei der Suche nach der Wahrheit decken sie eine Verschwörung auf, die ihre Familie zu zerreißen droht.\",\"releaseDate\":\"2026-01-28\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/jodAPxXMZppnmmJ9tccrmmq6YJ3.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/cz4vLJrmaV1zJlRYbxqtvLzeLWB.jpg\"},\"genres\":[\"Action\",\"Komödie\",\"Krimi\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1242898\"},\"name\":\"Predator: Badlands\",\"nameTranslations\":{},\"originalName\":\"Predator: Badlands\",\"description\":\"Ein noch junger Predator namens Dek wird von seinem eigenen Clan verstoßen. Die anderen sehen in ihm keinen starken, furchtlosen Krieger heranwachsen. Damit ist er für die Gemeinschaft wertlos, da niemand glaubt, dass Dek eine glorreiche Zukunft bei der Jagd bevorsteht. Fortan muss er also alleine auf einem abgelegenen Planeten klarkommen. Doch dort bleibt er nicht lange alleine. Dek stößt auf Thia mit der er eine unverhoffte Verbündete findet. Von nun an gehen die beiden also gemeinsam auf die Jagd und treffen einen weiteren Weggefährten. Zu dritt müssen sie sich schließlich auch einer scheinbar übermächtigen Bedrohung stellen. Im Laufe ihres gemeinsamen Abenteuers werden sie beste Freunde und lernen, einander auch in ausweglosen Situationen zu vertrauen. Dek wächst dabei als Jäger über sich hinaus und lernt, richtig gut zu jagen.\",\"releaseDate\":\"2025-11-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/lxw9cD6g5Ccfml1PthmO6YT2aMp.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gaKFXcB5J1gz0QqYj8bWIfrPc04.jpg\"},\"genres\":[\"Action\",\"Science Fiction\",\"Abenteuer\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1353333\"},\"name\":\"Mouseboat Massacre\",\"nameTranslations\":{},\"originalName\":\"Mouseboat Massacre\",\"releaseDate\":\"2025-05-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ctKqevqOwbeVg5GLQLu5VvnCjan.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/wt0gb7ISUf8IyaJ4tnZVltvWoo7.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"937101\"},\"name\":\"動物感傷の清晨\",\"nameTranslations\":{},\"originalName\":\"動物感傷の清晨\",\"releaseDate\":\"2023-10-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/dUcIdXXBBFhJcvnNhdpcxHN2UTL.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hoqE4Saa4fQyWhUxws2Lw4qv2oz.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1272837\"},\"name\":\"28 Years Later: The Bone Temple\",\"nameTranslations\":{},\"originalName\":\"28 Years Later: The Bone Temple\",\"description\":\"Nia DaCosta knüpft an die Welt an, die Danny Boyle und Alex Garland in „28 Years Later“ geschaffen haben – und stellt sie auf den Kopf. In der Fortsetzung dieser epischen Geschichte findet sich Dr. Kelson in einer schockierenden neuen Beziehung wieder – mit Konsequenzen, die die Welt, wie sie sie kennen, verändern könnten –, und Spikes (Alfie Williams) Begegnung mit Jimmy Crystal wird zu einem Albtraum, dem er nicht entkommen kann. In der Welt von The Bone Temple sind die Infizierten nicht mehr die größte Bedrohung für das Überleben – die Unmenschlichkeit der Überlebenden kann seltsamer und erschreckender sein.\",\"releaseDate\":\"2026-01-14\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qCyxbvtCm3V4KPEEFzTFK5HIFRT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hHDNOlATHhre4eZ7aYz5cdyJLik.jpg\"},\"genres\":[\"Horror\",\"Thriller\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"879945\"},\"name\":\"L'homme inconnu\",\"nameTranslations\":{},\"originalName\":\"L'homme inconnu\",\"releaseDate\":\"2021-10-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4TpBhdaSl5ALHbgeaYOLF8Q3haz.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/7uXzE0ZBkbAeKylOz7cUQF4Yw75.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1316092\"},\"name\":\"“Wuthering Heights” – Sturmhöhe\",\"nameTranslations\":{},\"originalName\":\"\\\"Wuthering Heights\\\"\",\"description\":\"Der Film, basierend auf dem gleichnamigen Roman von Emily Brontë aus dem Jahr 1847, erzählt die tragische Liebesgeschichte zwischen Cathy, einer wohlhabenden jungen Frau des 19. Jahrhunderts, und Heathcliff, einem gesellschaftlichen Außenseiter. Nachdem Cathy sich aus gesellschaftlichen Gründen für einen anderen Mann entscheidet, kehrt Heathcliff nach Jahren nach Wuthering Heights zurück, um sich seiner Vergangenheit zu stellen und um ihre Liebe zu kämpfen.\",\"releaseDate\":\"2026-02-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/zuXjNG3o6as2au643nyXcdiKrfB.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/vSQSYd2zZTqc0zmHImwWEGGluMI.jpg\"},\"genres\":[\"Liebesfilm\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1549519\"},\"name\":\"Sex Trip\",\"nameTranslations\":{},\"originalName\":\"Sex Trip\",\"releaseDate\":\"2026-02-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/sr4sLilBbPx4TfPnX2zzUxlySgu.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/q2UhJtqp4ONeARofhpIHx4S0ElU.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"804370\"},\"name\":\"Arco\",\"nameTranslations\":{},\"originalName\":\"Arco\",\"description\":\"Als der Junge Arco aus einer fernen Zukunft zufällig in die Welt der zehnjährigen Iris ins Jahr 2075 stürzt, müssen die beiden – unterstützt von ihrem Haushaltsroboter – über Zeit und Welten hinweg zusammenarbeiten, um Arco wieder nach Hause zu bringen.\",\"releaseDate\":\"2025-10-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/rWvbMnqLTpyTHmNii4TrnmgzpcS.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/iILwdZdpzJDhVn1TRJzS4GEZtVc.jpg\"},\"genres\":[\"Animation\",\"Abenteuer\",\"Fantasy\",\"Familie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1249508\"},\"name\":\"No Escape - Grizzly Night\",\"nameTranslations\":{},\"originalName\":\"Grizzly Night\",\"description\":\"Zwei Angriffe. Eine Nacht. Eine wahre Geschichte, die Amerika erschütterte. Im Sommer 1967 wird der Glacier-Nationalpark zum Schauplatz einer der blutigsten Nächte der US-Wildnis Geschichte. Zwei junge Frauen sterben bei getrennten Grizzly-Angriffen – nur neun Meilen voneinander entfernt. Mitten in der Dunkelheit muss eine unerfahrene Rangerin alles riskieren, um die Leben der anderen Touristen zu retten. Zwischen Naturgewalt, Panik und purer Angst formiert sich ein Rettungstrupp, der sich dem Unvorstellbaren stellt.\\r Die wahren Begebenheiten werden den Umgang mit Wildtieren in den USA für immer ändern und zur Entstehung heutiger Schutzregeln für Wildtiere führen.\",\"releaseDate\":\"2026-01-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/rxkqhRDmUIWPxzBux3iXDn8zDC8.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/i275mAQP4KhPtYUpMUgBGMmK4WN.jpg\"},\"genres\":[\"Horror\",\"Thriller\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"737709\"},\"name\":\"Tři nevinní\",\"nameTranslations\":{},\"originalName\":\"Tři nevinní\",\"releaseDate\":\"1974-03-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/beB35H9cn0jTBZeU2NZsOB1RVVV.jpg\"},\"genres\":[\"Komödie\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1389149\"},\"name\":\"अक्यूज़्ड\",\"nameTranslations\":{},\"originalName\":\"अक्यूज़्ड\",\"description\":\"Das Leben einer angesehenen Gynäkologin gerät aus den Fugen, als schwere Anschuldigungen gegen sie erhoben werden. Ihre Frau will der Wahrheit auf die Spur kommen.\",\"releaseDate\":\"2026-02-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/eeP55mdqj4KpWtEPBvZJoxmnkXI.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/8QRMlkCMFNKZM2ApnIaut5t4snf.jpg\"},\"genres\":[\"Thriller\",\"Mystery\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1555951\"},\"name\":\"Salikmata\",\"nameTranslations\":{},\"originalName\":\"Salikmata\",\"releaseDate\":\"2025-10-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/tto58PLymhlubrzRatwyUm6iWLw.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/dbvUYL1dN75xFH1QqQWQi4xYCuJ.jpg\"},\"genres\":[\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1297842\"},\"name\":\"G.O.A.T. - Bock auf große Sprünge\",\"nameTranslations\":{},\"originalName\":\"GOAT\",\"description\":\"Im Mittelpunkt der Geschichte steht Will, ein kleiner Ziegenbock mit großen Träumen. Er bekommt die einmalige Chance, einem Profiteam beizutreten und Roarball zu spielen – ein kontaktintensiver Hochleistungssport, bei dem die schnellsten und furchterregendsten Tiere der Welt dominieren. Wills neue Teammitglieder sind daher nicht gerade begeistert, nun eine schmächtige Ziege in ihrer Mannschaft zu haben, doch Will ist wild entschlossen, den Sport zu revolutionieren und ein für alle Mal zu beweisen, dass auch Kleine ganz groß rauskommen können.\",\"releaseDate\":\"2026-02-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/RV3EmWdwIoFz6knlYzpVk9WeYE.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1qwhYqg7YEZajh3Q4biqbuQoDq8.jpg\"},\"genres\":[\"Animation\",\"Komödie\",\"Familie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1244975\"},\"name\":\"The Orphans - Blutsbrüder\",\"nameTranslations\":{},\"originalName\":\"Les Orphelins\",\"description\":\"Gab und Driss waren einmal Freunde. Seit ihrer gemeinsamen Zeit im Waisenhaus haben sie sich allerdings zerstritten und führen nun völlig unterschiedliche Leben: Einer ist Polizist bei der IGPN,der internen Kontrollbehörde der französischen Nationalpolizei, der andere hat sich für ein Leben als Krimineller entschieden. Als ihre erste große Liebe bei einem seltsamen Unfall ums Leben kommt, schnappt sich deren 17-jährige Tochter Leïla Gabs Waffe und begibt sich auf die Spur einer mächtigen Organisation, die alles tun würde, um den Fall zu vertuschen. Gezwungen, zusammenzuarbeiten, müssen die beiden Waisen sie aufhalten, bevor sie eine Grenze überschreitet, von der es kein Zurück mehr gibt …\",\"releaseDate\":\"2025-08-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/e08WqjLKqcw6HqHK9QlH0XGxyGb.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/z4hZZQ1GRuNGdeeWfKZIt8PXrmX.jpg\"},\"genres\":[\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"24428\"},\"name\":\"Marvel's The Avengers\",\"nameTranslations\":{},\"originalName\":\"The Avengers\",\"description\":\"Nick Fury ist der Anführer der Organisation S.H.I.E.L.D., einer internationalen Friedensorganisation. Die Behörde ist ein Who's Who der Marvel Superhelden, mit Iron Man, Thor, Captain America, Hawkeye, dem Unglaublichen Hulk und Black Widow. Als die weltweite Sicherheit von Thors sinistrem Halbbruder Loki und seiner Schar bedroht wird, werden Nick Fury und sein Team all ihre Kräfte brauchen, um die Welt vor einer Katastrophe zu bewahren ...\",\"releaseDate\":\"2012-04-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/hGTqvK9WaI74szUDPMHXrrHfiH3.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/pGFQCp12a8andfPlpnmXz44IIvY.jpg\"},\"genres\":[\"Science Fiction\",\"Action\",\"Abenteuer\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1629382\"},\"name\":\"Banlieusards 3\",\"nameTranslations\":{},\"originalName\":\"Banlieusards 3\",\"description\":\"Noch immer trauernd, stellen sich die Traoré-Brüder den Konsequenzen ihrer Verbrechen und erhalten eine letzte Chance, einen neuen Weg einzuschlagen.\",\"releaseDate\":\"2026-03-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/rCkg72HTCyhvqez8ez9pJpaAmVs.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/jhfJZ82qzcMV4Kr7G0uczdU4n2v.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"7451\"},\"name\":\"xXx - Triple X\",\"nameTranslations\":{},\"originalName\":\"xXx\",\"description\":\"Vin Diesel ist Xander “xXx” Cage, Extremsportler und Adrenalinjunkie. Der tätowierte Draufgänger führt seine berüchtigten, lebensgefährlichen Stunts am liebsten in gestohlenen Luxusschlitten durch und besitzt nicht den geringsten Respekt vor jeglicher Autorität, ganz besonders nicht vor staatlicher – was xXx zum idealen Kandidaten für die Geheimmission des NSA-Agenten Gibbons macht. Dieser droht xXx mit einer Gefängnisstrafe, sollte er sich nicht bereit erklären, die äußerst gefährliche Untergrund-Organisation “Anarchie 99” zu infiltrieren. Unter der Führung des ehemaligen Soldaten Yorgi plant diese die Weltmächte USA und Russland mithilfe einer biologischen Waffe gegeneinander auszuspielen. Ein Himmelfahrtskommando wie es im Buche steht – genau das Richtige für xXx.\",\"releaseDate\":\"2002-08-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/o6QwWAedNuMoQ5yEqLaR1c81NoA.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/2OHa6ukEq3Hce7Pc2kvu8wkmMFY.jpg\"},\"genres\":[\"Action\",\"Abenteuer\",\"Thriller\",\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"157336\"},\"name\":\"Interstellar\",\"nameTranslations\":{},\"originalName\":\"Interstellar\",\"description\":\"Was Wissenschaftler, Politiker und Aktivisten seit Jahrzehnten prophezeien, ist eingetreten: Die Menschheit steht kurz davor, an einer globalen Nahrungsknappheit zugrunde zu gehen. Die einzige Hoffnung der Weltbevölkerung besteht in einem geheimen Projekt der US-Regierung, das von dem findigen Wissenschaftler Professor Brand geleitet wird. Der Plan sieht vor, eine Expedition in ein anderes Sternensystem zu starten, wo bewohnbare Planeten, Rohstoffe und vor allem Leben vermutet werden. Der Ingenieur und ehemalige NASA-Pilot Cooper und Brands Tochter Amelia führen die Besatzung an, die sich auf eine Reise ins Ungewisse begibt: Wurmlöcher sind so gut wie unerforscht und niemand kann mit Sicherheit sagen, was die Crew auf der anderen Seite erwartet. Ebenso ist unsicher, ob und wann Cooper und Brand wieder auf die Erde zurückkehren. Coopers Kinder, Tochter Murph und Sohn Tom, müssen mit Schwiegervater Donald zurückbleiben und auf seine Wiederkehr hoffen...\",\"releaseDate\":\"2014-11-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/hHdhfkkzt0Mwec33Ux177Z7CO8w.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/2ssWTSVklAEc98frZUQhgtGHx7s.jpg\"},\"genres\":[\"Abenteuer\",\"Drama\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1317288\"},\"name\":\"Marty Supreme\",\"nameTranslations\":{},\"originalName\":\"Marty Supreme\",\"description\":\"In den Hinterhöfen Manhattans träumt der junge Schuhverkäufer Marty von einer Zukunft, die ein paar Nummern größer ist als der kleine Schuhladen seines Onkels. Angetrieben von der Idee, Weltmeister im Tischtennis werden zu können, taucht er jede Nacht ab in die verrauchten Wettkampfhallen der Stadt, wo er sich mit viel Talent, der nötigen Chuzpe und dank der Hilfe seines besten Freundes ein paar Dollar dazu verdient. Zu wenig, um eine Profikarriere zu finanzieren und an den Turnieren in London, Paris oder Tokio teilnehmen zu können. Also ‚leiht‘ sich Marty kurzerhand Geld aus dem Safe seines Onkels, belügt seine Mutter ebenso wie seine Freundin (Odessa A’zion) und schmeißt sich schamlos an eine Hollywood-Diva (Gwyneth Paltrow) ran, deren Ehemann er gleichzeitig als Sponsor gewinnen will. Doch das ist erst der Anfang der Odyssey eines Mannes, der bereit ist, für Ruhm und Erfolg alles zu riskieren.\",\"releaseDate\":\"2025-12-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8LGm5kOZnWpUI4uiomBYit4GWdF.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/qKWDHofjMHPSEOTLaixkC9ZmjTT.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"858024\"},\"name\":\"Hamnet\",\"nameTranslations\":{},\"originalName\":\"Hamnet\",\"description\":\"Wir schreiben das Jahr 1580 und der im kleinen englischen Dorf Stratford-upon-Avon als Lateinlehrer arbeitende William Shakespeare verliebt sich in Agnes. Im Dorf wird hinter immer weniger vorgehaltener Hand vermutet, sie sei eigentlich gar keine Heilerin, sondern eine richtige Hexe. Aber das ist William egal. Die beiden stürzen sich Hals über Kopf in das gemeinsame Leben und bekommen auch schnell drei Kinder. Erst wird Susanna geboren, kurz darauf die Zwillinge Judith und Hamnet. Doch mit der Familie endet das Träumen zumindest für William noch nicht. Er will das Lehren endlich hinter sich lassen können und als Dramatiker arbeiten. Auf dem Land geht das jedoch eher schlecht als recht. Also geht er, ermutigt von Agnes, nach London. Erst ist die Familie als nur räumlich voneinander getrennt, dann pflügt die Pest durch das Land und tötet auch Hamnet mit gerade einmal elf Jahren. Das treibt William an, seinem Sohn zu Ehren ein Stück zu schreiben...\",\"releaseDate\":\"2025-11-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/Ua43qwtLJNtFcTeAtO3q1SG5NV.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/73BClq9FOcrWrutnpiqhCNEWEwJ.jpg\"},\"genres\":[\"Drama\",\"Liebesfilm\",\"Historie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"434853\"},\"name\":\"Space/Time\",\"nameTranslations\":{},\"originalName\":\"Space/Time\",\"description\":\"Nach einem tödlichen Test, der ihr Projekt stoppt, taucht ein entehrtes Team von Wissenschaftlern in die kriminelle Unterwelt ein, um einen verbotenen raumverbiegenden Motor neu zu bauen – eine Maschine, die die Menschheit retten oder sie vollständig auslöschen könnte.\",\"releaseDate\":\"2025-05-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/uje1ecKMnNpZp0at5TxlvVgVXqI.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/w1Z1I9PqTK5UjG6RVAFXLCjp1Sw.jpg\"},\"genres\":[\"Science Fiction\",\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1305781\"},\"name\":\"镖人：风起大漠\",\"nameTranslations\":{},\"originalName\":\"镖人：风起大漠\",\"releaseDate\":\"2026-02-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/AsWzPlQK2xJTIrzw6McT8Yvy6H2.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/cYyNJzwhaj7aC4uTlUctrfaERbf.jpg\"},\"genres\":[\"Action\",\"Drama\",\"Historie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1234731\"},\"name\":\"Anaconda\",\"nameTranslations\":{},\"originalName\":\"Anaconda\",\"description\":\"DIES IST KEIN REBOOT, sondern ist eine völlig neue Komödie, inspiriert vom „Klassiker“ Anaconda, in der Doug und Griff die Hauptrollen spielen. Die beiden sind seit ihrer Kindheit beste Freunde und träumen schon immer davon, ihren absoluten Lieblingsfilm neu zu verfilmen. Ihre Midlife-Crisis treibt sie dazu, ihren Traum endlich in die Tat umzusetzen. Sie reisen tief in den Amazonas, um mit den Dreharbeiten zu beginnen. Doch aus Spaß wird schnell Ernst, als plötzlich eine echte Riesenanaconda auftaucht – und das chaotisch-komische Filmset in eine tödliche Falle verwandelt.\",\"releaseDate\":\"2025-12-24\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/gEd2zQkOuPTMWmyJ3374cZ5iPLn.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/swxhEJsAWms6X1fDZ4HdbvYBSf9.jpg\"},\"genres\":[\"Abenteuer\",\"Komödie\",\"Horror\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1151993\"},\"name\":\"Fränk\",\"nameTranslations\":{},\"originalName\":\"Fränk\",\"releaseDate\":\"2025-03-21\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/zkcmXoYpBiDVocovHTaEsIXaD6J.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/9sbvQ3J4tWwJzFuIRJ1pirvIXDK.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1193501\"},\"name\":\"Whistle\",\"nameTranslations\":{},\"originalName\":\"Whistle\",\"description\":\"Eine Gruppe unangepasster Highschool-Schüler stößt auf eine alte aztekische Todespfeife. Sie entdecken, dass der furchterregende Klang, den sie ausstößt, sie in Zukunft zum Tode zwingt und sie aufspürt. Während die Zahl der Toten steigt, untersuchen die Freunde die Herkunft des tödlichen Artefakts in einem verzweifelten Versuch, die schreckliche Kette der Ereignisse zu stoppen, die sie selbst in Gang gesetzt haben.\",\"releaseDate\":\"2026-01-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4PvnAwa0JUo6ATPy15tiBxRwfP6.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yJi6g0CnsqANLNuVaRX28tZxeHX.jpg\"},\"genres\":[\"Horror\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1336595\"},\"name\":\"Fürst Seppl\",\"nameTranslations\":{},\"originalName\":\"Fürst Seppl\",\"description\":\"In dieser Komödie verwandelt sich ein einfaches Gasthaus in den Bergen in ein Grandhotel.\",\"releaseDate\":\"1932-10-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/oP9v0pu4RlC5UGU6ayB3YCDxrJl.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1601243\"},\"name\":\"Oscar Shaw\",\"nameTranslations\":{},\"originalName\":\"Oscar Shaw\",\"releaseDate\":\"2026-01-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/tsE3nySukwrfUjouz8vzvKTcXNC.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/6D6M5z4reppUxo2cnBEKI02Csp1.jpg\"},\"genres\":[\"Action\",\"Krimi\",\"Thriller\",\"Western\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1167307\"},\"name\":\"David\",\"nameTranslations\":{},\"originalName\":\"David\",\"releaseDate\":\"2025-12-14\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7lFG1WrCwAxBfyGK8ahlBVzXno7.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/oN4TQ1TxchynXlFiXFBL3NHLT54.jpg\"},\"genres\":[\"Animation\",\"Familie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1301306\"},\"name\":\"A Woman Scorned\",\"nameTranslations\":{},\"originalName\":\"A Woman Scorned\",\"releaseDate\":\"2025-06-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/dlOSBiNULMPzKIze84LDjvEN9z1.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/uzZ7LUx4Bb3nZXjvBx5PiqTE7rk.jpg\"},\"genres\":[\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"482600\"},\"name\":\"일본 엄마\",\"nameTranslations\":{},\"originalName\":\"일본 엄마\",\"releaseDate\":\"2017-02-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/hq1EaYIqUNrPM3QFYAbnH2UHoX8.jpg\"},\"genres\":[\"Liebesfilm\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1306368\"},\"name\":\"The Rip\",\"nameTranslations\":{},\"originalName\":\"The Rip\",\"description\":\"Das Vertrauen bröckelt, als ein Polizeiteam in Miami in einem verwahrlosten Haus Bargeld in Millionenhöhe entdeckt. Plötzlich stellen sie einander – und einfach alles – infrage.\",\"releaseDate\":\"2026-01-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/t8DBuGkmnEEZi0UqhbUtiZZDWkG.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/3F2EXWF1thX0BdrVaKvnm6mAhqh.jpg\"},\"genres\":[\"Action\",\"Thriller\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1511417\"},\"name\":\"Bāhubali: The Epic\",\"nameTranslations\":{},\"originalName\":\"Bāhubali: The Epic\",\"description\":\"Als ein Stammespaar in der Nähe eines tosenden Wasserfalls ein mysteriöses Kind findet, ziehen sie es wie ihr eigenes auf. Während er heranwächst, fühlt sich Sivudu unwiderstehlich zu der Welt jenseits der Klippen hingezogen. Dort entdeckt er das uralte Königreich Mahishmati, das von einem grausamen Tyrannen beherrscht, von Rebellion geplagt und eng mit seiner eigenen Vergangenheit verwoben ist. Was als eine Suche nach der Liebe beginnt, entpuppt sich bald als ein Vermächtnis aus Verrat, Opferbereitschaft und der Geschichte eines vergessenen Prinzen.\",\"releaseDate\":\"2025-10-29\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4sLSorDKKDN944kWngxgQlpdDeg.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/wCwZ4ljSsWyZyTiyk1tGQtBHTDx.jpg\"},\"genres\":[\"Action\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1289893\"},\"name\":\"Somnium\",\"nameTranslations\":{},\"originalName\":\"Somnium\",\"releaseDate\":\"2025-08-28\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cPUeMJkPLDWSOA6OU862EdZhylS.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/xM2dUqkpaSHOR87ojZ538DGQqcD.jpg\"},\"genres\":[\"Horror\",\"Science Fiction\",\"Thriller\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1426964\"},\"name\":\"Brotherhood: Angstzustand\",\"nameTranslations\":{},\"originalName\":\"Salve Geral: Irmandade\",\"description\":\"Inmitten einer Welle der Gewalt muss eine Anwältin in São Paulo mit Verbindungen zur Unterwelt einen Deal mit der Polizei machen, um ihre entführte Nichte zu retten.\",\"releaseDate\":\"2026-02-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/tKchRMJTliVxllDld3L6KHS6Gya.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1Xdsq7U7bvJJd2X7Jg4qNaKVkYO.jpg\"},\"genres\":[\"Action\",\"Thriller\",\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"321261\"},\"name\":\"Jezioro osobliwości\",\"nameTranslations\":{},\"originalName\":\"Jezioro osobliwości\",\"releaseDate\":\"1973-05-27\",\"images\":{},\"genres\":[\"Drama\",\"Familie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"803796\"},\"name\":\"KPop Demon Hunters\",\"nameTranslations\":{},\"originalName\":\"KPop Demon Hunters\",\"description\":\"Wenn die K-Pop-Superstars Rumi, Mira und Zoey nicht gerade vor ausverkauften Stadien auftreten, setzen sie ihre geheimen Kräfte gegen übernatürliche Bedrohungen ein.\",\"releaseDate\":\"2025-06-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3Ps8dRYdD4kcJQACirB2Vfqs01c.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/w3Bi0wygeFQctn6AqFTwhGNXRwL.jpg\"},\"genres\":[\"Fantasy\",\"Musik\",\"Komödie\",\"Animation\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"591488\"},\"name\":\"Porto Santo\",\"nameTranslations\":{},\"originalName\":\"Porto Santo\",\"releaseDate\":\"1997-08-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/oW9rFP9kH1DxCZ4eNz7SqX9UZ27.jpg\"},\"genres\":[\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"513343\"},\"name\":\"Allein an der Front\",\"nameTranslations\":{},\"originalName\":\"Soldado Milhões\",\"description\":\"Flandern, Frühling 1918: Die deutsche Frühjahrsoffensive ist in vollem Gange und kostet hunderttausende von Menschenleben, darunter auch viele der 75.000 portugiesischen Soldaten, die an diesem Frontabschnitt ihren Dienst tun. Unter ihnen ist auch Aníbal Augusto Milhais (Miguel Borges/João Arrais). Als sich die Schlacht zugunsten der Deutschen wendet, verteidigt er allein mit einem Maschinengewehr den Rückzug der Entente-Streitkräfte in seinem Abschnitt und gerät hinter die deutschen Frontlinien. Er erinnert sich, welche Versprechen er den Menschen zuhause und seinen Kameraden gegeben hat - und erreicht das Unmögliche. „Allein an der Front“ basiert auf der wahren Geschichte des Soldaten Aníbal Milhais, genannt Soldado Milhões („Millionensoldat“), dessen Heldentum in Flandern vielen seiner Kameraden das Leben rettete.\",\"releaseDate\":\"2018-04-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/6MqhPrsb2hl4aZTPKTLrcJRdnZJ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/y0jBSKfIEnob6sBdRTD8B3rLuq8.jpg\"},\"genres\":[\"Kriegsfilm\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1061474\"},\"name\":\"Superman\",\"nameTranslations\":{},\"originalName\":\"Superman\",\"description\":\"Superman ist bereits seit einiger Zeit als Superheld in Metropolis aktiv und arbeitet unter dem Deckmantel seines menschlichen Alter Egos, dem Reporter Clark Kent, bei der Zeitung „Daily Planet\\\". Dort hat er auch die Reporterin Lois Lane kennengelernt, die tatsächlich als einzige von seiner geheimen Identität als Superman weiß. Gemeinsam mit zahlreichen anderen Helden und Heldinnen, darunter Guy Gardner alias Green Lantern, Mister Terrific, Hawkgirl und Metamorpho, beschützt Superman die Menschheit vor Bedrohungen, von denen es wirklich zahlreiche gibt. Doch eine Bedrohung, die sticht hervor: Supermans Erzfeind Lex Luthor versucht mit allen Mitteln, ihn endgültig aus dem Weg zu räumen und in Ungnade fallen zu lassen. Dafür stellt sich ihm auch Angela Spica, bekannt als „The Engineer\\\", in den Weg …\",\"releaseDate\":\"2025-07-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/fJKSDmkXDLZ0qDmAZ5lXEaToN3L.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yRBc6WY3r1Fz5Cjd6DhSvzqunED.jpg\"},\"genres\":[\"Science Fiction\",\"Abenteuer\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1054867\"},\"name\":\"One Battle After Another\",\"nameTranslations\":{},\"originalName\":\"One Battle After Another\",\"description\":\"Vor 16 Jahren hat die Widerstandsgruppe namens „French 75“ auf einen Schlag 200 Häftlinge aus den Fängen des skrupellosen United States Immigration and Customs Enforcement – kurz: ICE – befreit. Danach verschwanden die Widerständler, darunter auch der von allen nur Ghetto Pat genannte Bob Ferguson, von der Bildfläche. Heute ist Bob getrieben von Paranoia, denn er fürchtet, dass es der damalige ICE-Colonel Steven J. Lockjaw immer noch auf ihn abgesehen hat.\",\"releaseDate\":\"2025-09-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5k2WV1i6jcnbPmRhoXSEQWQGT9u.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gre7gyocZSuwd7M51CGlqsJqBmB.jpg\"},\"genres\":[\"Thriller\",\"Krimi\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1253000\"},\"name\":\"Deathstalker\",\"nameTranslations\":{},\"originalName\":\"Deathstalker\",\"description\":\"Ein mächtiger Schwertkämpfer namens Deathstalker birgt ein verfluchtes Amulett von einem mit Leichen übersäten Schlachtfeld. Gezeichnet von dunkler Magie und gejagt von monströsen Attentätern, muss er sich dem aufsteigenden Bösen stellen und den Fluch brechen.\",\"releaseDate\":\"2025-10-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/nEI3DnzQC1afAjJOAizx6UX27pL.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/cugd16e3WbCG3Zogb8N7lwUnVXH.jpg\"},\"genres\":[\"Fantasy\",\"Action\",\"Abenteuer\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1037830\"},\"name\":\"Kara Krus\",\"nameTranslations\":{},\"originalName\":\"Kara Krus\",\"releaseDate\":\"2022-11-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1uLCXYgdb9Xe92JvaClK2uNpRhF.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yK6506AW43aGv7hzZhmxIe64bjN.jpg\"},\"genres\":[\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"84654\"},\"name\":\"Black Orchid\",\"nameTranslations\":{},\"originalName\":\"Black Orchid\",\"releaseDate\":\"1953-02-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/als75LctSKUpDeDmROv8dIrusc8.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/eIYlVmArfW6fGRcmr515HwStk69.jpg\"},\"genres\":[\"Mystery\",\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1233413\"},\"name\":\"Blood & Sinners\",\"nameTranslations\":{},\"originalName\":\"Sinners\",\"description\":\"Beim Versuch, ihr von Problemen geplagtes Leben hinter sich zu lassen, kehren Zwillingsbrüder in ihre Heimatstadt zurück, um dort einen Neuanfang zu wagen. Doch schon bald müssen sie feststellen, dass bei ihrer Rückkehr ein noch größeres Übel auf sie wartet.\",\"releaseDate\":\"2025-04-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/445HsfnktkmM5y4cr62vYGzfo6h.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nAxGnGHOsfzufThz20zgmRwKur3.jpg\"},\"genres\":[\"Horror\",\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"429769\"},\"name\":\"Thee Nagar\",\"nameTranslations\":{},\"originalName\":\"Thee Nagar\",\"releaseDate\":\"2007-07-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/vNc1JsWyoPfQ8XDE5rTgiisp5zh.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1484100\"},\"name\":\"Jesus Land\",\"nameTranslations\":{},\"originalName\":\"Jesus Land\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/f2KKIxryNaN1VJ1p3k62up2ze4A.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"211879\"},\"name\":\"Free Range\",\"nameTranslations\":{},\"originalName\":\"Free Range\",\"description\":\"Fred, ein aufstrebender Schriftsteller, erfährt, dass seine Freundin schwanger ist, nachdem er aus seinem Job bei einer Zeitung entlassen wurde, weil er eine vernichtende Kritik über einen berühmten Film geschrieben hat.\",\"releaseDate\":\"2013-09-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ys2HISdhI0qQqcb4MGOZ3yzTE56.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/80bqGQ76UuO14jNSPyrRqQ4Z6Ks.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"991494\"},\"name\":\"SpongeBob Schwammkopf: Piraten Ahoi!\",\"nameTranslations\":{},\"originalName\":\"The SpongeBob Movie: Search for SquarePants\",\"description\":\"In ihrem brandneuen und bisher größten Kinoabenteuer, SPONGEBOB SCHWAMMKOPF: PIRATEN AHOI!, stechen SpongeBob und seine Freunde aus Bikini Bottom in See! SpongeBob, der endlich auch zu den Großen gehören möchte und Mr. Krabs seinen Mut beweisen will, folgt dem Fliegenden Holländer - einem mysteriösen, verwegenen Geisterpiraten. Und so beginnt ein rasantes und witziges Seefahrts-Abenteuer, das ihn in die tiefsten Tiefen der Tiefsee führt, wo noch kein Schwamm zuvor gewesen ist.\",\"releaseDate\":\"2025-12-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/M7KKeJfhV5AVJO8JCd5Hix0vyH.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/kVSUUWiXoNwq2wVCZ4Mcqkniqvr.jpg\"},\"genres\":[\"Animation\",\"Familie\",\"Komödie\",\"Abenteuer\",\"Fantasy\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"469689\"},\"name\":\"AWOL\",\"nameTranslations\":{},\"originalName\":\"AWOL\",\"releaseDate\":\"2017-08-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3loA03mCxvyFVTNG0PhvekBYVaH.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/e2la4oHFaZ8kcxi0qdK2C6q1bUo.jpg\"},\"genres\":[\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"223702\"},\"name\":\"Sausage Party - Es geht um die Wurst\",\"nameTranslations\":{},\"originalName\":\"Sausage Party\",\"description\":\"Für Lebensmittel im Supermarkt gibt es nur die eine wahre Bestimmung im Leben: In einen Einkaufswagen gelegt zu werden und zu einem Menschen mit nach Hause zu dürfen, um dort in eine Art himmlisches Paradies zu kommen! Wurst Frank wünscht sich nichts sehnlicher, als dort endlich in das sexy Hotdog-Brötchen Brenda gesteckt zu werden. Ein Glas Honigsenf, das in den Laden zurückgegeben wurde, versucht die anderen Produkte vor dem wirklichen, grausamen Schicksal zu warnen, das bei den Menschen auf sie wartet, aber weder Frank und Brenda noch deren leckeren Kollegen wie Sammy Bagel Jr. oder Vash wollen dem Horrorszenario Glauben schenken – bis sie schon bald in der Küche einer Einkäuferin am eigenen Leib erfahren, dass die gefräßigen Riesen selbst vor kleinen Karottenkindern keinen Halt machen…\",\"releaseDate\":\"2016-07-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/k0Ro4c88NilTjDvxyRG6X9VuAAP.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hsb8nNBt3emvWqBs7Xv5IKlz6Im.jpg\"},\"genres\":[\"Abenteuer\",\"Animation\",\"Komödie\",\"Fantasy\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"232923\"},\"name\":\"Money Mad\",\"nameTranslations\":{},\"originalName\":\"Money Mad\",\"releaseDate\":\"1908-12-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/dQYVw2aPqgM952bjGEpsSzWVorF.jpg\"},\"genres\":[\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1480387\"},\"name\":\"undertone\",\"nameTranslations\":{},\"originalName\":\"undertone\",\"releaseDate\":\"2026-03-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1wREWUEHzjDWSreNFbFLDO7YEaM.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/711jYfJrsY5x2R0Yh0pFeJTPWA7.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"799130\"},\"name\":\"Redeemed\",\"nameTranslations\":{},\"originalName\":\"Redeemed\",\"releaseDate\":\"2021-02-18\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8nzm2SW3SP7K8IEAmU6eNJjN4AY.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hby5Xvuhebvye4jOCC9pkGN2ATe.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"262966\"},\"name\":\"Netru Indru\",\"nameTranslations\":{},\"originalName\":\"Netru Indru\",\"releaseDate\":\"2014-06-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/T1gnd02hrmu6i8yfciPrY3UJzZ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/kMOKYPG0PLS7ogqAKuG1goGhMRS.jpg\"},\"genres\":[\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1306368\"},\"name\":\"The Rip\",\"nameTranslations\":{},\"originalName\":\"The Rip\",\"description\":\"Das Vertrauen bröckelt, als ein Polizeiteam in Miami in einem verwahrlosten Haus Bargeld in Millionenhöhe entdeckt. Plötzlich stellen sie einander – und einfach alles – infrage.\",\"releaseDate\":\"2026-01-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/t8DBuGkmnEEZi0UqhbUtiZZDWkG.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/3F2EXWF1thX0BdrVaKvnm6mAhqh.jpg\"},\"genres\":[\"Action\",\"Thriller\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1054867\"},\"name\":\"One Battle After Another\",\"nameTranslations\":{},\"originalName\":\"One Battle After Another\",\"description\":\"Vor 16 Jahren hat die Widerstandsgruppe namens „French 75“ auf einen Schlag 200 Häftlinge aus den Fängen des skrupellosen United States Immigration and Customs Enforcement – kurz: ICE – befreit. Danach verschwanden die Widerständler, darunter auch der von allen nur Ghetto Pat genannte Bob Ferguson, von der Bildfläche. Heute ist Bob getrieben von Paranoia, denn er fürchtet, dass es der damalige ICE-Colonel Steven J. Lockjaw immer noch auf ihn abgesehen hat.\",\"releaseDate\":\"2025-09-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5k2WV1i6jcnbPmRhoXSEQWQGT9u.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gre7gyocZSuwd7M51CGlqsJqBmB.jpg\"},\"genres\":[\"Thriller\",\"Krimi\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1171145\"},\"name\":\"Crime 101\",\"nameTranslations\":{},\"originalName\":\"Crime 101\",\"description\":\"Davis ist ein schwer fassbarer Juwelendieb, dessen Überfallserie die Polizei vor ein Rätsel stellt. Als er gerade den Coup seines Lebens ins Visier nimmt, trifft er auf die desillusionierte Versicherungsmanagerin Sharon, die selbst an einem Scheideweg steht. Überzeugt davon, ein Muster entdeckt zu haben, kommt währenddessen der unerbittliche Detective Lt. Lubesnik der ganzen Operation immer näher und erhöht damit das Risiko noch weiter.\",\"releaseDate\":\"2026-02-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/6T7ra8tsoYCQJMTZpkAqbKS17lE.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yWZc7ZglTAecVLKHS0oROuetKce.jpg\"},\"genres\":[\"Krimi\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"586068\"},\"name\":\"Malibú\",\"nameTranslations\":{},\"originalName\":\"Malibú\",\"releaseDate\":\"2021-09-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/absKtXXvkjE8ngwCGeSgXS7bqXX.jpg\"},\"genres\":[\"Drama\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"81661\"},\"name\":\"Tilva Roš\",\"nameTranslations\":{},\"originalName\":\"Tilva Roš\",\"releaseDate\":\"2011-01-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1AJYzDk22n1eil3yyNmfGADDJ8G.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/79j2EJTZdE92UAUsVu2aTSA65oU.jpg\"},\"genres\":[\"Drama\",\"Liebesfilm\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1242937\"},\"name\":\"The Dreadful\",\"nameTranslations\":{},\"originalName\":\"The Dreadful\",\"releaseDate\":\"2026-02-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/hGH8Ji7pG2ytHxo7ABqHM3TpzFA.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/fAF3VGFBpItWNROmiGob60n0y5.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1511633\"},\"name\":\"Nammoora Raja\",\"nameTranslations\":{},\"originalName\":\"Nammoora Raja\",\"releaseDate\":\"1988-04-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/y0Jnu1PymfyN8JQ9FcDHaPTIaKw.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/u7KZNB10fiAQlzKe1wQ2u4YrsJb.jpg\"},\"genres\":[\"Action\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"429769\"},\"name\":\"Thee Nagar\",\"nameTranslations\":{},\"originalName\":\"Thee Nagar\",\"releaseDate\":\"2007-07-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/vNc1JsWyoPfQ8XDE5rTgiisp5zh.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"650920\"},\"name\":\"Glück gehabt\",\"nameTranslations\":{},\"originalName\":\"Glück gehabt\",\"description\":\"Was als komödiantische Dreiecksgeschichte beginnt, entwickelt sich für Artur bald zu einem Horror-Trip, der blutig enden wird. Der talentierte, aber ehrgeizlose Comic-Zeichner verdingt sich als Angestellter in einem Copy-Shop. Seine Frau Rita hat den Sprung zur jüngsten Schuldirektorin der Stadt geschafft. Die routinierte Ehe der beiden wird einem dramatischen Stress-Test ausgesetzt, als die ebenso geheimnisvolle wie reizvolle Alice Arturs Leben umkrempelt. Je mehr er sich in diese verhängnisvolle Affäre verstrickt, desto weniger weiß er, wer seine Geliebte eigentlich ist.\",\"releaseDate\":\"2019-12-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/sLrWo3dkhA9DWjjTYCNwiDoP8mX.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"535451\"},\"name\":\"O Prego\",\"nameTranslations\":{},\"originalName\":\"O Prego\",\"releaseDate\":\"1997-11-21\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/lqXoQ69MOb47g4iCQivvWaxjjo6.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1037830\"},\"name\":\"Kara Krus\",\"nameTranslations\":{},\"originalName\":\"Kara Krus\",\"releaseDate\":\"2022-11-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1uLCXYgdb9Xe92JvaClK2uNpRhF.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yK6506AW43aGv7hzZhmxIe64bjN.jpg\"},\"genres\":[\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"305119\"},\"name\":\"Madame Bäurin\",\"nameTranslations\":{},\"originalName\":\"Madame Bäurin\",\"releaseDate\":\"1993-01-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/bm7D2M0IlM3beqULdpdAlmxOQkD.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/LZZ1VrlhLsubkbIbEQ1Ai6rxe7.jpg\"},\"genres\":[\"Drama\",\"Liebesfilm\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"211879\"},\"name\":\"Free Range\",\"nameTranslations\":{},\"originalName\":\"Free Range\",\"description\":\"Fred, ein aufstrebender Schriftsteller, erfährt, dass seine Freundin schwanger ist, nachdem er aus seinem Job bei einer Zeitung entlassen wurde, weil er eine vernichtende Kritik über einen berühmten Film geschrieben hat.\",\"releaseDate\":\"2013-09-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ys2HISdhI0qQqcb4MGOZ3yzTE56.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/80bqGQ76UuO14jNSPyrRqQ4Z6Ks.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1480387\"},\"name\":\"undertone\",\"nameTranslations\":{},\"originalName\":\"undertone\",\"releaseDate\":\"2026-03-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1wREWUEHzjDWSreNFbFLDO7YEaM.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/711jYfJrsY5x2R0Yh0pFeJTPWA7.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1443576\"},\"name\":\"Los domingos\",\"nameTranslations\":{},\"originalName\":\"Los domingos\",\"releaseDate\":\"2025-10-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/kwpDm6qtON8pLCSY0C8MltMofEE.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/jVwvhKpw6a7c7JmHhMykKAn7buQ.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1205225\"},\"name\":\"Gates of Flesh\",\"nameTranslations\":{},\"originalName\":\"Gates of Flesh\",\"releaseDate\":\"2025-04-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cOiuCeECSRqzpwuY6wYKQzvPcXm.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5arE7ysejlE2byGyakuUrR5TmUt.jpg\"},\"genres\":[\"Horror\",\"Thriller\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1110034\"},\"name\":\"Kraken\",\"nameTranslations\":{},\"originalName\":\"Kraken\",\"description\":\"Eine Meeresbiologin untersucht eine Fischfarm, als mehrere Teenager unter mysteriösen Umständen ums Leben kommen. Ungewöhnliche Ereignisse lassen vermuten, dass in den Tiefen des Fjords ein riesiges, vielarmiges Wesen lauert. Auf der Suche nach Antworten geht sie der Frage nach, ob sich in Norwegens tiefstem Fjord tatsächlich ein legendäres Monster verbirgt.\",\"releaseDate\":\"2026-02-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/s8u6BmcOSJGVoxswoo0wDm6naAT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/xcBlMEvzuaHoWANKYn5PGvcW4OC.jpg\"},\"genres\":[\"Horror\",\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"196991\"},\"name\":\"Ystävät, toverit\",\"nameTranslations\":{},\"originalName\":\"Ystävät, toverit\",\"releaseDate\":\"1990-11-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/w1gwEiuMTbZH9ohSQC2TkYgVyG7.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/sVdRqbNr6Xdpwyi66ep22YY2eBU.jpg\"},\"genres\":[\"Drama\",\"Kriegsfilm\",\"Historie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1584215\"},\"name\":\"The Internship - Praktikum im Töten\",\"nameTranslations\":{},\"originalName\":\"The Internship\",\"description\":\"Eine von der CIA ausgebildete Attentäterin rekrutiert andere Absolventen des geheimen Programms „The Internship“, dem auch sie angehörte und das Ihre Kindheit und die vieler anderer zerstört hat, um diese Organisation gewaltsam zu zerschlagen. Die CIA schlägt mit tödlicher Gewalt zurück.\",\"releaseDate\":\"2026-01-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/swO8i4150zNjNpFESjHE28rN94M.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/eUERZRVjCTNdgnESlQxyaOJ2d4K.jpg\"},\"genres\":[\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"911430\"},\"name\":\"F1 - Der Film\",\"nameTranslations\":{},\"originalName\":\"F1\",\"description\":\"In den 1990er Jahren galt Sonny Hayes noch als die nächste große Nummer im Rennsport und der höchsten Klasse, der Formel 1. Doch auch als Rennfahrer legt man seinen Körper in die Waagschale und muss letztlich mit dem Schlimmsten rechnen. Für Sonny Hayes bedeutet das das Ende seiner Karriere als Formel-1-Profi nach einem folgenschweren Unfall auf der Rennstrecke. Fortan dümpelt er in niedrigeren Rennklassen herum und hält sich drei Jahrzehnte nach seinem schicksalsträchtigen Unfall noch als Gelegenheitsrennfahrer über Wasser und versucht dabei, von seinem alten Formel-1-Ruf zu zehren. Sein damaliger Teamkollege Ruben Cervantes weiß das. Der ist mittlerweile Chef des Teams APXGP, das scheinbar hoffnungs- und punktlos am untersten Ende der Formel-1-Tabelle verweilt. Weil Cervantes damit also fast nichts mehr zu verlieren hat, will er Hayes zurück in die Königsklasse holen und ihn zusammen mit dem Rookie Noah genannten Joshua Pearce einen Rettungsanker für den Rennstall formen lassen.\",\"releaseDate\":\"2025-06-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8IUkPSxOh0KRbbVNYHSyBKQI5J0.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1KFv63mmcBGVbFl3jxxozoSFlhA.jpg\"},\"genres\":[\"Action\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"327835\"},\"name\":\"La collegiale\",\"nameTranslations\":{},\"originalName\":\"La collegiale\",\"releaseDate\":\"1975-01-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/m6PcX3AY92dLATCnpSWXCoRUVCE.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/y8XRFrymH4PxwgAo5mdKAX3ywg7.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"638607\"},\"name\":\"La Matinée\",\"nameTranslations\":{},\"originalName\":\"La Matinée\",\"releaseDate\":\"2007-10-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qnQvJ8Uw0R5KfLmzubgfAilnNoW.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/vtbKbpOpVuCwTZxtUssorYlswED.jpg\"},\"genres\":[\"Dokumentarfilm\",\"Musik\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1205225\"},\"name\":\"Gates of Flesh\",\"nameTranslations\":{},\"originalName\":\"Gates of Flesh\",\"releaseDate\":\"2025-04-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cOiuCeECSRqzpwuY6wYKQzvPcXm.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5arE7ysejlE2byGyakuUrR5TmUt.jpg\"},\"genres\":[\"Horror\",\"Thriller\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"241635\"},\"name\":\"Die 12 Monate\",\"nameTranslations\":{},\"originalName\":\"Dvanáct měsíčků\",\"description\":\"Die sanfte Marie lebt nach dem Tod ihres Vaters bei der herrischen Stiefmutter und deren verwöhnten Tochter Flora in einer abgeschiedenen Berghütte. Sie wird schikaniert und als Magd für alle niederen Arbeiten missbraucht.  Es ist der Heilige Abend, und der Bruder von Maries Kamerad \\\"Näschen\\\" kommt aus der weiten Welt ins Dorf zurück - Karl ist in der Fremde reich geworden und somit der ideale Bräutigam für alle Mädchen, die ihn bewundern und bedrängen.  Karl erhält von seinem Bruder den Rat, drei im Winter nahezu nicht zu bestehende Prüfungen der künftigen Braut aufzuerlegen, damit er Ruhe vor ihnen hat.  Kann Marie unentdeckt Wunder vollbringen und die weiteren Aufgaben für ihre Stiefschwester erfüllen oder entlarvt Karl die Gemeinheiten der beiden berechnenden Frauen?\",\"releaseDate\":\"2013-10-15\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ib6GEbTE6eRDRjOUwnueCHNuyqc.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/c5PkkwfwVzJJ9B57K4IXEw3yjMH.jpg\"},\"genres\":[\"Familie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1228841\"},\"name\":\"Objet a\",\"nameTranslations\":{},\"originalName\":\"Objet a\",\"images\":{},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1429605\"},\"name\":\"F Valentine's Day\",\"nameTranslations\":{},\"originalName\":\"F Valentine's Day\",\"description\":\"Gina hasst es, ausgerechnet am Valentinstag Geburtstag zu haben. Alle Geschenke, die sie zeitlebens bekommt, sind voller kitschiger roter Herzen und irgendwie auf „Liebe“ gemünzt. Eines Tages überreicht ihr Freund Andrew ihr zum Frühstück ein Vorab-Geschenk in Form eines Gutscheins über eine gemeinsame Reise auf eine griechische Insel. Dort will er mit ihr ihren Ehrentag verbringen – und ihr, wie Gina von ihrer Mutter Wendy erfährt, außerdem einen Heiratsantrag machen! Gina versucht nun Mittel und Wege zu finden, dass nicht auch dieser Tag noch mit dem Valentinstag „zusammengelegt“ wird. Vor Ort auf der Insel findet sie dabei unter anderem Komplizen in den Geschwistern Johnny und Mickey. Zusammen setzen sie alle Hebel in Bewegung, um Andrew zumindest am 14. Februar von seinem Vorhaben abzuhalten. Doch bei alledem beginnt Gina zu hinterfragen, ob Andrew überhaupt der Richtige für sie ist.\",\"releaseDate\":\"2026-02-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8zPExowfpfZOTpS1W4J7G27lH4H.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/zFpaNGxW0FzRFKBOyCFVeYlCdI9.jpg\"},\"genres\":[\"Liebesfilm\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1273221\"},\"name\":\"Scary Movie 6\",\"nameTranslations\":{},\"originalName\":\"Scary Movie\",\"releaseDate\":\"2026-06-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/opJeybZ5EL4zObkgFPFkke0KnIq.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lj6AaDqDUbzm2XJltFNHeAm2uXN.jpg\"},\"genres\":[\"Komödie\",\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1137618\"},\"name\":\"The Rooster\",\"nameTranslations\":{},\"originalName\":\"The Rooster\",\"releaseDate\":\"2024-02-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/z7cvgWyZWuk9GbaErLEXvPfSBZ9.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/orrQoynvx37E0cpZyC4Dnirz6Pl.jpg\"},\"genres\":[\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"456550\"},\"name\":\"Weiße Wäsche\",\"nameTranslations\":{},\"originalName\":\"Weiße Wäsche\",\"description\":\"Deutscher Spielfilm von Paul Heidemann aus dem Jahre 1942\",\"releaseDate\":\"1942-09-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/hMGLLvCy8axoSvfgvExJBPIhCDM.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"28317\"},\"name\":\"Blood Legend\",\"nameTranslations\":{},\"originalName\":\"Blood Legend\",\"releaseDate\":\"2006-02-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/CrZQDzFt05AkmuEn83mCesm95e.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lvy2ykHQ9ndUC4s5faBYuIfAQMo.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"39104\"},\"name\":\"Dragonball Z: Angriff der Cyborgs\",\"nameTranslations\":{},\"originalName\":\"ドラゴンボールＺ 極限バトル！三大超サイヤ人\",\"description\":\"In der Stadt tauchen die von Dr. Geros Computer erschaffen Cyborgs C14 und C15 auf. Die beiden Kampfmaschinen haben nur ein Ziel: Sie wollen Son-Goku töten. Trunks und Son-Goku gelingt es, die beiden Cyborgs in eine einsame Gegend zu locken, um dort ungestört kämpfen zu können. Unerwartet erscheint dort plötzlich ein weiterer gefährlicher Cyborg: C13. Es entbrennt ein heftiger Kampf, in den sich auch noch Vegeta einmischt. Als Super-Saiyajins gelingt es Son-Goku, Trunks und Vegeta, die Cyborgs C14 und C15 zu vernichten. Schnell stellt sich jedoch heraus, dass C13 ein viel stärkerer Gegner ist als die anderen beiden Cyborgs. Werden Son-Goku und seine Freunde es schaffen, den gefährlichen C13 zu vernichten?\",\"releaseDate\":\"1992-07-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1lY0dIt035XvCAMnboH7p8AlESN.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1u3yIvWFZaNDSSXmWYCYaNpCBBu.jpg\"},\"genres\":[\"Action\",\"Animation\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"704427\"},\"name\":\"The Audition\",\"nameTranslations\":{},\"originalName\":\"The Audition\",\"releaseDate\":\"2009-04-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5383yCLlS8oPNX1rTXPLIpELmo1.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"396364\"},\"name\":\"Mujercitas\",\"nameTranslations\":{},\"originalName\":\"Mujercitas\",\"releaseDate\":\"1973-12-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7BtFy8CPQySVOIv2Ueq2k5N2MSb.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/qMFYic5TlBUcErfu4MSyRAgvjGn.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1387382\"},\"name\":\"Hunting Season\",\"nameTranslations\":{},\"originalName\":\"Hunting Season\",\"description\":\"Als ein zurückgezogen lebender Überlebenskünstler und seine Tochter eine mysteriöse, verletzte Frau aus einem Fluss retten, werden sie in einem tödlichen Netz aus Gewalt und Rache verstrickt, das sie zwingt, sich einem brutalen Verbrecher zu stellen, um zu überleben.\",\"releaseDate\":\"2025-12-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cbryTyaWdqrKpQCw6K7zm2jrB5v.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/eJ0HooOOD1uzI39CfOQNWIiWKlJ.jpg\"},\"genres\":[\"Action\",\"Drama\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"429748\"},\"name\":\"Nee Jathaleka\",\"nameTranslations\":{},\"originalName\":\"Nee Jathaleka\",\"releaseDate\":\"2016-10-16\",\"images\":{\"backdrop\":\"https://image.tmdb.org/t/p/original/h66vSfzLqORwry48O8QjNULsTL6.jpg\"},\"genres\":[\"Liebesfilm\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"4247\"},\"name\":\"Scary Movie\",\"nameTranslations\":{},\"originalName\":\"Scary Movie\",\"description\":\"Aus scheinbar heiterem Himmel wird die jungfräuliche Cindy Campbell von einem unheimlichen Maskenmann attackiert, doch im Gegensatz zu manch anderem Freund aus ihrer Clique, den es in der Folgezeit noch erwischen wird, überlebt sie die Attacke. Cindy entwickelt den Verdacht, daß ein vor Jahresfrist bei einem von der Clique verursachten Unfall getöteter Passant sein Ableben nur vorgetäuscht hat und nunmehr Rache sucht. Gemeinsam mit dem tölpelhaften Dorfsherriff und einer rasenden Reporterin geht sie der Sache auf den Grund.\",\"releaseDate\":\"2000-07-07\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/fVQFPRuw3yWXojYDJvA5EoFjUOY.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/uHZRTGMFb1RLmgWcqlIOZsGbDCT.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1110034\"},\"name\":\"Kraken\",\"nameTranslations\":{},\"originalName\":\"Kraken\",\"description\":\"Eine Meeresbiologin untersucht eine Fischfarm, als mehrere Teenager unter mysteriösen Umständen ums Leben kommen. Ungewöhnliche Ereignisse lassen vermuten, dass in den Tiefen des Fjords ein riesiges, vielarmiges Wesen lauert. Auf der Suche nach Antworten geht sie der Frage nach, ob sich in Norwegens tiefstem Fjord tatsächlich ein legendäres Monster verbirgt.\",\"releaseDate\":\"2026-02-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/s8u6BmcOSJGVoxswoo0wDm6naAT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/xcBlMEvzuaHoWANKYn5PGvcW4OC.jpg\"},\"genres\":[\"Horror\",\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"924181\"},\"name\":\"Alimony\",\"nameTranslations\":{},\"originalName\":\"Alimony\",\"releaseDate\":\"1924-02-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/88jSAB0wjnjUqOrSyGaqFvw63kV.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lHuc6k0fwXbI1FhHrPuw8HcsgSt.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"396364\"},\"name\":\"Mujercitas\",\"nameTranslations\":{},\"originalName\":\"Mujercitas\",\"releaseDate\":\"1973-12-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7BtFy8CPQySVOIv2Ueq2k5N2MSb.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/qMFYic5TlBUcErfu4MSyRAgvjGn.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"638607\"},\"name\":\"La Matinée\",\"nameTranslations\":{},\"originalName\":\"La Matinée\",\"releaseDate\":\"2007-10-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qnQvJ8Uw0R5KfLmzubgfAilnNoW.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/vtbKbpOpVuCwTZxtUssorYlswED.jpg\"},\"genres\":[\"Dokumentarfilm\",\"Musik\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"28317\"},\"name\":\"Blood Legend\",\"nameTranslations\":{},\"originalName\":\"Blood Legend\",\"releaseDate\":\"2006-02-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/CrZQDzFt05AkmuEn83mCesm95e.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lvy2ykHQ9ndUC4s5faBYuIfAQMo.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"101\"},\"name\":\"Léon - Der Profi\",\"nameTranslations\":{},\"originalName\":\"Léon\",\"description\":\"Die 12-jährige Mathilda wächst nicht gerade in den besten Verhältnissen auf: Ihre Mutter arbeitet als Prostituierte, ihr Vater versteckt Drogen für den korrupten Polizisten Norman Stansfield. Als sich dieser eines Tages betrogen fühlt, richtet er kurzerhand die ganze Familie hin und nur Mathilda entgeht dem Massaker knapp. Verzweifelt bittet sie ihren wenig gesprächigen Nachbarn Léon um Hilfe, der sie nur widerwillig in die Wohnung lässt. Schon kurze Zeit später stellt sie fest, dass er sein Geld als Profikiller verdient. Sie beschließt ebenfalls Cleaner zu werden, um den Mord an ihrer Familie zu rächen...\",\"releaseDate\":\"1994-09-14\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/opbFMtNw76Bine2UjWfZ2TSpzVg.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/jRJrQ72VLyEnVsvwfep8Xjlvu8c.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1523431\"},\"name\":\"Kopitiam Days\",\"nameTranslations\":{},\"originalName\":\"Kopitiam Days\",\"releaseDate\":\"2025-08-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/tBIR8oVI8seF5yu5ztZ1hSrvzw2.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/scUF3CEHuatxK7Rpmy2YpFqJiEW.jpg\"},\"genres\":[\"Drama\",\"Science Fiction\",\"Komödie\",\"Action\",\"Fantasy\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1439073\"},\"name\":\"Cable reddy\",\"nameTranslations\":{},\"originalName\":\"Cable reddy\",\"images\":{},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1196067\"},\"name\":\"Worldbreaker\",\"nameTranslations\":{},\"originalName\":\"Worldbreaker\",\"description\":\"Nachdem die Breakers aufgetaucht sind – Wesen, die ihre Opfer infizieren und verwandeln – bricht die bestehende Ordnung zusammen. Zunächst fallen die Männer, wodurch Frauen gezwungen sind, den bewaffneten Widerstand zu übernehmen. Willas Mutter gehört zu den gefürchtetsten Kämpferinnen dieses Krieges, während ihr vom Erlebten gezeichneter Vater sich mit der Tochter auf eine abgelegene Insel zurückgezogen hat, um sie dort auf das Überleben vorzubereiten. Abgeschieden von der Außenwelt scheint ihr Alltag zunächst sicher, bis ein fremdes Mädchen an der Küste angespült wird. Aus dem Wunsch nach Nähe nimmt Willa sie heimlich bei sich auf. Als verborgene Wahrheiten ans Licht kommen, gerät der fragile Schutzraum in Gefahr.\",\"releaseDate\":\"2025-10-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7K8w6mdrJp0oaSoKWGyjSZ4Zv2z.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gMItMzDOyrfQGZsMWRM9tdxq5cV.jpg\"},\"genres\":[\"Science Fiction\",\"Action\",\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"263894\"},\"name\":\"Sabash Babu\",\"nameTranslations\":{},\"originalName\":\"Sabash Babu\",\"releaseDate\":\"1993-11-13\",\"images\":{},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1634858\"},\"name\":\"Cuerno Azulado\",\"nameTranslations\":{},\"originalName\":\"Cuerno Azulado\",\"releaseDate\":\"2025-09-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/q0OveDlsh5BNq6ifZqNWKtLKiwb.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/4IEjHlV6ciUPopHnEs5AfBNJ6XS.jpg\"},\"genres\":[\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"934433\"},\"name\":\"Scream 6\",\"nameTranslations\":{},\"originalName\":\"Scream VI\",\"description\":\"Die Schwestern Sam und Tara Carpenter haben genauso wie die Zwillinge Chad und Mindy Meeks die letzten Ghostface-Morde überlebt. Sie wollen die traumatischen Ereignisse von Woodsboro hinter sich lassen und in New York einen Neuanfang wagen. Allerdings scheint der Killer ihnen gefolgt zu sein und zieht jetzt mordend durch ihre Stadt. Obwohl die vier bereits ihre Erfahrungen mit Ghostface gemacht haben, müssen sie feststellen, dass dieser Killer ganz neue Tricks auf Lager hat.\",\"releaseDate\":\"2023-03-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/pi6ecVg0rWSJfrhVODzBiJ72Fzm.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/44immBwzhDVyjn87b3x3l9mlhAD.jpg\"},\"genres\":[\"Horror\",\"Thriller\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"616288\"},\"name\":\"Les Chercheurs\",\"nameTranslations\":{},\"originalName\":\"Les Chercheurs\",\"releaseDate\":\"2015-05-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/obg7IRGabukYsHP95rezE0hySSD.jpg\"},\"genres\":[\"Komödie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"405074\"},\"name\":\"Ariyathe Ishtamai\",\"nameTranslations\":{},\"originalName\":\"Ariyathe Ishtamai\",\"releaseDate\":\"2015-12-11\",\"images\":{},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1084244\"},\"name\":\"Toy Story 5\",\"nameTranslations\":{},\"originalName\":\"Toy Story 5\",\"description\":\"Die Aufgaben von Buzz, Woody, Jessie und Co. werden immer schwieriger, wenn sie es mit einer ganz neuen Bedrohung der Spielzeit zu tun bekommen: der Technik.\",\"releaseDate\":\"2026-06-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/gaiMtK2ll6BLdK1qKFuZGDwwEuD.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/coyHrYHD2xHhDoYD6o4uwoJ2o7b.jpg\"},\"genres\":[\"Animation\",\"Familie\",\"Komödie\",\"Abenteuer\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1140793\"},\"name\":\"Blindelings\",\"nameTranslations\":{},\"originalName\":\"Blindelings\",\"releaseDate\":\"2023-08-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/str96JbpJIm3uWFb8a0sr5EA0dY.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/pssj7zwdQIgYwXU8ko5pWKFallR.jpg\"},\"genres\":[\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"520761\"},\"name\":\"Thug Life\",\"nameTranslations\":{},\"originalName\":\"Thug Life\",\"releaseDate\":\"2017-07-21\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/rRapmpZGdBd5uw0hOZV7cBOvkoT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/vOqhVnuglgtWUxj9YsWh3GLJxD1.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"276005\"},\"name\":\"Purnima\",\"nameTranslations\":{},\"originalName\":\"Purnima\",\"releaseDate\":\"1965-05-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/raTVqzFujHl9n6lR1zATa6BivG4.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"85562\"},\"name\":\"Nightmare Asylum\",\"nameTranslations\":{},\"originalName\":\"Nightmare Asylum\",\"releaseDate\":\"1992-01-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/p9mJJNykTkTtr7O7MSAVRFhv7gS.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1234821\"},\"name\":\"Jurassic World: Die Wiedergeburt\",\"nameTranslations\":{},\"originalName\":\"Jurassic World Rebirth\",\"description\":\"Fünf Jahre nach den Ereignissen von 'Jurassic World: Ein neue Zeitalter' wird die Spezialistin für verdeckte Operationen, Zora Bennett, auf eine streng geheime Mission geschickt: Sie soll genetisches Material von den drei größten Dinosauriern der Welt sichern. Doch als ihr Team auf eine Familie trifft, deren Boot bei einem Ausflug gekentert ist, stranden sie gemeinsam auf einer abgelegenen Insel. Dort stoßen sie auf eine finstere und schockierende Entdeckung, die jahrzehntelang vor der Menschheit verborgen blieb – und deren Geheimnis alles verändern könnte.\",\"releaseDate\":\"2025-07-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/uUGZdps8TesT34lPMfvTWuyZmZe.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/zNriRTr0kWwyaXPzdg1EIxf0BWk.jpg\"},\"genres\":[\"Science Fiction\",\"Abenteuer\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"704427\"},\"name\":\"The Audition\",\"nameTranslations\":{},\"originalName\":\"The Audition\",\"releaseDate\":\"2009-04-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5383yCLlS8oPNX1rTXPLIpELmo1.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"560688\"},\"name\":\"Batan Güneş\",\"nameTranslations\":{},\"originalName\":\"Batan Güneş\",\"releaseDate\":\"1978-01-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/b33TYQ9X1BQ884eno0pWeFAHjOM.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/6AJ00nrApTZOyWAFV0gpg7miyX6.jpg\"},\"genres\":[\"Drama\",\"Musik\",\"Liebesfilm\",\"Familie\"],\"similarItems\":[]}],\"nextCursor\":8}"},"redirectURL":"","headersSize":691,"bodySize":30434,"_status":"completed","_startTimestamp":1772842820815352,"_endTimestamp":1772842821026368},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"2606:4700:3032::ac43:cdc0","connection":"12","comment":"","_id":39,"_uid":"6da42341-a40c-4413-baf8-cb49f21049ef","_cid":12,"_ctime":1772842816360,"_sid":49,"_stime":1772842820373,"_serverAddress":"2606:4700:3032::ac43:cdc0","_server