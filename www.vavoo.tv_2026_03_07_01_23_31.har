"},{"name":"content-length","value":"173"},{"name":"content-type","value":"application/json; charset=utf-8"},{"name":"mediahubmx-signature","value":""},{"name":"user-agent","value":"MediaHubMX/2"},{"name":"accept","value":"*/*"},{"name":"accept-encoding","value":"gzip,deflate"},{"name":"sec-fetch-site","value":"none"},{"name":"sec-fetch-mode","value":"no-cors"},{"name":"sec-fetch-dest","value":"empty"},{"name":"accept-language","value":"de"}],"queryString":[],"postData":{"mimeType":"application/json","text":"{\"language\":\"de\",\"region\":\"DE\",\"catalogId\":\"tmdb.movie\",\"id\":\"movie/popular\",\"adult\":false,\"search\":\"\",\"sort\":\"popularity\",\"filter\":{},\"cursor\":null,\"clientVersion\":\"3.0.2\"}"},"headersSize":966,"bodySize":173,"_status":"completed","_startTimestamp":1772842854739352,"_endTimestamp":1772842854935738},"response":{"status":200,"statusText":"","httpVersion":"HTTP/2.0","cookies":[],"headers":[{"name":":status","value":"200"},{"name":"date","value":"Sat, 07 Mar 2026 00:20:55 GMT"},{"name":"content-type","value":"application/json; charset=utf-8"},{"name":"server","value":"cloudflare"},{"name":"mediahubmx-endpoint","value":"."},{"name":"etag","value":"W/\"14cf2-b8m/XrBaEYpOKO0P43lAQFNOass\""},{"name":"strict-transport-security","value":"max-age=31536000; includeSubDomains"},{"name":"content-encoding","value":"gzip"},{"name":"cf-cache-status","value":"DYNAMIC"},{"name":"vary","value":"accept-encoding"},{"name":"nel","value":"{\"report_to\":\"cf-nel\",\"success_fraction\":0.0,\"max_age\":604800}"},{"name":"report-to","value":"{\"group\":\"cf-nel\",\"max_age\":604800,\"endpoints\":[{\"url\":\"https://a.nel.cloudflare.com/report/v4?s=Id5DyzsD%2BG42NZQVsl7oVCEjvz9njDUqAdUADWheLddLv3xMGh18fS9H7Fz7HWIlAlIb5ESAYqn5jT4K%2FR6MRbG0ogevfG1xDa596WAPBZnQwzBGHg%3D%3D\"}]}"},{"name":"cf-ray","value":"9d856fe3cdefda39-TXL"},{"name":"alt-svc","value":"h3=\":443\"; ma=86400"}],"content":{"size":85234,"mimeType":"application/json","text":"{\"options\":{},\"items\":[{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1290821\"},\"name\":\"Shelter\",\"nameTranslations\":{},\"originalName\":\"Shelter\",\"description\":\"Ein Mann, der sich auf einer abgelegenen Insel in selbstgewählter Abgeschiedenheit befindet, rettet ein junges Mädchen vor einem heftigen Sturm und löst damit eine Kette von Ereignissen aus, die ihn zwingen, seine Abgeschiedenheit zu verlassen, um sie vor Feinden aus seiner Vergangenheit zu schützen.\",\"releaseDate\":\"2026-01-28\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/buPFnHZ3xQy6vZEHxbHgL1Pc6CR.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nHxWyy18SvAZ8jJeemtS8k1UNjM.jpg\"},\"genres\":[\"Action\",\"Krimi\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"10156\"},\"name\":\"Mel Brooks - Die verrückte Geschichte der Welt\",\"nameTranslations\":{},\"originalName\":\"History of the World: Part I\",\"description\":\"Die Weltgeschichte als bunter Reigen von ihren Anfängen bis zur Zukunft, wobei konsequent mit bislang herrschenden falschen Vorstellungen aufgeräumt wird: zeitgenössische Kritik an Höhlenmalerei in der Steinzeit, Moses ungeschickter Umgang mit den Gebotstafeln, der erste Auftritt des Stand-up-Philosophen Comicus in Caesars Palast, die Wahrheit über das letzte Abendmahl, die spanische Inquisition als Musical-Nummer und obszöne Spielchen zur Zeit der Französischen Revolution.\",\"releaseDate\":\"1981-06-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ywmaTE1MV0xMroXvAvZ8FavESFQ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/huW5dZywslw6muqmpDtMl6Ywl3m.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"799882\"},\"name\":\"The Bluff\",\"nameTranslations\":{},\"originalName\":\"The Bluff\",\"description\":\"Als ihr ruhiges Leben auf einer abgelegenen Insel durch die Rückkehr ihres rachsüchtigen Ex-Kapitäns zerstört wird, muss eine erfahrene ehemalige Piratin sich ihrer blutigen Vergangenheit stellen und ihre tödlichen Talente einsetzen, um ihre Familie vor einer gnadenlosen Belagerung zu retten.\",\"releaseDate\":\"2026-02-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4zC5m3JdO76guCDd5YMh7wj7JnQ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hYgUkH7TusddHRtelj53I6gFOWR.jpg\"},\"genres\":[\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1199193\"},\"name\":\"Pose\",\"nameTranslations\":{},\"originalName\":\"Pose\",\"releaseDate\":\"2026-02-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qhyyyWrHUbl6QG4udAJj17CBa5.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/bAFnjhweXxHUWjmFzMTuX12Ud3b.jpg\"},\"genres\":[\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1159559\"},\"name\":\"Scream 7\",\"nameTranslations\":{},\"originalName\":\"Scream 7\",\"description\":\"Als in der beschaulichen Stadt, in der sich Sidney Prescott ein neues Leben aufgebaut hat, ein neuer Ghostface-Killer auftaucht, werden ihre schlimmsten Befürchtungen wahr: Ihre Tochter gerät ins Visier der Ermordung. Entschlossen, ihre Familie zu schützen, muss Sidney sich den Schrecken ihrer Vergangenheit stellen, um dem Blutvergießen ein für alle Mal ein Ende zu setzen.\",\"releaseDate\":\"2026-02-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5VhF4IxrieKUVBYZ5As4AVphsUH.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hz7TdCrpLLt2Dz7S3PS2HG9rpAO.jpg\"},\"genres\":[\"Horror\",\"Mystery\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"680493\"},\"name\":\"Return to Silent Hill\",\"nameTranslations\":{},\"originalName\":\"Return to Silent Hill\",\"description\":\"Als ein geheimnisvoller Brief James auf der Suche nach seiner großen Liebe zurück nach Silent Hill ruft, findet er eine einst bekannte Stadt vor, die von einem unbekannten Übel verwandelt wurde. Während James tiefer in die Dunkelheit abtaucht, begegnet er furchterregenden Gestalten, sowohl bekannten als auch neuen, und beginnt, an seinem eigenen Verstand zu zweifeln, während er versucht, die Realität zu verstehen und lange genug durchzuhalten, um seine verlorene Liebe zu retten.\",\"releaseDate\":\"2026-01-21\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cytGWiEiqGD8vxaSD7noaLrZwIR.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nTbO6UF944b0VZrgypMK5rFYRSW.jpg\"},\"genres\":[\"Mystery\",\"Drama\",\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1499984\"},\"name\":\"Gladiator Underground\",\"nameTranslations\":{},\"originalName\":\"Gladiator Underground\",\"releaseDate\":\"2025-08-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qLN16AeIjS5P5Kk5B6pBi1Mh1mi.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/O50sdY6JEwpU7cQRaFtTO9eSAk.jpg\"},\"genres\":[\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1401778\"},\"name\":\"Turbulence\",\"nameTranslations\":{},\"originalName\":\"Turbulence\",\"releaseDate\":\"2025-11-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/jRuiKL4S9UpLma2ZlM47xIu2gbe.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/vOV4Qy3g791OTzEndiSGoJwuI2M.jpg\"},\"genres\":[\"Thriller\",\"Action\",\"Abenteuer\",\"Drama\",\"Fantasy\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1634301\"},\"name\":\"Vanaveera\",\"nameTranslations\":{},\"originalName\":\"Vanaveera\",\"releaseDate\":\"2026-02-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/oBYExKI8E3bTzQjPkofhpV2EJon.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lmns2jlRmATs8OGWKcCkgrbHLM4.jpg\"},\"genres\":[\"Action\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1461181\"},\"name\":\"Hierarchy\",\"nameTranslations\":{},\"originalName\":\"Hierarchy\",\"releaseDate\":\"2025-08-15\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3KVq24NkOn98nrSEAFphnRWVWNd.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/ImIRPOvlxKC1jsKld5ZEpxmvmV.jpg\"},\"genres\":[\"Action\",\"Krimi\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1236153\"},\"name\":\"Mercy\",\"nameTranslations\":{},\"originalName\":\"Mercy\",\"description\":\"LAPD-Detective Raymond steht, wie immer mehr in dieser dystopischen Zukunft, wegen des Mordes an seiner Frau vor Gericht. Die hochmoderne KI-Richterin Maddox, deren Einführung er einst selbst unterstützte, leitet schließlich das Verfahren gegen ihn. Binnen lediglich 90 Minuten muss der Gesetzeshüter nun seine eigene Unschuld hieb- und stichfest beweisen, bevor die künstliche Rechtsprechung über sein weiteres Leben – oder dessen Ende – entscheidet.\",\"releaseDate\":\"2026-01-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/lLyipreraQYBCpzABtqBXEeYlqJ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/7HKpc11uQfxnw0Y8tRUYn1fsKqE.jpg\"},\"genres\":[\"Science Fiction\",\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1088434\"},\"name\":\"Hellfire - Verbrannte Erde\",\"nameTranslations\":{},\"originalName\":\"Hellfire\",\"description\":\"Von seiner bewegten Vergangenheit verfolgt, hofft ein namenloser Mann in dem mitten im Nirgendwo des US-amerikanischen Südens gelegenen Städtchen Rondo, etwas Ruhe und Frieden zu finden. Schnell muss er jedoch feststellen, dass das Kaff und seine völlig verängstigten Einwohner von dem skrupellosen Verbrecherboss Jeremiah und dem auf seiner Gehaltsliste stehenden Sheriff Wiley terrorisiert werden. Als er Zeuge von brutalen Gewaltakten gegen harmlose Bürger wird, beschließt er, die Bösewichte nicht damit durchkommen zu lassen. Mit Hilfe seiner militärischen Ausbildung und des stattlichen Waffenarsenals, das er immer mit sich herumträgt, versucht er, Rondo als Ein-Mann-Armee von den Bösewichten zu befreien. Die setzen ihrerseits natürlich alles daran, sich seiner zu entledigen.\",\"releaseDate\":\"2026-02-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/korG41pRFj6npbX50dIszqFjx4j.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1gLFGrxHqQebqLWpISmoFR6XWtJ.jpg\"},\"genres\":[\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1084242\"},\"name\":\"Zoomania 2\",\"nameTranslations\":{},\"originalName\":\"Zootopia 2\",\"description\":\"Judy Hopps und Nick Wilde stoßen auf die rätselhafte Spur eines geheimnisvollen Reptils, das in Zootopia auftaucht und die Metropole völlig auf den Kopf stellt: Gary De'Snake! Um den Fall zu lösen, müssen die beiden Undercover in völlig unbekannte Stadtteile vordringen – und dabei wird ihre wachsende Partnerschaft auf eine harte Probe stellt.\",\"releaseDate\":\"2025-11-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/q4RqhHz21kwRyemR9gePrTstSSe.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5BeOSbwt6BR7q2Fax70lF4AIshD.jpg\"},\"genres\":[\"Animation\",\"Komödie\",\"Abenteuer\",\"Familie\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1419406\"},\"name\":\"Shadow Chase - Im Netz der Diebe\",\"nameTranslations\":{},\"originalName\":\"捕风追影\",\"description\":\"Wong Tak-chung ist ein pensionierter Überwachungsexperte der Polizei von Macau. Als eine Gangsterbande die Hafenstadt terrorisiert, sind seine ehemaligen Chefs allerdings am verzweifeln, weil seine Nachfolger den Verbrechern einfach nichts nachweisen können. Deshalb wird Wong aus dem Ruhestand zurück in den Dienst beordert. Gemeinsam mit einem Team junger Ermittler*innen, die mit modernster Technologie arbeiten, nimmt der Veteran sich des Falles an, verlässt sich dabei aber lieber weiterhin auf traditionelle Methoden und seine Old-School-Ausrüstung. Dass die Kollaboration zwischen Alt und Jung, abgebrüht und nassforsch nicht gerade reibungslos abläuft, ist glücklicherweise nur ein kleines Hindernis. Denn schnell stellen sich erste Ergebnisse ein. Als Fu Long-sheng, der Boss der Verbrecher, und sein psychopathischer Sohn Hu Feng bemerken, dass Wong und sein Team ihnen auf der Spur sind, gehen sie zum Frontalangriff auf die Cops über, die nun kompromisslos zusammenhalten müssen.\",\"releaseDate\":\"2025-08-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5u0SE4xPEfJdmgIpzQBzEIL2lsA.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/tn95fumbkVAgXjOuw9CQOg0aYQz.jpg\"},\"genres\":[\"Action\",\"Krimi\",\"Drama\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1523145\"},\"name\":\"Твое сердце будет разбито\",\"nameTranslations\":{},\"originalName\":\"Твое сердце будет разбито\",\"releaseDate\":\"2026-03-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/iGpMm603GUKH2SiXB2S5m4sZ17t.jpg\"},\"genres\":[\"Liebesfilm\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1266798\"},\"name\":\"Zone 3\",\"nameTranslations\":{},\"originalName\":\"Chien 51\",\"description\":\"Paris, 2045. Die Bevölkerung der Hauptstadt wird von einer künstlichen Intelligenz namens Alma überwacht und in drei Zonen unterteilt. In jeder Zone ist die gleiche soziale Schicht vertreten. Eines Tages wird der Schöpfer der KI ermordet. Die Ermittlungen werden Salia, einer Polizistin aus Zone 2, und Zem, einem Polizisten aus Zone 3, anvertraut.\",\"releaseDate\":\"2025-10-15\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5b2Ub037f5Z4eVLhpLlWrcGkdYD.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/OO75q1cTWWXDmy52bB79yzpxBt.jpg\"},\"genres\":[\"Thriller\",\"Science Fiction\",\"Krimi\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1497970\"},\"name\":\"Tom und Jerry: Der Verlorene Kompass\",\"nameTranslations\":{},\"originalName\":\"猫和老鼠：星盘奇缘\",\"releaseDate\":\"2025-08-02\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/fb91YKKxeG7kzB1oEicmvQICwC5.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/wmTBmCLPZSX5eAVAiBf8td8Hb9g.jpg\"},\"genres\":[\"Animation\",\"Komödie\",\"Familie\",\"Fantasy\",\"Abenteuer\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"840464\"},\"name\":\"Greenland 2\",\"nameTranslations\":{},\"originalName\":\"Greenland 2: Migration\",\"description\":\"Fünf Jahre nach dem verheerenden Einschlag des Kometen Clarke leben John (Gerard Butler), Allison (Morena Baccarin) und ihr Sohn Nathan (Roman Griffin Davis) noch immer in dem Bunker in Grönland, der ihr Überleben sicherte. Doch Frieden finden sie hier nicht: Luft und Wasser sind verseucht, Strahlungsstürme wüten über die Oberfläche und Fragmente des Kometen schweben noch immer in der Umlaufbahn und drohen auf die Erde zu stürzen. Als ein verheerendes Beben den Bunker zerstört, muss die Familie erneut aufbrechen und sich durch ein verwüstetes Europa bis zum einzig sicher scheinenden Ort auf dem Planeten durchschlagen – dem gigantischen Krater des Clarke-Kometen in Südfrankreich.  Ein absolutes Highlight für alle Action-Fans: Mit atemberaubenden Bildern, packender Spannung und einer emotionalen Familiengeschichte bietet GREENLAND 2 alles, was einen großen Endzeit-Blockbuster ausmacht.\",\"releaseDate\":\"2026-01-07\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4EfFRgXde2iFFDfdFDMAOB9RuYJ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/u9jE0R1nvkmdWu3bt7Op8joPywa.jpg\"},\"genres\":[\"Abenteuer\",\"Thriller\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"891644\"},\"name\":\"Zero - Wettlauf gegen die Zeit\",\"nameTranslations\":{},\"originalName\":\"Zero\",\"description\":\"Zwei Amerikaner erwachen in Dakar mit an ihren Körpern befestigten Bomben, deren Timer in zehn Stunden abläuft. Von einer bedrohlichen Stimme am Telefon gesteuert, führen die Männer eine Reihe gewalttätiger Aktionen aus, die in der Stadt zu starken Protesten gegen westlichen Einfluss führen.\",\"releaseDate\":\"2025-04-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/yuNU4a1s9UGPyKcnxDqicjihUVR.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/8h3Ev1xf3WBrzHD4fNOGs790GWZ.jpg\"},\"genres\":[\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1319280\"},\"name\":\"Run Baby Run\",\"nameTranslations\":{},\"originalName\":\"Run Baby Run\",\"releaseDate\":\"2024-08-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/p9e7gGdYfdRauIbh9dBu6PgzVGP.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/efcAOJ9Thm0NHzMk16Bpo4m550G.jpg\"},\"genres\":[\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"83533\"},\"name\":\"Avatar: Fire and Ash\",\"nameTranslations\":{},\"originalName\":\"Avatar: Fire and Ash\",\"description\":\"Nach dem verheerenden Krieg gegen die RDA und dem Verlust ihres ältesten Sohnes sehen sich Jake Sully und Neytiri mit einer neuen Bedrohung auf Pandora konfrontiert: dem Aschvolk, einem gewalttätigen und machthungrigen Na'vi-Stamm unter der Führung des skrupellosen Varang. Jakes Familie muss in einem Konflikt, der sie an ihre emotionalen und physischen Grenzen bringt, um ihr Überleben und die Zukunft von Pandora kämpfen. *Der Film enthält Sequenzen, die sich auf photosensitive Menschen oder Menschen mit photosensitiver Epilepsie auswirken könnten.\",\"releaseDate\":\"2025-12-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/lE9KpVwgeWHMwgwkNaeH5nEFh20.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/sdZSjtGUTSN8B3al5o0f2WoQfQQ.jpg\"},\"genres\":[\"Science Fiction\",\"Abenteuer\",\"Fantasy\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1368166\"},\"name\":\"The Housemaid - Wenn sie wüsste\",\"nameTranslations\":{},\"originalName\":\"The Housemaid\",\"description\":\"Nicht jeder Neuanfang bietet eine zweite Chance. Die 27-jährige Millie hofft nach der Entlassung aus dem Gefängnis als Hausmädchen bei einem wohlhabenden Ehepaar neu anzufangen. Doch schon bald merkt sie, dass sich hinter der Fassade aus Luxus und Eleganz eine dunkle Wahrheit verbirgt, die weitaus gefährlicher ist als ihre eigene. Ein verführerisches Spiel um Geheimnisse, Skandale und Macht beginnt…\",\"releaseDate\":\"2025-12-18\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/uXZ7i3BgcFkLdG5nD16zCDXPgjz.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5Q71GYwh2mOz5rr8tPTcvbeBWtN.jpg\"},\"genres\":[\"Drama\",\"Mystery\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1032892\"},\"name\":\"In the Blink of an Eye\",\"nameTranslations\":{},\"originalName\":\"In the Blink of an Eye\",\"description\":\"Drei über Jahrtausende hinweg verwobene Geschichten erzählen von Hoffnung, Gemeinschaft und dem Kreislauf des Lebens.\",\"releaseDate\":\"2026-01-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/odlnSrjODWOyZ2mZv5ZD1E2j1YH.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/uM5i623wwNfoGD97iwwQWQ7GlZL.jpg\"},\"genres\":[\"Drama\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1327819\"},\"name\":\"Hoppers\",\"nameTranslations\":{},\"originalName\":\"Hoppers\",\"description\":\"Das findet man am besten heraus, wenn man selbst zum Tier wird. In Disney Pixars HOPPERS gewinnt Tierfreundin Mabel als Biber äußerst überraschende Erkenntnisse. Aber anstatt sich an die Regeln zu halten, stellt sie die natürliche Ordnung völlig auf den Kopf und zettelt einen tierischen Aufstand an. Und das nur, weil sie unbedingt den Teich retten will.\",\"releaseDate\":\"2026-02-28\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/nP3oMYwggLjnv5v1oQSmUso6yTd.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/2RrLuIfIzGWWIH8IAEo6o0IYHmx.jpg\"},\"genres\":[\"Animation\",\"Familie\",\"Komödie\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1159831\"},\"name\":\"The Bride! - Es lebe die Braut\",\"nameTranslations\":{},\"originalName\":\"The Bride!\",\"description\":\"In den 1930er Jahren reist ein einsamer Frankenstein nach Chicago, um mit Hilfe eines Dr. Euphronius eine Gefährtin für sich zu erschaffen. Die beiden beleben eine ermordete junge Frau wieder und die Braut ist geboren. Sie übertrifft die Erwartungen der beiden und entfacht eine brennende Romanze, die Aufmerksamkeit der Polizei und eine wilde und radikale soziale Bewegung.\",\"releaseDate\":\"2026-03-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/p9Tm37C1C0yexPFx7bgTLQeDlKJ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/8XeUEIXiZiRNqz0EcKC65vje8Th.jpg\"},\"genres\":[\"Science Fiction\",\"Horror\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"755898\"},\"name\":\"Krieg der Welten\",\"nameTranslations\":{},\"originalName\":\"War of the Worlds\",\"description\":\"Will Radford ist ein Top-Cybersicherheitsanalytiker des Heimatschutzes, der potenzielle Bedrohungen für die nationale Sicherheit durch ein Massenüberwachungsprogramm aufspürt, bis ihn eines Tages ein Angriff eines unbekannten Wesens dazu bringt, sich zu fragen, ob die Regierung etwas vor ihm verbirgt … und vor dem Rest der Welt.\",\"releaseDate\":\"2025-07-29\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3dQfE0RRDgPEtTDY5iTM92DaqGA.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/iZLqwEwUViJdSkGVjePGhxYzbDb.jpg\"},\"genres\":[\"Science Fiction\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1311031\"},\"name\":\"Demon Slayer: Kimetsu no Yaiba Infinity Castle\",\"nameTranslations\":{},\"originalName\":\"劇場版「鬼滅の刃」無限城編 第一章 猗窩座再来\",\"description\":\"Während die Mitglieder des Dämonentöter-Korps und die Hashira in Vorbereitung auf den bevorstehenden Kampf gegen die Dämonen ein gemeinsames Krafttrainingsprogramm, das Hashira-Training, absolvieren, taucht Muzan Kibutsuji in der Ubuyashiki-Villa auf. Da der Leiter des Dämonenkorps in Gefahr ist, eilen Tanjiro und die Hashira zum Hauptquartier, werden aber von Muzan Kibutsuji in einen tiefen Abstieg in einen mysteriösen Raum gestürzt. Das Ziel, in das Tanjiro und das Dämonentöter-Korps gestürzt sind, ist die Festung der Dämonen - die Unendlichkeitsburg. Und so ist das Schlachtfeld für die finale Schlacht zwischen dem Dämonentöterkorps und den Dämonen bereitet.\",\"releaseDate\":\"2025-07-18\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cqlahADJmDdqQvLAPuEYD6EKPAN.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lNYympQM5O6QSInusbyG9eJDIe4.jpg\"},\"genres\":[\"Animation\",\"Action\",\"Fantasy\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1168190\"},\"name\":\"The Wrecking Crew\",\"nameTranslations\":{},\"originalName\":\"The Wrecking Crew\",\"description\":\"Die entfremdeten Halbbrüder Jonny und James kommen sich nach dem mysteriösen Tod ihres Vaters auf Hawaii wieder näher. Bei der Suche nach der Wahrheit decken sie eine Verschwörung auf, die ihre Familie zu zerreißen droht.\",\"releaseDate\":\"2026-01-28\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/jodAPxXMZppnmmJ9tccrmmq6YJ3.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/cz4vLJrmaV1zJlRYbxqtvLzeLWB.jpg\"},\"genres\":[\"Action\",\"Komödie\",\"Krimi\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1242898\"},\"name\":\"Predator: Badlands\",\"nameTranslations\":{},\"originalName\":\"Predator: Badlands\",\"description\":\"Ein noch junger Predator namens Dek wird von seinem eigenen Clan verstoßen. Die anderen sehen in ihm keinen starken, furchtlosen Krieger heranwachsen. Damit ist er für die Gemeinschaft wertlos, da niemand glaubt, dass Dek eine glorreiche Zukunft bei der Jagd bevorsteht. Fortan muss er also alleine auf einem abgelegenen Planeten klarkommen. Doch dort bleibt er nicht lange alleine. Dek stößt auf Thia mit der er eine unverhoffte Verbündete findet. Von nun an gehen die beiden also gemeinsam auf die Jagd und treffen einen weiteren Weggefährten. Zu dritt müssen sie sich schließlich auch einer scheinbar übermächtigen Bedrohung stellen. Im Laufe ihres gemeinsamen Abenteuers werden sie beste Freunde und lernen, einander auch in ausweglosen Situationen zu vertrauen. Dek wächst dabei als Jäger über sich hinaus und lernt, richtig gut zu jagen.\",\"releaseDate\":\"2025-11-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/lxw9cD6g5Ccfml1PthmO6YT2aMp.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gaKFXcB5J1gz0QqYj8bWIfrPc04.jpg\"},\"genres\":[\"Action\",\"Science Fiction\",\"Abenteuer\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1353333\"},\"name\":\"Mouseboat Massacre\",\"nameTranslations\":{},\"originalName\":\"Mouseboat Massacre\",\"releaseDate\":\"2025-05-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ctKqevqOwbeVg5GLQLu5VvnCjan.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/wt0gb7ISUf8IyaJ4tnZVltvWoo7.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"937101\"},\"name\":\"動物感傷の清晨\",\"nameTranslations\":{},\"originalName\":\"動物感傷の清晨\",\"releaseDate\":\"2023-10-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/dUcIdXXBBFhJcvnNhdpcxHN2UTL.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hoqE4Saa4fQyWhUxws2Lw4qv2oz.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1272837\"},\"name\":\"28 Years Later: The Bone Temple\",\"nameTranslations\":{},\"originalName\":\"28 Years Later: The Bone Temple\",\"description\":\"Nia DaCosta knüpft an die Welt an, die Danny Boyle und Alex Garland in „28 Years Later“ geschaffen haben – und stellt sie auf den Kopf. In der Fortsetzung dieser epischen Geschichte findet sich Dr. Kelson in einer schockierenden neuen Beziehung wieder – mit Konsequenzen, die die Welt, wie sie sie kennen, verändern könnten –, und Spikes (Alfie Williams) Begegnung mit Jimmy Crystal wird zu einem Albtraum, dem er nicht entkommen kann. In der Welt von The Bone Temple sind die Infizierten nicht mehr die größte Bedrohung für das Überleben – die Unmenschlichkeit der Überlebenden kann seltsamer und erschreckender sein.\",\"releaseDate\":\"2026-01-14\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qCyxbvtCm3V4KPEEFzTFK5HIFRT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hHDNOlATHhre4eZ7aYz5cdyJLik.jpg\"},\"genres\":[\"Horror\",\"Thriller\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"879945\"},\"name\":\"L'homme inconnu\",\"nameTranslations\":{},\"originalName\":\"L'homme inconnu\",\"releaseDate\":\"2021-10-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4TpBhdaSl5ALHbgeaYOLF8Q3haz.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/7uXzE0ZBkbAeKylOz7cUQF4Yw75.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1316092\"},\"name\":\"“Wuthering Heights” – Sturmhöhe\",\"nameTranslations\":{},\"originalName\":\"\\\"Wuthering Heights\\\"\",\"description\":\"Der Film, basierend auf dem gleichnamigen Roman von Emily Brontë aus dem Jahr 1847, erzählt die tragische Liebesgeschichte zwischen Cathy, einer wohlhabenden jungen Frau des 19. Jahrhunderts, und Heathcliff, einem gesellschaftlichen Außenseiter. Nachdem Cathy sich aus gesellschaftlichen Gründen für einen anderen Mann entscheidet, kehrt Heathcliff nach Jahren nach Wuthering Heights zurück, um sich seiner Vergangenheit zu stellen und um ihre Liebe zu kämpfen.\",\"releaseDate\":\"2026-02-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/zuXjNG3o6as2au643nyXcdiKrfB.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/vSQSYd2zZTqc0zmHImwWEGGluMI.jpg\"},\"genres\":[\"Liebesfilm\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1549519\"},\"name\":\"Sex Trip\",\"nameTranslations\":{},\"originalName\":\"Sex Trip\",\"releaseDate\":\"2026-02-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/sr4sLilBbPx4TfPnX2zzUxlySgu.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/q2UhJtqp4ONeARofhpIHx4S0ElU.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"804370\"},\"name\":\"Arco\",\"nameTranslations\":{},\"originalName\":\"Arco\",\"description\":\"Als der Junge Arco aus einer fernen Zukunft zufällig in die Welt der zehnjährigen Iris ins Jahr 2075 stürzt, müssen die beiden – unterstützt von ihrem Haushaltsroboter – über Zeit und Welten hinweg zusammenarbeiten, um Arco wieder nach Hause zu bringen.\",\"releaseDate\":\"2025-10-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/rWvbMnqLTpyTHmNii4TrnmgzpcS.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/iILwdZdpzJDhVn1TRJzS4GEZtVc.jpg\"},\"genres\":[\"Animation\",\"Abenteuer\",\"Fantasy\",\"Familie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1249508\"},\"name\":\"No Escape - Grizzly Night\",\"nameTranslations\":{},\"originalName\":\"Grizzly Night\",\"description\":\"Zwei Angriffe. Eine Nacht. Eine wahre Geschichte, die Amerika erschütterte. Im Sommer 1967 wird der Glacier-Nationalpark zum Schauplatz einer der blutigsten Nächte der US-Wildnis Geschichte. Zwei junge Frauen sterben bei getrennten Grizzly-Angriffen – nur neun Meilen voneinander entfernt. Mitten in der Dunkelheit muss eine unerfahrene Rangerin alles riskieren, um die Leben der anderen Touristen zu retten. Zwischen Naturgewalt, Panik und purer Angst formiert sich ein Rettungstrupp, der sich dem Unvorstellbaren stellt.\\r Die wahren Begebenheiten werden den Umgang mit Wildtieren in den USA für immer ändern und zur Entstehung heutiger Schutzregeln für Wildtiere führen.\",\"releaseDate\":\"2026-01-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/rxkqhRDmUIWPxzBux3iXDn8zDC8.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/i275mAQP4KhPtYUpMUgBGMmK4WN.jpg\"},\"genres\":[\"Horror\",\"Thriller\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"737709\"},\"name\":\"Tři nevinní\",\"nameTranslations\":{},\"originalName\":\"Tři nevinní\",\"releaseDate\":\"1974-03-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/beB35H9cn0jTBZeU2NZsOB1RVVV.jpg\"},\"genres\":[\"Komödie\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1389149\"},\"name\":\"अक्यूज़्ड\",\"nameTranslations\":{},\"originalName\":\"अक्यूज़्ड\",\"description\":\"Das Leben einer angesehenen Gynäkologin gerät aus den Fugen, als schwere Anschuldigungen gegen sie erhoben werden. Ihre Frau will der Wahrheit auf die Spur kommen.\",\"releaseDate\":\"2026-02-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/eeP55mdqj4KpWtEPBvZJoxmnkXI.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/8QRMlkCMFNKZM2ApnIaut5t4snf.jpg\"},\"genres\":[\"Thriller\",\"Mystery\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1555951\"},\"name\":\"Salikmata\",\"nameTranslations\":{},\"originalName\":\"Salikmata\",\"releaseDate\":\"2025-10-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/tto58PLymhlubrzRatwyUm6iWLw.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/dbvUYL1dN75xFH1QqQWQi4xYCuJ.jpg\"},\"genres\":[\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1297842\"},\"name\":\"G.O.A.T. - Bock auf große Sprünge\",\"nameTranslations\":{},\"originalName\":\"GOAT\",\"description\":\"Im Mittelpunkt der Geschichte steht Will, ein kleiner Ziegenbock mit großen Träumen. Er bekommt die einmalige Chance, einem Profiteam beizutreten und Roarball zu spielen – ein kontaktintensiver Hochleistungssport, bei dem die schnellsten und furchterregendsten Tiere der Welt dominieren. Wills neue Teammitglieder sind daher nicht gerade begeistert, nun eine schmächtige Ziege in ihrer Mannschaft zu haben, doch Will ist wild entschlossen, den Sport zu revolutionieren und ein für alle Mal zu beweisen, dass auch Kleine ganz groß rauskommen können.\",\"releaseDate\":\"2026-02-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/RV3EmWdwIoFz6knlYzpVk9WeYE.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1qwhYqg7YEZajh3Q4biqbuQoDq8.jpg\"},\"genres\":[\"Animation\",\"Komödie\",\"Familie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1244975\"},\"name\":\"The Orphans - Blutsbrüder\",\"nameTranslations\":{},\"originalName\":\"Les Orphelins\",\"description\":\"Gab und Driss waren einmal Freunde. Seit ihrer gemeinsamen Zeit im Waisenhaus haben sie sich allerdings zerstritten und führen nun völlig unterschiedliche Leben: Einer ist Polizist bei der IGPN,der internen Kontrollbehörde der französischen Nationalpolizei, der andere hat sich für ein Leben als Krimineller entschieden. Als ihre erste große Liebe bei einem seltsamen Unfall ums Leben kommt, schnappt sich deren 17-jährige Tochter Leïla Gabs Waffe und begibt sich auf die Spur einer mächtigen Organisation, die alles tun würde, um den Fall zu vertuschen. Gezwungen, zusammenzuarbeiten, müssen die beiden Waisen sie aufhalten, bevor sie eine Grenze überschreitet, von der es kein Zurück mehr gibt …\",\"releaseDate\":\"2025-08-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/e08WqjLKqcw6HqHK9QlH0XGxyGb.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/z4hZZQ1GRuNGdeeWfKZIt8PXrmX.jpg\"},\"genres\":[\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"24428\"},\"name\":\"Marvel's The Avengers\",\"nameTranslations\":{},\"originalName\":\"The Avengers\",\"description\":\"Nick Fury ist der Anführer der Organisation S.H.I.E.L.D., einer internationalen Friedensorganisation. Die Behörde ist ein Who's Who der Marvel Superhelden, mit Iron Man, Thor, Captain America, Hawkeye, dem Unglaublichen Hulk und Black Widow. Als die weltweite Sicherheit von Thors sinistrem Halbbruder Loki und seiner Schar bedroht wird, werden Nick Fury und sein Team all ihre Kräfte brauchen, um die Welt vor einer Katastrophe zu bewahren ...\",\"releaseDate\":\"2012-04-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/hGTqvK9WaI74szUDPMHXrrHfiH3.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/pGFQCp12a8andfPlpnmXz44IIvY.jpg\"},\"genres\":[\"Science Fiction\",\"Action\",\"Abenteuer\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1629382\"},\"name\":\"Banlieusards 3\",\"nameTranslations\":{},\"originalName\":\"Banlieusards 3\",\"description\":\"Noch immer trauernd, stellen sich die Traoré-Brüder den Konsequenzen ihrer Verbrechen und erhalten eine letzte Chance, einen neuen Weg einzuschlagen.\",\"releaseDate\":\"2026-03-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/rCkg72HTCyhvqez8ez9pJpaAmVs.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/jhfJZ82qzcMV4Kr7G0uczdU4n2v.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"7451\"},\"name\":\"xXx - Triple X\",\"nameTranslations\":{},\"originalName\":\"xXx\",\"description\":\"Vin Diesel ist Xander “xXx” Cage, Extremsportler und Adrenalinjunkie. Der tätowierte Draufgänger führt seine berüchtigten, lebensgefährlichen Stunts am liebsten in gestohlenen Luxusschlitten durch und besitzt nicht den geringsten Respekt vor jeglicher Autorität, ganz besonders nicht vor staatlicher – was xXx zum idealen Kandidaten für die Geheimmission des NSA-Agenten Gibbons macht. Dieser droht xXx mit einer Gefängnisstrafe, sollte er sich nicht bereit erklären, die äußerst gefährliche Untergrund-Organisation “Anarchie 99” zu infiltrieren. Unter der Führung des ehemaligen Soldaten Yorgi plant diese die Weltmächte USA und Russland mithilfe einer biologischen Waffe gegeneinander auszuspielen. Ein Himmelfahrtskommando wie es im Buche steht – genau das Richtige für xXx.\",\"releaseDate\":\"2002-08-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/o6QwWAedNuMoQ5yEqLaR1c81NoA.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/2OHa6ukEq3Hce7Pc2kvu8wkmMFY.jpg\"},\"genres\":[\"Action\",\"Abenteuer\",\"Thriller\",\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"157336\"},\"name\":\"Interstellar\",\"nameTranslations\":{},\"originalName\":\"Interstellar\",\"description\":\"Was Wissenschaftler, Politiker und Aktivisten seit Jahrzehnten prophezeien, ist eingetreten: Die Menschheit steht kurz davor, an einer globalen Nahrungsknappheit zugrunde zu gehen. Die einzige Hoffnung der Weltbevölkerung besteht in einem geheimen Projekt der US-Regierung, das von dem findigen Wissenschaftler Professor Brand geleitet wird. Der Plan sieht vor, eine Expedition in ein anderes Sternensystem zu starten, wo bewohnbare Planeten, Rohstoffe und vor allem Leben vermutet werden. Der Ingenieur und ehemalige NASA-Pilot Cooper und Brands Tochter Amelia führen die Besatzung an, die sich auf eine Reise ins Ungewisse begibt: Wurmlöcher sind so gut wie unerforscht und niemand kann mit Sicherheit sagen, was die Crew auf der anderen Seite erwartet. Ebenso ist unsicher, ob und wann Cooper und Brand wieder auf die Erde zurückkehren. Coopers Kinder, Tochter Murph und Sohn Tom, müssen mit Schwiegervater Donald zurückbleiben und auf seine Wiederkehr hoffen...\",\"releaseDate\":\"2014-11-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/hHdhfkkzt0Mwec33Ux177Z7CO8w.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/2ssWTSVklAEc98frZUQhgtGHx7s.jpg\"},\"genres\":[\"Abenteuer\",\"Drama\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1317288\"},\"name\":\"Marty Supreme\",\"nameTranslations\":{},\"originalName\":\"Marty Supreme\",\"description\":\"In den Hinterhöfen Manhattans träumt der junge Schuhverkäufer Marty von einer Zukunft, die ein paar Nummern größer ist als der kleine Schuhladen seines Onkels. Angetrieben von der Idee, Weltmeister im Tischtennis werden zu können, taucht er jede Nacht ab in die verrauchten Wettkampfhallen der Stadt, wo er sich mit viel Talent, der nötigen Chuzpe und dank der Hilfe seines besten Freundes ein paar Dollar dazu verdient. Zu wenig, um eine Profikarriere zu finanzieren und an den Turnieren in London, Paris oder Tokio teilnehmen zu können. Also ‚leiht‘ sich Marty kurzerhand Geld aus dem Safe seines Onkels, belügt seine Mutter ebenso wie seine Freundin (Odessa A’zion) und schmeißt sich schamlos an eine Hollywood-Diva (Gwyneth Paltrow) ran, deren Ehemann er gleichzeitig als Sponsor gewinnen will. Doch das ist erst der Anfang der Odyssey eines Mannes, der bereit ist, für Ruhm und Erfolg alles zu riskieren.\",\"releaseDate\":\"2025-12-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8LGm5kOZnWpUI4uiomBYit4GWdF.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/qKWDHofjMHPSEOTLaixkC9ZmjTT.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"858024\"},\"name\":\"Hamnet\",\"nameTranslations\":{},\"originalName\":\"Hamnet\",\"description\":\"Wir schreiben das Jahr 1580 und der im kleinen englischen Dorf Stratford-upon-Avon als Lateinlehrer arbeitende William Shakespeare verliebt sich in Agnes. Im Dorf wird hinter immer weniger vorgehaltener Hand vermutet, sie sei eigentlich gar keine Heilerin, sondern eine richtige Hexe. Aber das ist William egal. Die beiden stürzen sich Hals über Kopf in das gemeinsame Leben und bekommen auch schnell drei Kinder. Erst wird Susanna geboren, kurz darauf die Zwillinge Judith und Hamnet. Doch mit der Familie endet das Träumen zumindest für William noch nicht. Er will das Lehren endlich hinter sich lassen können und als Dramatiker arbeiten. Auf dem Land geht das jedoch eher schlecht als recht. Also geht er, ermutigt von Agnes, nach London. Erst ist die Familie als nur räumlich voneinander getrennt, dann pflügt die Pest durch das Land und tötet auch Hamnet mit gerade einmal elf Jahren. Das treibt William an, seinem Sohn zu Ehren ein Stück zu schreiben...\",\"releaseDate\":\"2025-11-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/Ua43qwtLJNtFcTeAtO3q1SG5NV.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/73BClq9FOcrWrutnpiqhCNEWEwJ.jpg\"},\"genres\":[\"Drama\",\"Liebesfilm\",\"Historie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"434853\"},\"name\":\"Space/Time\",\"nameTranslations\":{},\"originalName\":\"Space/Time\",\"description\":\"Nach einem tödlichen Test, der ihr Projekt stoppt, taucht ein entehrtes Team von Wissenschaftlern in die kriminelle Unterwelt ein, um einen verbotenen raumverbiegenden Motor neu zu bauen – eine Maschine, die die Menschheit retten oder sie vollständig auslöschen könnte.\",\"releaseDate\":\"2025-05-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/uje1ecKMnNpZp0at5TxlvVgVXqI.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/w1Z1I9PqTK5UjG6RVAFXLCjp1Sw.jpg\"},\"genres\":[\"Science Fiction\",\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1305781\"},\"name\":\"镖人：风起大漠\",\"nameTranslations\":{},\"originalName\":\"镖人：风起大漠\",\"releaseDate\":\"2026-02-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/AsWzPlQK2xJTIrzw6McT8Yvy6H2.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/cYyNJzwhaj7aC4uTlUctrfaERbf.jpg\"},\"genres\":[\"Action\",\"Drama\",\"Historie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1234731\"},\"name\":\"Anaconda\",\"nameTranslations\":{},\"originalName\":\"Anaconda\",\"description\":\"DIES IST KEIN REBOOT, sondern ist eine völlig neue Komödie, inspiriert vom „Klassiker“ Anaconda, in der Doug und Griff die Hauptrollen spielen. Die beiden sind seit ihrer Kindheit beste Freunde und träumen schon immer davon, ihren absoluten Lieblingsfilm neu zu verfilmen. Ihre Midlife-Crisis treibt sie dazu, ihren Traum endlich in die Tat umzusetzen. Sie reisen tief in den Amazonas, um mit den Dreharbeiten zu beginnen. Doch aus Spaß wird schnell Ernst, als plötzlich eine echte Riesenanaconda auftaucht – und das chaotisch-komische Filmset in eine tödliche Falle verwandelt.\",\"releaseDate\":\"2025-12-24\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/gEd2zQkOuPTMWmyJ3374cZ5iPLn.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/swxhEJsAWms6X1fDZ4HdbvYBSf9.jpg\"},\"genres\":[\"Abenteuer\",\"Komödie\",\"Horror\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1151993\"},\"name\":\"Fränk\",\"nameTranslations\":{},\"originalName\":\"Fränk\",\"releaseDate\":\"2025-03-21\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/zkcmXoYpBiDVocovHTaEsIXaD6J.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/9sbvQ3J4tWwJzFuIRJ1pirvIXDK.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1193501\"},\"name\":\"Whistle\",\"nameTranslations\":{},\"originalName\":\"Whistle\",\"description\":\"Eine Gruppe unangepasster Highschool-Schüler stößt auf eine alte aztekische Todespfeife. Sie entdecken, dass der furchterregende Klang, den sie ausstößt, sie in Zukunft zum Tode zwingt und sie aufspürt. Während die Zahl der Toten steigt, untersuchen die Freunde die Herkunft des tödlichen Artefakts in einem verzweifelten Versuch, die schreckliche Kette der Ereignisse zu stoppen, die sie selbst in Gang gesetzt haben.\",\"releaseDate\":\"2026-01-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4PvnAwa0JUo6ATPy15tiBxRwfP6.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yJi6g0CnsqANLNuVaRX28tZxeHX.jpg\"},\"genres\":[\"Horror\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1336595\"},\"name\":\"Fürst Seppl\",\"nameTranslations\":{},\"originalName\":\"Fürst Seppl\",\"description\":\"In dieser Komödie verwandelt sich ein einfaches Gasthaus in den Bergen in ein Grandhotel.\",\"releaseDate\":\"1932-10-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/oP9v0pu4RlC5UGU6ayB3YCDxrJl.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1601243\"},\"name\":\"Oscar Shaw\",\"nameTranslations\":{},\"originalName\":\"Oscar Shaw\",\"releaseDate\":\"2026-01-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/tsE3nySukwrfUjouz8vzvKTcXNC.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/6D6M5z4reppUxo2cnBEKI02Csp1.jpg\"},\"genres\":[\"Action\",\"Krimi\",\"Thriller\",\"Western\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1167307\"},\"name\":\"David\",\"nameTranslations\":{},\"originalName\":\"David\",\"releaseDate\":\"2025-12-14\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7lFG1WrCwAxBfyGK8ahlBVzXno7.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/oN4TQ1TxchynXlFiXFBL3NHLT54.jpg\"},\"genres\":[\"Animation\",\"Familie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1301306\"},\"name\":\"A Woman Scorned\",\"nameTranslations\":{},\"originalName\":\"A Woman Scorned\",\"releaseDate\":\"2025-06-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/dlOSBiNULMPzKIze84LDjvEN9z1.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/uzZ7LUx4Bb3nZXjvBx5PiqTE7rk.jpg\"},\"genres\":[\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"482600\"},\"name\":\"일본 엄마\",\"nameTranslations\":{},\"originalName\":\"일본 엄마\",\"releaseDate\":\"2017-02-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/hq1EaYIqUNrPM3QFYAbnH2UHoX8.jpg\"},\"genres\":[\"Liebesfilm\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1306368\"},\"name\":\"The Rip\",\"nameTranslations\":{},\"originalName\":\"The Rip\",\"description\":\"Das Vertrauen bröckelt, als ein Polizeiteam in Miami in einem verwahrlosten Haus Bargeld in Millionenhöhe entdeckt. Plötzlich stellen sie einander – und einfach alles – infrage.\",\"releaseDate\":\"2026-01-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/t8DBuGkmnEEZi0UqhbUtiZZDWkG.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/3F2EXWF1thX0BdrVaKvnm6mAhqh.jpg\"},\"genres\":[\"Action\",\"Thriller\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1511417\"},\"name\":\"Bāhubali: The Epic\",\"nameTranslations\":{},\"originalName\":\"Bāhubali: The Epic\",\"description\":\"Als ein Stammespaar in der Nähe eines tosenden Wasserfalls ein mysteriöses Kind findet, ziehen sie es wie ihr eigenes auf. Während er heranwächst, fühlt sich Sivudu unwiderstehlich zu der Welt jenseits der Klippen hingezogen. Dort entdeckt er das uralte Königreich Mahishmati, das von einem grausamen Tyrannen beherrscht, von Rebellion geplagt und eng mit seiner eigenen Vergangenheit verwoben ist. Was als eine Suche nach der Liebe beginnt, entpuppt sich bald als ein Vermächtnis aus Verrat, Opferbereitschaft und der Geschichte eines vergessenen Prinzen.\",\"releaseDate\":\"2025-10-29\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4sLSorDKKDN944kWngxgQlpdDeg.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/wCwZ4ljSsWyZyTiyk1tGQtBHTDx.jpg\"},\"genres\":[\"Action\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1289893\"},\"name\":\"Somnium\",\"nameTranslations\":{},\"originalName\":\"Somnium\",\"releaseDate\":\"2025-08-28\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cPUeMJkPLDWSOA6OU862EdZhylS.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/xM2dUqkpaSHOR87ojZ538DGQqcD.jpg\"},\"genres\":[\"Horror\",\"Science Fiction\",\"Thriller\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1426964\"},\"name\":\"Brotherhood: Angstzustand\",\"nameTranslations\":{},\"originalName\":\"Salve Geral: Irmandade\",\"description\":\"Inmitten einer Welle der Gewalt muss eine Anwältin in São Paulo mit Verbindungen zur Unterwelt einen Deal mit der Polizei machen, um ihre entführte Nichte zu retten.\",\"releaseDate\":\"2026-02-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/tKchRMJTliVxllDld3L6KHS6Gya.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1Xdsq7U7bvJJd2X7Jg4qNaKVkYO.jpg\"},\"genres\":[\"Action\",\"Thriller\",\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"321261\"},\"name\":\"Jezioro osobliwości\",\"nameTranslations\":{},\"originalName\":\"Jezioro osobliwości\",\"releaseDate\":\"1973-05-27\",\"images\":{},\"genres\":[\"Drama\",\"Familie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"803796\"},\"name\":\"KPop Demon Hunters\",\"nameTranslations\":{},\"originalName\":\"KPop Demon Hunters\",\"description\":\"Wenn die K-Pop-Superstars Rumi, Mira und Zoey nicht gerade vor ausverkauften Stadien auftreten, setzen sie ihre geheimen Kräfte gegen übernatürliche Bedrohungen ein.\",\"releaseDate\":\"2025-06-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3Ps8dRYdD4kcJQACirB2Vfqs01c.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/w3Bi0wygeFQctn6AqFTwhGNXRwL.jpg\"},\"genres\":[\"Fantasy\",\"Musik\",\"Komödie\",\"Animation\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"591488\"},\"name\":\"Porto Santo\",\"nameTranslations\":{},\"originalName\":\"Porto Santo\",\"releaseDate\":\"1997-08-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/oW9rFP9kH1DxCZ4eNz7SqX9UZ27.jpg\"},\"genres\":[\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"513343\"},\"name\":\"Allein an der Front\",\"nameTranslations\":{},\"originalName\":\"Soldado Milhões\",\"description\":\"Flandern, Frühling 1918: Die deutsche Frühjahrsoffensive ist in vollem Gange und kostet hunderttausende von Menschenleben, darunter auch viele der 75.000 portugiesischen Soldaten, die an diesem Frontabschnitt ihren Dienst tun. Unter ihnen ist auch Aníbal Augusto Milhais (Miguel Borges/João Arrais). Als sich die Schlacht zugunsten der Deutschen wendet, verteidigt er allein mit einem Maschinengewehr den Rückzug der Entente-Streitkräfte in seinem Abschnitt und gerät hinter die deutschen Frontlinien. Er erinnert sich, welche Versprechen er den Menschen zuhause und seinen Kameraden gegeben hat - und erreicht das Unmögliche. „Allein an der Front“ basiert auf der wahren Geschichte des Soldaten Aníbal Milhais, genannt Soldado Milhões („Millionensoldat“), dessen Heldentum in Flandern vielen seiner Kameraden das Leben rettete.\",\"releaseDate\":\"2018-04-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/6MqhPrsb2hl4aZTPKTLrcJRdnZJ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/y0jBSKfIEnob6sBdRTD8B3rLuq8.jpg\"},\"genres\":[\"Kriegsfilm\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1061474\"},\"name\":\"Superman\",\"nameTranslations\":{},\"originalName\":\"Superman\",\"description\":\"Superman ist bereits seit einiger Zeit als Superheld in Metropolis aktiv und arbeitet unter dem Deckmantel seines menschlichen Alter Egos, dem Reporter Clark Kent, bei der Zeitung „Daily Planet\\\". Dort hat er auch die Reporterin Lois Lane kennengelernt, die tatsächlich als einzige von seiner geheimen Identität als Superman weiß. Gemeinsam mit zahlreichen anderen Helden und Heldinnen, darunter Guy Gardner alias Green Lantern, Mister Terrific, Hawkgirl und Metamorpho, beschützt Superman die Menschheit vor Bedrohungen, von denen es wirklich zahlreiche gibt. Doch eine Bedrohung, die sticht hervor: Supermans Erzfeind Lex Luthor versucht mit allen Mitteln, ihn endgültig aus dem Weg zu räumen und in Ungnade fallen zu lassen. Dafür stellt sich ihm auch Angela Spica, bekannt als „The Engineer\\\", in den Weg …\",\"releaseDate\":\"2025-07-09\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/fJKSDmkXDLZ0qDmAZ5lXEaToN3L.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yRBc6WY3r1Fz5Cjd6DhSvzqunED.jpg\"},\"genres\":[\"Science Fiction\",\"Abenteuer\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1054867\"},\"name\":\"One Battle After Another\",\"nameTranslations\":{},\"originalName\":\"One Battle After Another\",\"description\":\"Vor 16 Jahren hat die Widerstandsgruppe namens „French 75“ auf einen Schlag 200 Häftlinge aus den Fängen des skrupellosen United States Immigration and Customs Enforcement – kurz: ICE – befreit. Danach verschwanden die Widerständler, darunter auch der von allen nur Ghetto Pat genannte Bob Ferguson, von der Bildfläche. Heute ist Bob getrieben von Paranoia, denn er fürchtet, dass es der damalige ICE-Colonel Steven J. Lockjaw immer noch auf ihn abgesehen hat.\",\"releaseDate\":\"2025-09-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5k2WV1i6jcnbPmRhoXSEQWQGT9u.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gre7gyocZSuwd7M51CGlqsJqBmB.jpg\"},\"genres\":[\"Thriller\",\"Krimi\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1253000\"},\"name\":\"Deathstalker\",\"nameTranslations\":{},\"originalName\":\"Deathstalker\",\"description\":\"Ein mächtiger Schwertkämpfer namens Deathstalker birgt ein verfluchtes Amulett von einem mit Leichen übersäten Schlachtfeld. Gezeichnet von dunkler Magie und gejagt von monströsen Attentätern, muss er sich dem aufsteigenden Bösen stellen und den Fluch brechen.\",\"releaseDate\":\"2025-10-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/nEI3DnzQC1afAjJOAizx6UX27pL.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/cugd16e3WbCG3Zogb8N7lwUnVXH.jpg\"},\"genres\":[\"Fantasy\",\"Action\",\"Abenteuer\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1037830\"},\"name\":\"Kara Krus\",\"nameTranslations\":{},\"originalName\":\"Kara Krus\",\"releaseDate\":\"2022-11-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1uLCXYgdb9Xe92JvaClK2uNpRhF.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yK6506AW43aGv7hzZhmxIe64bjN.jpg\"},\"genres\":[\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"84654\"},\"name\":\"Black Orchid\",\"nameTranslations\":{},\"originalName\":\"Black Orchid\",\"releaseDate\":\"1953-02-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/als75LctSKUpDeDmROv8dIrusc8.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/eIYlVmArfW6fGRcmr515HwStk69.jpg\"},\"genres\":[\"Mystery\",\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1233413\"},\"name\":\"Blood & Sinners\",\"nameTranslations\":{},\"originalName\":\"Sinners\",\"description\":\"Beim Versuch, ihr von Problemen geplagtes Leben hinter sich zu lassen, kehren Zwillingsbrüder in ihre Heimatstadt zurück, um dort einen Neuanfang zu wagen. Doch schon bald müssen sie feststellen, dass bei ihrer Rückkehr ein noch größeres Übel auf sie wartet.\",\"releaseDate\":\"2025-04-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/445HsfnktkmM5y4cr62vYGzfo6h.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/nAxGnGHOsfzufThz20zgmRwKur3.jpg\"},\"genres\":[\"Horror\",\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"429769\"},\"name\":\"Thee Nagar\",\"nameTranslations\":{},\"originalName\":\"Thee Nagar\",\"releaseDate\":\"2007-07-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/vNc1JsWyoPfQ8XDE5rTgiisp5zh.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1484100\"},\"name\":\"Jesus Land\",\"nameTranslations\":{},\"originalName\":\"Jesus Land\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/f2KKIxryNaN1VJ1p3k62up2ze4A.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"211879\"},\"name\":\"Free Range\",\"nameTranslations\":{},\"originalName\":\"Free Range\",\"description\":\"Fred, ein aufstrebender Schriftsteller, erfährt, dass seine Freundin schwanger ist, nachdem er aus seinem Job bei einer Zeitung entlassen wurde, weil er eine vernichtende Kritik über einen berühmten Film geschrieben hat.\",\"releaseDate\":\"2013-09-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ys2HISdhI0qQqcb4MGOZ3yzTE56.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/80bqGQ76UuO14jNSPyrRqQ4Z6Ks.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"991494\"},\"name\":\"SpongeBob Schwammkopf: Piraten Ahoi!\",\"nameTranslations\":{},\"originalName\":\"The SpongeBob Movie: Search for SquarePants\",\"description\":\"In ihrem brandneuen und bisher größten Kinoabenteuer, SPONGEBOB SCHWAMMKOPF: PIRATEN AHOI!, stechen SpongeBob und seine Freunde aus Bikini Bottom in See! SpongeBob, der endlich auch zu den Großen gehören möchte und Mr. Krabs seinen Mut beweisen will, folgt dem Fliegenden Holländer - einem mysteriösen, verwegenen Geisterpiraten. Und so beginnt ein rasantes und witziges Seefahrts-Abenteuer, das ihn in die tiefsten Tiefen der Tiefsee führt, wo noch kein Schwamm zuvor gewesen ist.\",\"releaseDate\":\"2025-12-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/M7KKeJfhV5AVJO8JCd5Hix0vyH.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/kVSUUWiXoNwq2wVCZ4Mcqkniqvr.jpg\"},\"genres\":[\"Animation\",\"Familie\",\"Komödie\",\"Abenteuer\",\"Fantasy\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"469689\"},\"name\":\"AWOL\",\"nameTranslations\":{},\"originalName\":\"AWOL\",\"releaseDate\":\"2017-08-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/3loA03mCxvyFVTNG0PhvekBYVaH.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/e2la4oHFaZ8kcxi0qdK2C6q1bUo.jpg\"},\"genres\":[\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"223702\"},\"name\":\"Sausage Party - Es geht um die Wurst\",\"nameTranslations\":{},\"originalName\":\"Sausage Party\",\"description\":\"Für Lebensmittel im Supermarkt gibt es nur die eine wahre Bestimmung im Leben: In einen Einkaufswagen gelegt zu werden und zu einem Menschen mit nach Hause zu dürfen, um dort in eine Art himmlisches Paradies zu kommen! Wurst Frank wünscht sich nichts sehnlicher, als dort endlich in das sexy Hotdog-Brötchen Brenda gesteckt zu werden. Ein Glas Honigsenf, das in den Laden zurückgegeben wurde, versucht die anderen Produkte vor dem wirklichen, grausamen Schicksal zu warnen, das bei den Menschen auf sie wartet, aber weder Frank und Brenda noch deren leckeren Kollegen wie Sammy Bagel Jr. oder Vash wollen dem Horrorszenario Glauben schenken – bis sie schon bald in der Küche einer Einkäuferin am eigenen Leib erfahren, dass die gefräßigen Riesen selbst vor kleinen Karottenkindern keinen Halt machen…\",\"releaseDate\":\"2016-07-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/k0Ro4c88NilTjDvxyRG6X9VuAAP.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hsb8nNBt3emvWqBs7Xv5IKlz6Im.jpg\"},\"genres\":[\"Abenteuer\",\"Animation\",\"Komödie\",\"Fantasy\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"232923\"},\"name\":\"Money Mad\",\"nameTranslations\":{},\"originalName\":\"Money Mad\",\"releaseDate\":\"1908-12-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/dQYVw2aPqgM952bjGEpsSzWVorF.jpg\"},\"genres\":[\"Krimi\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1480387\"},\"name\":\"undertone\",\"nameTranslations\":{},\"originalName\":\"undertone\",\"releaseDate\":\"2026-03-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1wREWUEHzjDWSreNFbFLDO7YEaM.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/711jYfJrsY5x2R0Yh0pFeJTPWA7.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"799130\"},\"name\":\"Redeemed\",\"nameTranslations\":{},\"originalName\":\"Redeemed\",\"releaseDate\":\"2021-02-18\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8nzm2SW3SP7K8IEAmU6eNJjN4AY.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hby5Xvuhebvye4jOCC9pkGN2ATe.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"262966\"},\"name\":\"Netru Indru\",\"nameTranslations\":{},\"originalName\":\"Netru Indru\",\"releaseDate\":\"2014-06-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/T1gnd02hrmu6i8yfciPrY3UJzZ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/kMOKYPG0PLS7ogqAKuG1goGhMRS.jpg\"},\"genres\":[\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1306368\"},\"name\":\"The Rip\",\"nameTranslations\":{},\"originalName\":\"The Rip\",\"description\":\"Das Vertrauen bröckelt, als ein Polizeiteam in Miami in einem verwahrlosten Haus Bargeld in Millionenhöhe entdeckt. Plötzlich stellen sie einander – und einfach alles – infrage.\",\"releaseDate\":\"2026-01-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/t8DBuGkmnEEZi0UqhbUtiZZDWkG.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/3F2EXWF1thX0BdrVaKvnm6mAhqh.jpg\"},\"genres\":[\"Action\",\"Thriller\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1054867\"},\"name\":\"One Battle After Another\",\"nameTranslations\":{},\"originalName\":\"One Battle After Another\",\"description\":\"Vor 16 Jahren hat die Widerstandsgruppe namens „French 75“ auf einen Schlag 200 Häftlinge aus den Fängen des skrupellosen United States Immigration and Customs Enforcement – kurz: ICE – befreit. Danach verschwanden die Widerständler, darunter auch der von allen nur Ghetto Pat genannte Bob Ferguson, von der Bildfläche. Heute ist Bob getrieben von Paranoia, denn er fürchtet, dass es der damalige ICE-Colonel Steven J. Lockjaw immer noch auf ihn abgesehen hat.\",\"releaseDate\":\"2025-09-23\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5k2WV1i6jcnbPmRhoXSEQWQGT9u.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gre7gyocZSuwd7M51CGlqsJqBmB.jpg\"},\"genres\":[\"Thriller\",\"Krimi\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1171145\"},\"name\":\"Crime 101\",\"nameTranslations\":{},\"originalName\":\"Crime 101\",\"description\":\"Davis ist ein schwer fassbarer Juwelendieb, dessen Überfallserie die Polizei vor ein Rätsel stellt. Als er gerade den Coup seines Lebens ins Visier nimmt, trifft er auf die desillusionierte Versicherungsmanagerin Sharon, die selbst an einem Scheideweg steht. Überzeugt davon, ein Muster entdeckt zu haben, kommt währenddessen der unerbittliche Detective Lt. Lubesnik der ganzen Operation immer näher und erhöht damit das Risiko noch weiter.\",\"releaseDate\":\"2026-02-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/6T7ra8tsoYCQJMTZpkAqbKS17lE.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yWZc7ZglTAecVLKHS0oROuetKce.jpg\"},\"genres\":[\"Krimi\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"586068\"},\"name\":\"Malibú\",\"nameTranslations\":{},\"originalName\":\"Malibú\",\"releaseDate\":\"2021-09-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/absKtXXvkjE8ngwCGeSgXS7bqXX.jpg\"},\"genres\":[\"Drama\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"81661\"},\"name\":\"Tilva Roš\",\"nameTranslations\":{},\"originalName\":\"Tilva Roš\",\"releaseDate\":\"2011-01-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1AJYzDk22n1eil3yyNmfGADDJ8G.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/79j2EJTZdE92UAUsVu2aTSA65oU.jpg\"},\"genres\":[\"Drama\",\"Liebesfilm\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1242937\"},\"name\":\"The Dreadful\",\"nameTranslations\":{},\"originalName\":\"The Dreadful\",\"releaseDate\":\"2026-02-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/hGH8Ji7pG2ytHxo7ABqHM3TpzFA.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/fAF3VGFBpItWNROmiGob60n0y5.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1511633\"},\"name\":\"Nammoora Raja\",\"nameTranslations\":{},\"originalName\":\"Nammoora Raja\",\"releaseDate\":\"1988-04-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/y0Jnu1PymfyN8JQ9FcDHaPTIaKw.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/u7KZNB10fiAQlzKe1wQ2u4YrsJb.jpg\"},\"genres\":[\"Action\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"429769\"},\"name\":\"Thee Nagar\",\"nameTranslations\":{},\"originalName\":\"Thee Nagar\",\"releaseDate\":\"2007-07-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/vNc1JsWyoPfQ8XDE5rTgiisp5zh.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"650920\"},\"name\":\"Glück gehabt\",\"nameTranslations\":{},\"originalName\":\"Glück gehabt\",\"description\":\"Was als komödiantische Dreiecksgeschichte beginnt, entwickelt sich für Artur bald zu einem Horror-Trip, der blutig enden wird. Der talentierte, aber ehrgeizlose Comic-Zeichner verdingt sich als Angestellter in einem Copy-Shop. Seine Frau Rita hat den Sprung zur jüngsten Schuldirektorin der Stadt geschafft. Die routinierte Ehe der beiden wird einem dramatischen Stress-Test ausgesetzt, als die ebenso geheimnisvolle wie reizvolle Alice Arturs Leben umkrempelt. Je mehr er sich in diese verhängnisvolle Affäre verstrickt, desto weniger weiß er, wer seine Geliebte eigentlich ist.\",\"releaseDate\":\"2019-12-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/sLrWo3dkhA9DWjjTYCNwiDoP8mX.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"535451\"},\"name\":\"O Prego\",\"nameTranslations\":{},\"originalName\":\"O Prego\",\"releaseDate\":\"1997-11-21\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/lqXoQ69MOb47g4iCQivvWaxjjo6.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1037830\"},\"name\":\"Kara Krus\",\"nameTranslations\":{},\"originalName\":\"Kara Krus\",\"releaseDate\":\"2022-11-04\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1uLCXYgdb9Xe92JvaClK2uNpRhF.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/yK6506AW43aGv7hzZhmxIe64bjN.jpg\"},\"genres\":[\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"305119\"},\"name\":\"Madame Bäurin\",\"nameTranslations\":{},\"originalName\":\"Madame Bäurin\",\"releaseDate\":\"1993-01-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/bm7D2M0IlM3beqULdpdAlmxOQkD.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/LZZ1VrlhLsubkbIbEQ1Ai6rxe7.jpg\"},\"genres\":[\"Drama\",\"Liebesfilm\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"211879\"},\"name\":\"Free Range\",\"nameTranslations\":{},\"originalName\":\"Free Range\",\"description\":\"Fred, ein aufstrebender Schriftsteller, erfährt, dass seine Freundin schwanger ist, nachdem er aus seinem Job bei einer Zeitung entlassen wurde, weil er eine vernichtende Kritik über einen berühmten Film geschrieben hat.\",\"releaseDate\":\"2013-09-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ys2HISdhI0qQqcb4MGOZ3yzTE56.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/80bqGQ76UuO14jNSPyrRqQ4Z6Ks.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1480387\"},\"name\":\"undertone\",\"nameTranslations\":{},\"originalName\":\"undertone\",\"releaseDate\":\"2026-03-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1wREWUEHzjDWSreNFbFLDO7YEaM.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/711jYfJrsY5x2R0Yh0pFeJTPWA7.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1443576\"},\"name\":\"Los domingos\",\"nameTranslations\":{},\"originalName\":\"Los domingos\",\"releaseDate\":\"2025-10-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/kwpDm6qtON8pLCSY0C8MltMofEE.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/jVwvhKpw6a7c7JmHhMykKAn7buQ.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1205225\"},\"name\":\"Gates of Flesh\",\"nameTranslations\":{},\"originalName\":\"Gates of Flesh\",\"releaseDate\":\"2025-04-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cOiuCeECSRqzpwuY6wYKQzvPcXm.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5arE7ysejlE2byGyakuUrR5TmUt.jpg\"},\"genres\":[\"Horror\",\"Thriller\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1110034\"},\"name\":\"Kraken\",\"nameTranslations\":{},\"originalName\":\"Kraken\",\"description\":\"Eine Meeresbiologin untersucht eine Fischfarm, als mehrere Teenager unter mysteriösen Umständen ums Leben kommen. Ungewöhnliche Ereignisse lassen vermuten, dass in den Tiefen des Fjords ein riesiges, vielarmiges Wesen lauert. Auf der Suche nach Antworten geht sie der Frage nach, ob sich in Norwegens tiefstem Fjord tatsächlich ein legendäres Monster verbirgt.\",\"releaseDate\":\"2026-02-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/s8u6BmcOSJGVoxswoo0wDm6naAT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/xcBlMEvzuaHoWANKYn5PGvcW4OC.jpg\"},\"genres\":[\"Horror\",\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"196991\"},\"name\":\"Ystävät, toverit\",\"nameTranslations\":{},\"originalName\":\"Ystävät, toverit\",\"releaseDate\":\"1990-11-16\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/w1gwEiuMTbZH9ohSQC2TkYgVyG7.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/sVdRqbNr6Xdpwyi66ep22YY2eBU.jpg\"},\"genres\":[\"Drama\",\"Kriegsfilm\",\"Historie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1584215\"},\"name\":\"The Internship - Praktikum im Töten\",\"nameTranslations\":{},\"originalName\":\"The Internship\",\"description\":\"Eine von der CIA ausgebildete Attentäterin rekrutiert andere Absolventen des geheimen Programms „The Internship“, dem auch sie angehörte und das Ihre Kindheit und die vieler anderer zerstört hat, um diese Organisation gewaltsam zu zerschlagen. Die CIA schlägt mit tödlicher Gewalt zurück.\",\"releaseDate\":\"2026-01-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/swO8i4150zNjNpFESjHE28rN94M.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/eUERZRVjCTNdgnESlQxyaOJ2d4K.jpg\"},\"genres\":[\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"911430\"},\"name\":\"F1 - Der Film\",\"nameTranslations\":{},\"originalName\":\"F1\",\"description\":\"In den 1990er Jahren galt Sonny Hayes noch als die nächste große Nummer im Rennsport und der höchsten Klasse, der Formel 1. Doch auch als Rennfahrer legt man seinen Körper in die Waagschale und muss letztlich mit dem Schlimmsten rechnen. Für Sonny Hayes bedeutet das das Ende seiner Karriere als Formel-1-Profi nach einem folgenschweren Unfall auf der Rennstrecke. Fortan dümpelt er in niedrigeren Rennklassen herum und hält sich drei Jahrzehnte nach seinem schicksalsträchtigen Unfall noch als Gelegenheitsrennfahrer über Wasser und versucht dabei, von seinem alten Formel-1-Ruf zu zehren. Sein damaliger Teamkollege Ruben Cervantes weiß das. Der ist mittlerweile Chef des Teams APXGP, das scheinbar hoffnungs- und punktlos am untersten Ende der Formel-1-Tabelle verweilt. Weil Cervantes damit also fast nichts mehr zu verlieren hat, will er Hayes zurück in die Königsklasse holen und ihn zusammen mit dem Rookie Noah genannten Joshua Pearce einen Rettungsanker für den Rennstall formen lassen.\",\"releaseDate\":\"2025-06-25\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8IUkPSxOh0KRbbVNYHSyBKQI5J0.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1KFv63mmcBGVbFl3jxxozoSFlhA.jpg\"},\"genres\":[\"Action\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"327835\"},\"name\":\"La collegiale\",\"nameTranslations\":{},\"originalName\":\"La collegiale\",\"releaseDate\":\"1975-01-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/m6PcX3AY92dLATCnpSWXCoRUVCE.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/y8XRFrymH4PxwgAo5mdKAX3ywg7.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"638607\"},\"name\":\"La Matinée\",\"nameTranslations\":{},\"originalName\":\"La Matinée\",\"releaseDate\":\"2007-10-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qnQvJ8Uw0R5KfLmzubgfAilnNoW.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/vtbKbpOpVuCwTZxtUssorYlswED.jpg\"},\"genres\":[\"Dokumentarfilm\",\"Musik\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1205225\"},\"name\":\"Gates of Flesh\",\"nameTranslations\":{},\"originalName\":\"Gates of Flesh\",\"releaseDate\":\"2025-04-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cOiuCeECSRqzpwuY6wYKQzvPcXm.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/5arE7ysejlE2byGyakuUrR5TmUt.jpg\"},\"genres\":[\"Horror\",\"Thriller\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"241635\"},\"name\":\"Die 12 Monate\",\"nameTranslations\":{},\"originalName\":\"Dvanáct měsíčků\",\"description\":\"Die sanfte Marie lebt nach dem Tod ihres Vaters bei der herrischen Stiefmutter und deren verwöhnten Tochter Flora in einer abgeschiedenen Berghütte. Sie wird schikaniert und als Magd für alle niederen Arbeiten missbraucht.  Es ist der Heilige Abend, und der Bruder von Maries Kamerad \\\"Näschen\\\" kommt aus der weiten Welt ins Dorf zurück - Karl ist in der Fremde reich geworden und somit der ideale Bräutigam für alle Mädchen, die ihn bewundern und bedrängen.  Karl erhält von seinem Bruder den Rat, drei im Winter nahezu nicht zu bestehende Prüfungen der künftigen Braut aufzuerlegen, damit er Ruhe vor ihnen hat.  Kann Marie unentdeckt Wunder vollbringen und die weiteren Aufgaben für ihre Stiefschwester erfüllen oder entlarvt Karl die Gemeinheiten der beiden berechnenden Frauen?\",\"releaseDate\":\"2013-10-15\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/ib6GEbTE6eRDRjOUwnueCHNuyqc.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/c5PkkwfwVzJJ9B57K4IXEw3yjMH.jpg\"},\"genres\":[\"Familie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1228841\"},\"name\":\"Objet a\",\"nameTranslations\":{},\"originalName\":\"Objet a\",\"images\":{},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1429605\"},\"name\":\"F Valentine's Day\",\"nameTranslations\":{},\"originalName\":\"F Valentine's Day\",\"description\":\"Gina hasst es, ausgerechnet am Valentinstag Geburtstag zu haben. Alle Geschenke, die sie zeitlebens bekommt, sind voller kitschiger roter Herzen und irgendwie auf „Liebe“ gemünzt. Eines Tages überreicht ihr Freund Andrew ihr zum Frühstück ein Vorab-Geschenk in Form eines Gutscheins über eine gemeinsame Reise auf eine griechische Insel. Dort will er mit ihr ihren Ehrentag verbringen – und ihr, wie Gina von ihrer Mutter Wendy erfährt, außerdem einen Heiratsantrag machen! Gina versucht nun Mittel und Wege zu finden, dass nicht auch dieser Tag noch mit dem Valentinstag „zusammengelegt“ wird. Vor Ort auf der Insel findet sie dabei unter anderem Komplizen in den Geschwistern Johnny und Mickey. Zusammen setzen sie alle Hebel in Bewegung, um Andrew zumindest am 14. Februar von seinem Vorhaben abzuhalten. Doch bei alledem beginnt Gina zu hinterfragen, ob Andrew überhaupt der Richtige für sie ist.\",\"releaseDate\":\"2026-02-12\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/8zPExowfpfZOTpS1W4J7G27lH4H.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/zFpaNGxW0FzRFKBOyCFVeYlCdI9.jpg\"},\"genres\":[\"Liebesfilm\",\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1273221\"},\"name\":\"Scary Movie 6\",\"nameTranslations\":{},\"originalName\":\"Scary Movie\",\"releaseDate\":\"2026-06-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/opJeybZ5EL4zObkgFPFkke0KnIq.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lj6AaDqDUbzm2XJltFNHeAm2uXN.jpg\"},\"genres\":[\"Komödie\",\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1137618\"},\"name\":\"The Rooster\",\"nameTranslations\":{},\"originalName\":\"The Rooster\",\"releaseDate\":\"2024-02-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/z7cvgWyZWuk9GbaErLEXvPfSBZ9.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/orrQoynvx37E0cpZyC4Dnirz6Pl.jpg\"},\"genres\":[\"Drama\",\"Mystery\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"456550\"},\"name\":\"Weiße Wäsche\",\"nameTranslations\":{},\"originalName\":\"Weiße Wäsche\",\"description\":\"Deutscher Spielfilm von Paul Heidemann aus dem Jahre 1942\",\"releaseDate\":\"1942-09-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/hMGLLvCy8axoSvfgvExJBPIhCDM.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"28317\"},\"name\":\"Blood Legend\",\"nameTranslations\":{},\"originalName\":\"Blood Legend\",\"releaseDate\":\"2006-02-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/CrZQDzFt05AkmuEn83mCesm95e.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lvy2ykHQ9ndUC4s5faBYuIfAQMo.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"39104\"},\"name\":\"Dragonball Z: Angriff der Cyborgs\",\"nameTranslations\":{},\"originalName\":\"ドラゴンボールＺ 極限バトル！三大超サイヤ人\",\"description\":\"In der Stadt tauchen die von Dr. Geros Computer erschaffen Cyborgs C14 und C15 auf. Die beiden Kampfmaschinen haben nur ein Ziel: Sie wollen Son-Goku töten. Trunks und Son-Goku gelingt es, die beiden Cyborgs in eine einsame Gegend zu locken, um dort ungestört kämpfen zu können. Unerwartet erscheint dort plötzlich ein weiterer gefährlicher Cyborg: C13. Es entbrennt ein heftiger Kampf, in den sich auch noch Vegeta einmischt. Als Super-Saiyajins gelingt es Son-Goku, Trunks und Vegeta, die Cyborgs C14 und C15 zu vernichten. Schnell stellt sich jedoch heraus, dass C13 ein viel stärkerer Gegner ist als die anderen beiden Cyborgs. Werden Son-Goku und seine Freunde es schaffen, den gefährlichen C13 zu vernichten?\",\"releaseDate\":\"1992-07-11\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/1lY0dIt035XvCAMnboH7p8AlESN.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/1u3yIvWFZaNDSSXmWYCYaNpCBBu.jpg\"},\"genres\":[\"Action\",\"Animation\",\"Science Fiction\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"704427\"},\"name\":\"The Audition\",\"nameTranslations\":{},\"originalName\":\"The Audition\",\"releaseDate\":\"2009-04-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5383yCLlS8oPNX1rTXPLIpELmo1.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"396364\"},\"name\":\"Mujercitas\",\"nameTranslations\":{},\"originalName\":\"Mujercitas\",\"releaseDate\":\"1973-12-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7BtFy8CPQySVOIv2Ueq2k5N2MSb.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/qMFYic5TlBUcErfu4MSyRAgvjGn.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1387382\"},\"name\":\"Hunting Season\",\"nameTranslations\":{},\"originalName\":\"Hunting Season\",\"description\":\"Als ein zurückgezogen lebender Überlebenskünstler und seine Tochter eine mysteriöse, verletzte Frau aus einem Fluss retten, werden sie in einem tödlichen Netz aus Gewalt und Rache verstrickt, das sie zwingt, sich einem brutalen Verbrecher zu stellen, um zu überleben.\",\"releaseDate\":\"2025-12-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/cbryTyaWdqrKpQCw6K7zm2jrB5v.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/eJ0HooOOD1uzI39CfOQNWIiWKlJ.jpg\"},\"genres\":[\"Action\",\"Drama\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"429748\"},\"name\":\"Nee Jathaleka\",\"nameTranslations\":{},\"originalName\":\"Nee Jathaleka\",\"releaseDate\":\"2016-10-16\",\"images\":{\"backdrop\":\"https://image.tmdb.org/t/p/original/h66vSfzLqORwry48O8QjNULsTL6.jpg\"},\"genres\":[\"Liebesfilm\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"4247\"},\"name\":\"Scary Movie\",\"nameTranslations\":{},\"originalName\":\"Scary Movie\",\"description\":\"Aus scheinbar heiterem Himmel wird die jungfräuliche Cindy Campbell von einem unheimlichen Maskenmann attackiert, doch im Gegensatz zu manch anderem Freund aus ihrer Clique, den es in der Folgezeit noch erwischen wird, überlebt sie die Attacke. Cindy entwickelt den Verdacht, daß ein vor Jahresfrist bei einem von der Clique verursachten Unfall getöteter Passant sein Ableben nur vorgetäuscht hat und nunmehr Rache sucht. Gemeinsam mit dem tölpelhaften Dorfsherriff und einer rasenden Reporterin geht sie der Sache auf den Grund.\",\"releaseDate\":\"2000-07-07\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/fVQFPRuw3yWXojYDJvA5EoFjUOY.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/uHZRTGMFb1RLmgWcqlIOZsGbDCT.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1110034\"},\"name\":\"Kraken\",\"nameTranslations\":{},\"originalName\":\"Kraken\",\"description\":\"Eine Meeresbiologin untersucht eine Fischfarm, als mehrere Teenager unter mysteriösen Umständen ums Leben kommen. Ungewöhnliche Ereignisse lassen vermuten, dass in den Tiefen des Fjords ein riesiges, vielarmiges Wesen lauert. Auf der Suche nach Antworten geht sie der Frage nach, ob sich in Norwegens tiefstem Fjord tatsächlich ein legendäres Monster verbirgt.\",\"releaseDate\":\"2026-02-06\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/s8u6BmcOSJGVoxswoo0wDm6naAT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/xcBlMEvzuaHoWANKYn5PGvcW4OC.jpg\"},\"genres\":[\"Horror\",\"Action\",\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"924181\"},\"name\":\"Alimony\",\"nameTranslations\":{},\"originalName\":\"Alimony\",\"releaseDate\":\"1924-02-03\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/88jSAB0wjnjUqOrSyGaqFvw63kV.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lHuc6k0fwXbI1FhHrPuw8HcsgSt.jpg\"},\"genres\":[\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"396364\"},\"name\":\"Mujercitas\",\"nameTranslations\":{},\"originalName\":\"Mujercitas\",\"releaseDate\":\"1973-12-13\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7BtFy8CPQySVOIv2Ueq2k5N2MSb.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/qMFYic5TlBUcErfu4MSyRAgvjGn.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"638607\"},\"name\":\"La Matinée\",\"nameTranslations\":{},\"originalName\":\"La Matinée\",\"releaseDate\":\"2007-10-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/qnQvJ8Uw0R5KfLmzubgfAilnNoW.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/vtbKbpOpVuCwTZxtUssorYlswED.jpg\"},\"genres\":[\"Dokumentarfilm\",\"Musik\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"28317\"},\"name\":\"Blood Legend\",\"nameTranslations\":{},\"originalName\":\"Blood Legend\",\"releaseDate\":\"2006-02-20\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/CrZQDzFt05AkmuEn83mCesm95e.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/lvy2ykHQ9ndUC4s5faBYuIfAQMo.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"101\"},\"name\":\"Léon - Der Profi\",\"nameTranslations\":{},\"originalName\":\"Léon\",\"description\":\"Die 12-jährige Mathilda wächst nicht gerade in den besten Verhältnissen auf: Ihre Mutter arbeitet als Prostituierte, ihr Vater versteckt Drogen für den korrupten Polizisten Norman Stansfield. Als sich dieser eines Tages betrogen fühlt, richtet er kurzerhand die ganze Familie hin und nur Mathilda entgeht dem Massaker knapp. Verzweifelt bittet sie ihren wenig gesprächigen Nachbarn Léon um Hilfe, der sie nur widerwillig in die Wohnung lässt. Schon kurze Zeit später stellt sie fest, dass er sein Geld als Profikiller verdient. Sie beschließt ebenfalls Cleaner zu werden, um den Mord an ihrer Familie zu rächen...\",\"releaseDate\":\"1994-09-14\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/opbFMtNw76Bine2UjWfZ2TSpzVg.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/jRJrQ72VLyEnVsvwfep8Xjlvu8c.jpg\"},\"genres\":[\"Krimi\",\"Drama\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1523431\"},\"name\":\"Kopitiam Days\",\"nameTranslations\":{},\"originalName\":\"Kopitiam Days\",\"releaseDate\":\"2025-08-05\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/tBIR8oVI8seF5yu5ztZ1hSrvzw2.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/scUF3CEHuatxK7Rpmy2YpFqJiEW.jpg\"},\"genres\":[\"Drama\",\"Science Fiction\",\"Komödie\",\"Action\",\"Fantasy\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1439073\"},\"name\":\"Cable reddy\",\"nameTranslations\":{},\"originalName\":\"Cable reddy\",\"images\":{},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1196067\"},\"name\":\"Worldbreaker\",\"nameTranslations\":{},\"originalName\":\"Worldbreaker\",\"description\":\"Nachdem die Breakers aufgetaucht sind – Wesen, die ihre Opfer infizieren und verwandeln – bricht die bestehende Ordnung zusammen. Zunächst fallen die Männer, wodurch Frauen gezwungen sind, den bewaffneten Widerstand zu übernehmen. Willas Mutter gehört zu den gefürchtetsten Kämpferinnen dieses Krieges, während ihr vom Erlebten gezeichneter Vater sich mit der Tochter auf eine abgelegene Insel zurückgezogen hat, um sie dort auf das Überleben vorzubereiten. Abgeschieden von der Außenwelt scheint ihr Alltag zunächst sicher, bis ein fremdes Mädchen an der Küste angespült wird. Aus dem Wunsch nach Nähe nimmt Willa sie heimlich bei sich auf. Als verborgene Wahrheiten ans Licht kommen, gerät der fragile Schutzraum in Gefahr.\",\"releaseDate\":\"2025-10-30\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/7K8w6mdrJp0oaSoKWGyjSZ4Zv2z.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/gMItMzDOyrfQGZsMWRM9tdxq5cV.jpg\"},\"genres\":[\"Science Fiction\",\"Action\",\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"263894\"},\"name\":\"Sabash Babu\",\"nameTranslations\":{},\"originalName\":\"Sabash Babu\",\"releaseDate\":\"1993-11-13\",\"images\":{},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1634858\"},\"name\":\"Cuerno Azulado\",\"nameTranslations\":{},\"originalName\":\"Cuerno Azulado\",\"releaseDate\":\"2025-09-10\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/q0OveDlsh5BNq6ifZqNWKtLKiwb.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/4IEjHlV6ciUPopHnEs5AfBNJ6XS.jpg\"},\"genres\":[\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"934433\"},\"name\":\"Scream 6\",\"nameTranslations\":{},\"originalName\":\"Scream VI\",\"description\":\"Die Schwestern Sam und Tara Carpenter haben genauso wie die Zwillinge Chad und Mindy Meeks die letzten Ghostface-Morde überlebt. Sie wollen die traumatischen Ereignisse von Woodsboro hinter sich lassen und in New York einen Neuanfang wagen. Allerdings scheint der Killer ihnen gefolgt zu sein und zieht jetzt mordend durch ihre Stadt. Obwohl die vier bereits ihre Erfahrungen mit Ghostface gemacht haben, müssen sie feststellen, dass dieser Killer ganz neue Tricks auf Lager hat.\",\"releaseDate\":\"2023-03-08\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/pi6ecVg0rWSJfrhVODzBiJ72Fzm.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/44immBwzhDVyjn87b3x3l9mlhAD.jpg\"},\"genres\":[\"Horror\",\"Thriller\",\"Krimi\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"616288\"},\"name\":\"Les Chercheurs\",\"nameTranslations\":{},\"originalName\":\"Les Chercheurs\",\"releaseDate\":\"2015-05-22\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/obg7IRGabukYsHP95rezE0hySSD.jpg\"},\"genres\":[\"Komödie\",\"Drama\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"405074\"},\"name\":\"Ariyathe Ishtamai\",\"nameTranslations\":{},\"originalName\":\"Ariyathe Ishtamai\",\"releaseDate\":\"2015-12-11\",\"images\":{},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1084244\"},\"name\":\"Toy Story 5\",\"nameTranslations\":{},\"originalName\":\"Toy Story 5\",\"description\":\"Die Aufgaben von Buzz, Woody, Jessie und Co. werden immer schwieriger, wenn sie es mit einer ganz neuen Bedrohung der Spielzeit zu tun bekommen: der Technik.\",\"releaseDate\":\"2026-06-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/gaiMtK2ll6BLdK1qKFuZGDwwEuD.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/coyHrYHD2xHhDoYD6o4uwoJ2o7b.jpg\"},\"genres\":[\"Animation\",\"Familie\",\"Komödie\",\"Abenteuer\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1140793\"},\"name\":\"Blindelings\",\"nameTranslations\":{},\"originalName\":\"Blindelings\",\"releaseDate\":\"2023-08-26\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/str96JbpJIm3uWFb8a0sr5EA0dY.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/pssj7zwdQIgYwXU8ko5pWKFallR.jpg\"},\"genres\":[\"Thriller\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"520761\"},\"name\":\"Thug Life\",\"nameTranslations\":{},\"originalName\":\"Thug Life\",\"releaseDate\":\"2017-07-21\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/rRapmpZGdBd5uw0hOZV7cBOvkoT.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/vOqhVnuglgtWUxj9YsWh3GLJxD1.jpg\"},\"genres\":[\"Komödie\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"276005\"},\"name\":\"Purnima\",\"nameTranslations\":{},\"originalName\":\"Purnima\",\"releaseDate\":\"1965-05-27\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/raTVqzFujHl9n6lR1zATa6BivG4.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"85562\"},\"name\":\"Nightmare Asylum\",\"nameTranslations\":{},\"originalName\":\"Nightmare Asylum\",\"releaseDate\":\"1992-01-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/p9mJJNykTkTtr7O7MSAVRFhv7gS.jpg\"},\"genres\":[\"Horror\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"1234821\"},\"name\":\"Jurassic World: Die Wiedergeburt\",\"nameTranslations\":{},\"originalName\":\"Jurassic World Rebirth\",\"description\":\"Fünf Jahre nach den Ereignissen von 'Jurassic World: Ein neue Zeitalter' wird die Spezialistin für verdeckte Operationen, Zora Bennett, auf eine streng geheime Mission geschickt: Sie soll genetisches Material von den drei größten Dinosauriern der Welt sichern. Doch als ihr Team auf eine Familie trifft, deren Boot bei einem Ausflug gekentert ist, stranden sie gemeinsam auf einer abgelegenen Insel. Dort stoßen sie auf eine finstere und schockierende Entdeckung, die jahrzehntelang vor der Menschheit verborgen blieb – und deren Geheimnis alles verändern könnte.\",\"releaseDate\":\"2025-07-01\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/uUGZdps8TesT34lPMfvTWuyZmZe.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/zNriRTr0kWwyaXPzdg1EIxf0BWk.jpg\"},\"genres\":[\"Science Fiction\",\"Abenteuer\",\"Action\"],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"704427\"},\"name\":\"The Audition\",\"nameTranslations\":{},\"originalName\":\"The Audition\",\"releaseDate\":\"2009-04-19\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/5383yCLlS8oPNX1rTXPLIpELmo1.jpg\"},\"genres\":[],\"similarItems\":[]},{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"560688\"},\"name\"