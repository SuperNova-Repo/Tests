},{"name":"alt-svc","value":"h3=\":443\"; ma=86400"}],"content":{"size":10019,"mimeType":"application/json","text":"{\"type\":\"movie\",\"ids\":{\"tmdb_id\":\"799882\",\"imdb_id\":\"tt14181714\"},\"name\":\"The Bluff\",\"episode\":{},\"nameTranslations\":{\"tr\":\"Uçurum\",\"fr\":\"La Falaise\",\"pt\":\"O Refúgio\",\"es\":\"El engaño\",\"bg\":\"Скалата\",\"zh\":\"悬崖绝壁\",\"pl\":\"Urwisko\",\"cs\":\"Útes\",\"th\":\"เดอะบลัฟ ชำระแค้นราชินีโจรสลัด\",\"uk\":\"Блеф\",\"he\":\"הצוק\",\"ko\":\"더 블러프\",\"hu\":\"A szikla\",\"ca\":\"L'engany\",\"ro\":\"Promontoriul\",\"eu\":\"Engainua\",\"ar\":\"الخدعة\",\"el\":\"Η Μπλόφα\",\"hi\":\"द ब्लफ़\",\"gl\":\"O Engano\",\"ml\":\"ദ ബ്ലഫ്\",\"ja\":\"ザ・ブラフ ブラッディ・メアリーの戦い\",\"kn\":\"ದ ಬ್ಲಫ್\",\"te\":\"ద బ్లఫ్\",\"ta\":\"த ப்ளஃப்\",\"vi\":\"Cú Lừa\",\"ru\":\"Блеф\",\"sk\":\"Útes\",\"ka\":\"ბლეფი\"},\"originalName\":\"The Bluff\",\"description\":\"Als ihr ruhiges Leben auf einer abgelegenen Insel durch die Rückkehr ihres rachsüchtigen Ex-Kapitäns zerstört wird, muss eine erfahrene ehemalige Piratin sich ihrer blutigen Vergangenheit stellen und ihre tödlichen Talente einsetzen, um ihre Familie vor einer gnadenlosen Belagerung zu retten.\",\"releaseDate\":\"2026-02-17\",\"images\":{\"poster\":\"https://image.tmdb.org/t/p/original/4zC5m3JdO76guCDd5YMh7wj7JnQ.jpg\",\"backdrop\":\"https://image.tmdb.org/t/p/original/hYgUkH7TusddHRtelj53I6gFOWR.jpg\"},\"runtime\":6060000,\"production\":[\"AGBO\",\"Cinestar Pictures\",\"Big Indie Pictures\"],\"countries\":[\"US\"],\"spokenLanguages\":[\"en\"],\"genres\":[\"Action\",\"Thriller\"],\"writer\":[{\"name\":\"Frank E. Flowers\",\"gender\":\"male\",\"poster\":\"https://image.tmdb.org/t/p/original/eguppPFKy8xfEOajWrbHugA0uJ.jpg\"},{\"name\":\"Joe Ballarini\",\"gender\":\"male\",\"poster\":\"https://image.tmdb.org/t/p/original/hQ9zJG84u3zf375gDmV5GTK4VSE.jpg\"},{\"name\":\"Nathan Newman\",\"gender\":\"male\"},{\"name\":\"Connor Van Vuuren\",\"gender\":\"male\"}],\"director\":[{\"name\":\"Anthony Russo\",\"gender\":\"male\",\"poster\":\"https://image.tmdb.org/t/p/original/xbINBnWn28YygYWUJ1aSAw0xPRv.jpg\"},{\"name\":\"Joe Russo\",\"gender\":\"male\",\"poster\":\"https://image.tmdb.org/t/p/original/o0OXjFzL10jCy89iAs7UzzSbyoK.jpg\"},{\"name\":\"Chris Castaldi\",\"gender\":\"male\",\"poster\":\"https://image.tmdb.org/t/p/original/8wndmlAfA7R5JuGwxTK7S4TB64O.jpg\"},{\"name\":\"Ari Costa\",\"gender\":\"male\"},{\"name\":\"Matt Haggerty\",\"gender\":\"male\"},{\"name\":\"Phoebe Billington\",\"gender\":\"male\"},{\"name\":\"Brittney McDonald\",\"gender\":\"male\"}],\"cast\":[{\"name\":\"Priyanka Chopra Jonas\",\"gender\":\"female\",\"character\":\"Ercell\",\"poster\":\"https://image.tmdb.org/t/p/original/9n2n3fUFI553HKH0CEAb2TPLtCx.jpg\"},{\"name\":\"Karl Urban\",\"gender\":\"male\",\"character\":\"Captain Connor\",\"poster\":\"https://image.tmdb.org/t/p/original/6CkZLwEJxfqqcJHyeXegMAvOlPh.jpg\"},{\"name\":\"Safia Oakley-Green\",\"gender\":\"female\",\"character\":\"Elizabeth\",\"poster\":\"https://image.tmdb.org/t/p/original/k4JrjdSIfwWF1Qd5KHChDfnXpF2.jpg\"},{\"name\":\"Ismael Cruz Cordova\",\"gender\":\"male\",\"character\":\"T.H. Bodden\",\"poster\":\"https://image.tmdb.org/t/p/original/oXcrsQGndk60iFkNB8qFnMHlNzL.jpg\"},{\"name\":\"Temuera Morrison\",\"gender\":\"male\",\"character\":\"Quartermaster Lee\",\"poster\":\"https://image.tmdb.org/t/p/original/AvtSC0f9QW7fMyFFNXEWDeQyfUk.jpg\"},{\"name\":\"Vedanten Naidoo\",\"gender\":\"male\",\"character\":\"Isaac\",\"poster\":\"https://image.tmdb.org/t/p/original/gF55JKge7cMTP2DNH0asEiWkoJJ.jpg\"},{\"name\":\"David Field\",\"gender\":\"male\",\"character\":\"Pastor Bradley\",\"poster\":\"https://image.tmdb.org/t/p/original/aYtVOMnak4JmlLGw63lJObLf1J.jpg\"},{\"name\":\"Greg Hatton\",\"gender\":\"male\",\"character\":\"Scout\",\"poster\":\"https://image.tmdb.org/t/p/original/j0jioHCWjJJEr41Vr2vHgRRtEMx.jpg\"},{\"name\":\"Pacharo Mzembe\",\"gender\":\"male\",\"character\":\"Chien\",\"poster\":\"https://image.tmdb.org/t/p/origina